        -annotation "# Safe purge: only your tool modules\nimport sys\n\ntry:\n    import importlib\n    if hasattr(importlib, 'invalidate_caches'):\n        importlib.invalidate_caches()\nexcept Exception:\n    pass\n\n# 移除包内与可能的顶层副本\nprefixes = (\n    'ck_rig_Box',         # 包及子模块\n    'Fk_SetUp_ui',        # 顶层副本（曾经直接 import Fk_SetUp_ui）\n    'Fk_SetUp',           # 顶层副本\n    'qt_compat',          # 顶层副本\n    'sur_curve'\n)\n\nfor _name in list(sys.modules):\n    if _name.startswith(prefixes):\n        sys.modules.pop(_name, None)\n\ndef remove_pyc_files(target_dir):\n    \"\"\"删除指定目录及其子目录中的所有 .pyc 文件\"\"\"\n    if not os.path.exists(target_dir):\n        print(u\"目录不存在: {}\".format(target_dir))\n        return\n\n    removed = 0\n    for root, _, files in os.walk(target_dir):\n        for f in files:\n            if f.endswith(\".pyc\"):\n                try:\n                    os.remove(os.path.join(root, f))\n                    removed += 1\n                except Exception as e:\n                    print(u\"删除失败: {}\".format(e))\n\n    print(u\"共删除 {} 个 .pyc 文件。\".format(removed))\n\n# 指定目录\nremove_pyc_files(r\"C:\\Users\\Administrator\\Documents\\maya\\scripts\\ck_rig_Box\")\n\n# 重新导入并运行最新版 UI\nimport sys\nsys.path.append(r\"C:\\Users\\Administrator\\Documents\\maya\\scripts\")  # 只加 scripts 上层目录\nfrom ck_rig_Box import Fk_SetUp_ui\nFk_SetUp_ui.show()\n\n" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
