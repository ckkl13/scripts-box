        -annotation "import maya.cmds as cmds\n\n# 获取当前选择的物体\njnt = cmds.ls(selection=True)\n\nif not jnt:\n    cmds.warning(\"当前没有选择任何物体！\")\nelse:\n    # 打印选择列表（普通字符串，Python 2 下不会有 u''）\n    print(\"=== 当前选择的物体列表 ===\")\n    print([str(obj) for obj in jnt])\n\n    # 每行最多显示的元素数量\n    line_length = 8\n    lines = []\n    for i in range(0, len(jnt), line_length):\n        chunk = jnt[i:i+line_length]\n        lines.append(\", \".join(\"'{}'\".format(obj) for obj in chunk))\n    \n    # 生成代码，保证 [ 紧跟第一行\n    code_str = \"import maya.cmds as cmds\\n\\n\"\n    code_str += \"jnt = [\"\n    if lines:\n        code_str += lines[0]  # 第一行紧跟 [\n    if len(lines) > 1:\n        for line in lines[1:]:\n            code_str += \",\\n    \" + line  # 后续行缩进\n    code_str += \"]\\n\"\n    code_str += \"cmds.select(jnt, r=True)\\n\"\n\n    print(\"\\n=== 可直接使用的选择代码 ===\")\n    print(code_str)\n" 
