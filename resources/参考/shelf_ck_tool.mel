        -annotation "运行 选择模型上已蒙皮的骨骼 (PYTHON)" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "选择模型上已蒙皮的骨骼" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "已蒙皮的骨骼" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef select_skin_influence_joints():\n    \"\"\"选中当前模型上参与蒙皮的所有骨骼，并生成 Python 2/3 都可用的选择代码\"\"\"\n    sel = cmds.ls(sl=True, dag=True, shapes=False)\n    if not sel:\n        cmds.warning(\"请先选择一个模型或蒙皮的网格\")\n        return\n    \n    joints_to_select = []\n\n    for obj in sel:\n        skin_clusters = cmds.ls(cmds.listHistory(obj), type='skinCluster') or []\n        for sc in skin_clusters:\n            influences = cmds.skinCluster(sc, q=True, influence=True) or []\n            for jnt in influences:\n                if jnt not in joints_to_select:\n                    joints_to_select.append(jnt)\n    \n    if joints_to_select:\n        cmds.select(joints_to_select, r=True)\n        print(\"=== 蒙皮骨骼识别结果 ===\")\n        print(\"找到 {} 个骨骼:\".format(len(joints_to_select)))\n        print([str(j) for j in joints_to_select])  # 列表形式打印\n\n        # 生成可复用代码（Python 2 不带 u''）\n        joints_str = \", \".join(\"'{}'\".format(j) for j in joints_to_select)\n        code_str = \"import maya.cmds as cmds\\n\\n\"\n        code_str += \"jnt = [{}]\\n\".format(joints_str)\n        code_str += \"cmds.select(jnt, r=True)\\n\"\n        print(\"\\n=== 可直接使用的选择代码 ===\")\n        print(code_str)\n    else:\n        cmds.warning(\"未找到任何蒙皮骨骼\")\n\n# 运行\nselect_skin_influence_joints()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "运行 权重传递 (PYTHON)" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "权重传递" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "权重传递" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\nimport maya.cmds as cmds\nfrom contextlib import contextmanager\nfrom PySide2.QtWidgets import QDialog, QVBoxLayout, QHBoxLayout, QLabel, QPushButton, QProgressDialog, QApplication, QCheckBox\nfrom PySide2.QtCore import Qt\nimport shiboken2\n\ndef get_maya_main_window():\n    from maya.OpenMayaUI import MQtUtil\n    from PySide2.QtWidgets import QWidget\n    main_window_ptr = MQtUtil.mainWindow()\n    if main_window_ptr:\n        return shiboken2.wrapInstance(int(main_window_ptr), QWidget)\n    return None\n\n@contextmanager\ndef undo_chunk():\n    cmds.undoInfo(openChunk=True)\n    try:\n        yield\n    finally:\n        cmds.undoInfo(closeChunk=True)\n\ndef get_skin_cluster(node):\n    history = cmds.listHistory(node, pruneDagObjects=True) or []\n    return next((s for s in cmds.ls(history, type='skinCluster')), None)\n\nclass ConfirmDialog(QDialog):\n    def __init__(self, source_mesh, target_count, parent=None):\n        super(ConfirmDialog, self).__init__(parent)\n        self.setWindowTitle(u\"确认操作\")\n        self.setModal(True)\n        self.result = False\n        self.cleanup_unused = False\n        self.setFixedSize(350, 120)\n\n        layout = QVBoxLayout()\n        layout.setSpacing(8)\n        layout.setContentsMargins(15, 15, 15, 15)\n\n        label = QLabel(u\"是否将 {} 的蒙皮权重复制到 {} 个目标网格？\".format(source_mesh, target_count))\n        label.setWordWrap(True)\n        layout.addWidget(label)\n\n        self.cleanup_checkbox = QCheckBox(u\"清理未使用的影响\")\n        self.cleanup_checkbox.setChecked(False)\n        layout.addWidget(self.cleanup_checkbox)\n\n        button_layout = QHBoxLayout()\n        button_layout.setSpacing(10)\n\n        confirm_button = QPushButton(u\"确定\")\n        cancel_button = QPushButton(u\"取消\")\n        confirm_button.setFixedHeight(25)\n        cancel_button.setFixedHeight(25)\n\n        confirm_button.clicked.connect(self.accept)\n        cancel_button.clicked.connect(self.reject)\n\n        button_layout.addWidget(confirm_button)\n        button_layout.addWidget(cancel_button)\n\n        layout.addLayout(button_layout)\n        self.setLayout(layout)\n\n    def accept(self):\n        self.result = True\n        self.cleanup_unused = self.cleanup_checkbox.isChecked()\n        super(ConfirmDialog, self).accept()\n\n    def reject(self):\n        self.result = False\n        super(ConfirmDialog, self).reject()\n\nclass ProgressWithEsc(QProgressDialog):\n    def __init__(self, label, parent=None):\n        super(ProgressWithEsc, self).__init__(label, None, 0, 100, parent)\n        self.setWindowTitle(u\"处理进度\")\n        self.setWindowModality(Qt.WindowModal)\n        self.setMinimumDuration(0)\n        self.setAutoClose(True)\n        self.esc_pressed = False\n\n    def keyPressEvent(self, event):\n        if event.key() == Qt.Key_Escape:\n            self.esc_pressed = True\n        super(ProgressWithEsc, self).keyPressEvent(event)\n\n    def wasCanceled(self):\n        return self.esc_pressed\n\ndef copy_skin_weights_optimized(source_mesh, target_meshes, cleanup_unused_influences=False):\n    source_skin = get_skin_cluster(source_mesh)\n    if not source_skin:\n        cmds.error(u\"源网格 {} 未绑定皮肤集群\".format(source_mesh))\n        return False\n\n    source_joints = cmds.skinCluster(source_skin, query=True, influence=True)\n    if not source_joints:\n        cmds.warning(u\"源皮肤集群 {} 没有影响关节\".format(source_skin))\n        return False\n\n    source_max_influences = cmds.skinCluster(source_skin, query=True, maximumInfluences=True)\n    source_maintain_max_influences = cmds.getAttr(\"{}.maintainMaxInfluences\".format(source_skin))\n    print(u\"源皮肤集群最大影响物数量: {}\".format(source_max_influences))\n    print(u\"源皮肤集群保持最大影响物状态: {}\".format(source_maintain_max_influences))\n\n    app = QApplication.instance() or QApplication([])\n\n    confirm_dialog = ConfirmDialog(source_mesh, len(target_meshes), get_maya_main_window())\n    confirm_dialog.exec_()\n    if not confirm_dialog.result:\n        print(u\"用户取消了权重复制操作\")\n        return False\n\n    cleanup_unused_influences = confirm_dialog.cleanup_unused\n\n    progress = ProgressWithEsc(u\"初始化...\", get_maya_main_window())\n    progress.show()\n\n    # 删除目标网格已存在的 skinCluster\n    to_delete = [get_skin_cluster(target) for target in target_meshes]\n    to_delete = [s for s in to_delete if s]\n    if to_delete:\n        cmds.delete(to_delete)\n    else:\n        print(u\"目标网格没有已存在的 skinCluster，无需删除\")\n\n    with undo_chunk():\n        steps_per_mesh = 3 if cleanup_unused_influences else 2\n        total_steps = len(target_meshes) * steps_per_mesh\n        step = 0\n        created_skin_clusters = []\n\n        for i, target_mesh in enumerate(target_meshes):\n            if progress.wasCanceled():\n                cmds.warning(u\"操作已被用户取消\")\n                return False\n\n            progress.setLabelText(u\"绑定皮肤: {} ({}/{})\".format(target_mesh, i + 1, len(target_meshes)))\n            progress.setValue(int((step / float(total_steps)) * 100))\n            QApplication.processEvents()\n\n            target_skin = cmds.skinCluster(\n                source_joints, target_mesh,\n                toSelectedBones=True,\n                bindMethod=0,\n                normalizeWeights=1,\n                weightDistribution=0,\n                maximumInfluences=source_max_influences\n            )[0]\n            step += 1\n\n            if progress.wasCanceled():\n                cmds.warning(u\"操作已被用户取消\")\n                return False\n\n            progress.setLabelText(u\"复制权重: {} ({}/{})\".format(target_mesh, i + 1, len(target_meshes)))\n            progress.setValue(int((step / float(total_steps)) * 100))\n            QApplication.processEvents()\n\n            cmds.copySkinWeights(\n                sourceSkin=source_skin,\n                destinationSkin=target_skin,\n                noMirror=True,\n                surfaceAssociation='closestPoint',\n                influenceAssociation=['label', 'oneToOne'],\n                normalize=True\n            )\n            step += 1\n\n            if cleanup_unused_influences:\n                if progress.wasCanceled():\n                    cmds.warning(u\"操作已被用户取消\")\n                    return False\n\n                progress.setLabelText(u\"清理未使用影响: {} ({}/{})\".format(target_mesh, i + 1, len(target_meshes)))\n                progress.setValue(int((step / float(total_steps)) * 100))\n                QApplication.processEvents()\n\n                weighted_influences = cmds.skinCluster(target_skin, query=True, weightedInfluence=True)\n                unused_joints = set(source_joints) - set(weighted_influences)\n                if unused_joints:\n                    cmds.skinCluster(target_skin, edit=True, removeInfluence=list(unused_joints))\n                step += 1\n\n            if target_mesh.startswith('mesh_'):\n                new_name = target_mesh.replace('mesh_', 'skinCluster_')\n                target_skin = cmds.rename(target_skin, new_name)\n\n            created_skin_clusters.append(target_skin)\n\n        if source_maintain_max_influences:\n            for skin_cluster in created_skin_clusters:\n                try:\n                    cmds.setAttr(\"{}.maintainMaxInfluences\".format(skin_cluster), 1)\n                    print(u\"已为 {} 设置保持最大影响物\".format(skin_cluster))\n                except Exception as e:\n                    print(u\"设置 {} 保持最大影响物失败: {}\".format(skin_cluster, e))\n            print(u\"蒙皮权重复制完成，已为 {} 个skinCluster设置保持最大影响物\".format(len(created_skin_clusters)))\n        else:\n            print(u\"蒙皮权重复制完成，源未开启保持最大影响物，跳过目标设置\")\n\n        progress.setLabelText(u\"完成蒙皮权重复制\")\n        progress.setValue(100)\n\n    return True\n\ndef main():\n    sel = cmds.ls(selection=True, long=True)\n    if len(sel) < 2:\n        cmds.error(u\"请至少选择一个源网格和一个目标网格\")\n        return\n\n    source_mesh = sel[0]\n    target_meshes = sel[1:]\n    copy_skin_weights_optimized(source_mesh, target_meshes)\n\nif __name__ == \"__main__\":\n    main()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
