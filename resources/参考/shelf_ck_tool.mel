        -command "import maya.cmds as cmds\n\ndef create_flat_surface_from_joint_chain(bones=None, name='surface_from_joints', axis='z', offset=2.0):\n    \"\"\"\n    根据骨骼链生成扁平多边形曲面。\n    \n    参数:\n        bones: list of str, 骨骼列表。如果为 None，则使用当前选择。\n        name: str, 最终生成曲面名字。\n        axis: str, 偏移方向 'x','y','z'。\n        offset: float, 偏移距离。\n        \n    返回:\n        str, 生成的多边形网格名字。\n    \"\"\"\n    # 自动获取选择\n    if bones is None:\n        bones = cmds.ls(sl=True, type='joint')\n        if not bones:\n            cmds.warning(\"请先选择一条连续骨骼链！\")\n            return\n\n    if len(bones) < 2:\n        cmds.error(\"至少需要两根连续骨骼\")\n        return\n\n    # 骨骼链连续性检查\n    for i in range(len(bones)-1):\n        if bones[i+1] not in (cmds.listRelatives(bones[i], children=True, type='joint') or []):\n            cmds.error(\"请选择连续骨骼链\")\n            return\n\n    # 冻结第一个骨骼旋转\n    if any(abs(x) > 1e-4 for x in cmds.getAttr(bones[0]+'.rotate')[0]):\n        cmds.makeIdentity(bones[0], apply=True, t=1, r=1, s=1)\n\n    # 获取骨骼世界位置\n    positions = [cmds.xform(j, q=True, ws=True, t=True) for j in bones]\n\n    # 计算偏移向量\n    def axis_vec(j, ax):\n        m = cmds.xform(j, q=True, ws=True, m=True)\n        return {'x': m[:3], 'y': m[4:7], 'z': m[8:11]}.get(ax.lower(), [0,0,0])\n\n    plus = [[p[i] + axis_vec(j, axis)[i]*offset for i in range(3)] for j,p in zip(bones, positions)]\n    minus = [[p[i] - axis_vec(j, axis)[i]*offset for i in range(3)] for j,p in zip(bones, positions)]\n\n    # 创建曲线并 loft\n    c1 = cmds.curve(d=1, p=plus)\n    c2 = cmds.curve(d=1, p=minus)\n    surf = cmds.loft(c1, c2, n=name, ch=False, uniform=True, autoReverse=True)[0]\n    cmds.delete(c1, c2)  # 删除曲线\n\n    # 转换为多边形，不保留历史，安全删除曲面\n    mesh_list = cmds.nurbsToPoly(surf, ch=False, mnd=1, f=2, pt=1, pc=200, chr=0.9, ft=0.01,\n                                 mel=0.001, d=0.1, ut=1, un=1, vt=3, vn=1, uch=0, ucr=0,\n                                 cht=0.01, es=0, ntr=0, mrt=0, uss=1)\n    mesh = mesh_list[0] if mesh_list else None\n    if mesh:\n        cmds.delete(surf)  # 删除 loft 曲面\n        cmds.select(mesh)\n        cmds.polyNormal(mesh, normalMode=0, userNormalMode=0, ch=1)  # 重置法线\n        cmds.select(d = True)\n        cmds.select(mesh)\n        cmds.inViewMessage(amg=f\"<hl>曲面创建完成：{mesh}</hl>\", pos='midCenter', fade=True)\n\n    return mesh\n\n\ncreate_flat_surface_from_joint_chain(name='test_surface', axis='z', offset=2)" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
