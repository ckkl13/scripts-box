        -command "import maya.cmds as cmds\n\n# 查找所有 skinCluster 节点\nskin_clusters = cmds.ls(type=\"skinCluster\")\n\n\n# 如果找到了，就设置属性\nfor sc in skin_clusters:\n    if cmds.objExists(f\"{sc}.maintainMaxInfluences\"):\n        cmds.setAttr(f\"{sc}.maintainMaxInfluences\", 1)\n        print(f\"设置 {sc}.maintainMaxInfluences 为 1\")\n    else:\n        print(f\"{sc} 没有属性 maintainMaxInfluences\")\n\n# 如果找到了，就设置属性\nfor sc in skin_clusters:\n    if cmds.objExists(f\"{sc}.maxInfluences\"):\n        cmds.setAttr(f\"{sc}.maxInfluences\", 4)\n        print(f\"设置 {sc}.maxInfluences 为 4\")\n    else:\n        print(f\"{sc} 没有属性 maxInfluences\")" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
