        -command "# -*- coding: utf-8 -*-\n\"\"\"\nMaya文件重新加载工具\n功能：重新加载当前Maya文件，并在重加载前询问是否保存当前文件\n兼容Python 2.7和Python 3.x\n\"\"\"\n\nimport maya.cmds as cmds\nimport maya.mel as mel\nimport os\nimport sys\n\n# Python 2/3 兼容性处理\nif sys.version_info[0] >= 3:\n    unicode = str\n\ndef reload_maya_file():\n    \"\"\"\n    重新加载当前Maya文件\n    在重加载前会询问用户是否保存当前文件\n    \"\"\"\n    # 获取当前文件路径\n    current_file = cmds.file(query=True, sceneName=True)\n    \n    if not current_file:\n        cmds.warning(\"当前没有打开的文件，无法重新加载\")\n        return\n    \n    # 检查文件是否存在\n    if not os.path.exists(current_file):\n        cmds.warning(\"当前文件路径不存在: {}\".format(current_file))\n        return\n    \n    # 检查文件是否被修改\n    is_modified = cmds.file(query=True, modified=True)\n    \n    if is_modified:\n        # 询问用户是否保存\n        result = cmds.confirmDialog(\n            title='重新加载文件',\n            message='当前文件已被修改，是否在重新加载前保存？',\n            button=['保存并重加载', '不保存直接重加载', '取消'],\n            defaultButton='保存并重加载',\n            cancelButton='取消',\n            dismissString='取消'\n        )\n        \n        if result == '取消':\n            return\n        elif result == '保存并重加载':\n            try:\n                # 保存当前文件\n                cmds.file(save=True)\n                print(\"文件已保存: {}\".format(current_file))\n            except Exception as e:\n                cmds.error(\"保存文件失败: {}\".format(str(e)))\n                return\n    \n    try:\n        # 重新加载文件\n        cmds.file(current_file, open=True, force=True)\n        print(\"文件重新加载成功: {}\".format(current_file))\n    except Exception as e:\n        cmds.error(\"重新加载文件失败: {}\".format(str(e)))\n\n# 直接运行重新加载功能\nif __name__ == '__main__':\n    reload_maya_file()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "运行 A选择层级 (PYTHON)" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "A选择层级" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "选择层级" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "C:/Users/PC/Documents/maya/2023/zh_CN/prefs/icons/选择层级.png" 
        -image1 "C:/Users/PC/Documents/maya/2023/zh_CN/prefs/icons/选择层级.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\n\"\"\"\nMaya脚本：选择层级结构中的所有对象\n功能：选择当前选中对象及其所有子级对象\n兼容：Python 2.7 和 Python 3.x\n\"\"\"\n\n# Python 2/3 兼容性导入\nfrom __future__ import print_function\nfrom __future__ import unicode_literals\nfrom __future__ import division\nfrom __future__ import absolute_import\n\nimport sys\nimport maya.cmds as cmds\n\n# Python 2/3 兼容性处理\nif sys.version_info[0] >= 3:\n    unicode = str\n    basestring = str\nelse:\n    # Python 2\n    pass\n\ndef ensure_unicode(text):\n    \"\"\"确保文本为unicode格式（Python 2/3兼容）\"\"\"\n    if sys.version_info[0] >= 3:\n        return str(text)\n    else:\n        if isinstance(text, str):\n            return text.decode('utf-8')\n        return unicode(text)\n\ndef safe_format(template, *args, **kwargs):\n    \"\"\"安全的字符串格式化（Python 2/3兼容）\"\"\"\n    try:\n        return template.format(*args, **kwargs)\n    except (UnicodeDecodeError, UnicodeEncodeError):\n        if sys.version_info[0] < 3:\n            template = ensure_unicode(template)\n            args = [ensure_unicode(arg) if isinstance(arg, basestring) else arg for arg in args]\n            for key, value in kwargs.items():\n                if isinstance(value, basestring):\n                    kwargs[key] = ensure_unicode(value)\n        return template.format(*args, **kwargs)\n\ndef collect_hierarchy_ordered(obj, collected_objects=None, level=0):\n    \"\"\"按层级顺序递归收集对象\"\"\"\n    if collected_objects is None:\n        collected_objects = []\n    if not cmds.objExists(obj):\n        return collected_objects\n    if obj not in collected_objects:\n        collected_objects.append(obj)\n    children = cmds.listRelatives(obj, children=True, fullPath=True) or []\n    for child in children:\n        collect_hierarchy_ordered(child, collected_objects, level + 1)\n    return collected_objects\n\ndef select_hierarchy():\n    \"\"\"按层级顺序选择当前选中对象及其所有子级对象\"\"\"\n    selected_objects = cmds.ls(selection=True)\n    if not selected_objects:\n        cmds.warning(\"请先选择一个对象\")\n        return\n    \n    all_objects = []\n    for obj in selected_objects:\n        if not cmds.objExists(obj):\n            continue\n        hierarchy_objects = collect_hierarchy_ordered(obj)\n        for hierarchy_obj in hierarchy_objects:\n            if hierarchy_obj not in all_objects:\n                all_objects.append(hierarchy_obj)\n    \n    if all_objects:\n        cmds.select(clear=True)\n        cmds.select(all_objects, add=True)\n        print(\"=== 层级选择结果 ===\")\n        print(\"共选择 {0} 个对象:\".format(len(all_objects)))\n        print(all_objects)\n    else:\n        cmds.warning(\"未找到有效的对象\")\n\ndef collect_hierarchy_by_type_ordered(obj, node_type='transform', collected_objects=None, level=0):\n    \"\"\"按层级顺序递归收集指定类型的对象\"\"\"\n    if collected_objects is None:\n        collected_objects = []\n    if not cmds.objExists(obj):\n        return collected_objects\n    if cmds.nodeType(obj) == node_type and obj not in collected_objects:\n        collected_objects.append(obj)\n    children = cmds.listRelatives(obj, children=True, fullPath=True) or []\n    for child in children:\n        collect_hierarchy_by_type_ordered(child, node_type, collected_objects, level + 1)\n    return collected_objects\n\ndef select_hierarchy_transforms_only():\n    \"\"\"按层级顺序只选择层级中的变换节点\"\"\"\n    selected_objects = cmds.ls(selection=True)\n    if not selected_objects:\n        cmds.warning(\"请先选择一个对象\")\n        return\n    \n    all_transforms = []\n    for obj in selected_objects:\n        if not cmds.objExists(obj):\n            continue\n        hierarchy_transforms = collect_hierarchy_by_type_ordered(obj, 'transform')\n        for transform_obj in hierarchy_transforms:\n            if transform_obj not in all_transforms:\n                all_transforms.append(transform_obj)\n    \n    if all_transforms:\n        cmds.select(clear=True)\n        cmds.select(all_transforms, add=True)\n        print(\"=== 层级变换节点选择结果 ===\")\n        print(\"共选择 {0} 个变换节点:\".format(len(all_transforms)))\n        print(all_transforms)\n    else:\n        cmds.warning(\"未找到有效的变换节点\")\n\ndef select_hierarchy_by_type(node_type='transform'):\n    \"\"\"按层级顺序选择指定类型的层级中的对象\"\"\"\n    selected_objects = cmds.ls(selection=True)\n    if not selected_objects:\n        cmds.warning(\"请先选择一个对象\")\n        return\n    \n    all_nodes = []\n    for obj in selected_objects:\n        if not cmds.objExists(obj):\n            continue\n        hierarchy_nodes = collect_hierarchy_by_type_ordered(obj, node_type)\n        for node_obj in hierarchy_nodes:\n            if node_obj not in all_nodes:\n                all_nodes.append(node_obj)\n    \n    if all_nodes:\n        cmds.select(clear=True)\n        cmds.select(all_nodes, add=True)\n        print(\"=== 层级{0}节点选择结果 ===\".format(node_type))\n        print(\"共选择 {0} 个{1}节点:\".format(len(all_nodes), node_type))\n        print(all_nodes)\n    else:\n        cmds.warning(\"未找到有效的 {0} 节点\".format(node_type))\n\n\n# 主执行部分\nif __name__ == \"__main__\":\n    select_hierarchy()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "# -*- coding: utf-8 -*-\nimport maya.cmds as cmds\n\ndef get_unique_name(base_name):\n    \"\"\"如果名称存在，自动添加递增编号\"\"\"\n    if not cmds.objExists(base_name):\n        return base_name\n    i = 1\n    while cmds.objExists(\"{}_{:02d}\".format(base_name, i)):\n        i += 1\n    return \"{}_{:02d}\".format(base_name, i)\n\ndef create_joints_in_selection(parent_under_object=True, prefix='jnt_'):\n    \"\"\"\n    自动判断选择内容：\n    - 顶点模式：根据顶点创建骨骼（无层级）\n    - 物体模式：匹配物体世界变换并冻结旋转\n    \"\"\"\n    cmds.undoInfo(openChunk=True)\n    try:\n        sel = cmds.ls(selection=True, long=True, fl=True) or []\n        if not sel:\n            cmds.select(clear=True)\n            jnt = cmds.joint(name=prefix + \"world\", position=(0, 0, 0))\n            return\n\n        # 判断是否为顶点模式\n        verts = cmds.filterExpand(sel, sm=31)\n        if verts:\n            created_joints = []\n            for i, vtx in enumerate(verts, start=1):\n                pos = cmds.pointPosition(vtx, world=True)\n                jnt_name = get_unique_name(\"{}fromVertex_{:03d}\".format(prefix, i))\n                cmds.select(clear=True)\n                jnt = cmds.joint(name=jnt_name, position=pos)\n                cmds.setAttr(jnt + \".jointOrient\", 0, 0, 0)\n                created_joints.append(jnt)\n\n            # 解除层级关系\n            for jnt in created_joints:\n                parent = cmds.listRelatives(jnt, parent=True)\n                if parent:\n                    cmds.parent(jnt, world=True)\n\n            cmds.select(created_joints)\n            return\n\n        # ----------------------------\n        # 物体模式\n        # ----------------------------\n        created_joints = []\n        for obj in sel:\n            if not cmds.objExists(obj):\n                cmds.warning(\"对象不存在：{}\".format(obj))\n                continue\n\n            cmds.select(clear=True)\n            base_name = obj.split('|')[-1]\n            jnt_name = get_unique_name(prefix + base_name)\n            jnt = cmds.joint(name=jnt_name)\n\n            try:\n                cmds.matchTransform(jnt, obj, pos=True, rot=True, scl=False)\n                cmds.makeIdentity(jnt, apply=True, translate=False, rotate=True, scale=False, normal=False)\n            except Exception as e:\n                cmds.warning(u\"无法匹配 {} 的变换：{}\".format(obj, str(e)))\n                if cmds.objExists(jnt):\n                    cmds.delete(jnt)\n                continue\n\n            if parent_under_object:\n                try:\n                    cmds.parent(jnt, obj)\n                except Exception:\n                    pass\n\n            created_joints.append(jnt)\n\n        if created_joints:\n            cmds.select(created_joints)\n        else:\n            cmds.warning(\"未创建任何骨骼。\")\n\n    finally:\n        cmds.undoInfo(closeChunk=True)\n\n\n# 执行\ncreate_joints_in_selection()\n" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "# -*- coding: utf-8 -*-\nimport maya.cmds as cmds\n\ndef get_unique..." 
