        -command "\n# -----------------------------------\n# 工作室图书馆V2.16.0.c1\n# -----------------------------------\n\nimport os\nimport sys\n    \nif not os.path.exists(r'F:\\maya\\A\\scripts box\\jiaoben\\studiolibrary\\src'):\n    raise IOError(r'The source path \"F:\\maya\\A\\scripts box\\jiaoben\\studiolibrary\\src\" does not exist!')\n    \nif r'F:\\maya\\A\\scripts box\\jiaoben\\studiolibrary\\src' not in sys.path:\n    sys.path.insert(0, r'F:\\maya\\A\\scripts box\\jiaoben\\studiolibrary\\src')\n\nimport studiolibrary\nstudiolibrary.reload()\n    \nimport studiolibrary\nstudiolibrary.main()\n" 
