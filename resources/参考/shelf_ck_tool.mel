        -mi "adv合集" ( "" )
        -mi "刷新列表" ( "string $Seventh_ADV_shelves[]=`tabLayout -q -ca $gShelfTopLevel`;\nstring $Seventh_ADV_tempPathFinal;\nfor ($i=0;$i<size($Seventh_ADV_shelves);$i++)\n\t{\n\t$buttons=`layout -q -ca $Seventh_ADV_shelves[$i]`;\n    for ($y=0;$y<size($buttons);$y++)\n        {\n\t\tif (!`shelfButton -q -ex $buttons[$y]`)\n\t\t\tcontinue;\n        string $label=`shelfButton -q -label $buttons[$y]`;        \n        if ($label==\"Seventh:AdvancedSkeleton\"){\n            string $command=`shelfButton -q -c $buttons[$y]`;\n            string $replaceString = `match \"(AdvancedSkeleton/AdvancedSkeleton)+[0-9]+(.)+[0-9]\" $command`;\n            string $substitute = `substitute $replaceString $command \"^^^^^^\"`; \n            string $buffer[];\n            $numTokens = `tokenize $substitute \"^^^^^^\" $buffer`;\n            string $tempPathFront = $buffer[0];\n            $Seventh_ADV_tempPathFinal = $tempPathFront+\"install.mel\\\";\";                   \n            deleteUI -control $buttons[$y];\n            }\n        if ($label==\"Seventh:biped\"){\n            deleteUI -control $buttons[$y];\n            }\n        if ($label==\"Seventh:face\"){\n            deleteUI -control $buttons[$y];\n            }\n        if ($label==\"Seventh:picker\"){\n            deleteUI -control $buttons[$y];\n            }        \n        }   \n\t}\nevalDeferred($Seventh_ADV_tempPathFinal);" )
        -mi "5.250" ( "string $Seventh_ADV_Version = \"5.250\";\nstring $Seventh_ADV_Version_Num = startString($Seventh_ADV_Version, 1);\nstring $Seventh_ADV_iol = $Seventh_ADV_Version;\nstring $tempPathFront;\nstring $Seventh_ADV_shelves[]=`tabLayout -q -ca $gShelfTopLevel`;\nfor ($i=0;$i<size($Seventh_ADV_shelves);$i++)\n\t{\n\t$buttons=`layout -q -ca $Seventh_ADV_shelves[$i]`;\n    for ($y=0;$y<size($buttons);$y++)\n\t\t{\n\t\tif (!`shelfButton -q -ex $buttons[$y]`)\n\t\t\tcontinue;\n        string $label=`shelfButton -q -label $buttons[$y]`;\n        if ($label==\"Seventh:AdvancedSkeleton\")\n\t\t\t{\n            string $command=`shelfButton -q -c $buttons[$y]`;\n            string $replaceString = `match \"(AdvancedSkeleton)+[0-9]+(.)+[0-9]\" $command`;\n            string $substitute = `substitute $replaceString $command \"^^^^^^\"`; \n            string $advIolString = \"AdvancedSkeleton\" + $Seventh_ADV_iol; \n            string $buffer[];\n            $numTokens = `tokenize $substitute \"^^^^^^\" $buffer`;\n            string $tempPathFront = $buffer[0];\n            if ($Seventh_ADV_Version_Num==\"6\")\n                {\n                $endCommand = \"/AdvancedSkeleton.mel\\\";AdvancedSkeleton;\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            if ($Seventh_ADV_Version_Num==\"5\")\n                {\n                $endCommand = \"/AdvancedSkeleton5.mel\\\";AdvancedSkeleton5;\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            }\n        if ($label==\"Seventh:biped\")\n\t\t\t{\n            string $command=`shelfButton -q -c $buttons[$y]`;\n            string $replaceString = `match \"(AdvancedSkeleton)+[0-9]+(.)+[0-9]\" $command`;\n            string $substitute = `substitute $replaceString $command \"^^^^^^\"`; \n            string $advIolString = \"AdvancedSkeleton\" + $Seventh_ADV_iol; \n            string $buffer[];\n            $numTokens = `tokenize $substitute \"^^^^^^\" $buffer`;\n            string $tempPathFront = $buffer[0];\n            if ($Seventh_ADV_Version_Num==\"6\")\n                {\n                $endCommand = \"/AdvancedSkeletonFiles/Selector/biped.mel\\\";\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            if ($Seventh_ADV_Version_Num==\"5\")\n                {\n                $endCommand = \"/AdvancedSkeleton5Files/Selector/biped.mel\\\";\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            }\n        if ($label==\"Seventh:face\")\n\t\t\t{\n            string $command=`shelfButton -q -c $buttons[$y]`;\n            string $replaceString = `match \"(AdvancedSkeleton)+[0-9]+(.)+[0-9]\" $command`;\n            string $substitute = `substitute $replaceString $command \"^^^^^^\"`; \n            string $advIolString = \"AdvancedSkeleton\" + $Seventh_ADV_iol; \n            string $buffer[];\n            $numTokens = `tokenize $substitute \"^^^^^^\" $buffer`;\n            string $tempPathFront = $buffer[0];\n            if ($Seventh_ADV_Version_Num==\"6\")\n                {\n                $endCommand = \"/AdvancedSkeletonFiles/Selector/face.mel\\\";\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            if ($Seventh_ADV_Version_Num==\"5\")\n                {\n                $endCommand = \"/AdvancedSkeleton5Files/Selector/face.mel\\\";\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            }\n        if ($label==\"Seventh:picker\")\n\t\t\t{\n            string $command=`shelfButton -q -c $buttons[$y]`;\n            string $replaceString = `match \"(AdvancedSkeleton)+[0-9]+(.)+[0-9]\" $command`;\n            string $substitute = `substitute $replaceString $command \"^^^^^^\"`; \n            string $advIolString = \"AdvancedSkeleton\" + $Seventh_ADV_iol; \n            string $buffer[];\n            $numTokens = `tokenize $substitute \"^^^^^^\" $buffer`;\n            string $tempPathFront = $buffer[0];\n            if ($Seventh_ADV_Version_Num==\"6\")\n                {\n                $endCommand = \"/AdvancedSkeletonFiles/picker/picker.mel\\\";\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            if ($Seventh_ADV_Version_Num==\"5\")\n                {\n                $endCommand = \"/AdvancedSkeleton5Files/picker/picker.mel\\\";\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            }\n        }\n\t}" )
        -mi "5.340" ( "string $Seventh_ADV_Version = \"5.340\";\nstring $Seventh_ADV_Version_Num = startString($Seventh_ADV_Version, 1);\nstring $Seventh_ADV_iol = $Seventh_ADV_Version;\nstring $tempPathFront;\nstring $Seventh_ADV_shelves[]=`tabLayout -q -ca $gShelfTopLevel`;\nfor ($i=0;$i<size($Seventh_ADV_shelves);$i++)\n\t{\n\t$buttons=`layout -q -ca $Seventh_ADV_shelves[$i]`;\n    for ($y=0;$y<size($buttons);$y++)\n\t\t{\n\t\tif (!`shelfButton -q -ex $buttons[$y]`)\n\t\t\tcontinue;\n        string $label=`shelfButton -q -label $buttons[$y]`;\n        if ($label==\"Seventh:AdvancedSkeleton\")\n\t\t\t{\n            string $command=`shelfButton -q -c $buttons[$y]`;\n            string $replaceString = `match \"(AdvancedSkeleton)+[0-9]+(.)+[0-9]\" $command`;\n            string $substitute = `substitute $replaceString $command \"^^^^^^\"`; \n            string $advIolString = \"AdvancedSkeleton\" + $Seventh_ADV_iol; \n            string $buffer[];\n            $numTokens = `tokenize $substitute \"^^^^^^\" $buffer`;\n            string $tempPathFront = $buffer[0];\n            if ($Seventh_ADV_Version_Num==\"6\")\n                {\n                $endCommand = \"/AdvancedSkeleton.mel\\\";AdvancedSkeleton;\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            if ($Seventh_ADV_Version_Num==\"5\")\n                {\n                $endCommand = \"/AdvancedSkeleton5.mel\\\";AdvancedSkeleton5;\";\n                string $finalCommand = $tempPathFront+$advIolString+$endCommand;\n                shelfButton -e -iol $Seventh_ADV_iol -c $finalCommand $buttons[$y];\n                }\n            }\n        if ($label==\"Seventh:biped\")\n\t\t\t{\n            string $command=`shelfButton -q -c $buttons[$y]`;\n            string $replaceString = `match \"(AdvancedSkeleton)+[0-9]+(.)+[0-9]\" $command`;\n            string $substi