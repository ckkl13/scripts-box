        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "import maya.cmds as cmds\n\n# 获取当前选中的物体\njnt = cmds.ls(sel..." 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "打印选择" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\nimport maya.cmds as cmds\n\n# 获取当前选择（短名）\njnt = cmds.ls(sl=True, l=False)\n\nif not jnt:\n    cmds.warning(\"当前没有选择任何物体！\")\nelse:\n    count = len(jnt)\n\n    print(\"=== 当前选择的物体列表 ===\")\n    print([str(obj) for obj in jnt])\n    print(\"=== 选择的物体数量：{} ===\".format(count))\n\n    line_length = 8\n    lines = []\n\n    for i in range(0, count, line_length):\n        chunk = jnt[i:i + line_length]\n        lines.append(\", \".join(\"'{}'\".format(obj) for obj in chunk))\n\n    code_str = \"import maya.cmds as cmds\\n\\n\"\n    code_str += \"jnt = [\"\n\n    if lines:\n        code_str += lines[0]\n\n    for line in lines[1:]:\n        code_str += \",\\n    \" + line\n\n    code_str += \"]\\n\"\n    code_str += \"cmds.select(jnt, r=True)\\n\"\n\n    print(\"\\n=== 可直接使用的选择代码（共 {} 个） ===\".format(count))\n    print(code_str)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "# -*- coding: utf-8 -*-\n\"\"\"\nMaya骨骼半径设置工具\n功能：设置场景中所有骨骼的半径\n兼容Python 2.7和Python 3.x\n\"\"\"\n\nimport maya.cmds as cmds\nimport sys\n\n# Python 2/3 兼容性处理\nif sys.version_info[0] >= 3:\n    unicode = str\n\ndef set_all_joints_radius(radius=1.0):\n    \"\"\"\n    设置场景中所有骨骼的半径\n    \n    Args:\n        radius (float): 要设置的半径值\n    \n    Returns:\n        list: 被修改的骨骼节点列表\n    \"\"\"\n    # 获取场景中所有的骨骼节点\n    all_joints = cmds.ls(type='joint')\n    \n    if not all_joints:\n        cmds.warning(\"场景中没有找到任何骨骼节点\")\n        return []\n    \n    # 设置每个骨骼的半径\n    modified_joints = []\n    for joint in all_joints:\n        try:\n            cmds.setAttr(joint + '.radius', radius)\n            modified_joints.append(joint)\n        except Exception as e:\n            print(\"设置骨骼 {} 的半径时出错: {}\".format(joint, str(e)))\n    \n    # 打印结果\n    print(\"已设置 {} 个骨骼的半径为 {}\".format(len(modified_joints), radius))\n    \n    return modified_joints\n\ndef set_selected_joints_radius(radius=1.0):\n    \"\"\"\n    设置选中骨骼的半径\n    \n    Args:\n        radius (float): 要设置的半径值\n    \n    Returns:\n        list: 被修改的骨骼节点列表\n    \"\"\"\n    # 获取当前选择的对象\n    selected = cmds.ls(selection=True, type='joint')\n    \n    if not selected:\n        cmds.warning(\"请先选择骨骼节点\")\n        return []\n    \n    # 设置每个选中骨骼的半径\n    modified_joints = []\n    for joint in selected:\n        try:\n            cmds.setAttr(joint + '.radius', radius)\n            modified_joints.append(joint)\n        except Exception as e:\n            print(\"设置骨骼 {} 的半径时出错: {}\".format(joint, str(e)))\n    \n    # 打印结果\n    print(\"已设置 {} 个选中骨骼的半径为 {}\".format(len(modified_joints), radius))\n    \n    return modified_joints\n\ndef get_joints_radius_info():\n    \"\"\"\n    获取场景中所有骨骼的半径信息\n    \n    Returns:\n        dict: 骨骼名称和半径值的字典\n    \"\"\"\n    all_joints = cmds.ls(type='joint')\n    radius_info = {}\n    \n    for joint in all_joints:\n        try:\n            radius = cmds.getAttr(joint + '.radius')\n            radius_info[joint] = radius\n        except:\n            radius_info[joint] = \"无法获取\"\n    \n    return radius_info\n\ndef update_field_from_slider(field, value):\n    \"\"\"\n    从滑条更新输入框的值\n    \"\"\"\n    cmds.floatField(field, edit=True, value=value)\n\ndef update_slider_from_field(slider, value):\n    \"\"\"\n    从输入框更新滑条值\n    \"\"\"\n    cmds.floatSlider(slider, edit=True, value=value)\n\ndef on_preview_checkbox_change(state):\n    \"\"\"\n    选中骨骼预览复选框状态改变时的回调\n    \"\"\"\n    if state:\n        # 如果选中骨骼预览被启用，禁用全部骨骼预览\n        cmds.checkBox('preview_all_checkbox', edit=True, value=False)\n\ndef on_preview_all_checkbox_change(state):\n    \"\"\"\n    全部骨骼预览复选框状态改变时的回调\n    \"\"\"\n    if state:\n        # 如果全部骨骼预览被启用，禁用选中骨骼预览\n        cmds.checkBox('preview_checkbox', edit=True, value=False)\n\ndef preview_radius_change(value):\n    \"\"\"\n    实时预览半径变化\n    \"\"\"\n    # 检查是否启用全部骨骼实时预览\n    if cmds.checkBox('preview_all_checkbox', query=True, value=True):\n        all_joints = cmds.ls(type='joint')\n        if all_joints:\n            for joint in all_joints:\n                try:\n                    cmds.setAttr(joint + '.radius', value)\n                except:\n                    pass\n    # 检查是否启用选中骨骼实时预览\n    elif cmds.checkBox('preview_checkbox', query=True, value=True):\n        selected_joints = cmds.ls(selection=True, type='joint')\n        if selected_joints:\n            for joint in selected_joints:\n                try:\n                    cmds.setAttr(joint + '.radius', value)\n                except:\n                    pass\n\ndef create_radius_ui():\n    \"\"\"\n    创建骨骼半径设置UI界面\n    \"\"\"\n    window_name = \"jointRadiusUI\"\n    \n    # 如果窗口已存在，删除它\n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    \n    # 创建窗口\n    window = cmds.window(window_name, title=\"骨骼半径设置工具\", widthHeight=(320, 280), sizeable=False)\n    \n    # 创建主布局\n    main_layout = cmds.columnLayout(adjustableColumn=True, rowSpacing=5, columnOffset=('both', 10))\n    \n    # 添加顶部间距\n    cmds.separator(height=5, style='none')\n    \n    # 标题\n    cmds.text(label=\"骨骼半径设置工具\", font=\"boldLabelFont\", height=30)\n    cmds.separator(height=10)\n    \n    # 半径输入区域\n    cmds.text(label=\"设置半径值:\", align=\"left\")\n    \n    # 创建行布局用于数值输入和滑条\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(100, 180), columnAttach=[(1, 'both', 5), (2, 'both', 5)])\n    \n    # 数值输入框\n    radius_field = cmds.floatField(value=1.0, precision=3, minValue=0.001, maxValue=10.0, step=0.1)\n    \n    # 滑条控件\n    radius_slider = cmds.floatSlider(min=0.001, max=10.0, value=1.0, step=0.01, \n                                   changeCommand=lambda x: update_field_from_slider(radius_field, x),\n                                   dragCommand=lambda x: preview_radius_change(x))\n    \n    cmds.setParent('..')\n    \n    # 连接输入框到滑条的回调\n    cmds.floatField(radius_field, edit=True, \n                   changeCommand=lambda x: update_slider_from_field(radius_slider, x))\n    \n    cmds.separator(height=5)\n    \n    # 实时预览选项\n    cmds.text(label=\"实时预览选项：\", align='left', font='boldLabelFont')\n    cmds.checkBox('preview_checkbox', label=\"选中骨骼\", value=False, \n                 annotation=\"启用后拖拽滑条时会实时更新选中骨骼的半径\",\n                 changeCommand=on_preview_checkbox_change)\n    cmds.checkBox('preview_all_checkbox', label=\"全部骨骼\", value=False, \n                 annotation=\"启用后拖拽滑条时会实时更新场景中所有骨骼的半径\",\n                 changeCommand=on_preview_all_checkbox_change)\n    \n    cmds.separator(height=10)\n    \n    # 按钮区域\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(140, 140), columnAttach=[(1, 'both', 5), (2, 'both', 5)])\n    \n    # 设置所有骨骼按钮\n    cmds.button(label=\"设置所有骨骼\", \n                command=lambda x: set_all_joints_radius_from_ui(radius_field),\n                backgroundColor=(0.6, 0.8, 0.6))\n    \n    # 设置选中骨骼按钮\n    cmds.button(label=\"设置选中骨骼\", \n                command=lambda x: set_selected_joints_radius_from_ui(radius_field),\n                backgroundColor=(0.8, 0.8, 0.6))\n    \n    cmds.setParent('..')\n    \n    cmds.separator(height=10)\n    \n    # 信息显示按钮\n    cmds.button(label=\"显示骨骼半径信息\", \n                command=lambda x: show_radius_info(),\n                backgroundColor=(0.7, 0.7, 0.9))\n    \n    # 添加底部间距\n    cmds.separator(height=5, style='none')\n    \n    # 显示窗口\n    cmds.showWindow(window)\n\ndef set_all_joints_radius_from_ui(radius_field):\n    \"\"\"\n    从UI获取半径值并设置所有骨骼\n    \"\"\"\n    radius = cmds.floatField(radius_field, query=True, value=True)\n    \n    # 确认对话框\n    confirm = cmds.confirmDialog(\n        title='确认设置',\n        message='确定要将所有骨骼的半径设置为 {} 吗？'.format(radius),\n        button=['确认', '取消'],\n        defaultButton='确认',\n        cancelButton='取消',\n        dismissString='取消'\n    )\n    \n    if confirm == '确认':\n        modified_joints = set_all_joints_radius(radius)\n        if modified_joints:\n            cmds.inViewMessage(amg='成功设置 {} 个骨骼的半径为 {}'.format(len(modified_joints), radius), \n                             pos='midCenter', fade=True, fts=14)\n\ndef set_selected_joints_radius_from_ui(radius_field):\n    \"\"\"\n    从UI获取半径值并设置选中骨骼\n    \"\"\"\n    radius = cmds.floatField(radius_field, query=True, value=True)\n    \n    modified_joints = set_selected_joints_radius(radius)\n    if modified_joints:\n        cmds.inViewMessage(amg='成功设置 {} 个选中骨骼的半径为 {}'.format(len(modified_joints), radius), \n                         pos='midCenter', fade=True, fts=14)\n\ndef show_radius_info():\n    \"\"\"\n    显示骨骼半径信息\n    \"\"\"\n    radius_info = get_joints_radius_info()\n    \n    if not radius_info:\n        cmds.warning(\"场景中没有找到任何骨骼节点\")\n        return\n    \n    print(\"\\n=== 骨骼半径信息 ===\")\n    for joint, radius in radius_info.items():\n        print(\"{}: {}\".format(joint, radius))\n    print(\"=== 共 {} 个骨骼 ===\\n\".format(len(radius_info)))\n    \n    cmds.inViewMessage(amg='骨骼半径信息已输出到脚本编辑器', \n                     pos='midCenter', fade=True, fts=14)\n\n# 主执行函数\nif __name__ == '__main__':\n    # 创建UI界面\n    create_radius_ui()\n\n\"\"\"\n使用说明：\n\n1. 基本功能：\n   - 设置场景中所有骨骼的半径\n   - 设置选中骨骼的半径\n   - 查看骨骼半径信息\n\n2. UI界面：\n   - 运行脚本会自动打开设置界面\n   - 可以输入半径值（支持小数）\n   - 提供确认对话框防止误操作\n\n3. 函数说明：\n   - set_all_joints_radius(radius)：设置所有骨骼半径\n   - set_selected_joints_radius(radius)：设置选中骨骼半径\n   - get_joints_radius_info()：获取骨骼半径信息\n   - create_radius_ui()：创建UI界面\n\n4. 注意事项：\n   - 半径值范围：0.001 - 100.0\n   - 脚本会自动检查骨骼是否存在\n   - 操作结果会在视图中显示提示信息\n   - 兼容Python 2.7和Python 3.x\n\n5. 错误处理：\n   - 如果场景中没有骨骼，会显示警告\n   - 如果设置失败，会在控制台输出错误信息\n   - 提供确认对话框防止误操作\n\"\"\"" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "骨骼半径" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "骨骼半径" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\n\"\"\"\nMaya骨骼半径设置工具\n功能：设置场景中所有骨骼的半径\n兼容Python 2.7和Python 3.x\n\"\"\"\n\nimport maya.cmds as cmds\nimport sys\n\n# Python 2/3 兼容性处理\nif sys.version_info[0] >= 3:\n    unicode = str\n\ndef set_all_joints_radius(radius=1.0):\n    \"\"\"\n    设置场景中所有骨骼的半径\n    \n    Args:\n        radius (float): 要设置的半径值\n    \n    Returns:\n        list: 被修改的骨骼节点列表\n    \"\"\"\n    # 获取场景中所有的骨骼节点\n    all_joints = cmds.ls(type='joint')\n    \n    if not all_joints:\n        cmds.warning(\"场景中没有找到任何骨骼节点\")\n        return []\n    \n    # 设置每个骨骼的半径\n    modified_joints = []\n    for joint in all_joints:\n        try:\n            cmds.setAttr(joint + '.radius', radius)\n            modified_joints.append(joint)\n        except Exception as e:\n            print(\"设置骨骼 {} 的半径时出错: {}\".format(joint, str(e)))\n    \n    # 打印结果\n    print(\"已设置 {} 个骨骼的半径为 {}\".format(len(modified_joints), radius))\n    \n    return modified_joints\n\ndef set_selected_joints_radius(radius=1.0):\n    \"\"\"\n    设置选中骨骼的半径\n    \n    Args:\n        radius (float): 要设置的半径值\n    \n    Returns:\n        list: 被修改的骨骼节点列表\n    \"\"\"\n    # 获取当前选择的对象\n    selected = cmds.ls(selection=True, type='joint')\n    \n    if not selected:\n        cmds.warning(\"请先选择骨骼节点\")\n        return []\n    \n    # 设置每个选中骨骼的半径\n    modified_joints = []\n    for joint in selected:\n        try:\n            cmds.setAttr(joint + '.radius', radius)\n            modified_joints.append(joint)\n        except Exception as e:\n            print(\"设置骨骼 {} 的半径时出错: {}\".format(joint, str(e)))\n    \n    # 打印结果\n    print(\"已设置 {} 个选中骨骼的半径为 {}\".format(len(modified_joints), radius))\n    \n    return modified_joints\n\ndef get_joints_radius_info():\n    \"\"\"\n    获取场景中所有骨骼的半径信息\n    \n    Returns:\n        dict: 骨骼名称和半径值的字典\n    \"\"\"\n    all_joints = cmds.ls(type='joint')\n    radius_info = {}\n    \n    for joint in all_joints:\n        try:\n            radius = cmds.getAttr(joint + '.radius')\n            radius_info[joint] = radius\n        except:\n            radius_info[joint] = \"无法获取\"\n    \n    return radius_info\n\ndef update_field_from_slider(field, value):\n    \"\"\"\n    从滑条更新输入框的值\n    \"\"\"\n    cmds.floatField(field, edit=True, value=value)\n\ndef update_slider_from_field(slider, value):\n    \"\"\"\n    从输入框更新滑条值\n    \"\"\"\n    cmds.floatSlider(slider, edit=True, value=value)\n\ndef on_preview_checkbox_change(state):\n    \"\"\"\n    选中骨骼预览复选框状态改变时的回调\n    \"\"\"\n    if state:\n        # 如果选中骨骼预览被启用，禁用全部骨骼预览\n        cmds.checkBox('preview_all_checkbox', edit=True, value=False)\n\ndef on_preview_all_checkbox_change(state):\n    \"\"\"\n    全部骨骼预览复选框状态改变时的回调\n    \"\"\"\n    if state:\n        # 如果全部骨骼预览被启用，禁用选中骨骼预览\n        cmds.checkBox('preview_checkbox', edit=True, value=False)\n\ndef preview_radius_change(value):\n    \"\"\"\n    实时预览半径变化\n    \"\"\"\n    # 检查是否启用全部骨骼实时预览\n    if cmds.checkBox('preview_all_checkbox', query=True, value=True):\n        all_joints = cmds.ls(type='joint')\n        if all_joints:\n            for joint in all_joints:\n                try:\n                    cmds.setAttr(joint + '.radius', value)\n                except:\n                    pass\n    # 检查是否启用选中骨骼实时预览\n    elif cmds.checkBox('preview_checkbox', query=True, value=True):\n        selected_joints = cmds.ls(selection=True, type='joint')\n        if selected_joints:\n            for joint in selected_joints:\n                try:\n                    cmds.setAttr(joint + '.radius', value)\n                except:\n                    pass\n\ndef create_radius_ui():\n    \"\"\"\n    创建骨骼半径设置UI界面\n    \"\"\"\n    window_name = \"jointRadiusUI\"\n    \n    # 如果窗口已存在，删除它\n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    \n    # 创建窗口\n    window = cmds.window(window_name, title=\"骨骼半径设置工具\", widthHeight=(320, 280), sizeable=False)\n    \n    # 创建主布局\n    main_layout = cmds.columnLayout(adjustableColumn=True, rowSpacing=5, columnOffset=('both', 10))\n    \n    # 添加顶部间距\n    cmds.separator(height=5, style='none')\n    \n    # 标题\n    cmds.text(label=\"骨骼半径设置工具\", font=\"boldLabelFont\", height=30)\n    cmds.separator(height=10)\n    \n    # 半径输入区域\n    cmds.text(label=\"设置半径值:\", align=\"left\")\n    \n    # 创建行布局用于数值输入和滑条\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(100, 180), columnAttach=[(1, 'both', 5), (2, 'both', 5)])\n    \n    # 数值输入框\n    radius_field = cmds.floatField(value=1.0, precision=3, minValue=0.001, maxValue=10.0, step=0.1)\n    \n    # 滑条控件\n    radius_slider = cmds.floatSlider(min=0.001, max=10.0, value=1.0, step=0.01, \n                                   changeCommand=lambda x: update_field_from_slider(radius_field, x),\n                                   dragCommand=lambda x: preview_radius_change(x))\n    \n    cmds.setParent('..')\n    \n    # 连接输入框到滑条的回调\n    cmds.floatField(radius_field, edit=True, \n                   changeCommand=lambda x: update_slider_from_field(radius_slider, x))\n    \n    cmds.separator(height=5)\n    \n    # 实时预览选项\n    cmds.text(label=\"实时预览选项：\", align='left', font='boldLabelFont')\n    cmds.checkBox('preview_checkbox', label=\"选中骨骼\", value=False, \n                 annotation=\"启用后拖拽滑条时会实时更新选中骨骼的半径\",\n                 changeCommand=on_preview_checkbox_change)\n    cmds.checkBox('preview_all_checkbox', label=\"全部骨骼\", value=False, \n                 annotation=\"启用后拖拽滑条时会实时更新场景中所有骨骼的半径\",\n                 changeCommand=on_preview_all_checkbox_change)\n    \n    cmds.separator(height=10)\n    \n    # 按钮区域\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(140, 140), columnAttach=[(1, 'both', 5), (2, 'both', 5)])\n    \n    # 设置所有骨骼按钮\n    cmds.button(label=\"设置所有骨骼\", \n                command=lambda x: set_all_joints_radius_from_ui(radius_field),\n                backgroundColor=(0.6, 0.8, 0.6))\n    \n    # 设置选中骨骼按钮\n    cmds.button(label=\"设置选中骨骼\", \n                command=lambda x: set_selected_joints_radius_from_ui(radius_field),\n                backgroundColor=(0.8, 0.8, 0.6))\n    \n    cmds.setParent('..')\n    \n    cmds.separator(height=10)\n    \n    # 信息显示按钮\n    cmds.button(label=\"显示骨骼半径信息\", \n                command=lambda x: show_radius_info(),\n                backgroundColor=(0.7, 0.7, 0.9))\n    \n    # 添加底部间距\n    cmds.separator(height=5, style='none')\n    \n    # 显示窗口\n    cmds.showWindow(window)\n\ndef set_all_joints_radius_from_ui(radius_field):\n    \"\"\"\n    从UI获取半径值并设置所有骨骼\n    \"\"\"\n    radius = cmds.floatField(radius_field, query=True, value=True)\n    \n    # 确认对话框\n    confirm = cmds.confirmDialog(\n        title='确认设置',\n        message='确定要将所有骨骼的半径设置为 {} 吗？'.format(radius),\n        button=['确认', '取消'],\n        defaultButton='确认',\n        cancelButton='取消',\n        dismissString='取消'\n    )\n    \n    if confirm == '确认':\n        modified_joints = set_all_joints_radius(radius)\n        if modified_joints:\n            cmds.inViewMessage(amg='成功设置 {} 个骨骼的半径为 {}'.format(len(modified_joints), radius), \n                             pos='midCenter', fade=True, fts=14)\n\ndef set_selected_joints_radius_from_ui(radius_field):\n    \"\"\"\n    从UI获取半径值并设置选中骨骼\n    \"\"\"\n    radius = cmds.floatField(radius_field, query=True, value=True)\n    \n    modified_joints = set_selected_joints_radius(radius)\n    if modified_joints:\n        cmds.inViewMessage(amg='成功设置 {} 个选中骨骼的半径为 {}'.format(len(modified_joints), radius), \n                         pos='midCenter', fade=True, fts=14)\n\ndef show_radius_info():\n    \"\"\"\n    显示骨骼半径信息\n    \"\"\"\n    radius_info = get_joints_radius_info()\n    \n    if not radius_info:\n        cmds.warning(\"场景中没有找到任何骨骼节点\")\n        return\n    \n    print(\"\\n=== 骨骼半径信息 ===\")\n    for joint, radius in radius_info.items():\n        print(\"{}: {}\".format(joint, radius))\n    print(\"=== 共 {} 个骨骼 ===\\n\".format(len(radius_info)))\n    \n    cmds.inViewMessage(amg='骨骼半径信息已输出到脚本编辑器', \n                     pos='midCenter', fade=True, fts=14)\n\n# 主执行函数\nif __name__ == '__main__':\n    # 创建UI界面\n    create_radius_ui()\n\n\"\"\"\n使用说明：\n\n1. 基本功能：\n   - 设置场景中所有骨骼的半径\n   - 设置选中骨骼的半径\n   - 查看骨骼半径信息\n\n2. UI界面：\n   - 运行脚本会自动打开设置界面\n   - 可以输入半径值（支持小数）\n   - 提供确认对话框防止误操作\n\n3. 函数说明：\n   - set_all_joints_radius(radius)：设置所有骨骼半径\n   - set_selected_joints_radius(radius)：设置选中骨骼半径\n   - get_joints_radius_info()：获取骨骼半径信息\n   - create_radius_ui()：创建UI界面\n\n4. 注意事项：\n   - 半径值范围：0.001 - 100.0\n   - 脚本会自动检查骨骼是否存在\n   - 操作结果会在视图中显示提示信息\n   - 兼容Python 2.7和Python 3.x\n\n5. 错误处理：\n   - 如果场景中没有骨骼，会显示警告\n   - 如果设置失败，会在控制台输出错误信息\n   - 提供确认对话框防止误操作\n\"\"\"" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
