        -command "import maya.cmds as cmds\n\n# 获取选择\nsel = cmds.ls(selection=True, long=True)\n\nif not sel:\n    cmds.warning(\"请先选择物体。\")\nelse:\n    zero_groups = []  # 存放创建的组\n\n    for obj in sel:\n        if not cmds.objExists(obj):\n            continue\n\n        short_name = obj.split('|')[-1]\n        zero_name = short_name + \"_zero\"\n\n        # 如果已有相同名字的组，则重命名避免冲突\n        if cmds.objExists(zero_name):\n            zero_name = cmds.rename(zero_name, zero_name + \"_1\")\n\n        # 创建空组\n        zero_grp = cmds.group(empty=True, name=zero_name)\n\n        # 匹配组的变换到物体\n        cmds.matchTransform(zero_grp, obj, pos=True, rot=True, scl=True)\n\n        # 如果物体有父级，把组放在相同层级下\n        parent = cmds.listRelatives(obj, parent=True)\n        if parent:\n            cmds.parent(zero_grp, parent[0])\n        else:\n            print()\n\n        # 把物体放进 zero 组里\n        cmds.parent(obj, zero_grp)\n\n        zero_groups.append(zero_grp)\n\n    # 最后选中所有创建的 zero 组\n    cmds.select(zero_groups)\n\n\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "选择要进行混合的两个或更多对象；最后选择基础形状" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "混合变形" 
        -labelOffset 0
