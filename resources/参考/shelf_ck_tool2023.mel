        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "k帧" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "k帧" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\n# 设置变量aniR为60\naniR = 90\n\n# 获取选择的物体\nselected_objects = cmds.ls(selection=True)\n\n# 批量执行旋转动画\nfor obj in selected_objects:\n    # 获取初始旋转X的数值为变量del\n    del_valueX = cmds.getAttr(obj + '.rotateX')\n    \n    # 在第0帧旋转X K一帧\n    cmds.setKeyframe(obj, attribute='rotateX', time=0, value=del_valueX)\n    \n    # 第10帧，旋转X数值加aniR K一帧\n    cmds.currentTime(10, edit=True)\n    cmds.setAttr(obj + '.rotateX', del_valueX + aniR)\n    cmds.setKeyframe(obj, attribute='rotateX')\n    \n    # 第20帧，旋转X数值为del K一帧\n    cmds.currentTime(20, edit=True)\n    cmds.setAttr(obj + '.rotateX', del_valueX)\n    cmds.setKeyframe(obj, attribute='rotateX')\n    \n    # 第30帧，旋转X数值减aniR K一帧\n    cmds.currentTime(30, edit=True)\n    cmds.setAttr(obj + '.rotateX', del_valueX - aniR)\n    cmds.setKeyframe(obj, attribute='rotateX')\n    \n    # 第40帧，旋转X数值为del K一帧\n    cmds.currentTime(40, edit=True)\n    cmds.setAttr(obj + '.rotateX', del_valueX)\n    cmds.setKeyframe(obj, attribute='rotateX')\n    \n    # 获取初始旋转y的数值为变量del\n    del_valueY = cmds.getAttr(obj + '.rotateY')\n    \n    # 在第40帧旋转y K一帧\n    cmds.setKeyframe(obj, attribute='rotateY', time=40, value=del_valueY)\n    \n    # 第50帧，旋转y数值加aniR K一帧\n    cmds.currentTime(50, edit=True)\n    cmds.setAttr(obj + '.rotateY', del_valueY + aniR)\n    cmds.setKeyframe(obj, attribute='rotateY')\n    \n    # 第60帧，旋转y数值为del K一帧\n    cmds.currentTime(60, edit=True)\n    cmds.setAttr(obj + '.rotateY', del_valueY)\n    cmds.setKeyframe(obj, attribute='rotateY')\n    \n    # 第70帧，旋转y数值减aniR K一帧\n    cmds.currentTime(70, edit=True)\n    cmds.setAttr(obj + '.rotateY', del_valueY - aniR)\n    cmds.setKeyframe(obj, attribute='rotateY')\n    \n    # 第80帧，旋转y数值为del K一帧\n    cmds.currentTime(80, edit=True)\n    cmds.setAttr(obj + '.rotateY', del_valueY)\n    cmds.setKeyframe(obj, attribute='rotateY')\n    \n    \n    # 获取初始旋转z的数值为变量del\n    del_valueZ = cmds.getAttr(obj + '.rotateZ')\n    \n    # 在第80帧旋转y K一帧\n    cmds.setKeyframe(obj, attribute='rotateZ', time=80, value=del_valueZ)\n    \n    # 第90帧，旋转y数值加aniR K一帧\n    cmds.currentTime(90, edit=True)\n    cmds.setAttr(obj + '.rotateZ', del_valueZ + aniR)\n    cmds.setKeyframe(obj, attribute='rotateZ')\n    \n    # 第100帧，旋转y数值为del K一帧\n    cmds.currentTime(100, edit=True)\n    cmds.setAttr(obj + '.rotateZ', del_valueZ)\n    cmds.setKeyframe(obj, attribute='rotateZ')\n    \n    # 第110帧，旋转y数值减aniR K一帧\n    cmds.currentTime(110, edit=True)\n    cmds.setAttr(obj + '.rotateZ', del_valueZ - aniR)\n    cmds.setKeyframe(obj, attribute='rotateZ')\n    \n    # 第120帧，旋转y数值为del K一帧\n    cmds.currentTime(120, edit=True)\n    cmds.setAttr(obj + '.rotateZ', del_valueZ)\n    cmds.setKeyframe(obj, attribute='rotateZ')\n    \n# 设置时间轴范围为0到120帧\ncmds.playbackOptions(minTime=0, maxTime=120)\ncmds.playbackOptions(animationStartTime=0, animationEndTime=120)\ncmds.currentTime(0, edit=True)" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "删帧" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "删帧" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "删帧" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\n# 获取当前选择的物体\nselected_objects = cmds.ls(selection=True)\n\n# 将时间滑块回到第0帧\ncmds.currentTime(0)\n\n# 删除选定物体的动画\nfor obj in selected_objects:\n    cmds.cutKey(obj, clear=True)\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "# -*- coding: utf-8 -*-\n\"\"\"\n传递权重到一个选择的顶点范围 - Python 2 版本\n作者: Scripts Box\n\"\"\"\n\nimport maya.cmds as cmds\nimport maya.mel as mel\nfrom maya import OpenMayaUI as omui\nimport json\nimport os\nimport io  # Python2 读写带编码文件\n\ntry:\n    from PySide2.QtCore import Qt\n    from PySide2.QtWidgets import (\n        QDialog, QVBoxLayout, QHBoxLayout, QLabel,\n        QLineEdit, QPushButton, QTextEdit, QApplication,\n        QListWidget, QListWidgetItem, QAbstractItemView,\n        QInputDialog, QMessageBox, QWidget, QFrame\n    )\n    from PySide2.QtGui import QFont, QTextCursor\n    from shiboken2 import wrapInstance\nexcept ImportError:\n    try:\n        from PyQt4.QtCore import Qt\n        from PyQt4.QtGui import (\n            QDialog, QVBoxLayout, QHBoxLayout, QLabel,\n            QLineEdit, QPushButton, QTextEdit, QApplication,\n            QListWidget, QListWidgetItem, QAbstractItemView,\n            QInputDialog, QMessageBox, QWidget, QFrame, QFont, QTextCursor\n        )\n        from sip import wrapinstance as wrapInstance\n    except ImportError:\n        raise ImportError(\"需要 PySide2 或 PyQt4\")\n\n\ndef maya_main_window():\n    \"\"\"获取 Maya 主窗口\"\"\"\n    main_window_ptr = omui.MQtUtil.mainWindow()\n    if main_window_ptr is not None:\n        return wrapInstance(long(main_window_ptr), QWidget)  # Python2 需要 long\n    return None\n\n\nclass CopyWeightsToVerticesUI(QDialog):\n    \"\"\"传递权重到顶点范围 UI 类\"\"\"\n    \n    WINDOW_TITLE = u\"传递权重到顶点范围\"\n\n    def __init__(self, parent=maya_main_window()):\n        super(CopyWeightsToVerticesUI, self).__init__(parent)\n\n        self.setWindowTitle(self.WINDOW_TITLE)\n        self.setMinimumSize(500, 400)\n        self.setWindowFlags(self.windowFlags() ^ Qt.WindowContextHelpButtonHint)\n\n        # 顶点预设\n        self.vertex_presets = {}\n        self.preset_order = []\n\n        # 固定文件夹路径\n        self.presets_dir = \"D:/ck/代码py2翻版/预设顶点\"\n        self.presets_file = os.path.join(self.presets_dir, \"vertex_presets.json\")\n        self.order_file = os.path.join(self.presets_dir, \"preset_order.json\")\n\n        if not os.path.exists(self.presets_dir):\n            os.makedirs(self.presets_dir)\n\n        self.create_widgets()\n        self.create_layouts()\n        self.create_connections()\n\n        # 加载已保存的预设\n        self.load_presets_from_file()\n        self.update_preset_list()\n\n    # -------------------- UI 创建 --------------------\n    def create_widgets(self):\n        self.title_label = QLabel(u\"传递权重到选择的顶点范围\")\n        self.title_label.setAlignment(Qt.AlignCenter)\n        font = QFont()\n        font.setBold(True)\n        font.setPointSize(12)\n        self.title_label.setFont(font)\n\n        # 源模型输入\n        self.source_label = QLabel(u\"源模型:\")\n        self.source_line_edit = QLineEdit()\n        self.source_line_edit.setPlaceholderText(u\"输入源蒙皮模型名称\")\n        self.select_source_btn = QPushButton(u\"选择\")\n        self.select_source_btn.setMaximumWidth(60)\n\n        # 顶点预设管理\n        self.preset_label = QLabel(u\"顶点预设管理:\")\n        self.preset_label.setFont(QFont(\"Arial\", 10, QFont.Bold))\n\n        self.preset_list = QListWidget()\n        self.preset_list.setMaximumHeight(200)\n        self.preset_list.setSelectionMode(QAbstractItemView.ExtendedSelection)\n        self.preset_list.setDragDropMode(QAbstractItemView.InternalMove)\n        self.preset_list.setDefaultDropAction(Qt.MoveAction)\n\n        # 预设按钮\n        self.save_preset_btn = QPushButton(u\"保存当前选择\")\n        self.load_preset_btn = QPushButton(u\"应用选择\")\n        self.load_preset_btn.setToolTip(u\"支持多选预设，Ctrl+点击可选择多个预设\")\n        self.delete_preset_btn = QPushButton(u\"删除\")\n        self.delete_preset_btn.setToolTip(u\"删除预设（支持多选）\")\n\n        self.target_label = QLabel(u\"目标顶点: 选择顶点后可保存为预设，或从预设中应用（支持多选预设，可拖拽排序）\")\n        self.target_label.setAlignment(Qt.AlignCenter)\n        self.target_label.setStyleSheet(\"color: #666666; font-size: 10px;\")\n\n        self.info_text = QTextEdit()\n        self.info_text.setMaximumHeight(80)\n        self.info_text.setReadOnly(True)\n        self.info_text.setPlaceholderText(u\"操作信息将在这里显示...\")\n\n        self.execute_btn = QPushButton(u\"执行传递权重\")\n        self.close_btn = QPushButton(u\"关闭\")\n\n    def create_layouts(self):\n        main_layout = QVBoxLayout(self)\n        main_layout.setSpacing(10)\n        main_layout.setContentsMargins(15, 15, 15, 15)\n\n        main_layout.addWidget(self.title_label)\n        line1 = QFrame()\n        line1.setFrameShape(QFrame.HLine)\n        line1.setFrameShadow(QFrame.Sunken)\n        main_layout.addWidget(line1)\n\n        source_layout = QHBoxLayout()\n        source_layout.addWidget(self.source_label)\n        source_layout.addWidget(self.source_line_edit)\n        source_layout.addWidget(self.select_source_btn)\n        main_layout.addLayout(source_layout)\n\n        main_layout.addWidget(self.preset_label)\n        main_layout.addWidget(self.preset_list)\n\n        preset_btn_layout = QHBoxLayout()\n        preset_btn_layout.addWidget(self.save_preset_btn)\n        preset_btn_layout.addWidget(self.load_preset_btn)\n        preset_btn_layout.addWidget(self.delete_preset_btn)\n        main_layout.addLayout(preset_btn_layout)\n\n        main_layout.addWidget(self.target_label)\n        main_layout.addWidget(QLabel(u\"操作信息:\"))\n        main_layout.addWidget(self.info_text)\n\n        line2 = QFrame()\n        line2.setFrameShape(QFrame.HLine)\n        line2.setFrameShadow(QFrame.Sunken)\n        main_layout.addWidget(line2)\n\n        btn_layout = QHBoxLayout()\n        btn_layout.addWidget(self.execute_btn)\n        btn_layout.addWidget(self.close_btn)\n        main_layout.addLayout(btn_layout)\n\n    def create_connections(self):\n        self.select_source_btn.clicked.connect(self.set_source_from_selection)\n        self.save_preset_btn.clicked.connect(self.save_vertex_preset)\n        self.load_preset_btn.clicked.connect(self.load_vertex_preset)\n        self.delete_preset_btn.clicked.connect(self.delete_vertex_preset)\n        self.preset_list.itemDoubleClicked.connect(self.load_vertex_preset)\n        self.preset_list.itemSelectionChanged.connect(self.update_button_states)\n        self.preset_list.model().rowsMoved.connect(self.on_preset_order_changed)\n        self.execute_btn.clicked.connect(self.execute_copy_weights)\n        self.close_btn.clicked.connect(self.close)\n\n    # -------------------- 功能函数 --------------------\n    def log_message(self, message):\n        self.info_text.append(message)\n        cursor = self.info_text.textCursor()\n        cursor.movePosition(cursor.End)\n        self.info_text.setTextCursor(cursor)\n\n    def set_source_from_selection(self):\n        selection = cmds.ls(selection=True)\n        if selection:\n            source_model = selection[0]\n            self.source_line_edit.setText(source_model)\n            self.log_message(u\"已设置源模型: {}\".format(source_model))\n            print u\"已设置源模型: {}\".format(source_model)\n        else:\n            cmds.warning(u\"请先选择一个对象作为源模型\")\n            self.log_message(u\"警告: 请先选择一个对象作为源模型\")\n\n    def save_vertex_preset(self):\n        current_selection = cmds.ls(selection=True)\n        if not current_selection:\n            cmds.warning(u\"请先选择顶点\")\n            self.log_message(u\"错误: 请先选择顶点\")\n            return\n\n        vertices = cmds.filterExpand(current_selection, selectionMask=31)\n        if not vertices:\n            cmds.warning(u\"当前选择中没有顶点\")\n            self.log_message(u\"错误: 当前选择中没有顶点\")\n            return\n\n        preset_name, ok = QInputDialog.getText(self, u\"保存顶点预设\", u\"请输入预设名称:\", QLineEdit.Normal,\n                                               u\"顶点预设_{}\".format(len(self.vertex_presets) + 1))\n        if ok and preset_name.strip():\n            preset_name = preset_name.strip()\n            if preset_name in self.vertex_presets:\n                reply = QMessageBox.question(self, u\"预设已存在\",\n                                             u\"预设 '{}' 已存在，是否覆盖？\".format(preset_name),\n                                             QMessageBox.Yes | QMessageBox.No, QMessageBox.No)\n                if reply != QMessageBox.Yes:\n                    return\n\n            self.vertex_presets[preset_name] = vertices[:]\n            if preset_name not in self.preset_order:\n                self.preset_order.append(preset_name)\n\n            self.save_presets_to_file()\n            self.save_order_to_file()\n            self.update_preset_list()\n            self.log_message(u\"已保存顶点预设: {} ({} 个顶点)\".format(preset_name, len(vertices)))\n            print u\"已保存顶点预设: {} ({} 个顶点)\".format(preset_name, len(vertices))\n\n    def load_vertex_preset(self):\n        selected_items = self.preset_list.selectedItems()\n        if not selected_items:\n            cmds.warning(u\"请先选择一个或多个顶点预设\")\n            self.log_message(u\"错误: 请先选择一个或多个顶点预设\")\n            return\n\n        all_vertices = []\n        applied_presets = []\n\n        for item in selected_items:\n            preset_name = item.data(Qt.UserRole)\n            if preset_name in self.vertex_presets:\n                vertices = self.vertex_presets[preset_name]\n                existing_vertices = [v for v in vertices if cmds.objExists(v)]\n                if existing_vertices:\n                    all_vertices.extend(existing_vertices)\n                    applied_presets.append(u\"{}({}个)\".format(preset_name, len(existing_vertices)))\n                    if len(existing_vertices) != len(vertices):\n                        self.log_message(u\"警告: 预设 '{}' 中部分顶点不存在，应用了 {}/{} 个顶点\".format(\n                            preset_name, len(existing_vertices), len(vertices)))\n                else:\n                    self.log_message(u\"警告: 预设 '{}' 中的顶点都不存在\".format(preset_name))\n\n        if all_vertices:\n            unique_vertices = list(set(all_vertices))\n            cmds.select(unique_vertices, replace=True)\n            preset_info = \", \".join(applied_presets)\n            self.log_message(u\"已应用顶点预设: {}，总计 {} 个顶点\".format(preset_info, len(unique_vertices)))\n            print u\"已应用顶点预设: {}，总计 {} 个顶点\".format(preset_info, len(unique_vertices))\n        else:\n            cmds.warning(u\"所选预设中没有有效的顶点\")\n            self.log_message(u\"错误: 所选预设中没有有效的顶点\")\n\n    def delete_vertex_preset(self):\n        selected_items = self.preset_list.selectedItems()\n        if not selected_items:\n            cmds.warning(u\"请先选择要删除的顶点预设\")\n            self.log_message(u\"错误: 请先选择要删除的顶点预设\")\n            return\n\n        preset_names = [item.data(Qt.UserRole) for item in selected_items]\n\n        if len(preset_names) == 1:\n            confirm_msg = u\"确定要删除预设 '{}' 吗？\".format(preset_names[0])\n        else:\n            confirm_msg = u\"确定要删除以下 {} 个预设吗？\\n\\n{}\".format(len(preset_names), \"\\n\".join(preset_names))\n\n        reply = QMessageBox.question(self, u\"删除预设\", confirm_msg,\n                                     QMessageBox.Yes | QMessageBox.No, QMessageBox.No)\n\n        if reply == QMessageBox.Yes:\n            for preset_name in preset_names:\n                if preset_name in self.vertex_presets:\n                    del self.vertex_presets[preset_name]\n                if preset_name in self.preset_order:\n                    self.preset_order.remove(preset_name)\n            self.save_presets_to_file()\n            self.save_order_to_file()\n            self.update_preset_list()\n            self.log_message(u\"已删除 {} 个顶点预设\".format(len(preset_names)))\n            print u\"已删除 {} 个顶点预设\".format(len(preset_names))\n\n    # -------------------- JSON 保存/加载 --------------------\n    def save_presets_to_file(self):\n        try:\n            with io.open(self.presets_file, 'w', encoding='utf-8') as f:\n                f.write(unicode(json.dumps(self.vertex_presets, ensure_ascii=False, indent=2)))\n        except Exception as e:\n            self.log_message(u\"保存预设文件失败: {}\".format(str(e)))\n\n    def save_order_to_file(self):\n        try:\n            with io.open(self.order_file, 'w', encoding='utf-8') as f:\n                f.write(unicode(json.dumps(self.preset_order, ensure_ascii=False, indent=2)))\n        except Exception as e:\n            self.log_message(u\"保存排序文件失败: {}\".format(str(e)))\n\n    def load_order_from_file(self):\n        try:\n            if os.path.exists(self.order_file):\n                with io.open(self.order_file, 'r', encoding='utf-8') as f:\n                    loaded_order = json.load(f)\n                    self.preset_order = loaded_order\n                    self.log_message(u\"已加载预设排序信息\")\n        except Exception as e:\n            self.log_message(u\"加载排序文件失败: {}\".format(str(e)))\n\n    def load_presets_from_file(self):\n        try:\n            if os.path.exists(self.presets_file):\n                with io.open(self.presets_file, 'r', encoding='utf-8') as f:\n                    loaded_presets = json.load(f)\n                    self.vertex_presets.update(loaded_presets)\n                    self.log_message(u\"已加载 {} 个顶点预设\".format(len(loaded_presets)))\n            self.load_order_from_file()\n        except Exception as e:\n            self.log_message(u\"加载预设文件失败: {}\".format(str(e)))\n\n    # -------------------- 权重传递 --------------------\n    def execute_copy_weights(self):\n        source_model = self.source_line_edit.text().strip()\n        if not source_model:\n            cmds.warning(u\"请输入源蒙皮模型名称\")\n            self.log_message(u\"错误: 请输入源蒙皮模型名称\")\n            return\n        if not cmds.objExists(source_model):\n            cmds.warning(u\"源模型 '{}' 不存在\".format(source_model))\n            self.log_message(u\"错误: 源模型 '{}' 不存在\".format(source_model))\n            return\n\n        current_selection = cmds.ls(selection=True)\n        if not current_selection:\n            cmds.warning(u\"请先选择目标顶点\")\n            self.log_message(u\"错误: 请先选择目标顶点\")\n            return\n\n        vertices = cmds.filterExpand(current_selection, selectionMask=31)\n        if not vertices:\n            cmds.warning(u\"当前选择中没有顶点\")\n            self.log_message(u\"错误: 当前选择中没有顶点\")\n            return\n\n        try:\n            self.log_message(u\"开始传递权重从 '{}' 到 {} 个顶点...\".format(source_model, len(vertices)))\n            cmds.select(source_model, r=True)\n            cmds.select(vertices, add=True)\n            mel.eval(\"CopySkinWeights\")\n            cmds.select(vertices, r=True)\n            self.log_message(u\"权重传递完成!\")\n            cmds.inViewMessage(amg=u\"<hl>权重传递成功!</hl><br>从 {} 传递到 {} 个顶点\".format(source_model, len(vertices)),\n                               pos='midCenter', fade=True, fts=12)\n        except Exception as e:\n            self.log_message(u\"错误: 权重传递失败: {}\".format(str(e)))\n\n    # -------------------- UI 状态 --------------------\n    def update_preset_list(self):\n        self.preset_list.clear()\n        ordered_presets = self.get_ordered_presets()\n        for preset_name in ordered_presets:\n            if preset_name in self.vertex_presets:\n                vertex_count = len(self.vertex_presets[preset_name])\n                item_text = u\"{} ({} 个顶点)\".format(preset_name, vertex_count)\n                item = QListWidgetItem(item_text)\n                item.setData(Qt.UserRole, preset_name)\n                self.preset_list.addItem(item)\n        self.update_button_states()\n\n    def update_button_states(self):\n        selected_items = self.preset_list.selectedItems()\n        has_selection = len(selected_items) > 0\n        self.load_preset_btn.setEnabled(has_selection)\n        self.delete_preset_btn.setEnabled(has_selection)\n\n    def on_preset_order_changed(self, parent, start, end, destination, row):\n        self.update_preset_order_from_ui()\n        self.save_order_to_file()\n        self.log_message(u\"预设排序已更新\")\n\n    def update_preset_order_from_ui(self):\n        new_order = []\n        for i in range(self.preset_list.count()):\n            item = self.preset_list.item(i)\n            preset_name = item.data(Qt.UserRole)\n            new_order.append(preset_name)\n        self.preset_order = new_order\n\n    def get_ordered_presets(self):\n        ordered = [name for name in self.preset_order if name in self.vertex_presets]\n        unordered = sorted([name for name in self.vertex_presets.keys() if name not in self.preset_order])\n        for name in unordered:\n            if name not in self.preset_order:\n                self.preset_order.append(name)\n        return ordered + unordered\n\n    def closeEvent(self, event):\n        self.deleteLater()\n        event.accept()\n\n\ndef show_copy_weights_ui():\n    for widget in QApplication.allWidgets():\n        if isinstance(widget, CopyWeightsToVerticesUI):\n            widget.close()\n            widget.deleteLater()\n    dialog = CopyWeightsToVerticesUI()\n    dialog.show()\n    return dialog\n\n\nif __name__ == \"__main__\":\n    show_copy_weights_ui()\n" 
        -enableBackground 1
        -backgroundColor 0.0946975 0.199893 0.254307 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "传递顶点" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "传递顶点" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\n\"\"\"\n传递权重到一个选择的顶点范围 - Python 3 版本 (Maya 2022+)\n作者: Scripts Box (已移植)\n\"\"\"\n\nimport maya.cmds as cmds\nimport maya.mel as mel\nfrom maya import OpenMayaUI as omui\nimport json\nimport os\n\ntry:\n    from PySide2.QtCore import Qt\n    from PySide2.QtWidgets import (\n        QDialog, QVBoxLayout, QHBoxLayout, QLabel,\n        QLineEdit, QPushButton, QTextEdit, QApplication,\n        QListWidget, QListWidgetItem, QAbstractItemView,\n        QInputDialog, QMessageBox, QWidget, QFrame\n    )\n    from PySide2.QtGui import QFont, QTextCursor\n    from shiboken2 import wrapInstance\nexcept ImportError:\n    raise ImportError(\"需要 PySide2（在 Maya 2022+ 中可用）\")\n\n\ndef maya_main_window():\n    \"\"\"获取 Maya 主窗口（返回 QWidget）\"\"\"\n    main_window_ptr = omui.MQtUtil.mainWindow()\n    if main_window_ptr is not None:\n        return wrapInstance(int(main_window_ptr), QWidget)\n    return None\n\n\nclass CopyWeightsToVerticesUI(QDialog):\n    \"\"\"传递权重到顶点范围 UI 类\"\"\"\n\n    WINDOW_TITLE = \"传递权重到顶点范围\"\n\n    def __init__(self, parent=maya_main_window()):\n        super(CopyWeightsToVerticesUI, self).__init__(parent)\n\n        self.setWindowTitle(self.WINDOW_TITLE)\n        self.setMinimumSize(500, 400)\n        self.setWindowFlags(self.windowFlags() ^ Qt.WindowContextHelpButtonHint)\n\n        # 顶点预设\n        self.vertex_presets = {}\n        self.preset_order = []\n\n        # 固定文件夹路径（可根据需要修改）\n        # 注意路径中反斜杠用 r'' 或 双反斜杠避免转义\n        self.presets_dir = r\"D:\\ck\\scripts box\\maya_PY2脚本转译\\代码py2翻版\\预设顶点\"\n        self.presets_file = os.path.join(self.presets_dir, \"vertex_presets.json\")\n        self.order_file = os.path.join(self.presets_dir, \"preset_order.json\")\n\n        if not os.path.exists(self.presets_dir):\n            os.makedirs(self.presets_dir)\n\n        self.create_widgets()\n        self.create_layouts()\n        self.create_connections()\n\n        # 加载已保存的预设\n        self.load_presets_from_file()\n        self.update_preset_list()\n\n    # -------------------- UI 创建 --------------------\n    def create_widgets(self):\n        self.title_label = QLabel(\"传递权重到选择的顶点范围\")\n        self.title_label.setAlignment(Qt.AlignCenter)\n        font = QFont()\n        font.setBold(True)\n        font.setPointSize(12)\n        self.title_label.setFont(font)\n\n        # 源模型输入\n        self.source_label = QLabel(\"源模型:\")\n        self.source_line_edit = QLineEdit()\n        self.source_line_edit.setPlaceholderText(\"输入源蒙皮模型名称\")\n        self.select_source_btn = QPushButton(\"选择\")\n        self.select_source_btn.setMaximumWidth(60)\n\n        # 顶点预设管理\n        self.preset_label = QLabel(\"顶点预设管理:\")\n        self.preset_label.setFont(QFont(\"Arial\", 10, QFont.Bold))\n\n        self.preset_list = QListWidget()\n        self.preset_list.setMaximumHeight(200)\n        self.preset_list.setSelectionMode(QAbstractItemView.ExtendedSelection)\n        self.preset_list.setDragDropMode(QAbstractItemView.InternalMove)\n        self.preset_list.setDefaultDropAction(Qt.MoveAction)\n\n        # 预设按钮\n        self.save_preset_btn = QPushButton(\"保存当前选择\")\n        self.load_preset_btn = QPushButton(\"应用选择\")\n        self.load_preset_btn.setToolTip(\"支持多选预设，Ctrl+点击可选择多个预设\")\n        self.delete_preset_btn = QPushButton(\"删除\")\n        self.delete_preset_btn.setToolTip(\"删除预设（支持多选）\")\n\n        self.target_label = QLabel(\"目标顶点: 选择顶点后可保存为预设，或从预设中应用（支持多选预设，可拖拽排序）\")\n        self.target_label.setAlignment(Qt.AlignCenter)\n        self.target_label.setStyleSheet(\"color: #666666; font-size: 10px;\")\n\n        self.info_text = QTextEdit()\n        self.info_text.setMaximumHeight(80)\n        self.info_text.setReadOnly(True)\n        self.info_text.setPlaceholderText(\"操作信息将在这里显示...\")\n\n        self.execute_btn = QPushButton(\"执行传递权重\")\n        self.close_btn = QPushButton(\"关闭\")\n\n    def create_layouts(self):\n        main_layout = QVBoxLayout(self)\n        main_layout.setSpacing(10)\n        main_layout.setContentsMargins(15, 15, 15, 15)\n\n        main_layout.addWidget(self.title_label)\n        line1 = QFrame()\n        line1.setFrameShape(QFrame.HLine)\n        line1.setFrameShadow(QFrame.Sunken)\n        main_layout.addWidget(line1)\n\n        source_layout = QHBoxLayout()\n        source_layout.addWidget(self.source_label)\n        source_layout.addWidget(self.source_line_edit)\n        source_layout.addWidget(self.select_source_btn)\n        main_layout.addLayout(source_layout)\n\n        main_layout.addWidget(self.preset_label)\n        main_layout.addWidget(self.preset_list)\n\n        preset_btn_layout = QHBoxLayout()\n        preset_btn_layout.addWidget(self.save_preset_btn)\n        preset_btn_layout.addWidget(self.load_preset_btn)\n        preset_btn_layout.addWidget(self.delete_preset_btn)\n        main_layout.addLayout(preset_btn_layout)\n\n        main_layout.addWidget(self.target_label)\n        main_layout.addWidget(QLabel(\"操作信息:\"))\n        main_layout.addWidget(self.info_text)\n\n        line2 = QFrame()\n        line2.setFrameShape(QFrame.HLine)\n        line2.setFrameShadow(QFrame.Sunken)\n        main_layout.addWidget(line2)\n\n        btn_layout = QHBoxLayout()\n        btn_layout.addWidget(self.execute_btn)\n        btn_layout.addWidget(self.close_btn)\n        main_layout.addLayout(btn_layout)\n\n    def create_connections(self):\n        self.select_source_btn.clicked.connect(self.set_source_from_selection)\n        self.save_preset_btn.clicked.connect(self.save_vertex_preset)\n        self.load_preset_btn.clicked.connect(self.load_vertex_preset)\n        self.delete_preset_btn.clicked.connect(self.delete_vertex_preset)\n        self.preset_list.itemDoubleClicked.connect(self.load_vertex_preset)\n        self.preset_list.itemSelectionChanged.connect(self.update_button_states)\n        # rowsMoved 信号在不同 Qt 版本可能参数略有不同，但大多数情况下下面能工作\n        try:\n            self.preset_list.model().rowsMoved.connect(self.on_preset_order_changed)\n        except Exception:\n            # 如果无法连接信号，仍允许拖放但不会自动保存顺序\n            pass\n        self.execute_btn.clicked.connect(self.execute_copy_weights)\n        self.close_btn.clicked.connect(self.close)\n\n    # -------------------- 功能函数 --------------------\n    def log_message(self, message):\n        self.info_text.append(message)\n        cursor = self.info_text.textCursor()\n        cursor.movePosition(cursor.End)\n        self.info_text.setTextCursor(cursor)\n\n    def set_source_from_selection(self):\n        selection = cmds.ls(selection=True)\n        if selection:\n            source_model = selection[0]\n            self.source_line_edit.setText(source_model)\n            self.log_message(\"已设置源模型: {}\".format(source_model))\n            print(\"已设置源模型: {}\".format(source_model))\n        else:\n            cmds.warning(\"请先选择一个对象作为源模型\")\n            self.log_message(\"警告: 请先选择一个对象作为源模型\")\n\n    def save_vertex_preset(self):\n        current_selection = cmds.ls(selection=True)\n        if not current_selection:\n            cmds.warning(\"请先选择顶点\")\n            self.log_message(\"错误: 请先选择顶点\")\n            return\n\n        vertices = cmds.filterExpand(current_selection, selectionMask=31)\n        if not vertices:\n            cmds.warning(\"当前选择中没有顶点\")\n            self.log_message(\"错误: 当前选择中没有顶点\")\n            return\n\n        preset_name, ok = QInputDialog.getText(\n            self, \"保存顶点预设\", \"请输入预设名称:\", QLineEdit.Normal,\n            \"顶点预设_{}\".format(len(self.vertex_presets) + 1)\n        )\n        if ok and str(preset_name).strip():\n            preset_name = str(preset_name).strip()\n            if preset_name in self.vertex_presets:\n                reply = QMessageBox.question(\n                    self, \"预设已存在\",\n                    \"预设 '{}' 已存在，是否覆盖？\".format(preset_name),\n                    QMessageBox.Yes | QMessageBox.No, QMessageBox.No\n                )\n                if reply != QMessageBox.Yes:\n                    return\n\n            self.vertex_presets[preset_name] = vertices[:]\n            if preset_name not in self.preset_order:\n                self.preset_order.append(preset_name)\n\n            self.save_presets_to_file()\n            self.save_order_to_file()\n            self.update_preset_list()\n            self.log_message(\"已保存顶点预设: {} ({} 个顶点)\".format(preset_name, len(vertices)))\n            print(\"已保存顶点预设: {} ({} 个顶点)\".format(preset_name, len(vertices)))\n\n    def load_vertex_preset(self):\n        selected_items = self.preset_list.selectedItems()\n        if not selected_items:\n            cmds.warning(\"请先选择一个或多个顶点预设\")\n            self.log_message(\"错误: 请先选择一个或多个顶点预设\")\n            return\n\n        all_vertices = []\n        applied_presets = []\n\n        for item in selected_items:\n            preset_name = item.data(Qt.UserRole)\n            if preset_name in self.vertex_presets:\n                vertices = self.vertex_presets[preset_name]\n                existing_vertices = [v for v in vertices if cmds.objExists(v)]\n                if existing_vertices:\n                    all_vertices.extend(existing_vertices)\n                    applied_presets.append(\"{}({}个)\".format(preset_name, len(existing_vertices)))\n                    if len(existing_vertices) != len(vertices):\n                        self.log_message(\"警告: 预设 '{}' 中部分顶点不存在，应用了 {}/{} 个顶点\".format(\n                            preset_name, len(existing_vertices), len(vertices)))\n                else:\n                    self.log_message(\"警告: 预设 '{}' 中的顶点都不存在\".format(preset_name))\n\n        if all_vertices:\n            unique_vertices = list(dict.fromkeys(all_vertices))  # 保持顺序且去重\n            cmds.select(unique_vertices, replace=True)\n            preset_info = \", \".join(applied_presets)\n            self.log_message(\"已应用顶点预设: {}，总计 {} 个顶点\".format(preset_info, len(unique_vertices)))\n            print(\"已应用顶点预设: {}，总计 {} 个顶点\".format(preset_info, len(unique_vertices)))\n        else:\n            cmds.warning(\"所选预设中没有有效的顶点\")\n            self.log_message(\"错误: 所选预设中没有有效的顶点\")\n\n    def delete_vertex_preset(self):\n        selected_items = self.preset_list.selectedItems()\n        if not selected_items:\n            cmds.warning(\"请先选择要删除的顶点预设\")\n            self.log_message(\"错误: 请先选择要删除的顶点预设\")\n            return\n\n        preset_names = [item.data(Qt.UserRole) for item in selected_items]\n\n        if len(preset_names) == 1:\n            confirm_msg = \"确定要删除预设 '{}' 吗？\".format(preset_names[0])\n        else:\n            confirm_msg = \"确定要删除以下 {} 个预设吗？\\n\\n{}\".format(len(preset_names), \"\\n\".join(preset_names))\n\n        reply = QMessageBox.question(self, \"删除预设\", confirm_msg,\n                                     QMessageBox.Yes | QMessageBox.No, QMessageBox.No)\n\n        if reply == QMessageBox.Yes:\n            for preset_name in preset_names:\n                if preset_name in self.vertex_presets:\n                    del self.vertex_presets[preset_name]\n                if preset_name in self.preset_order:\n                    self.preset_order.remove(preset_name)\n            self.save_presets_to_file()\n            self.save_order_to_file()\n            self.update_preset_list()\n            self.log_message(\"已删除 {} 个顶点预设\".format(len(preset_names)))\n            print(\"已删除 {} 个顶点预设\".format(len(preset_names)))\n\n    # -------------------- JSON 保存/加载 --------------------\n    def save_presets_to_file(self):\n        try:\n            with open(self.presets_file, 'w', encoding='utf-8') as f:\n                json.dump(self.vertex_presets, f, ensure_ascii=False, indent=2)\n        except Exception as e:\n            self.log_message(\"保存预设文件失败: {}\".format(str(e)))\n\n    def save_order_to_file(self):\n        try:\n            with open(self.order_file, 'w', encoding='utf-8') as f:\n                json.dump(self.preset_order, f, ensure_ascii=False, indent=2)\n        except Exception as e:\n            self.log_message(\"保存排序文件失败: {}\".format(str(e)))\n\n    def load_order_from_file(self):\n        try:\n            if os.path.exists(self.order_file):\n                with open(self.order_file, 'r', encoding='utf-8') as f:\n                    loaded_order = json.load(f)\n                    self.preset_order = loaded_order\n                    self.log_message(\"已加载预设排序信息\")\n        except Exception as e:\n            self.log_message(\"加载排序文件失败: {}\".format(str(e)))\n\n    def load_presets_from_file(self):\n        try:\n            if os.path.exists(self.presets_file):\n                with open(self.presets_file, 'r', encoding='utf-8') as f:\n                    loaded_presets = json.load(f)\n                    # 确保 keys/values 合法\n                    if isinstance(loaded_presets, dict):\n                        self.vertex_presets.update(loaded_presets)\n                        self.log_message(\"已加载 {} 个顶点预设\".format(len(loaded_presets)))\n            self.load_order_from_file()\n        except Exception as e:\n            self.log_message(\"加载预设文件失败: {}\".format(str(e)))\n\n    # -------------------- 权重传递 --------------------\n    def execute_copy_weights(self):\n        source_model = self.source_line_edit.text().strip()\n        if not source_model:\n            cmds.warning(\"请输入源蒙皮模型名称\")\n            self.log_message(\"错误: 请输入源蒙皮模型名称\")\n            return\n        if not cmds.objExists(source_model):\n            cmds.warning(\"源模型 '{}' 不存在\".format(source_model))\n            self.log_message(\"错误: 源模型 '{}' 不存在\".format(source_model))\n            return\n\n        current_selection = cmds.ls(selection=True)\n        if not current_selection:\n            cmds.warning(\"请先选择目标顶点\")\n            self.log_message(\"错误: 请先选择目标顶点\")\n            return\n\n        vertices = cmds.filterExpand(current_selection, selectionMask=31)\n        if not vertices:\n            cmds.warning(\"当前选择中没有顶点\")\n            self.log_message(\"错误: 当前选择中没有顶点\")\n            return\n\n        try:\n            self.log_message(\"开始传递权重从 '{}' 到 {} 个顶点...\".format(source_model, len(vertices)))\n            cmds.select(source_model, r=True)\n            cmds.select(vertices, add=True)\n            # CopySkinWeights 根据 Maya 版本可能需要参数，这里使用默认 MEL 命令（UI 弹窗可能会出现）\n            mel.eval(\"CopySkinWeights\")\n            cmds.select(vertices, r=True)\n            self.log_message(\"权重传递完成!\")\n            cmds.inViewMessage(amg=\"<hl>权重传递成功!</hl><br>从 {} 传递到 {} 个顶点\".format(source_model, len(vertices)),\n                               pos='midCenter', fade=True, fts=12)\n        except Exception as e:\n            self.log_message(\"错误: 权重传递失败: {}\".format(str(e)))\n\n    # -------------------- UI 状态 --------------------\n    def update_preset_list(self):\n        self.preset_list.clear()\n        ordered_presets = self.get_ordered_presets()\n        for preset_name in ordered_presets:\n            if preset_name in self.vertex_presets:\n                vertex_count = len(self.vertex_presets[preset_name])\n                item_text = \"{} ({} 个顶点)\".format(preset_name, vertex_count)\n                item = QListWidgetItem(item_text)\n                item.setData(Qt.UserRole, preset_name)\n                self.preset_list.addItem(item)\n        self.update_button_states()\n\n    def update_button_states(self):\n        selected_items = self.preset_list.selectedItems()\n        has_selection = len(selected_items) > 0\n        self.load_preset_btn.setEnabled(has_selection)\n        self.delete_preset_btn.setEnabled(has_selection)\n\n    def on_preset_order_changed(self, parent, start, end, destination, row):\n        self.update_preset_order_from_ui()\n        self.save_order_to_file()\n        self.log_message(\"预设排序已更新\")\n\n    def update_preset_order_from_ui(self):\n        new_order = []\n        for i in range(self.preset_list.count()):\n            item = self.preset_list.item(i)\n            preset_name = item.data(Qt.UserRole)\n            new_order.append(preset_name)\n        self.preset_order = new_order\n\n    def get_ordered_presets(self):\n        ordered = [name for name in self.preset_order if name in self.vertex_presets]\n        unordered = sorted([name for name in self.vertex_presets.keys() if name not in self.preset_order])\n        for name in unordered:\n            if name not in self.preset_order:\n                self.preset_order.append(name)\n        return ordered + unordered\n\n    def closeEvent(self, event):\n        self.deleteLater()\n        event.accept()\n\n\ndef show_copy_weights_ui():\n    # 关闭已存在的窗口实例\n    app = QApplication.instance()\n    if app is None:\n        app = QApplication([])\n\n    for widget in QApplication.allWidgets():\n        if isinstance(widget, CopyWeightsToVerticesUI):\n            try:\n                widget.close()\n                widget.deleteLater()\n            except Exception:\n                pass\n    dialog = CopyWeightsToVerticesUI()\n    dialog.show()\n    return dialog\n\n\nif __name__ == \"__main__\":\n    show_copy_weights_ui()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "# Safe purge: only your tool modules\nimport sys\n\ntry:\n    import importlib\n    if hasattr(importlib, 'invalidate_caches'):\n        importlib.invalidate_caches()\nexcept Exception:\n    pass\n\n# 移除包内与可能的顶层副本\nprefixes = (\n    'ck_rig_Box',         # 包及子模块\n    'Fk_SetUp_ui',        # 顶层副本（曾经直接 import Fk_SetUp_ui）\n    'Fk_SetUp',           # 顶层副本\n    'qt_compat',          # 顶层副本\n)\n\nfor _name in list(sys.modules):\n    if _name.startswith(prefixes):\n        sys.modules.pop(_name, None)\n\ndef remove_pyc_files(target_dir):\n    \"\"\"删除指定目录及其子目录中的所有 .pyc 文件\"\"\"\n    if not os.path.exists(target_dir):\n        print(u\"目录不存在: {}\".format(target_dir))\n        return\n\n    removed = 0\n    for root, _, files in os.walk(target_dir):\n        for f in files:\n            if f.endswith(\".pyc\"):\n                try:\n                    os.remove(os.path.join(root, f))\n                    removed += 1\n                except Exception as e:\n                    print(u\"删除失败: {}\".format(e))\n\n    print(u\"共删除 {} 个 .pyc 文件。\".format(removed))\n\n# 指定目录\nremove_pyc_files(r\"C:\\Users\\ck\\Documents\\maya\\scripts\\ck_rig_Box\")\n\n# 重新导入并运行最新版 UI\nimport sys\nsys.path.append(r\"c:\\Users\\ck\\Documents\\maya\\scripts\")  # 只加 scripts 上层目录\nfrom ck_rig_Box import Fk_SetUp_ui\nFk_SetUp_ui.show()\n\n" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "# Safe purge: only your tool modules\nimport sys\n\ntry:\n    import..." 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "打组" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# Safe purge: only your tool modules\nimport sys\n\ntry:\n    import importlib\n    if hasattr(importlib, 'invalidate_caches'):\n        importlib.invalidate_caches()\nexcept Exception:\n    pass\n\n# 移除包内与可能的顶层副本\nprefixes = (\n    'ck_rig_Box',         # 包及子模块\n    'Fk_SetUp_ui',        # 顶层副本（曾经直接 import Fk_SetUp_ui）\n    'Fk_SetUp',           # 顶层副本\n    'qt_compat',          # 顶层副本\n    'sur_curve'\n)\n\nfor _name in list(sys.modules):\n    if _name.startswith(prefixes):\n        sys.modules.pop(_name, None)\n\ndef remove_pyc_files(target_dir):\n    \"\"\"删除指定目录及其子目录中的所有 .pyc 文件\"\"\"\n    if not os.path.exists(target_dir):\n        print(u\"目录不存在: {}\".format(target_dir))\n        return\n\n    removed = 0\n    for root, _, files in os.walk(target_dir):\n        for f in files:\n            if f.endswith(\".pyc\"):\n                try:\n                    os.remove(os.path.join(root, f))\n                    removed += 1\n                except Exception as e:\n                    print(u\"删除失败: {}\".format(e))\n\n    print(u\"共删除 {} 个 .pyc 文件。\".format(removed))\n\n# 指定目录\nremove_pyc_files(r\"C:\\Users\\Administrator\\Documents\\maya\\scripts\\ck_rig_Box\")\n\n# 重新导入并运行最新版 UI\nimport sys\nsys.path.append(r\"C:\\Users\\Administrator\\Documents\\maya\\scripts\")  # 只加 scripts 上层目录\nfrom ck_rig_Box import Fk_SetUp_ui\nFk_SetUp_ui.show()\n\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
