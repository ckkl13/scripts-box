        -annotation "运行 骨骼创建面片 (PYTHON)" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "骨骼创建面片" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "面片" 
        -overlayLabelColor 0.8 0.8 0.8 
