        -command "# -*- coding: utf-8 -*-\n\"\"\"\n为场景内所有 skinCluster 节点设置 ngSkinTools2 修剪小权重功能\n阈值设置为 0.0001\n\"\"\"\n\nfrom __future__ import print_function, unicode_literals\nimport maya.cmds as cmds\nfrom ngSkinTools2.api import Layers\nimport sys\n\n# Python2 下设置默认编码为 utf-8\nif sys.version_info[0] < 3:\n    reload(sys)\n    sys.setdefaultencoding('utf-8')\n\n# 查找所有 skinCluster 节点\nskin_clusters = cmds.ls(type=\"skinCluster\")\n\nfor sc in skin_clusters:\n    # 尝试获取 skinCluster 绑定的几何体\n    geometry = cmds.skinCluster(sc, q=True, g=True)\n    if not geometry:\n        print(\"[跳过] {} 没有关联的几何体\".format(sc))\n        continue\n\n    try:\n        layers = Layers(geometry[0])\n        layers.prune_weights_filter_threshold = 0.0001\n        print(\"设置 {} 的修剪阈值为 0.0001\".format(geometry[0]))\n    except Exception as e:\n        print(\"{} 设置修剪阈值失败: {}\".format(geometry[0], e))\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
