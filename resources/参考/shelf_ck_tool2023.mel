global proc shelf_ck_tool () {
    global string $gBuffStr;
    global string $gBuffStr0;
    global string $gBuffStr1;


    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "# -*- coding: utf-8 -*-\n\"\"\"\nMaya文件重新加载工具\n功能：重新加载当前Maya文件，并在重加载前询问是否保存当前文件\n兼容Python 2.7和Python 3.x\n\"\"\"\n\nimport maya.cmds as cmds\nimport maya.mel as mel\nimport os\nimport sys\n\n# Python 2/3 兼容性处理\nif sys.version_info[0] >= 3:\n    unicode = str\n\ndef reload_maya_file():\n    \"\"\"\n    重新加载当前Maya文件\n    在重加载前会询问用户是否保存当前文件\n    \"\"\"\n    # 获取当前文件路径\n    current_file = cmds.file(query=True, sceneName=True)\n    \n    if not current_file:\n        cmds.warning(\"当前没有打开的文件，无法重新加载\")\n        return\n    \n    # 检查文件是否存在\n    if not os.path.exists(current_file):\n        cmds.warning(\"当前文件路径不存在: {}\".format(current_file))\n        return\n    \n    # 检查文件是否被修改\n    is_modified = cmds.file(query=True, modified=True)\n    \n    if is_modified:\n        # 询问用户是否保存\n        result = cmds.confirmDialog(\n            title='重新加载文件',\n            message='当前文件已被修改，是否在重新加载前保存？',\n            button=['保存并重加载', '不保存直接重加载', '取消'],\n            defaultButton='保存并重加载',\n            cancelButton='取消',\n            dismissString='取消'\n        )\n        \n        if result == '取消':\n            return\n        elif result == '保存并重加载':\n            try:\n                # 保存当前文件\n                cmds.file(save=True)\n                print(\"文件已保存: {}\".format(current_file))\n            except Exception as e:\n                cmds.error(\"保存文件失败: {}\".format(str(e)))\n                return\n    \n    try:\n        # 重新加载文件\n        cmds.file(current_file, open=True, force=True)\n        print(\"文件重新加载成功: {}\".format(current_file))\n    except Exception as e:\n        cmds.error(\"重新加载文件失败: {}\".format(str(e)))\n\n# 直接运行重新加载功能\nif __name__ == '__main__':\n    reload_maya_file()" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "重加载" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "重加载" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "D:/ck/scripts box/icons/加载.png" 
        -image1 "D:/ck/scripts box/icons/加载.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\n\"\"\"\nMaya文件重新加载工具\n功能：重新加载当前Maya文件，并在重加载前询问是否保存当前文件\n兼容Python 2.7和Python 3.x\n\"\"\"\n\n\nimport maya.cmds as cmds\nimport maya.mel as mel\nimport os\nimport sys\n\n\n# Python 2/3 兼容性处理\nif sys.version_info[0] >= 3:\n    unicode = str\n\n\n# 统一按钮文本（使用 Unicode，兼容 Maya 2018–2020 的 Python 2）\nBTN_SAVE_RELOAD = u'保存并重加载'\nBTN_RELOAD_NO_SAVE = u'不保存直接重加载'\nBTN_CANCEL = u'取消'\n\n\ndef reload_maya_file():\n    \"\"\"\n    重新加载当前Maya文件\n    在重加载前会询问用户是否保存当前文件\n    \"\"\"\n    # 获取当前文件路径\n    current_file = cmds.file(query=True, sceneName=True)\n    \n    if not current_file:\n        cmds.warning(u\"当前没有打开的文件，无法重新加载\")\n        return\n    \n    # 检查文件是否存在\n    if not os.path.exists(current_file):\n        # 避免因中文路径导致的编码问题，不在消息中输出路径\n        cmds.warning(u\"当前文件路径不存在\")\n        return\n    \n    # 检查文件是否被修改\n    is_modified = cmds.file(query=True, modified=True)\n    \n    if is_modified:\n        # 询问用户是否保存\n        result = cmds.confirmDialog(\n            title='重新加载文件',\n            message='当前文件已被修改，是否在重新加载前保存？',\n            button=[BTN_SAVE_RELOAD, BTN_RELOAD_NO_SAVE, BTN_CANCEL],\n            defaultButton=BTN_SAVE_RELOAD,\n            cancelButton=BTN_CANCEL,\n            dismissString=BTN_CANCEL\n        )\n        \n        # 在 2018–2020（Python 2）中，返回值为 unicode；确保正确匹配“取消”\n        if result == BTN_CANCEL:\n            return\n        elif result == BTN_SAVE_RELOAD:\n            try:\n                # 保存当前文件\n                cmds.file(save=True)\n                cmds.warning(u\"文件已保存\")\n            except Exception as e:\n                try:\n                    cmds.error(u\"保存文件失败: {}\".format(unicode(e)))\n                except Exception:\n                    cmds.error(u\"保存文件失败\")\n                return\n        elif result == BTN_RELOAD_NO_SAVE:\n            # 不保存直接重加载\n            pass\n        else:\n            # 未知返回值，安全退出\n            cmds.warning(u\"操作已取消\")\n            return\n    \n    try:\n        # 重新加载文件\n        cmds.file(current_file, open=True, force=True)\n        # 在视口中显示加载成功提示（避免控制台编码问题）\n        try:\n            cmds.inViewMessage(amg=u'文件重新加载成功', pos='topCenter', fade=True, fit=True, alpha=0.9)\n        except Exception:\n            # 回退到控制台提示\n            cmds.warning(u\"文件重新加载成功\")\n    except Exception as e:\n        try:\n            cmds.error(u\"重新加载文件失败: {}\".format(unicode(e)))\n        except Exception:\n            cmds.error(u\"重新加载文件失败\")\n\n\n# 直接运行重新加载功能\nif __name__ == '__main__':\n    reload_maya_file()\n\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "运行 绑定工具箱 (MEL)" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "绑定工具箱" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "绑定工具箱" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "//You should be lazy ! Otherwise the society how progress !\n\nglobal proc Auxiliary_Means_For_Maya ()\n{\n    if(`window -ex winjntplug` )\n    { deleteUI winjntplug ;}\n    string $winjntplug = `window\n    -title \"Auxiliary Means For Maya_RIG Ver 2.4.5\"  \n    -w 470 \n    -h 500 -s 0 winjntplug`;\n    scrollLayout -w 470  -h 500;\n    rowColumnLayout Main01;\n    \n    menuBarLayout;\n\t menu -label \"文件\";\n\t menuItem -label \"退出\" -command \"deleteUI winjntplug\";\n\t menu -label \"请求帮助\" -helpMenu true;\n\t menuItem -label \"查看Maya帮助文档\" -c \"checkHelpPrefs\";\n\t menuItem -label \"<<绑定师学习俱乐部>>\" -c \"ContactTheAuthor\";\t\t\n\t setParent Main01;;\n    text -fn \"smallBoldLabelFont\" -l \"Auxiliary Means For Maya_RIG\";\n    text  -l \"绑定师辅助强化包\";\n    text -l \"\";\n    \n    separator -style double ;\n\n    rowColumnLayout -nc 1 -cw 1 450 ;\n    floatSliderButtonGrp \n    -label \"全局骨骼大小\" \n    -cw 1 80 \n    -max 100 \n    -min 0.1 \n    -v 0.1 \n    -field true \n    -buttonLabel \"设    置\"  \n    -bc \"SetBonesRadius\" \n    -symbolButtonDisplay true \n    -columnWidth 5 23 getfloatButtonSliderGrp;\n\n    floatSliderButtonGrp \n    -label \"控制器大小\" \n    -cw 1 80 \n    -max 100 \n    -min 1 \n    -v 50 \n    -field true \n    -buttonLabel \"设    置\" \n    -bc \"editCvHandles\"  \n    -symbolButtonDisplay true \n    -columnWidth 5 23  getCvHandleScale;  \n\n    text -fn \"smallBoldLabelFont\" -l \"Look Me !\" LookMeCons;\n    separator -style double ;\n    rowColumnLayout -nc 3 -cw 1 150 -cw 2 150 -cw 3 150 UISwich01;  \t\t\n    button -l \"锁定UI界面\"  -command \"AuxiliaryRIGLockUI\" LOCKUISET;\n    button -l \"标记新功能界面颜色\"  -enable 0 -command \"\";\n    button -l \"未开发完成的功能\"  -command \"SwichUIDisplay\";\n\n    setParent UISwich01 ;\n    setParent..;    \n\n    frameLayout -li 10 -mw 10 -cll 1 -cl 0   -l \"常用功能[ 12 ]\" FunLayout01;\n    \n    rowColumnLayout -nc 1 -cw 1 425 ;\n    frameLayout -li 10 -bv 0 -cll 1 -cl 1  -bgc 0.1 0.5 0.5 -l \"骨骼类[ 7 ]\" CreateframeLayout01;\n    rowColumnLayout -nc 2 -cw 1 320 -cw 2 100 ; \n    text -l\"        说明：创建骨骼在世界网格中。\" -align \"left\";\t\n    button -l \"创建默认骨骼\"  -command \"jntWorld\";\n    setParent..;\n    separator -style double ;\n    rowColumnLayout -nc 2 -cw 1 320 -cw 2 100 ; \n    text -l\"        说明：在点线面多元素中间创建骨骼。\" -align \"left\"; \n \n    button -l \"创建元素骨骼\"  -command \"CreatjntOnV\";\t\t\n    setParent..;\n    separator -style double ;     \n    rowColumnLayout -nc 2 -cw 1 320 -cw 2 100 ;    \n    text -l\"        说明：强制显示或者隐藏所有骨骼。\" -align \"left\";\n    setParent..;\n    rowColumnLayout -nc 3 -cw 1 20 -cw 2 300 -cw 3 100 ; \n    text -l \"\" ;\n    checkBox -l \"自动选择全部\" -v 1 SelectSceneBones01 ;\n    button -l \"显示/隐藏\"  -command \"HiddenAllBonesPro\";\n    setParent..;\n    separator -style double ;\n    rowColumnLayout -nc 2 -cw 1 340 -cw 2 100 ; \n    text -l\"        说明：从根部依次选择物体，将物体连接成FK链。\" -align \"left\";\n    setParent..;\n    rowColumnLayout -nc 4 -cw 1 20 -cw 2 150 -cw 3 150 -cw 4 100 ;  \n    text -l \"\" ;\n    checkBox -l \"针对骨骼\" -v 1  \n    -ofc \"checkBox -e -v 0 -en 0 selCreatejnt02\" \n    -onc \"checkBox -e -en 1 selCreatejnt02\" selCreatejnt01;\n    checkBox -l \"自动纠正骨骼方向\" -v 0  selCreatejnt02 ;\t        \n    button -l \"创建链\" -command \"ParentBonesline\";\n\tsetParent..;\n    separator -style double ;   \n    rowColumnLayout -nc 2 -cw 1 320 -cw 2 100 ; \n    text -l\"        说明：在物体的中心点上自动创建骨骼。\" -align \"left\";\n    setParent..;\n    rowColumnLayout -nc 4 -cw 1 20 -cw 2 150 -cw 3 150 -cw 4 100 ;  \n    text -l \"\" ;\n    checkBox -l \"与物体方向一致\" -v 1 CenterCreateObj01 ;\n    checkBox -l \"创建蒙皮\" -v 0 CenterCreateObj02;\t\n    button -l \"创建中心骨骼\"   -command \"MeshCenterCreateBones\"; \t\t\n\tsetParent..;\n    separator -style double ; \n        \n    rowColumnLayout; \n    text -l\"        说明：在模型顶点上可创建locator和骨骼，同时也可以使用顶点约束locator。\" -align \"left\";\n    setParent..; \n    rowColumnLayout -nc 5 -cw 1 20 -cw 2 100 -cw 3 100 -cw 4 100 -cw 5 100; \n    text -l\"\";\n    checkBox -l \"Locator\" -v 1 \n    -ofc \" checkBox -e -v 0 UserVertex02;checkBox -e -en 0 UserVertex02 \"  \n    -onc \" checkBox -e -en 1 UserVertex02 \" UserVertex01 ; \n    checkBox -l \"约束\" -v 1 -en 1  UserVertex02 ; \n    checkBox -l \"骨骼\" -v 1 UserVertex03 ;   \n    button -l \"Locator / joint\"  -command \"CreateLocOnPolyVertex\";\n    setParent..;\n    separator -style double ;   \n    rowColumnLayout -nc 2 -cw 1 320 -cw 2 100 ; \n    text -l\"        说明：批量镜像骨骼。\" -align \"left\";\n    setParent..;\n    rowColumnLayout -nc 5 -cw 1 20 -cw 2 100 -cw 3 100 -cw 4 100 -cw 5 100; \n    text -l\"\";\n    checkBox -l \"XY方向\" -v 0  -onc \"checkBox -e -v 0 UserBonesMirror02 ;checkBox -e -v 0 UserBonesMirror03 ; \"  UserBonesMirror01; \n    checkBox -l \"YZ方向\" -v 1  -onc \"checkBox -e -v 0 UserBonesMirror01 ;checkBox -e -v 0 UserBonesMirror03 ; \"  UserBonesMirror02; \n    checkBox -l \"XZ方向\" -v 0  -onc \"checkBox -e -v 0 UserBonesMirror01 ;checkBox -e -v 0 UserBonesMirror02 ; \"  UserBonesMirror03;\t\n    button -l \"镜像骨骼\"   -command \"BonesMirrorSet\";\n     \n    setParent..;\n    separator -style double ;   \n\n    setParent CreateframeLayout01 ;\n    setParent .. ;\n//************************************************************************************************************************************\n\n    \n    \n\n    frameLayout -li 10 -bv 0 -cll 1 -cl 1 -bgc 0.1 0.5 0.5  -l  \"链接类[ 3 ]\" CreateframeLayout02;\n    separator -style double ;\n    rowColumnLayout ;  \t\n    text -l\"        说明：将自动创建新的层级，且将通道栏变换属性转移到父子层级上。\" -align \"left\";\n    setParent..;\n    rowColumnLayout -nc 4 -cw 1 20 -cw 2 150 -cw 3 150 -cw 4 100 ;  \n    text -l \"\" ;\n    checkBox -l \"使用Locator继承\" -v 0 \n    -onc \" checkBox -e -v 0 succession02 \" \n    -ofc \"checkBox -e -v 1 succession02\" succession01;\n    checkBox -l \"使用组继承\" -v 1 \n    -onc \" checkBox -e -v 0 succession01 \" \n    -ofc \"checkBox -e -v 1 succession01\" succession02 ;  \n    button -l \"乾坤大挪移\" -command \"ReSetBonesPostion\";\n    setParent..;\n    separator -style double ;   \n\n    \n    \n    rowColumnLayout;\n    text -l\"        说明：链接旋转位移缩放等常用属性。\" -align \"left\";\n    setParent..;    \n    rowColumnLayout -nc 5 -cw 1 20 -cw 2 100 -cw 3 100 -cw 4 100 -cw 5 100; \n    text -l\"\";\n    checkBox -l \"链接位移\"  -v 1   ConnectAttr01 ;\n    checkBox -l \"链接旋转\" -v 1  ConnectAttr02 ;\n    checkBox -l \"链接缩放\"  -v 1  ConnectAttr03;\t\n    button -l \"链接常用属性\"   -command \"ConnectAttrConBones\";\n    setParent..;    \n    separator -style double ;\n      \n    rowColumnLayout -nc 2 -cw 1 320 -cw 2 100 ; \n    text -l\"        说明：任意选择一根曲线自动创建骨骼跟随曲线顶点。\" -align \"left\";\t\n    button -l \"创建曲线约束\"   -command \"PointOnCurveLocBones\";\n    setParent..;\n    separator -style double ;          \n    setParent..; \n  \n    setParent CreateframeLayout02 ;\n    setParent .. ;\n    \n//************************************************************************************************************************************    \n    \n    frameLayout -li 10 -bv 0 -cll 1 -cl 1 -bgc 0.1 0.5 0.5 -l  \"其他类[ 2 ]\" CreateframeLayout03;\n    \n    \n    \n \n    rowColumnLayout ; \n    text    -l\"        说明：如果需要更大的操作3D视图窗口请点击这里。\" -align \"left\";\n    setParent..;\n    rowColumnLayout -nc 4 -cw 1 20 -cw 2 150 -cw 3 150 -cw 4 100 ; \n    text -l \"\" ;\n    checkBox -l \"添加新的摄像机\" \n    -ofc \"checkBox -e -en 0 Add3DCam02 ;checkBox -e -v 0 Add3DCam02\" \n    -onc \"checkBox -e -en 1 Add3DCam02\" -v 1  Add3DCam01  ;\n    checkBox -l \"替换persp位置\" -v 0 Add3DCam02 ;\n    button -l \"开启3D视图\" -command \"ModelEditorPanl\";\n    setParent..;\n    separator -style double ; \n    \n    \n    \n    \n    \n    rowColumnLayout -nc 2 -cw 1 340 -cw 2 100 ;\n    text -l\"        说明：解锁或者锁定场景中所有被不可选择的模型。\" -align \"left\";\n    setParent..;\n    rowColumnLayout -nc 4 -cw 1 20 -cw 2 150 -cw 3 150 -cw 4 100 ; \n    text -l \"\" ;\n    checkBox -l \"自动选择全部\" -v 1 MeshShapeLock01 ;\n    checkBox -l \"包含形态节点\" -v 1 MeshShapeLock02 ;\n\n    button -l \"解锁/锁定\"    -command \"LockAllRIGPolyMesh\";\n    setParent..;\t\n\n      \n   \n   \n    setParent CreateframeLayout03 ;\n    setParent FunLayout01 ;\n    setParent .. ;\n    \n //************************************************************************************************************************************       \n    \n    \n    \n\n   \n    \n    \n    \n   \n         \n//&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&        \n    frameLayout -li 10 -bv 0 -cll 1 -cl 1 -bgc 0.1 0.5 0.5 -l \"创建FK骨骼链\" FunLayout06;\n    \n    rowColumnLayout -nc 3 -cw 1 240  -cw 2  30 -cw 3 170 ;\n    intSliderGrp -field true  -cw 1 50 -minValue 4 -maxValue 360 -label \"定位器:\"  -value 8 NumberLocs01 ;\n    text -l\"\";\n    \n    button -l \"创建骨骼辅助工具\"   -command \"CreateBonesAuxiliaryLocator\";  \n    setParent..;\n        separator -style double ;\n    rowColumnLayout -nc 3 -cw 1 240  -cw 2  30 -cw 3 170 ;\n\n   \n    intSliderGrp -field true  -cw 1 50 -minValue 1 -maxValue 100 -label \"骨骼数量:\" -value 10 NumberBones ;\n   text -l\"\";    \n    button -l \"骨骼链==>>>曲线\" -command \"LineBonesToLineCrv\" BonesToCrv01;\n    setParent..;\n    separator -style double ;\n    rowColumnLayout -nc 3 -cw 1 120 -cw 2 150  -cw 3  170 ;    \n\n    \n\t\t\n    optionMenuGrp   -label \"骨骼朝向:\" -cw 1 50    BonesDirAsFK  ;\n    \n    menuItem -label \"+\"  BonesDirAs01;\n    menuItem -label \"-\" BonesDirAs02;\n    checkBox -l\"顶点创建模式\" -v 0 \n     -ofc \"button -e -en 1 BonesToCrv01;button -e -en 1 CrvToBones01; button -e -l \\\"创建FK骨骼链\\\"  CreateFKBonesStly  \"\n     -onc \"button -e -en 0 BonesToCrv01;button -e -en 0 CrvToBones01;button -e -l \\\"选择顶点后创建FK骨骼链\\\"  CreateFKBonesStly \"\n     PointCreateStyle ;\n     \t\t\n    button -l \"曲线==>>>骨骼链\"   -command \"CurveCreateFKBones\"CrvToBones01;\t\t\t\n    setParent..;  \n    separator -style double ;\n    rowColumnLayout -nc 4 -cw 1 25  -cw 2 200 -cw 3 10 -cw 4 200 ;\n    text -l \"\";\n\n    button -l \"创建FK骨骼链\"   -command \"CreateFKLineBones\" CreateFKBonesStly;   \n    text -l\"\";\n    \n    button -l \"纠正链骨骼关节方向\"  -command \"hierarchyAxisOrientBones\";    \n    setParent ..;\n    setParent ..;\n    \n     \n    \n    frameLayout -li 10 -bv 0 -cll 1 -cl 1 -bgc 0.1 0.5 0.5  -l \"调试骨骼链方向\" FunLayout07 ;\n  \n\n    rowColumnLayout ;\n    rowColumnLayout -nc 3 -cw 1 120 -cw 2 20  -cw 3  300 ;\n      \n    optionMenuGrp -label \"调节方向:\" -cw 1 50  setBonesDir  ;      \n    menuItem -label \"X\" setBones01;\n    menuItem -label \"Y\" setBones02;\t\t\n    menuItem -label \"Z\" setBones03;\n    text -l \"\" ;\n    intSliderGrp -field true  -cw 1 50 -minValue -360 -maxValue 360 -label \"调试角度:\" -value 15 SetNumberBonesDir ;\n\n    setParent..; \n      \n    rowColumnLayout -nc 3 -cw 1 100 -cw 2 100  -cw 3  240 ; \n    checkBox -v 1 -l \"自动选择层级\" AutoSelectHierarchy01;\n    checkBox -v 1 -l \"自动显示轴向\" AutoShowBonesDir02; \n      \n    button -l \"调试骨骼关节方向\"  -command \"AdjustBoneAxialDirection\";   \n         \n    setParent FunLayout07;\n        separator -style double ;\n    rowColumnLayout -nc 3 -cw 1 100 -cw 2 100  -cw 3  240 ;  \n    checkBox -l \"自动选择全部\" -v 1 UserSelectStyle01 ; \n    checkBox -l \"显示轴向\" -v 1 UserSelectStyle02 ; \n    button -l \"显示骨骼轴向\"  -command \"showBonesLRA\";\n    setParent..;\n    separator -style double ;\n    setParent..;      \n    \n    \n    \n    //////////////////////////////////////////////////////////////////////////////////////////////\n    frameLayout -li 10 -bv 0 -cll 1 -cl 1 -bgc 0.1 0.5 0.5-l \"创建FK控制器\" ;\n    rowColumnLayout  -nc 3 -cw 1 300 -cw 2 25 -cw 3 120  ;\n    radioButtonGrp \n\t\t\t\n\t\t\t-numberOfRadioButtons 3\n\t\t\t-cal 1 \"center\"\n\t\t\t-cw 1 55\n\t\t\t-cw 2 100\n\t\t\t-cw 3 100\n\t\t\t-sl 1\n\t\t\t-label \"控制朝向:\" \n\t\t\t-labelArray3 \"X\" \"Y\" \"Z\"  selectCreateConsDir01 ;\n\t\t\ttext -l \"\"