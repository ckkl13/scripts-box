        -annotation "运行 选择模型上已蒙皮的骨骼 (PYTHON)" 
        -enableBackground 1
        -backgroundColor 0.385504 0.578302 0.558495 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "选择模型上已蒙皮的骨骼" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "已蒙皮的骨骼" 
        -overlayLabelColor 0.831325 0.831325 0.831325 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef select_skin_influence_joints():\n    \"\"\"选中当前模型上参与蒙皮的所有骨骼，并生成 Python 2/3 都可用的选择代码\"\"\"\n    sel = cmds.ls(sl=True, dag=True, shapes=False)\n    if not sel:\n        cmds.warning(\"请先选择一个模型或蒙皮的网格\")\n        return\n    \n    joints_to_select = []\n\n    for obj in sel:\n        skin_clusters = cmds.ls(cmds.listHistory(obj), type='skinCluster') or []\n        for sc in skin_clusters:\n            influences = cmds.skinCluster(sc, q=True, influence=True) or []\n            for jnt in influences:\n                if jnt not in joints_to_select:\n                    joints_to_select.append(jnt)\n    \n    if joints_to_select:\n        cmds.select(joints_to_select, r=True)\n        print(\"=== 蒙皮骨骼识别结果 ===\")\n        print(\"找到 {} 个骨骼:\".format(len(joints_to_select)))\n        print([str(j) for j in joints_to_select])  # 列表形式打印\n\n        # 生成可复用代码（Python 2 不带 u''）\n        joints_str = \", \".join(\"'{}'\".format(j) for j in joints_to_select)\n        code_str = \"import maya.cmds as cmds\\n\\n\"\n        code_str += \"jnt = [{}]\\n\".format(joints_str)\n        code_str += \"cmds.select(jnt, r=True)\\n\"\n        print(\"\\n=== 可直接使用的选择代码 ===\")\n        print(code_str)\n    else:\n        cmds.warning(\"未找到任何蒙皮骨骼\")\n\n# 运行\nselect_skin_influence_joints()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "可开启或关闭清理未使用的影响" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "权重传递" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "权重传递" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\nimport maya.cmds as cmds\nfrom contextlib import contextmanager\nfrom PySide2.QtWidgets import QDialog, QVBoxLayout, QHBoxLayout, QLabel, QPushButton, QProgressDialog, QApplication, QCheckBox\nfrom PySide2.QtCore import Qt\nimport shiboken2\n\ndef get_maya_main_window():\n    from maya.OpenMayaUI import MQtUtil\n    from PySide2.QtWidgets import QWidget\n    main_window_ptr = MQtUtil.mainWindow()\n    if main_window_ptr:\n        return shiboken2.wrapInstance(int(main_window_ptr), QWidget)\n    return None\n\n@contextmanager\ndef undo_chunk():\n    cmds.undoInfo(openChunk=True)\n    try:\n        yield\n    finally:\n        cmds.undoInfo(closeChunk=True)\n\ndef get_skin_cluster(node):\n    history = cmds.listHistory(node, pruneDagObjects=True) or []\n    return next((s for s in cmds.ls(history, type='skinCluster')), None)\n\nclass ConfirmDialog(QDialog):\n    def __init__(self, source_mesh, target_count, parent=None):\n        super(ConfirmDialog, self).__init__(parent)\n        self.setWindowTitle(u\"确认操作\")\n        self.setModal(True)\n        self.result = False\n        self.cleanup_unused = False\n        self.setFixedSize(350, 120)\n\n        layout = QVBoxLayout()\n        layout.setSpacing(8)\n        layout.setContentsMargins(15, 15, 15, 15)\n\n        label = QLabel(u\"是否将 {} 的蒙皮权重复制到 {} 个目标网格？\".format(source_mesh, target_count))\n        label.setWordWrap(True)\n        layout.addWidget(label)\n\n        self.cleanup_checkbox = QCheckBox(u\"清理未使用的影响\")\n        self.cleanup_checkbox.setChecked(False)\n        layout.addWidget(self.cleanup_checkbox)\n\n        button_layout = QHBoxLayout()\n        button_layout.setSpacing(10)\n\n        confirm_button = QPushButton(u\"确定\")\n        cancel_button = QPushButton(u\"取消\")\n        confirm_button.setFixedHeight(25)\n        cancel_button.setFixedHeight(25)\n\n        confirm_button.clicked.connect(self.accept)\n        cancel_button.clicked.connect(self.reject)\n\n        button_layout.addWidget(confirm_button)\n        button_layout.addWidget(cancel_button)\n\n        layout.addLayout(button_layout)\n        self.setLayout(layout)\n\n    def accept(self):\n        self.result = True\n        self.cleanup_unused = self.cleanup_checkbox.isChecked()\n        super(ConfirmDialog, self).accept()\n\n    def reject(self):\n        self.result = False\n        super(ConfirmDialog, self).reject()\n\nclass ProgressWithEsc(QProgressDialog):\n    def __init__(self, label, parent=None):\n        super(ProgressWithEsc, self).__init__(label, None, 0, 100, parent)\n        self.setWindowTitle(u\"处理进度\")\n        self.setWindowModality(Qt.WindowModal)\n        self.setMinimumDuration(0)\n        self.setAutoClose(True)\n        self.esc_pressed = False\n\n    def keyPressEvent(self, event):\n        if event.key() == Qt.Key_Escape:\n            self.esc_pressed = True\n        super(ProgressWithEsc, self).keyPressEvent(event)\n\n    def wasCanceled(self):\n        return self.esc_pressed\n\ndef copy_skin_weights_optimized(source_mesh, target_meshes, cleanup_unused_influences=False):\n    source_skin = get_skin_cluster(source_mesh)\n    if not source_skin:\n        cmds.error(u\"源网格 {} 未绑定皮肤集群\".format(source_mesh))\n        return False\n\n    source_joints = cmds.skinCluster(source_skin, query=True, influence=True)\n    if not source_joints:\n        cmds.warning(u\"源皮肤集群 {} 没有影响关节\".format(source_skin))\n        return False\n\n    source_max_influences = cmds.skinCluster(source_skin, query=True, maximumInfluences=True)\n    source_maintain_max_influences = cmds.getAttr(\"{}.maintainMaxInfluences\".format(source_skin))\n    print(u\"源皮肤集群最大影响物数量: {}\".format(source_max_influences))\n    print(u\"源皮肤集群保持最大影响物状态: {}\".format(source_maintain_max_influences))\n\n    app = QApplication.instance() or QApplication([])\n\n    confirm_dialog = ConfirmDialog(source_mesh, len(target_meshes), get_maya_main_window())\n    confirm_dialog.exec_()\n    if not confirm_dialog.result:\n        print(u\"用户取消了权重复制操作\")\n        return False\n\n    cleanup_unused_influences = confirm_dialog.cleanup_unused\n\n    progress = ProgressWithEsc(u\"初始化...\", get_maya_main_window())\n    progress.show()\n\n    # 删除目标网格已存在的 skinCluster\n    to_delete = [get_skin_cluster(target) for target in target_meshes]\n    to_delete = [s for s in to_delete if s]\n    if to_delete:\n        cmds.delete(to_delete)\n    else:\n        print(u\"目标网格没有已存在的 skinCluster，无需删除\")\n\n    with undo_chunk():\n        steps_per_mesh = 3 if cleanup_unused_influences else 2\n        total_steps = len(target_meshes) * steps_per_mesh\n        step = 0\n        created_skin_clusters = []\n\n        for i, target_mesh in enumerate(target_meshes):\n            if progress.wasCanceled():\n                cmds.warning(u\"操作已被用户取消\")\n                return False\n\n            progress.setLabelText(u\"绑定皮肤: {} ({}/{})\".format(target_mesh, i + 1, len(target_meshes)))\n            progress.setValue(int((step / float(total_steps)) * 100))\n            QApplication.processEvents()\n\n            target_skin = cmds.skinCluster(\n                source_joints, target_mesh,\n                toSelectedBones=True,\n                bindMethod=0,\n                normalizeWeights=1,\n                weightDistribution=0,\n                maximumInfluences=source_max_influences\n            )[0]\n            step += 1\n\n            if progress.wasCanceled():\n                cmds.warning(u\"操作已被用户取消\")\n                return False\n\n            progress.setLabelText(u\"复制权重: {} ({}/{})\".format(target_mesh, i + 1, len(target_meshes)))\n            progress.setValue(int((step / float(total_steps)) * 100))\n            QApplication.processEvents()\n\n            cmds.copySkinWeights(\n                sourceSkin=source_skin,\n                destinationSkin=target_skin,\n                noMirror=True,\n                surfaceAssociation='closestPoint',\n                influenceAssociation=['label', 'oneToOne'],\n                normalize=True\n            )\n            step += 1\n\n            if cleanup_unused_influences:\n                if progress.wasCanceled():\n                    cmds.warning(u\"操作已被用户取消\")\n                    return False\n\n                progress.setLabelText(u\"清理未使用影响: {} ({}/{})\".format(target_mesh, i + 1, len(target_meshes)))\n                progress.setValue(int((step / float(total_steps)) * 100))\n                QApplication.processEvents()\n\n                weighted_influences = cmds.skinCluster(target_skin, query=True, weightedInfluence=True)\n                unused_joints = set(source_joints) - set(weighted_influences)\n                if unused_joints:\n                    cmds.skinCluster(target_skin, edit=True, removeInfluence=list(unused_joints))\n                step += 1\n\n            if target_mesh.startswith('mesh_'):\n                new_name = target_mesh.replace('mesh_', 'skinCluster_')\n                target_skin = cmds.rename(target_skin, new_name)\n\n            created_skin_clusters.append(target_skin)\n\n        if source_maintain_max_influences:\n            for skin_cluster in created_skin_clusters:\n                try:\n                    cmds.setAttr(\"{}.maintainMaxInfluences\".format(skin_cluster), 1)\n                    print(u\"已为 {} 设置保持最大影响物\".format(skin_cluster))\n                except Exception as e:\n                    print(u\"设置 {} 保持最大影响物失败: {}\".format(skin_cluster, e))\n            print(u\"蒙皮权重复制完成，已为 {} 个skinCluster设置保持最大影响物\".format(len(created_skin_clusters)))\n        else:\n            print(u\"蒙皮权重复制完成，源未开启保持最大影响物，跳过目标设置\")\n\n        progress.setLabelText(u\"完成蒙皮权重复制\")\n        progress.setValue(100)\n\n    return True\n\ndef main():\n    sel = cmds.ls(selection=True, long=True)\n    if len(sel) < 2:\n        cmds.error(u\"请至少选择一个源网格和一个目标网格\")\n        return\n\n    source_mesh = sel[0]\n    target_meshes = sel[1:]\n    copy_skin_weights_optimized(source_mesh, target_meshes)\n\nif __name__ == \"__main__\":\n    main()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "import maya.cmds as cmds\n\n\ndef snap_to_pivot():\n    \"\"\"\n    snap the last selected object to other selected nodes' average pivot position\n    \"\"\"\n    # get selected nodes, the last one is the one need to be snapped, others are drivers\n    selected_nodes = cmds.ls(selection=True, flatten=True)\n\n    if not selected_nodes or len(selected_nodes) < 2:\n        cmds.warning('need to select at least two nodes to do the snap')\n    else:\n        driver_nodes = selected_nodes[:-1]\n        driven_node = selected_nodes[-1]\n\n        # get driver nodes' xyz in different lists\n        drivers_x = []\n        drivers_y = []\n        drivers_z = []\n\n        for driver in driver_nodes:\n            pos = cmds.xform(driver, query=True, translation=True, worldSpace=True)\n            drivers_x.append(pos[0])\n            drivers_y.append(pos[1])\n            drivers_z.append(pos[2])\n\n        # get maximum and minimum values\n        max_x = max(drivers_x)\n        min_x = min(drivers_x)\n\n        max_y = max(drivers_y)\n        min_y = min(drivers_y)\n\n        max_z = max(drivers_z)\n        min_z = min(drivers_z)\n\n        # get center position for xyz\n        pos_x = 0.5 * max_x + 0.5 * min_x\n        pos_y = 0.5 * max_y + 0.5 * min_y\n        pos_z = 0.5 * max_z + 0.5 * min_z\n\n        # set driven node's position\n        cmds.xform(driven_node, translation=[pos_x, pos_y, pos_z], worldSpace=True)\n\nsnap_to_pivot()" 
        -enableBackground 1
        -backgroundColor 0.811734 0.763928 0.620691 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "选择" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "选择匹配" 
        -overlayLabelColor 0 0 0 
        -overlayLabelBackColor 0 0 0 0 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\n\ndef snap_to_pivot():\n    \"\"\"\n    snap the last selected object to other selected nodes' average pivot position\n    \"\"\"\n    # get selected nodes, the last one is the one need to be snapped, others are drivers\n    selected_nodes = cmds.ls(selection=True, flatten=True)\n\n    if not selected_nodes or len(selected_nodes) < 2:\n        cmds.warning('need to select at least two nodes to do the snap')\n    else:\n        driver_nodes = selected_nodes[:-1]\n        driven_node = selected_nodes[-1]\n\n        # get driver nodes' xyz in different lists\n        drivers_x = []\n        drivers_y = []\n        drivers_z = []\n\n        for driver in driver_nodes:\n            pos = cmds.xform(driver, query=True, translation=True, worldSpace=True)\n            drivers_x.append(pos[0])\n            drivers_y.append(pos[1])\n            drivers_z.append(pos[2])\n\n        # get maximum and minimum values\n        max_x = max(drivers_x)\n        min_x = min(drivers_x)\n\n        max_y = max(drivers_y)\n        min_y = min(drivers_y)\n\n        max_z = max(drivers_z)\n        min_z = min(drivers_z)\n\n        # get center position for xyz\n        pos_x = 0.5 * max_x + 0.5 * min_x\n        pos_y = 0.5 * max_y + 0.5 * min_y\n        pos_z = 0.5 * max_z + 0.5 * min_z\n\n        # set driven node's position\n        cmds.xform(driven_node, translation=[pos_x, pos_y, pos_z], worldSpace=True)\n\nsnap_to_pivot()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "# -*- coding: utf-8 -*-\nimport maya.cmds as cmds\nimport maya.mel as mel\nimport time\nfrom collections import defaultdict\nimport threading\n\n\n# 简单的缓存实现，替代lru_cache\n_skin_cluster_cache = {}\n\ndef get_skin_cluster_cache(shape_name):\n    \"\"\"\n    缓存蒙皮簇查询结果\n    \"\"\"\n    if shape_name in _skin_cluster_cache:\n        return _skin_cluster_cache[shape_name]\n    \n    try:\n        skin_clusters = cmds.ls(cmds.listHistory(shape_name), type='skinCluster')\n        result = skin_clusters[0] if skin_clusters else None\n        _skin_cluster_cache[shape_name] = result\n        return result\n    except:\n        return None\n\n\ndef find_vertices_with_excessive_influences(max_influences=4, show_progress=True):\n    \"\"\"\n    查找蒙皮权重影响超过指定数量的顶点（高性能优化版本）\n    \n    Args:\n        max_influences (int): 最大允许的影响骨骼数量，默认为4\n        show_progress (bool): 是否显示进度条\n        \n    Returns:\n        dict: 包含问题顶点信息的字典\n    \"\"\"\n    # 获取当前选择的物体\n    selected_objects = cmds.ls(selection=True, type='transform')\n    \n    if not selected_objects:\n        cmds.warning(u\"请先选择要检查的物体\")\n        return {}\n    \n    problem_vertices = {}\n    progress_window = None\n    \n    try:\n        # 创建进度窗口\n        if show_progress:\n            progress_window = create_progress_window()\n        \n        total_objects = len(selected_objects)\n        \n        for obj_index, obj in enumerate(selected_objects):\n            if show_progress:\n                update_progress(progress_window, obj_index, total_objects, u\"检查物体: {0}\".format(obj))\n            \n            # 获取物体的形状节点\n            shapes = cmds.listRelatives(obj, shapes=True, type='mesh')\n            if not shapes:\n                continue\n                \n            shape = shapes[0]\n            \n            # 使用缓存获取蒙皮簇\n            skin_cluster = get_skin_cluster_cache(shape)\n            if not skin_cluster:\n                print(u\"物体 {0} 没有蒙皮\".format(obj))\n                continue\n            \n            # 获取顶点数量\n            vertex_count = cmds.polyEvaluate(shape, vertex=True)\n            \n            # 批量获取所有影响骨骼\n            all_influences = cmds.skinCluster(skin_cluster, query=True, influence=True)\n            \n            obj_problem_vertices = []\n            \n            # 优化的批量处理 - 使用更大的批次以减少API调用\n            batch_size = min(500, vertex_count)  # 增加批次大小\n            \n            for batch_start in range(0, vertex_count, batch_size):\n                batch_end = min(batch_start + batch_size, vertex_count)\n                \n                if show_progress and vertex_count > 1000:\n                    progress = float(obj_index) / total_objects + (float(batch_start) / vertex_count) / total_objects\n                    update_progress_value(progress_window, progress * 100)\n                \n                # 批量获取权重数据 - 一次性获取整个批次\n                batch_vertices = [\"{0}.vtx[{1}]\".format(shape, i) for i in range(batch_start, batch_end)]\n                \n                try:\n                    # 使用mel命令批量获取权重，性能更好\n                    for vertex in batch_vertices:\n                        # 获取该顶点的所有权重值\n                        weights = cmds.skinPercent(skin_cluster, vertex, query=True, value=True)\n                        \n                        if not weights:\n                            continue\n                        \n                        # 快速计算非零权重数量（忽略小于0.001的权重）\n                        non_zero_count = sum(1 for w in weights if w >= 0.001)\n                        \n                        # 如果影响数量超过限制，记录该顶点\n                        if non_zero_count > max_influences:\n                            # 获取有效影响的详细信息\n                            influences_info = []\n                            for i, weight in enumerate(weights):\n                                if weight >= 0.001 and i < len(all_influences):\n                                    influences_info.append((all_influences[i], weight))\n                            \n                            # 按权重排序\n                            influences_info.sort(key=lambda x: x[1], reverse=True)\n                            \n                            obj_problem_vertices.append({\n                                'vertex': vertex,\n                                'influence_count': non_zero_count,\n                                'influences': influences_info,\n                                'max_allowed': max_influences\n                            })\n                \n                except Exception as e:\n                    print(u\"警告: 批次处理失败，跳过: {0}\".format(str(e)))\n                    continue\n            \n            if obj_problem_vertices:\n                problem_vertices[obj] = obj_problem_vertices\n        \n        if show_progress:\n            update_progress(progress_window, total_objects, total_objects, u\"检查完成\")\n            time.sleep(0.3)  # 减少等待时间\n    \n    finally:\n        # 关闭进度窗口\n        if show_progress and progress_window:\n            close_progress_window(progress_window)\n    \n    return problem_vertices\n\n\ndef find_vertices_with_small_weights(min_weight_threshold=0.001, show_progress=True):\n    \"\"\"\n    查找蒙皮权重小于指定阈值的顶点（高性能优化版本）\n    \n    Args:\n        min_weight_threshold (float): 最小权重阈值，默认为0.001\n        show_progress (bool): 是否显示进度条\n        \n    Returns:\n        dict: 包含小权重顶点信息的字典\n    \"\"\"\n    # 获取当前选择的物体\n    selected_objects = cmds.ls(selection=True, type='transform')\n    \n    if not selected_objects:\n        cmds.warning(u\"请先选择要检查的物体\")\n        return {}\n    \n    problem_vertices = {}\n    progress_window = None\n    \n    try:\n        # 创建进度窗口\n        if show_progress:\n            progress_window = create_progress_window()\n        \n        total_objects = len(selected_objects)\n        \n        for obj_index, obj in enumerate(selected_objects):\n            if show_progress:\n                update_progress(progress_window, obj_index, total_objects, u\"检查物体: {0}\".format(obj))\n            \n            # 获取物体的形状节点\n            shapes = cmds.listRelatives(obj, shapes=True, type='mesh')\n            if not shapes:\n                continue\n                \n            shape = shapes[0]\n            \n            # 使用缓存获取蒙皮簇\n            skin_cluster = get_skin_cluster_cache(shape)\n            if not skin_cluster:\n                print(u\"物体 {0} 没有蒙皮\".format(obj))\n                continue\n            \n            # 获取顶点数量\n            vertex_count = cmds.polyEvaluate(shape, vertex=True)\n            \n            # 批量获取所有影响骨骼\n            all_influences = cmds.skinCluster(skin_cluster, query=True, influence=True)\n            \n            obj_problem_vertices = []\n            \n            # 优化的批量处理 - 使用更大的批次以减少API调用\n            batch_size = min(500, vertex_count)  # 增加批次大小\n            \n            for batch_start in range(0, vertex_count, batch_size):\n                batch_end = min(batch_start + batch_size, vertex_count)\n                \n                if show_progress and vertex_count > 1000:\n                    progress = float(obj_index) / total_objects + (float(batch_start) / vertex_count) / total_objects\n                    update_progress_value(progress_window, progress * 100)\n                \n                # 批量获取权重数据\n                batch_vertices = [\"{0}.vtx[{1}]\".format(shape, i) for i in range(batch_start, batch_end)]\n                \n                try:\n                    # 批量处理顶点权重\n                    for vertex in batch_vertices:\n                        # 获取该顶点的所有权重值\n                        weights = cmds.skinPercent(skin_cluster, vertex, query=True, value=True)\n                        \n                        if not weights:\n                            continue\n                        \n                        # 快速查找小权重影响（忽略小于0.001的权重）\n                        small_weight_influences = []\n                        \n                        for i, weight in enumerate(weights):\n                            if 0.001 <= weight < min_weight_threshold and i < len(all_influences):\n                                small_weight_influences.append((all_influences[i], weight))\n                        \n                        # 如果有小权重影响，记录该顶点\n                        if small_weight_influences:\n                            # 按权重排序（从小到大）\n                            small_weight_influences.sort(key=lambda x: x[1])\n                            \n                            obj_problem_vertices.append({\n                                'vertex': vertex,\n                                'small_weight_count': len(small_weight_influences),\n                                'small_weights': small_weight_influences,\n                                'threshold': min_weight_threshold\n                            })\n                \n                except Exception as e:\n                    print(u\"警告: 批次处理失败，跳过: {0}\".format(str(e)))\n                    continue\n            \n            if obj_problem_vertices:\n                problem_vertices[obj] = obj_problem_vertices\n        \n        if show_progress:\n            update_progress(progress_window, total_objects, total_objects, u\"检查完成\")\n            time.sleep(0.3)  # 减少等待时间\n    \n    finally:\n        # 关闭进度窗口\n        if show_progress and progress_window:\n            close_progress_window(progress_window)\n    \n    return problem_vertices\n\n\ndef select_problem_vertices(problem_vertices_dict):\n    \"\"\"\n    选择所有有问题的顶点\n    \n    Args:\n        problem_vertices_dict (dict): find_vertices_with_excessive_influences返回的字典\n    \"\"\"\n    all_problem_vertices = []\n    \n    for obj, vertices_info in problem_vertices_dict.items():\n        for vertex_info in vertices_info:\n            all_problem_vertices.append(vertex_info['vertex'])\n    \n    if all_problem_vertices:\n        cmds.select(all_problem_vertices, replace=True)\n        print(u\"已选择 {0} 个问题顶点\".format(len(all_problem_vertices)))\n    else:\n        cmds.select(clear=True)\n        print(u\"没有发现问题顶点\")\n\n\ndef select_small_weight_vertices(small_weight_vertices_dict):\n    \"\"\"\n    选择所有小权重问题顶点\n    \n    Args:\n        small_weight_vertices_dict (dict): find_vertices_with_small_weights返回的字典\n    \"\"\"\n    all_problem_vertices = []\n    \n    for obj, vertices_info in small_weight_vertices_dict.items():\n        for vertex_info in vertices_info:\n            all_problem_vertices.append(vertex_info['vertex'])\n    \n    if all_problem_vertices:\n        cmds.select(all_problem_vertices, replace=True)\n        print(u\"已选择 {0} 个小权重问题顶点\".format(len(all_problem_vertices)))\n    else:\n        cmds.select(clear=True)\n        print(u\"没有发现小权重问题顶点\")\n\n\ndef clean_vertex_weights(problem_vertices_dict, max_influences=4, show_progress=True):\n    \"\"\"\n    清理问题顶点的权重：保留权重最大的前N个影响（高性能批量处理版本）\n    \n    Args:\n        problem_vertices_dict (dict): 问题顶点字典\n        max_influences (int): 最大允许的影响数量\n        show_progress (bool): 是否显示进度\n    \"\"\"\n    if not problem_vertices_dict:\n        print(u\"没有问题顶点需要清理\")\n        return 0\n    \n    progress_window = None\n    total_cleaned = 0\n    \n    try:\n        if show_progress:\n            progress_window = create_progress_window()\n        \n        total_vertices = sum(len(vertices) for vertices in problem_vertices_dict.values())\n        current_vertex = 0\n        \n        for obj, vertices_info in problem_vertices_dict.items():\n            # 获取物体的蒙皮簇\n            shapes = cmds.listRelatives(obj, shapes=True, type='mesh')\n            if not shapes:\n                continue\n                \n            shape = shapes[0]\n            skin_cluster = get_skin_cluster_cache(shape)\n            if not skin_cluster:\n                continue\n            \n            # 批量获取所有影响骨骼（避免重复查询）\n            all_influences = cmds.skinCluster(skin_cluster, query=True, influence=True)\n            if not all_influences:\n                continue\n            \n            # 批量处理顶点（提升性能）\n            batch_size = min(100, len(vertices_info))  # 增加批处理大小\n            \n            for batch_start in range(0, len(vertices_info), batch_size):\n                batch_end = min(batch_start + batch_size, len(vertices_info))\n                batch_vertices_info = vertices_info[batch_start:batch_end]\n                \n                # 批量操作数据\n                batch_operations = []\n                \n                for vertex_info in batch_vertices_info:\n                    current_vertex += 1\n                    vertex = vertex_info['vertex']\n                    influences = vertex_info.get('influences', [])\n                    \n                    if show_progress and current_vertex % 20 == 0:  # 减少进度更新频率\n                        update_progress(progress_window, current_vertex, total_vertices, \n                                      u\"清理顶点: {0}\".format(vertex))\n                    \n                    try:\n                        # 保留权重最大的前N个影响\n                        influences_to_keep = influences[:max_influences]\n                        \n                        # 重新归一化权重\n                        total_weight = sum(inf[1] for inf in influences_to_keep)\n                        if total_weight > 0:\n                            normalized_weights = [(inf[0], inf[1] / total_weight) for inf in influences_to_keep]\n                            \n                            # 准备批量操作\n                            batch_operations.append({\n                                'vertex': vertex,\n                                'normalized_weights': normalized_weights,\n                                'current_influences': [inf[0] for inf in influences]\n                            })\n                    \n                    except Exception as e:\n                        print(u\"分析顶点 {0} 时出错: {1}\".format(vertex, str(e)))\n                        continue\n                \n                # 执行批量权重清理操作\n                if batch_operations:\n                    try:\n                        # 暂时禁用撤销以提升性能\n                        cmds.undoInfo(stateWithoutFlush=False)\n                        \n                        for operation in batch_operations:\n                            vertex = operation['vertex']\n                            normalized_weights = operation['normalized_weights']\n                            current_influences = operation['current_influences']\n                            \n                            # 先将当前有权重的影响设为0\n                            zero_weights = [(inf, 0.0) for inf in current_influences]\n                            cmds.skinPercent(skin_cluster, vertex, transformValue=zero_weights)\n                            \n                            # 设置保留的权重\n                            cmds.skinPercent(skin_cluster, vertex, transformValue=normalized_weights)\n                            \n                            total_cleaned += 1\n                        \n                        # 重新启用撤销\n                        cmds.undoInfo(stateWithoutFlush=True)\n                        \n                        print(u\"批量清理完成: {0} 个顶点\".format(len(batch_operations)))\n                    \n                    except Exception as e:\n                        # 重新启用撤销\n                        cmds.undoInfo(stateWithoutFlush=True)\n                        print(u\"批量清理出错: {0}\".format(str(e)))\n                        continue\n        \n        if show_progress:\n            update_progress(progress_window, total_vertices, total_vertices, u\"清理完成\")\n            time.sleep(0.3)\n    \n    finally:\n        if show_progress and progress_window:\n            close_progress_window(progress_window)\n        \n        # 确保撤销状态正常\n        try:\n            cmds.undoInfo(stateWithoutFlush=True)\n        except:\n            pass\n    \n    print(u\"\\n权重清理完成！共清理了 {0} 个顶点\".format(total_cleaned))\n    return total_cleaned\n\n\ndef clean_small_weights(small_weight_vertices_dict, show_progress=True):\n    \"\"\"\n    清理小权重顶点：将小权重设置为0并重新归一化（高性能批量处理版本）\n    \n    Args:\n        small_weight_vertices_dict (dict): 小权重问题顶点字典\n        show_progress (bool): 是否显示进度\n    \"\"\"\n    if not small_weight_vertices_dict:\n        print(u\"没有小权重顶点需要清理\")\n        return 0\n    \n    progress_window = None\n    total_cleaned = 0\n    \n    try:\n        if show_progress:\n            progress_window = create_progress_window()\n        \n        total_vertices = sum(len(vertices) for vertices in small_weight_vertices_dict.values())\n        current_vertex = 0\n        \n        for obj, vertices_info in small_weight_vertices_dict.items():\n            # 获取物体的蒙皮簇\n            shapes = cmds.listRelatives(obj, shapes=True, type='mesh')\n            if not shapes:\n                continue\n                \n            shape = shapes[0]\n            skin_cluster = get_skin_cluster_cache(shape)\n            if not skin_cluster:\n                continue\n            \n            # 优化的批量处理 - 使用更大的批次以减少API调用\n            batch_size = min(100, len(vertices_info))  # 增加批次大小\n            \n            for batch_start in range(0, len(vertices_info), batch_size):\n                batch_end = min(batch_start + batch_size, len(vertices_info))\n                batch_vertices_info = vertices_info[batch_start:batch_end]\n                \n                # 批量操作数据\n                batch_operations = []\n                \n                for vertex_info in batch_vertices_info:\n                    current_vertex += 1\n                    vertex = vertex_info['vertex']\n                    small_weights = vertex_info.get('small_weights', [])\n                    \n                    if show_progress and current_vertex % 20 == 0:  # 减少进度更新频率\n                        update_progress(progress_window, current_vertex, total_vertices, \n                                      u\"清理小权重: {0}\".format(vertex))\n                    \n                    try:\n                        # 准备要清理的小权重影响\n                        influences_to_remove = [inf for inf, weight in small_weights]\n                        \n                        if influences_to_remove:\n                            batch_operations.append({\n                                'vertex': vertex,\n                                'influences_to_remove': influences_to_remove,\n                                'small_weight_count': len(small_weights)\n                            })\n                    \n                    except Exception as e:\n                        print(u\"分析顶点 {0} 时出错: {1}\".format(vertex, str(e)))\n                        continue\n                \n                # 执行批量权重清理操作\n                if batch_operations:\n                    try:\n                        # 暂时禁用撤销以提升性能\n                        cmds.undoInfo(stateWithoutFlush=False)\n                        \n                        for operation in batch_operations:\n                            vertex = operation['vertex']\n                            influences_to_remove = operation['influences_to_remove']\n                            \n                            # 批量设置小权重为0\n                            transform_values = [(inf, 0.0) for inf in influences_to_remove]\n                            cmds.skinPercent(skin_cluster, vertex, transformValue=transform_values)\n                            \n                            # 归一化权重\n                            cmds.skinPercent(skin_cluster, vertex, normalize=True)\n                            total_cleaned += 1\n                        \n                        # 重新启用撤销\n                        cmds.undoInfo(stateWithoutFlush=True)\n                        \n                        print(u\"批量清理小权重完成: {0} 个顶点\".format(len(batch_operations)))\n                    \n                    except Exception as e:\n                        # 重新启用撤销\n                        cmds.undoInfo(stateWithoutFlush=True)\n                        print(u\"批量清理小权重出错: {0}\".format(str(e)))\n                        continue\n        \n        if show_progress:\n            update_progress(progress_window, total_vertices, total_vertices, u\"清理完成\")\n            time.sleep(0.3)\n    \n    finally:\n        if show_progress and progress_window:\n            close_progress_window(progress_window)\n        \n        # 确保撤销状态正常\n        try:\n            cmds.undoInfo(stateWithoutFlush=True)\n        except:\n            pass\n    \n    print(u\"\\n小权重清理完成！共清理了 {0} 个顶点\".format(total_cleaned))\n    return total_cleaned\n\n\ndef print_detailed_report(problem_vertices_dict, max_influences=4):\n    \"\"\"\n    打印详细的问题顶点报告\n    \n    Args:\n        problem_vertices_dict (dict): 问题顶点字典\n        max_influences (int): 最大允许的影响数量\n    \"\"\"\n    if not problem_vertices_dict:\n        print(u\"没有发现问题顶点\")\n        return\n    \n    total_problem_vertices = 0\n    \n    print(u\"\\n=== 蒙皮权重问题报告 ===\")\n    print(u\"最大允许影响数: {0}\".format(max_influences))\n    print(u\"检查时间: {0}\".format(time.strftime(\"%Y-%m-%d %H:%M:%S\")))\n    print(u\"=\"*50)\n    \n    for obj, vertices_info in problem_vertices_dict.items():\n        print(u\"\\n物体: {0}\".format(obj))\n        print(u\"问题顶点数: {0}\".format(len(vertices_info)))\n        \n        # 显示前10个问题顶点的详细信息\n        for i, vertex_info in enumerate(vertices_info[:10]):\n            vertex = vertex_info['vertex']\n            influence_count = vertex_info['influence_count']\n            influences = vertex_info['influences']\n            \n            print(u\"  {0}. {1} (影响数: {2})\".format(i+1, vertex, influence_count))\n            \n            # 显示前5个最大权重的影响\n            for j, (influence, weight) in enumerate(influences[:5]):\n                print(u\"    - {0}: {1:.6f}\".format(influence, weight))\n        \n        if len(vertices_info) > 10:\n            print(u\"  ... 还有 {0} 个问题顶点\".format(len(vertices_info) - 10))\n        \n        total_problem_vertices += len(vertices_info)\n    \n    print(u\"\\n总计发现 {0} 个问题顶点\".format(total_problem_vertices))\n    print(u\"\\n建议: 使用 clean_vertex_weights() 函数清理这些顶点的权重\")\n\n\ndef print_small_weights_report(problem_vertices_dict, min_threshold=0.001):\n    \"\"\"\n    打印小权重问题顶点报告\n    \n    Args:\n        problem_vertices_dict (dict): 小权重问题顶点字典\n        min_threshold (float): 最小权重阈值\n    \"\"\"\n    if not problem_vertices_dict:\n        print(u\"没有发现小权重问题顶点\")\n        return\n    \n    total_problem_vertices = 0\n    \n    print(u\"\\n=== 小权重问题报告 ===\")\n    print(u\"权重阈值: {0}\".format(min_threshold))\n    print(u\"检查时间: {0}\".format(time.strftime(\"%Y-%m-%d %H:%M:%S\")))\n    print(u\"=\"*50)\n    \n    for obj, vertices_info in problem_vertices_dict.items():\n        print(u\"\\n物体: {0}\".format(obj))\n        print(u\"小权重顶点数: {0}\".format(len(vertices_info)))\n        \n        # 显示前10个问题顶点的详细信息\n        for i, vertex_info in enumerate(vertices_info[:10]):\n            vertex = vertex_info['vertex']\n            small_weight_count = vertex_info['small_weight_count']\n            small_weights = vertex_info['small_weights']\n            \n            print(u\"  {0}. {1} (小权重数: {2})\".format(i+1, vertex, small_weight_count))\n            \n            # 显示所有小权重影响\n            for influence, weight in small_weights:\n                print(u\"    - {0}: {1:.6f}\".format(influence, weight))\n        \n        if len(vertices_info) > 10:\n            print(u\"  ... 还有 {0} 个小权重顶点\".format(len(vertices_info) - 10))\n        \n        total_problem_vertices += len(vertices_info)\n    \n    print(u\"\\n总计发现 {0} 个小权重顶点\".format(total_problem_vertices))\n    print(u\"\\n建议: 清理这些小于 {0} 的权重值以优化性能\".format(min_threshold))\n\n\ndef create_progress_window():\n    \"\"\"\n    创建进度显示窗口（优化版）\n    \"\"\"\n    progress_window = \"SkinWeightProgress\"\n    \n    if cmds.window(progress_window, exists=True):\n        cmds.deleteUI(progress_window)\n    \n    window = cmds.window(progress_window, title=u\"处理进度\", widthHeight=(450, 140), \n                        sizeable=False, minimizeButton=False, maximizeButton=False)\n    \n    cmds.columnLayout(adjustableColumn=True, rowSpacing=10, columnOffset=('both', 20))\n    \n    # 状态文本\n    status_text = cmds.text(label=u\"准备开始处理...\", height=25, align='center')\n    \n    # 进度条\n    progress_bar = cmds.progressBar(maxValue=100, width=410, height=20)\n    \n    # 时间和性能信息\n    time_text = cmds.text(label=\"\", height=20, align='center')\n    performance_text = cmds.text(label=\"\", height=20, align='center', font='smallPlainLabelFont')\n    \n    cmds.showWindow(window)\n    \n    return {\n        'window': progress_window,\n        'status_text': status_text,\n        'progress_bar': progress_bar,\n        'time_text': time_text,\n        'performance_text': performance_text,\n        'start_time': time.time(),\n        'last_update': time.time()\n    }\n\n\ndef update_progress(progress_info, current, total, status_msg):\n    \"\"\"\n    更新进度显示（优化版，减少UI更新频率）\n    \"\"\"\n    # 增强的有效性检查\n    if not progress_info or not isinstance(progress_info, dict):\n        return\n    \n    if 'window' not in progress_info or not progress_info['window']:\n        return\n        \n    try:\n        if not cmds.window(progress_info['window'], exists=True):\n            return\n    except:\n        return\n    \n    # 限制更新频率，避免UI卡顿\n    current_time = time.time()\n    if current_time - progress_info.get('last_update', 0) < 0.1 and current < total:  # 最多每100ms更新一次\n        return\n    \n    progress_info['last_update'] = current_time\n    \n    try:\n        # 更新状态文本\n        if 'status_text' in progress_info and progress_info['status_text']:\n            if cmds.text(progress_info['status_text'], exists=True):\n                cmds.text(progress_info['status_text'], edit=True, label=status_msg)\n        \n        # 更新进度条\n        if 'progress_bar' in progress_info and progress_info['progress_bar']:\n            if cmds.progressBar(progress_info['progress_bar'], exists=True):\n                progress = (float(current) / total) * 100 if total > 0 else 0\n                cmds.progressBar(progress_info['progress_bar'], edit=True, progress=progress)\n        \n        # 更新时间信息\n        if 'time_text' in progress_info and progress_info['time_text']:\n            if cmds.text(progress_info['time_text'], exists=True):\n                elapsed_time = current_time - progress_info.get('start_time', current_time)\n                if current > 0 and total > current:\n                    estimated_total = elapsed_time * total / current\n                    remaining_time = estimated_total - elapsed_time\n                    time_str = u\"已用时: {0:.1f}s | 预计剩余: {1:.1f}s\".format(elapsed_time, remaining_time)\n                else:\n                    time_str = u\"已用时: {0:.1f}s\".format(elapsed_time)\n                cmds.text(progress_info['time_text'], edit=True, label=time_str)\n        \n        # 更新性能信息\n        if 'performance_text' in progress_info and progress_info['performance_text']:\n            if cmds.text(progress_info['performance_text'], exists=True):\n                if current > 0:\n                    elapsed_time = current_time - progress_info.get('start_time', current_time)\n                    if elapsed_time > 0:\n                        rate = float(current) / elapsed_time\n                        perf_str = u\"处理速度: {0:.1f} 顶点/秒\".format(rate)\n                        cmds.text(progress_info['performance_text'], edit=True, label=perf_str)\n        \n        # 减少刷新频率\n        if current % 20 == 0 or current == total:  # 每20个或完成时才刷新\n            cmds.refresh()\n        \n    except Exception as e:\n        print(u\"更新进度时出错: {0}\".format(str(e)))\n        # 如果更新失败，将progress_info标记为无效\n        if progress_info:\n            progress_info['window'] = None\n\n\ndef update_progress_value(progress_info, value):\n    \"\"\"\n    直接更新进度条数值\n    \"\"\"\n    # 增强的有效性检查\n    if not progress_info or not isinstance(progress_info, dict):\n        return\n    \n    if 'window' not in progress_info or not progress_info['window']:\n        return\n        \n    try:\n        if not cmds.window(progress_info['window'], exists=True):\n            return\n    except:\n        return\n    \n    try:\n        if 'progress_bar' in progress_info and progress_info['progress_bar']:\n            if cmds.progressBar(progress_info['progress_bar'], exists=True):\n                cmds.progressBar(progress_info['progress_bar'], edit=True, progress=value)\n                cmds.refresh()\n    except Exception as e:\n        print(u\"更新进度条数值时出错: {0}\".format(str(e)))\n        # 如果更新失败，将progress_info标记为无效\n        if progress_info:\n            progress_info['window'] = None\n\n\ndef close_progress_window(progress_info):\n    \"\"\"\n    关闭进度窗口\n    \"\"\"\n    # 增强的有效性检查\n    if not progress_info or not isinstance(progress_info, dict):\n        return\n    \n    if 'window' not in progress_info or not progress_info['window']:\n        return\n        \n    try:\n        if cmds.window(progress_info['window'], exists=True):\n            cmds.deleteUI(progress_info['window'])\n    except Exception as e:\n        print(u\"关闭进度窗口时出错: {0}\".format(str(e)))\n    finally:\n        # 清理progress_info\n        if progress_info:\n            progress_info['window'] = None\n\n\ndef check_skin_weights_ui():\n    \"\"\"\n    创建紧凑的UI界面（优化版）\n    \"\"\"\n    window_name = \"SkinWeightChecker\"\n    \n    # 如果窗口已存在，删除它\n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    \n    # 创建紧凑窗口\n    window = cmds.window(window_name, title=u\"蒙皮权重检查器 v3.2 (高性能版)\", widthHeight=(380, 320), sizeable=False)\n    \n    # 创建紧凑布局\n    cmds.columnLayout(adjustableColumn=True, rowSpacing=3, columnOffset=('both', 10))\n    \n    cmds.text(label=u\"蒙皮权重检查器\", height=20, font='boldLabelFont')\n    cmds.separator(height=5)\n    \n    # === 检查参数区域（合并） ===\n    cmds.frameLayout(label=u\"检查参数\", collapsable=True, collapse=False, marginHeight=3, marginWidth=5)\n    \n    # 参数设置行\n    cmds.rowLayout(numberOfColumns=4, columnWidth4=(80, 60, 80, 60), columnAttach=[(1, 'left', 5), (3, 'left', 10)])\n    cmds.text(label=u\"影响数:\")\n    max_influences_field = cmds.intField(value=4, minValue=1, maxValue=20, width=50)\n    cmds.text(label=u\"小权重:\")\n    min_weight_field = cmds.floatField(value=0.001, minValue=0.0001, maxValue=0.1, precision=6, width=50)\n    cmds.setParent('..')\n    \n    # 进度条选项\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(100, 50))\n    cmds.text(label=u\"显示进度:\")\n    show_progress_field = cmds.checkBox(value=True, label=\"\")\n    cmds.setParent('..')\n    \n    cmds.setParent('..')  # frameLayout\n    \n    # === 检查按钮区域 ===\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(185, 185), columnAttach=[(1, 'both', 2), (2, 'both', 2)])\n    cmds.button(label=u\"检查影响数量\", height=28, backgroundColor=(0.4, 0.7, 0.4),\n                command=lambda x: execute_check_enhanced(max_influences_field, show_progress_field))\n    cmds.button(label=u\"检查小权重\", height=28, backgroundColor=(0.7, 0.4, 0.4),\n                command=lambda x: execute_small_weight_check(min_weight_field, show_progress_field))\n    cmds.setParent('..')\n    \n    cmds.separator(height=8)\n    \n    # === 结果操作按钮 ===\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(185, 185), columnAttach=[(1, 'both', 2), (2, 'both', 2)])\n    cmds.button(label=u\"选择问题顶点\", height=25, backgroundColor=(0.7, 0.7, 0.4),\n                command=lambda x: select_last_results())\n    cmds.button(label=u\"清理问题权重\", height=25, backgroundColor=(0.7, 0.4, 0.4),\n                command=lambda x: clean_last_results(cmds.checkBox(show_progress_field, query=True, value=True)))\n    cmds.setParent('..')\n    \n    cmds.separator(height=8)\n    \n    # === 快速检查按钮（紧凑排列） ===\n    cmds.text(label=u\"快速检查\", height=15, font='smallBoldLabelFont')\n    cmds.rowLayout(numberOfColumns=3, columnWidth3=(123, 123, 123), columnAttach=[(1, 'both', 1), (2, 'both', 1), (3, 'both', 1)])\n    cmds.button(label=u\"4影响\", height=22, \n                command=lambda x: quick_check_enhanced(4, cmds.checkBox(show_progress_field, query=True, value=True)))\n    cmds.button(label=u\"6影响\", height=22,\n                command=lambda x: quick_check_enhanced(6, cmds.checkBox(show_progress_field, query=True, value=True)))\n    cmds.button(label=u\"8影响\", height=22,\n                command=lambda x: quick_check_enhanced(8, cmds.checkBox(show_progress_field, query=True, value=True)))\n    cmds.setParent('..')\n    \n    cmds.separator(height=5)\n    \n    # 信息文本\n    cmds.text(label=u\"选择蒙皮物体后点击检查按钮\", height=15, \n              backgroundColor=(0.2, 0.2, 0.2), font='smallPlainLabelFont')\n    \n    # 显示窗口\n    cmds.showWindow(window)\n\n\n# 全局变量存储检查结果和缓存\nlast_check_results = {}\nlast_small_weight_results = {}\nskin_cluster_cache = {}  # 蒙皮簇缓存\n\ndef get_skin_cluster_cache(shape):\n    \"\"\"\n    获取蒙皮簇（带缓存）\n    \n    Args:\n        shape (str): 形状节点名称\n        \n    Returns:\n        str: 蒙皮簇名称，如果没有则返回None\n    \"\"\"\n    global skin_cluster_cache\n    \n    # 检查缓存\n    if shape in skin_cluster_cache:\n        # 验证缓存的蒙皮簇是否仍然存在\n        cached_cluster = skin_cluster_cache[shape]\n        if cached_cluster and cmds.objExists(cached_cluster):\n            return cached_cluster\n        else:\n            # 清除无效缓存\n            del skin_cluster_cache[shape]\n    \n    # 查找蒙皮簇\n    skin_clusters = cmds.ls(cmds.listHistory(shape), type='skinCluster')\n    if skin_clusters:\n        skin_cluster = skin_clusters[0]\n        # 缓存结果\n        skin_cluster_cache[shape] = skin_cluster\n        return skin_cluster\n    else:\n        # 缓存空结果\n        skin_cluster_cache[shape] = None\n        return None\n\ndef clear_skin_cluster_cache():\n    \"\"\"\n    清空蒙皮簇缓存\n    \"\"\"\n    global skin_cluster_cache\n    skin_cluster_cache.clear()\n    print(u\"蒙皮簇缓存已清空\")\n\n\ndef execute_check_enhanced(max_influences_field, show_progress_field):\n    \"\"\"\n    执行增强检查（UI回调函数）\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    try:\n        max_influences = cmds.intField(max_influences_field, query=True, value=True)\n        show_progress = cmds.checkBox(show_progress_field, query=True, value=True)\n        \n        print(u\"\\n开始检查蒙皮权重影响数量...\")\n        print(u\"最大允许影响数: {0}\".format(max_influences))\n        \n        # 清空之前的小权重检查结果\n        last_small_weight_results = {}\n        \n        # 执行检查\n        start_time = time.time()\n        results = find_vertices_with_excessive_influences(max_influences, show_progress)\n        end_time = time.time()\n        \n        # 保存结果\n        last_check_results = results\n        \n        # 显示结果\n        if results:\n            total_vertices = sum(len(vertices) for vertices in results.values())\n            print(u\"\\n检查完成！发现 {0} 个物体共 {1} 个问题顶点\".format(len(results), total_vertices))\n            print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n            \n            # 打印详细报告\n            print_detailed_report(results, max_influences)\n            \n            # 自动选择问题顶点\n            select_problem_vertices(results)\n        else:\n            print(u\"\\n检查完成！没有发现问题顶点\")\n            print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n            cmds.select(clear=True)\n        \n    except Exception as e:\n        print(u\"检查过程中出错: {0}\".format(str(e)))\n        import traceback\n        traceback.print_exc()\n\n\ndef execute_small_weight_check(min_weight_field, show_progress_field):\n    \"\"\"\n    执行小权重检查（UI回调函数）\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    try:\n        min_weight = cmds.floatField(min_weight_field, query=True, value=True)\n        show_progress = cmds.checkBox(show_progress_field, query=True, value=True)\n        \n        print(u\"\\n开始检查小权重顶点...\")\n        print(u\"权重阈值: {0}\".format(min_weight))\n        \n        # 清空之前的影响数检查结果\n        last_check_results = {}\n        \n        # 执行检查\n        start_time = time.time()\n        results = find_vertices_with_small_weights(min_weight, show_progress)\n        end_time = time.time()\n        \n        # 保存结果\n        last_small_weight_results = results\n        \n        # 显示结果\n        if results:\n            total_vertices = sum(len(vertices) for vertices in results.values())\n            print(u\"\\n检查完成！发现 {0} 个物体共 {1} 个小权重顶点\".format(len(results), total_vertices))\n            print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n            \n            # 打印详细报告\n            print_small_weights_report(results, min_weight)\n            \n            # 自动选择问题顶点\n            select_small_weight_vertices(results)\n        else:\n            print(u\"\\n检查完成！没有发现小权重问题顶点\")\n            print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n            cmds.select(clear=True)\n        \n    except Exception as e:\n        print(u\"检查过程中出错: {0}\".format(str(e)))\n        import traceback\n        traceback.print_exc()\n\n\ndef execute_check(max_influences_field):\n    \"\"\"\n    执行检查（UI回调函数）- 兼容旧版本\n    \"\"\"\n    execute_check_enhanced(max_influences_field, None)\n\n\ndef select_last_results():\n    \"\"\"\n    选择上次检查的结果顶点\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    if last_check_results:\n        select_problem_vertices(last_check_results)\n        print(u\"已选择影响数检查的问题顶点\")\n    elif last_small_weight_results:\n        select_small_weight_vertices(last_small_weight_results)\n        print(u\"已选择小权重检查的问题顶点\")\n    else:\n        print(u\"没有检查结果可选择，请先运行检查\")\n        cmds.select(clear=True)\n\n\ndef clean_last_results(show_progress=True):\n    \"\"\"\n    清理上次检查的结果\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    cleaned_count = 0\n    \n    try:\n        if last_check_results:\n            print(u\"\\n开始清理影响数问题顶点...\")\n            \n            # 获取最大影响数（从第一个顶点信息中获取）\n            max_influences = 4  # 默认值\n            for obj, vertices_info in last_check_results.items():\n                if vertices_info:\n                    max_influences = vertices_info[0].get('max_allowed', 4)\n                    break\n            \n            cleaned_count = clean_vertex_weights(last_check_results, max_influences, show_progress)\n            \n            if cleaned_count > 0:\n                print(u\"影响数问题清理完成！\")\n                # 清空结果，避免重复清理\n                last_check_results = {}\n            \n        elif last_small_weight_results:\n            print(u\"\\n开始清理小权重问题顶点...\")\n            cleaned_count = clean_small_weights(last_small_weight_results, show_progress)\n            \n            if cleaned_count > 0:\n                print(u\"小权重问题清理完成！\")\n                # 清空结果，避免重复清理\n                last_small_weight_results = {}\n        \n        else:\n            print(u\"没有检查结果可清理，请先运行检查\")\n            return\n        \n        if cleaned_count > 0:\n            print(u\"\\n建议: 清理完成后可以重新检查以确认结果\")\n        \n    except Exception as e:\n        print(u\"清理过程中出错: {0}\".format(str(e)))\n        import traceback\n        traceback.print_exc()\n\n\ndef main():\n    \"\"\"\n    主函数 - 显示UI\n    \"\"\"\n    print(u\"\\n启动蒙皮权重检查器 UI...\")\n    check_skin_weights_ui()\n\n\nif __name__ == \"__main__\":\n    main()\n\n\ndef quick_check_enhanced(max_influences=8, show_progress=True):\n    \"\"\"\n    快速检查当前选择的物体（增强版）\n    \n    Args:\n        max_influences (int): 最大允许的影响骨骼数量\n        show_progress (bool): 是否显示进度条\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    print(u\"\\n=== 快速检查模式 ===\")\n    print(u\"最大允许影响数: {0}\".format(max_influences))\n    \n    # 清空之前的结果\n    last_small_weight_results = {}\n    \n    start_time = time.time()\n    results = find_vertices_with_excessive_influences(max_influences, show_progress)\n    end_time = time.time()\n    \n    # 保存结果\n    last_check_results = results\n    \n    if results:\n        total_vertices = sum(len(vertices) for vertices in results.values())\n        print(u\"发现 {0} 个物体共 {1} 个问题顶点\".format(len(results), total_vertices))\n        print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n        select_problem_vertices(results)\n        return results\n    else:\n        print(u\"没有发现问题顶点\")\n        print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n        cmds.select(clear=True)\n        return {}\n\n\ndef quick_check(max_influences=8):\n    \"\"\"\n    快速检查当前选择的物体（兼容旧版本）\n    \n    Args:\n        max_influences (int): 最大允许的影响骨骼数量\n    \"\"\"\n    return quick_check_enhanced(max_influences, True)\n\n\n# 加载提示信息\nprint(u\"\\n蒙皮权重检查器已加载 (v3.2 高性能版 - Python 2兼容)\")\nprint(u\"使用方法:\")\nprint(u\"1. main() - 显示UI界面\")\nprint(u\"2. quick_check() - 快速检查当前选择的物体\")\nprint(u\"3. quick_check(6) - 检查影响超过6个骨骼的顶点\")\nprint(u\"4. clean_vertex_weights(results) - 清理问题顶点权重\")\nprint(u\"\\n性能优化特性:\")\nprint(u\"- 蒙皮簇缓存: 避免重复查找，提升检查速度\")\nprint(u\"- 批量处理: 大幅提升大模型处理效率\")\nprint(u\"- 智能进度显示: 减少界面刷新，提升响应速度\")\nprint(u\"- 内存优化: 降低大场景内存占用\")\nprint(u\"\\n功能特性:\")\nprint(u\"- 小权重检查: 检查权重值小于指定阈值的顶点\")\nprint(u\"- 支持两种检查模式: 影响数量检查 和 小权重检查\")\nprint(u\"- 智能清理: 根据检查类型自动选择清理方法\")\nprint(u\"\\n请先选择要检查的蒙皮物体，然后运行相应函数\")" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "检查权重" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "检查权重" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\nimport maya.cmds as cmds\nimport maya.mel as mel\nimport time\nfrom collections import defaultdict\nimport threading\n\n\n# 简单的缓存实现，替代lru_cache\n_skin_cluster_cache = {}\n\ndef get_skin_cluster_cache(shape_name):\n    \"\"\"\n    缓存蒙皮簇查询结果\n    \"\"\"\n    if shape_name in _skin_cluster_cache:\n        return _skin_cluster_cache[shape_name]\n    \n    try:\n        skin_clusters = cmds.ls(cmds.listHistory(shape_name), type='skinCluster')\n        result = skin_clusters[0] if skin_clusters else None\n        _skin_cluster_cache[shape_name] = result\n        return result\n    except:\n        return None\n\n\ndef find_vertices_with_excessive_influences(max_influences=4, show_progress=True):\n    \"\"\"\n    查找蒙皮权重影响超过指定数量的顶点（高性能优化版本）\n    \n    Args:\n        max_influences (int): 最大允许的影响骨骼数量，默认为4\n        show_progress (bool): 是否显示进度条\n        \n    Returns:\n        dict: 包含问题顶点信息的字典\n    \"\"\"\n    # 获取当前选择的物体\n    selected_objects = cmds.ls(selection=True, type='transform')\n    \n    if not selected_objects:\n        cmds.warning(u\"请先选择要检查的物体\")\n        return {}\n    \n    problem_vertices = {}\n    progress_window = None\n    \n    try:\n        # 创建进度窗口\n        if show_progress:\n            progress_window = create_progress_window()\n        \n        total_objects = len(selected_objects)\n        \n        for obj_index, obj in enumerate(selected_objects):\n            if show_progress:\n                update_progress(progress_window, obj_index, total_objects, u\"检查物体: {0}\".format(obj))\n            \n            # 获取物体的形状节点\n            shapes = cmds.listRelatives(obj, shapes=True, type='mesh')\n            if not shapes:\n                continue\n                \n            shape = shapes[0]\n            \n            # 使用缓存获取蒙皮簇\n            skin_cluster = get_skin_cluster_cache(shape)\n            if not skin_cluster:\n                print(u\"物体 {0} 没有蒙皮\".format(obj))\n                continue\n            \n            # 获取顶点数量\n            vertex_count = cmds.polyEvaluate(shape, vertex=True)\n            \n            # 批量获取所有影响骨骼\n            all_influences = cmds.skinCluster(skin_cluster, query=True, influence=True)\n            \n            obj_problem_vertices = []\n            \n            # 优化的批量处理 - 使用更大的批次以减少API调用\n            batch_size = min(500, vertex_count)  # 增加批次大小\n            \n            for batch_start in range(0, vertex_count, batch_size):\n                batch_end = min(batch_start + batch_size, vertex_count)\n                \n                if show_progress and vertex_count > 1000:\n                    progress = float(obj_index) / total_objects + (float(batch_start) / vertex_count) / total_objects\n                    update_progress_value(progress_window, progress * 100)\n                \n                # 批量获取权重数据 - 一次性获取整个批次\n                batch_vertices = [\"{0}.vtx[{1}]\".format(shape, i) for i in range(batch_start, batch_end)]\n                \n                try:\n                    # 使用mel命令批量获取权重，性能更好\n                    for vertex in batch_vertices:\n                        # 获取该顶点的所有权重值\n                        weights = cmds.skinPercent(skin_cluster, vertex, query=True, value=True)\n                        \n                        if not weights:\n                            continue\n                        \n                        # 快速计算非零权重数量（忽略小于0.001的权重）\n                        non_zero_count = sum(1 for w in weights if w >= 0.001)\n                        \n                        # 如果影响数量超过限制，记录该顶点\n                        if non_zero_count > max_influences:\n                            # 获取有效影响的详细信息\n                            influences_info = []\n                            for i, weight in enumerate(weights):\n                                if weight >= 0.001 and i < len(all_influences):\n                                    influences_info.append((all_influences[i], weight))\n                            \n                            # 按权重排序\n                            influences_info.sort(key=lambda x: x[1], reverse=True)\n                            \n                            obj_problem_vertices.append({\n                                'vertex': vertex,\n                                'influence_count': non_zero_count,\n                                'influences': influences_info,\n                                'max_allowed': max_influences\n                            })\n                \n                except Exception as e:\n                    print(u\"警告: 批次处理失败，跳过: {0}\".format(str(e)))\n                    continue\n            \n            if obj_problem_vertices:\n                problem_vertices[obj] = obj_problem_vertices\n        \n        if show_progress:\n            update_progress(progress_window, total_objects, total_objects, u\"检查完成\")\n            time.sleep(0.3)  # 减少等待时间\n    \n    finally:\n        # 关闭进度窗口\n        if show_progress and progress_window:\n            close_progress_window(progress_window)\n    \n    return problem_vertices\n\n\ndef find_vertices_with_small_weights(min_weight_threshold=0.001, show_progress=True):\n    \"\"\"\n    查找蒙皮权重小于指定阈值的顶点（高性能优化版本）\n    \n    Args:\n        min_weight_threshold (float): 最小权重阈值，默认为0.001\n        show_progress (bool): 是否显示进度条\n        \n    Returns:\n        dict: 包含小权重顶点信息的字典\n    \"\"\"\n    # 获取当前选择的物体\n    selected_objects = cmds.ls(selection=True, type='transform')\n    \n    if not selected_objects:\n        cmds.warning(u\"请先选择要检查的物体\")\n        return {}\n    \n    problem_vertices = {}\n    progress_window = None\n    \n    try:\n        # 创建进度窗口\n        if show_progress:\n            progress_window = create_progress_window()\n        \n        total_objects = len(selected_objects)\n        \n        for obj_index, obj in enumerate(selected_objects):\n            if show_progress:\n                update_progress(progress_window, obj_index, total_objects, u\"检查物体: {0}\".format(obj))\n            \n            # 获取物体的形状节点\n            shapes = cmds.listRelatives(obj, shapes=True, type='mesh')\n            if not shapes:\n                continue\n                \n            shape = shapes[0]\n            \n            # 使用缓存获取蒙皮簇\n            skin_cluster = get_skin_cluster_cache(shape)\n            if not skin_cluster:\n                print(u\"物体 {0} 没有蒙皮\".format(obj))\n                continue\n            \n            # 获取顶点数量\n            vertex_count = cmds.polyEvaluate(shape, vertex=True)\n            \n            # 批量获取所有影响骨骼\n            all_influences = cmds.skinCluster(skin_cluster, query=True, influence=True)\n            \n            obj_problem_vertices = []\n            \n            # 优化的批量处理 - 使用更大的批次以减少API调用\n            batch_size = min(500, vertex_count)  # 增加批次大小\n            \n            for batch_start in range(0, vertex_count, batch_size):\n                batch_end = min(batch_start + batch_size, vertex_count)\n                \n                if show_progress and vertex_count > 1000:\n                    progress = float(obj_index) / total_objects + (float(batch_start) / vertex_count) / total_objects\n                    update_progress_value(progress_window, progress * 100)\n                \n                # 批量获取权重数据\n                batch_vertices = [\"{0}.vtx[{1}]\".format(shape, i) for i in range(batch_start, batch_end)]\n                \n                try:\n                    # 批量处理顶点权重\n                    for vertex in batch_vertices:\n                        # 获取该顶点的所有权重值\n                        weights = cmds.skinPercent(skin_cluster, vertex, query=True, value=True)\n                        \n                        if not weights:\n                            continue\n                        \n                        # 快速查找小权重影响（忽略小于0.001的权重）\n                        small_weight_influences = []\n                        \n                        for i, weight in enumerate(weights):\n                            if 0.001 <= weight < min_weight_threshold and i < len(all_influences):\n                                small_weight_influences.append((all_influences[i], weight))\n                        \n                        # 如果有小权重影响，记录该顶点\n                        if small_weight_influences:\n                            # 按权重排序（从小到大）\n                            small_weight_influences.sort(key=lambda x: x[1])\n                            \n                            obj_problem_vertices.append({\n                                'vertex': vertex,\n                                'small_weight_count': len(small_weight_influences),\n                                'small_weights': small_weight_influences,\n                                'threshold': min_weight_threshold\n                            })\n                \n                except Exception as e:\n                    print(u\"警告: 批次处理失败，跳过: {0}\".format(str(e)))\n                    continue\n            \n            if obj_problem_vertices:\n                problem_vertices[obj] = obj_problem_vertices\n        \n        if show_progress:\n            update_progress(progress_window, total_objects, total_objects, u\"检查完成\")\n            time.sleep(0.3)  # 减少等待时间\n    \n    finally:\n        # 关闭进度窗口\n        if show_progress and progress_window:\n            close_progress_window(progress_window)\n    \n    return problem_vertices\n\n\ndef select_problem_vertices(problem_vertices_dict):\n    \"\"\"\n    选择所有有问题的顶点\n    \n    Args:\n        problem_vertices_dict (dict): find_vertices_with_excessive_influences返回的字典\n    \"\"\"\n    all_problem_vertices = []\n    \n    for obj, vertices_info in problem_vertices_dict.items():\n        for vertex_info in vertices_info:\n            all_problem_vertices.append(vertex_info['vertex'])\n    \n    if all_problem_vertices:\n        cmds.select(all_problem_vertices, replace=True)\n        print(u\"已选择 {0} 个问题顶点\".format(len(all_problem_vertices)))\n    else:\n        cmds.select(clear=True)\n        print(u\"没有发现问题顶点\")\n\n\ndef select_small_weight_vertices(small_weight_vertices_dict):\n    \"\"\"\n    选择所有小权重问题顶点\n    \n    Args:\n        small_weight_vertices_dict (dict): find_vertices_with_small_weights返回的字典\n    \"\"\"\n    all_problem_vertices = []\n    \n    for obj, vertices_info in small_weight_vertices_dict.items():\n        for vertex_info in vertices_info:\n            all_problem_vertices.append(vertex_info['vertex'])\n    \n    if all_problem_vertices:\n        cmds.select(all_problem_vertices, replace=True)\n        print(u\"已选择 {0} 个小权重问题顶点\".format(len(all_problem_vertices)))\n    else:\n        cmds.select(clear=True)\n        print(u\"没有发现小权重问题顶点\")\n\n\ndef clean_vertex_weights(problem_vertices_dict, max_influences=4, show_progress=True):\n    \"\"\"\n    清理问题顶点的权重：保留权重最大的前N个影响（高性能批量处理版本）\n    \n    Args:\n        problem_vertices_dict (dict): 问题顶点字典\n        max_influences (int): 最大允许的影响数量\n        show_progress (bool): 是否显示进度\n    \"\"\"\n    if not problem_vertices_dict:\n        print(u\"没有问题顶点需要清理\")\n        return 0\n    \n    progress_window = None\n    total_cleaned = 0\n    \n    try:\n        if show_progress:\n            progress_window = create_progress_window()\n        \n        total_vertices = sum(len(vertices) for vertices in problem_vertices_dict.values())\n        current_vertex = 0\n        \n        for obj, vertices_info in problem_vertices_dict.items():\n            # 获取物体的蒙皮簇\n            shapes = cmds.listRelatives(obj, shapes=True, type='mesh')\n            if not shapes:\n                continue\n                \n            shape = shapes[0]\n            skin_cluster = get_skin_cluster_cache(shape)\n            if not skin_cluster:\n                continue\n            \n            # 批量获取所有影响骨骼（避免重复查询）\n            all_influences = cmds.skinCluster(skin_cluster, query=True, influence=True)\n            if not all_influences:\n                continue\n            \n            # 批量处理顶点（提升性能）\n            batch_size = min(100, len(vertices_info))  # 增加批处理大小\n            \n            for batch_start in range(0, len(vertices_info), batch_size):\n                batch_end = min(batch_start + batch_size, len(vertices_info))\n                batch_vertices_info = vertices_info[batch_start:batch_end]\n                \n                # 批量操作数据\n                batch_operations = []\n                \n                for vertex_info in batch_vertices_info:\n                    current_vertex += 1\n                    vertex = vertex_info['vertex']\n                    influences = vertex_info.get('influences', [])\n                    \n                    if show_progress and current_vertex % 20 == 0:  # 减少进度更新频率\n                        update_progress(progress_window, current_vertex, total_vertices, \n                                      u\"清理顶点: {0}\".format(vertex))\n                    \n                    try:\n                        # 保留权重最大的前N个影响\n                        influences_to_keep = influences[:max_influences]\n                        \n                        # 重新归一化权重\n                        total_weight = sum(inf[1] for inf in influences_to_keep)\n                        if total_weight > 0:\n                            normalized_weights = [(inf[0], inf[1] / total_weight) for inf in influences_to_keep]\n                            \n                            # 准备批量操作\n                            batch_operations.append({\n                                'vertex': vertex,\n                                'normalized_weights': normalized_weights,\n                                'current_influences': [inf[0] for inf in influences]\n                            })\n                    \n                    except Exception as e:\n                        print(u\"分析顶点 {0} 时出错: {1}\".format(vertex, str(e)))\n                        continue\n                \n                # 执行批量权重清理操作\n                if batch_operations:\n                    try:\n                        # 暂时禁用撤销以提升性能\n                        cmds.undoInfo(stateWithoutFlush=False)\n                        \n                        for operation in batch_operations:\n                            vertex = operation['vertex']\n                            normalized_weights = operation['normalized_weights']\n                            current_influences = operation['current_influences']\n                            \n                            # 先将当前有权重的影响设为0\n                            zero_weights = [(inf, 0.0) for inf in current_influences]\n                            cmds.skinPercent(skin_cluster, vertex, transformValue=zero_weights)\n                            \n                            # 设置保留的权重\n                            cmds.skinPercent(skin_cluster, vertex, transformValue=normalized_weights)\n                            \n                            total_cleaned += 1\n                        \n                        # 重新启用撤销\n                        cmds.undoInfo(stateWithoutFlush=True)\n                        \n                        print(u\"批量清理完成: {0} 个顶点\".format(len(batch_operations)))\n                    \n                    except Exception as e:\n                        # 重新启用撤销\n                        cmds.undoInfo(stateWithoutFlush=True)\n                        print(u\"批量清理出错: {0}\".format(str(e)))\n                        continue\n        \n        if show_progress:\n            update_progress(progress_window, total_vertices, total_vertices, u\"清理完成\")\n            time.sleep(0.3)\n    \n    finally:\n        if show_progress and progress_window:\n            close_progress_window(progress_window)\n        \n        # 确保撤销状态正常\n        try:\n            cmds.undoInfo(stateWithoutFlush=True)\n        except:\n            pass\n    \n    print(u\"\\n权重清理完成！共清理了 {0} 个顶点\".format(total_cleaned))\n    return total_cleaned\n\n\ndef clean_small_weights(small_weight_vertices_dict, show_progress=True):\n    \"\"\"\n    清理小权重顶点：将小权重设置为0并重新归一化（高性能批量处理版本）\n    \n    Args:\n        small_weight_vertices_dict (dict): 小权重问题顶点字典\n        show_progress (bool): 是否显示进度\n    \"\"\"\n    if not small_weight_vertices_dict:\n        print(u\"没有小权重顶点需要清理\")\n        return 0\n    \n    progress_window = None\n    total_cleaned = 0\n    \n    try:\n        if show_progress:\n            progress_window = create_progress_window()\n        \n        total_vertices = sum(len(vertices) for vertices in small_weight_vertices_dict.values())\n        current_vertex = 0\n        \n        for obj, vertices_info in small_weight_vertices_dict.items():\n            # 获取物体的蒙皮簇\n            shapes = cmds.listRelatives(obj, shapes=True, type='mesh')\n            if not shapes:\n                continue\n                \n            shape = shapes[0]\n            skin_cluster = get_skin_cluster_cache(shape)\n            if not skin_cluster:\n                continue\n            \n            # 优化的批量处理 - 使用更大的批次以减少API调用\n            batch_size = min(100, len(vertices_info))  # 增加批次大小\n            \n            for batch_start in range(0, len(vertices_info), batch_size):\n                batch_end = min(batch_start + batch_size, len(vertices_info))\n                batch_vertices_info = vertices_info[batch_start:batch_end]\n                \n                # 批量操作数据\n                batch_operations = []\n                \n                for vertex_info in batch_vertices_info:\n                    current_vertex += 1\n                    vertex = vertex_info['vertex']\n                    small_weights = vertex_info.get('small_weights', [])\n                    \n                    if show_progress and current_vertex % 20 == 0:  # 减少进度更新频率\n                        update_progress(progress_window, current_vertex, total_vertices, \n                                      u\"清理小权重: {0}\".format(vertex))\n                    \n                    try:\n                        # 准备要清理的小权重影响\n                        influences_to_remove = [inf for inf, weight in small_weights]\n                        \n                        if influences_to_remove:\n                            batch_operations.append({\n                                'vertex': vertex,\n                                'influences_to_remove': influences_to_remove,\n                                'small_weight_count': len(small_weights)\n                            })\n                    \n                    except Exception as e:\n                        print(u\"分析顶点 {0} 时出错: {1}\".format(vertex, str(e)))\n                        continue\n                \n                # 执行批量权重清理操作\n                if batch_operations:\n                    try:\n                        # 暂时禁用撤销以提升性能\n                        cmds.undoInfo(stateWithoutFlush=False)\n                        \n                        for operation in batch_operations:\n                            vertex = operation['vertex']\n                            influences_to_remove = operation['influences_to_remove']\n                            \n                            # 批量设置小权重为0\n                            transform_values = [(inf, 0.0) for inf in influences_to_remove]\n                            cmds.skinPercent(skin_cluster, vertex, transformValue=transform_values)\n                            \n                            # 归一化权重\n                            cmds.skinPercent(skin_cluster, vertex, normalize=True)\n                            total_cleaned += 1\n                        \n                        # 重新启用撤销\n                        cmds.undoInfo(stateWithoutFlush=True)\n                        \n                        print(u\"批量清理小权重完成: {0} 个顶点\".format(len(batch_operations)))\n                    \n                    except Exception as e:\n                        # 重新启用撤销\n                        cmds.undoInfo(stateWithoutFlush=True)\n                        print(u\"批量清理小权重出错: {0}\".format(str(e)))\n                        continue\n        \n        if show_progress:\n            update_progress(progress_window, total_vertices, total_vertices, u\"清理完成\")\n            time.sleep(0.3)\n    \n    finally:\n        if show_progress and progress_window:\n            close_progress_window(progress_window)\n        \n        # 确保撤销状态正常\n        try:\n            cmds.undoInfo(stateWithoutFlush=True)\n        except:\n            pass\n    \n    print(u\"\\n小权重清理完成！共清理了 {0} 个顶点\".format(total_cleaned))\n    return total_cleaned\n\n\ndef print_detailed_report(problem_vertices_dict, max_influences=4):\n    \"\"\"\n    打印详细的问题顶点报告\n    \n    Args:\n        problem_vertices_dict (dict): 问题顶点字典\n        max_influences (int): 最大允许的影响数量\n    \"\"\"\n    if not problem_vertices_dict:\n        print(u\"没有发现问题顶点\")\n        return\n    \n    total_problem_vertices = 0\n    \n    print(u\"\\n=== 蒙皮权重问题报告 ===\")\n    print(u\"最大允许影响数: {0}\".format(max_influences))\n    print(u\"检查时间: {0}\".format(time.strftime(\"%Y-%m-%d %H:%M:%S\")))\n    print(u\"=\"*50)\n    \n    for obj, vertices_info in problem_vertices_dict.items():\n        print(u\"\\n物体: {0}\".format(obj))\n        print(u\"问题顶点数: {0}\".format(len(vertices_info)))\n        \n        # 显示前10个问题顶点的详细信息\n        for i, vertex_info in enumerate(vertices_info[:10]):\n            vertex = vertex_info['vertex']\n            influence_count = vertex_info['influence_count']\n            influences = vertex_info['influences']\n            \n            print(u\"  {0}. {1} (影响数: {2})\".format(i+1, vertex, influence_count))\n            \n            # 显示前5个最大权重的影响\n            for j, (influence, weight) in enumerate(influences[:5]):\n                print(u\"    - {0}: {1:.6f}\".format(influence, weight))\n        \n        if len(vertices_info) > 10:\n            print(u\"  ... 还有 {0} 个问题顶点\".format(len(vertices_info) - 10))\n        \n        total_problem_vertices += len(vertices_info)\n    \n    print(u\"\\n总计发现 {0} 个问题顶点\".format(total_problem_vertices))\n    print(u\"\\n建议: 使用 clean_vertex_weights() 函数清理这些顶点的权重\")\n\n\ndef print_small_weights_report(problem_vertices_dict, min_threshold=0.001):\n    \"\"\"\n    打印小权重问题顶点报告\n    \n    Args:\n        problem_vertices_dict (dict): 小权重问题顶点字典\n        min_threshold (float): 最小权重阈值\n    \"\"\"\n    if not problem_vertices_dict:\n        print(u\"没有发现小权重问题顶点\")\n        return\n    \n    total_problem_vertices = 0\n    \n    print(u\"\\n=== 小权重问题报告 ===\")\n    print(u\"权重阈值: {0}\".format(min_threshold))\n    print(u\"检查时间: {0}\".format(time.strftime(\"%Y-%m-%d %H:%M:%S\")))\n    print(u\"=\"*50)\n    \n    for obj, vertices_info in problem_vertices_dict.items():\n        print(u\"\\n物体: {0}\".format(obj))\n        print(u\"小权重顶点数: {0}\".format(len(vertices_info)))\n        \n        # 显示前10个问题顶点的详细信息\n        for i, vertex_info in enumerate(vertices_info[:10]):\n            vertex = vertex_info['vertex']\n            small_weight_count = vertex_info['small_weight_count']\n            small_weights = vertex_info['small_weights']\n            \n            print(u\"  {0}. {1} (小权重数: {2})\".format(i+1, vertex, small_weight_count))\n            \n            # 显示所有小权重影响\n            for influence, weight in small_weights:\n                print(u\"    - {0}: {1:.6f}\".format(influence, weight))\n        \n        if len(vertices_info) > 10:\n            print(u\"  ... 还有 {0} 个小权重顶点\".format(len(vertices_info) - 10))\n        \n        total_problem_vertices += len(vertices_info)\n    \n    print(u\"\\n总计发现 {0} 个小权重顶点\".format(total_problem_vertices))\n    print(u\"\\n建议: 清理这些小于 {0} 的权重值以优化性能\".format(min_threshold))\n\n\ndef create_progress_window():\n    \"\"\"\n    创建进度显示窗口（优化版）\n    \"\"\"\n    progress_window = \"SkinWeightProgress\"\n    \n    if cmds.window(progress_window, exists=True):\n        cmds.deleteUI(progress_window)\n    \n    window = cmds.window(progress_window, title=u\"处理进度\", widthHeight=(450, 140), \n                        sizeable=False, minimizeButton=False, maximizeButton=False)\n    \n    cmds.columnLayout(adjustableColumn=True, rowSpacing=10, columnOffset=('both', 20))\n    \n    # 状态文本\n    status_text = cmds.text(label=u\"准备开始处理...\", height=25, align='center')\n    \n    # 进度条\n    progress_bar = cmds.progressBar(maxValue=100, width=410, height=20)\n    \n    # 时间和性能信息\n    time_text = cmds.text(label=\"\", height=20, align='center')\n    performance_text = cmds.text(label=\"\", height=20, align='center', font='smallPlainLabelFont')\n    \n    cmds.showWindow(window)\n    \n    return {\n        'window': progress_window,\n        'status_text': status_text,\n        'progress_bar': progress_bar,\n        'time_text': time_text,\n        'performance_text': performance_text,\n        'start_time': time.time(),\n        'last_update': time.time()\n    }\n\n\ndef update_progress(progress_info, current, total, status_msg):\n    \"\"\"\n    更新进度显示（优化版，减少UI更新频率）\n    \"\"\"\n    # 增强的有效性检查\n    if not progress_info or not isinstance(progress_info, dict):\n        return\n    \n    if 'window' not in progress_info or not progress_info['window']:\n        return\n        \n    try:\n        if not cmds.window(progress_info['window'], exists=True):\n            return\n    except:\n        return\n    \n    # 限制更新频率，避免UI卡顿\n    current_time = time.time()\n    if current_time - progress_info.get('last_update', 0) < 0.1 and current < total:  # 最多每100ms更新一次\n        return\n    \n    progress_info['last_update'] = current_time\n    \n    try:\n        # 更新状态文本\n        if 'status_text' in progress_info and progress_info['status_text']:\n            if cmds.text(progress_info['status_text'], exists=True):\n                cmds.text(progress_info['status_text'], edit=True, label=status_msg)\n        \n        # 更新进度条\n        if 'progress_bar' in progress_info and progress_info['progress_bar']:\n            if cmds.progressBar(progress_info['progress_bar'], exists=True):\n                progress = (float(current) / total) * 100 if total > 0 else 0\n                cmds.progressBar(progress_info['progress_bar'], edit=True, progress=progress)\n        \n        # 更新时间信息\n        if 'time_text' in progress_info and progress_info['time_text']:\n            if cmds.text(progress_info['time_text'], exists=True):\n                elapsed_time = current_time - progress_info.get('start_time', current_time)\n                if current > 0 and total > current:\n                    estimated_total = elapsed_time * total / current\n                    remaining_time = estimated_total - elapsed_time\n                    time_str = u\"已用时: {0:.1f}s | 预计剩余: {1:.1f}s\".format(elapsed_time, remaining_time)\n                else:\n                    time_str = u\"已用时: {0:.1f}s\".format(elapsed_time)\n                cmds.text(progress_info['time_text'], edit=True, label=time_str)\n        \n        # 更新性能信息\n        if 'performance_text' in progress_info and progress_info['performance_text']:\n            if cmds.text(progress_info['performance_text'], exists=True):\n                if current > 0:\n                    elapsed_time = current_time - progress_info.get('start_time', current_time)\n                    if elapsed_time > 0:\n                        rate = float(current) / elapsed_time\n                        perf_str = u\"处理速度: {0:.1f} 顶点/秒\".format(rate)\n                        cmds.text(progress_info['performance_text'], edit=True, label=perf_str)\n        \n        # 减少刷新频率\n        if current % 20 == 0 or current == total:  # 每20个或完成时才刷新\n            cmds.refresh()\n        \n    except Exception as e:\n        print(u\"更新进度时出错: {0}\".format(str(e)))\n        # 如果更新失败，将progress_info标记为无效\n        if progress_info:\n            progress_info['window'] = None\n\n\ndef update_progress_value(progress_info, value):\n    \"\"\"\n    直接更新进度条数值\n    \"\"\"\n    # 增强的有效性检查\n    if not progress_info or not isinstance(progress_info, dict):\n        return\n    \n    if 'window' not in progress_info or not progress_info['window']:\n        return\n        \n    try:\n        if not cmds.window(progress_info['window'], exists=True):\n            return\n    except:\n        return\n    \n    try:\n        if 'progress_bar' in progress_info and progress_info['progress_bar']:\n            if cmds.progressBar(progress_info['progress_bar'], exists=True):\n                cmds.progressBar(progress_info['progress_bar'], edit=True, progress=value)\n                cmds.refresh()\n    except Exception as e:\n        print(u\"更新进度条数值时出错: {0}\".format(str(e)))\n        # 如果更新失败，将progress_info标记为无效\n        if progress_info:\n            progress_info['window'] = None\n\n\ndef close_progress_window(progress_info):\n    \"\"\"\n    关闭进度窗口\n    \"\"\"\n    # 增强的有效性检查\n    if not progress_info or not isinstance(progress_info, dict):\n        return\n    \n    if 'window' not in progress_info or not progress_info['window']:\n        return\n        \n    try:\n        if cmds.window(progress_info['window'], exists=True):\n            cmds.deleteUI(progress_info['window'])\n    except Exception as e:\n        print(u\"关闭进度窗口时出错: {0}\".format(str(e)))\n    finally:\n        # 清理progress_info\n        if progress_info:\n            progress_info['window'] = None\n\n\ndef check_skin_weights_ui():\n    \"\"\"\n    创建紧凑的UI界面（优化版）\n    \"\"\"\n    window_name = \"SkinWeightChecker\"\n    \n    # 如果窗口已存在，删除它\n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    \n    # 创建紧凑窗口\n    window = cmds.window(window_name, title=u\"蒙皮权重检查器 v3.2 (高性能版)\", widthHeight=(380, 320), sizeable=False)\n    \n    # 创建紧凑布局\n    cmds.columnLayout(adjustableColumn=True, rowSpacing=3, columnOffset=('both', 10))\n    \n    cmds.text(label=u\"蒙皮权重检查器\", height=20, font='boldLabelFont')\n    cmds.separator(height=5)\n    \n    # === 检查参数区域（合并） ===\n    cmds.frameLayout(label=u\"检查参数\", collapsable=True, collapse=False, marginHeight=3, marginWidth=5)\n    \n    # 参数设置行\n    cmds.rowLayout(numberOfColumns=4, columnWidth4=(80, 60, 80, 60), columnAttach=[(1, 'left', 5), (3, 'left', 10)])\n    cmds.text(label=u\"影响数:\")\n    max_influences_field = cmds.intField(value=4, minValue=1, maxValue=20, width=50)\n    cmds.text(label=u\"小权重:\")\n    min_weight_field = cmds.floatField(value=0.001, minValue=0.0001, maxValue=0.1, precision=6, width=50)\n    cmds.setParent('..')\n    \n    # 进度条选项\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(100, 50))\n    cmds.text(label=u\"显示进度:\")\n    show_progress_field = cmds.checkBox(value=True, label=\"\")\n    cmds.setParent('..')\n    \n    cmds.setParent('..')  # frameLayout\n    \n    # === 检查按钮区域 ===\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(185, 185), columnAttach=[(1, 'both', 2), (2, 'both', 2)])\n    cmds.button(label=u\"检查影响数量\", height=28, backgroundColor=(0.4, 0.7, 0.4),\n                command=lambda x: execute_check_enhanced(max_influences_field, show_progress_field))\n    cmds.button(label=u\"检查小权重\", height=28, backgroundColor=(0.7, 0.4, 0.4),\n                command=lambda x: execute_small_weight_check(min_weight_field, show_progress_field))\n    cmds.setParent('..')\n    \n    cmds.separator(height=8)\n    \n    # === 结果操作按钮 ===\n    cmds.rowLayout(numberOfColumns=2, columnWidth2=(185, 185), columnAttach=[(1, 'both', 2), (2, 'both', 2)])\n    cmds.button(label=u\"选择问题顶点\", height=25, backgroundColor=(0.7, 0.7, 0.4),\n                command=lambda x: select_last_results())\n    cmds.button(label=u\"清理问题权重\", height=25, backgroundColor=(0.7, 0.4, 0.4),\n                command=lambda x: clean_last_results(cmds.checkBox(show_progress_field, query=True, value=True)))\n    cmds.setParent('..')\n    \n    cmds.separator(height=8)\n    \n    # === 快速检查按钮（紧凑排列） ===\n    cmds.text(label=u\"快速检查\", height=15, font='smallBoldLabelFont')\n    cmds.rowLayout(numberOfColumns=3, columnWidth3=(123, 123, 123), columnAttach=[(1, 'both', 1), (2, 'both', 1), (3, 'both', 1)])\n    cmds.button(label=u\"4影响\", height=22, \n                command=lambda x: quick_check_enhanced(4, cmds.checkBox(show_progress_field, query=True, value=True)))\n    cmds.button(label=u\"6影响\", height=22,\n                command=lambda x: quick_check_enhanced(6, cmds.checkBox(show_progress_field, query=True, value=True)))\n    cmds.button(label=u\"8影响\", height=22,\n                command=lambda x: quick_check_enhanced(8, cmds.checkBox(show_progress_field, query=True, value=True)))\n    cmds.setParent('..')\n    \n    cmds.separator(height=5)\n    \n    # 信息文本\n    cmds.text(label=u\"选择蒙皮物体后点击检查按钮\", height=15, \n              backgroundColor=(0.2, 0.2, 0.2), font='smallPlainLabelFont')\n    \n    # 显示窗口\n    cmds.showWindow(window)\n\n\n# 全局变量存储检查结果和缓存\nlast_check_results = {}\nlast_small_weight_results = {}\nskin_cluster_cache = {}  # 蒙皮簇缓存\n\ndef get_skin_cluster_cache(shape):\n    \"\"\"\n    获取蒙皮簇（带缓存）\n    \n    Args:\n        shape (str): 形状节点名称\n        \n    Returns:\n        str: 蒙皮簇名称，如果没有则返回None\n    \"\"\"\n    global skin_cluster_cache\n    \n    # 检查缓存\n    if shape in skin_cluster_cache:\n        # 验证缓存的蒙皮簇是否仍然存在\n        cached_cluster = skin_cluster_cache[shape]\n        if cached_cluster and cmds.objExists(cached_cluster):\n            return cached_cluster\n        else:\n            # 清除无效缓存\n            del skin_cluster_cache[shape]\n    \n    # 查找蒙皮簇\n    skin_clusters = cmds.ls(cmds.listHistory(shape), type='skinCluster')\n    if skin_clusters:\n        skin_cluster = skin_clusters[0]\n        # 缓存结果\n        skin_cluster_cache[shape] = skin_cluster\n        return skin_cluster\n    else:\n        # 缓存空结果\n        skin_cluster_cache[shape] = None\n        return None\n\ndef clear_skin_cluster_cache():\n    \"\"\"\n    清空蒙皮簇缓存\n    \"\"\"\n    global skin_cluster_cache\n    skin_cluster_cache.clear()\n    print(u\"蒙皮簇缓存已清空\")\n\n\ndef execute_check_enhanced(max_influences_field, show_progress_field):\n    \"\"\"\n    执行增强检查（UI回调函数）\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    try:\n        max_influences = cmds.intField(max_influences_field, query=True, value=True)\n        show_progress = cmds.checkBox(show_progress_field, query=True, value=True)\n        \n        print(u\"\\n开始检查蒙皮权重影响数量...\")\n        print(u\"最大允许影响数: {0}\".format(max_influences))\n        \n        # 清空之前的小权重检查结果\n        last_small_weight_results = {}\n        \n        # 执行检查\n        start_time = time.time()\n        results = find_vertices_with_excessive_influences(max_influences, show_progress)\n        end_time = time.time()\n        \n        # 保存结果\n        last_check_results = results\n        \n        # 显示结果\n        if results:\n            total_vertices = sum(len(vertices) for vertices in results.values())\n            print(u\"\\n检查完成！发现 {0} 个物体共 {1} 个问题顶点\".format(len(results), total_vertices))\n            print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n            \n            # 打印详细报告\n            print_detailed_report(results, max_influences)\n            \n            # 自动选择问题顶点\n            select_problem_vertices(results)\n        else:\n            print(u\"\\n检查完成！没有发现问题顶点\")\n            print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n            cmds.select(clear=True)\n        \n    except Exception as e:\n        print(u\"检查过程中出错: {0}\".format(str(e)))\n        import traceback\n        traceback.print_exc()\n\n\ndef execute_small_weight_check(min_weight_field, show_progress_field):\n    \"\"\"\n    执行小权重检查（UI回调函数）\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    try:\n        min_weight = cmds.floatField(min_weight_field, query=True, value=True)\n        show_progress = cmds.checkBox(show_progress_field, query=True, value=True)\n        \n        print(u\"\\n开始检查小权重顶点...\")\n        print(u\"权重阈值: {0}\".format(min_weight))\n        \n        # 清空之前的影响数检查结果\n        last_check_results = {}\n        \n        # 执行检查\n        start_time = time.time()\n        results = find_vertices_with_small_weights(min_weight, show_progress)\n        end_time = time.time()\n        \n        # 保存结果\n        last_small_weight_results = results\n        \n        # 显示结果\n        if results:\n            total_vertices = sum(len(vertices) for vertices in results.values())\n            print(u\"\\n检查完成！发现 {0} 个物体共 {1} 个小权重顶点\".format(len(results), total_vertices))\n            print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n            \n            # 打印详细报告\n            print_small_weights_report(results, min_weight)\n            \n            # 自动选择问题顶点\n            select_small_weight_vertices(results)\n        else:\n            print(u\"\\n检查完成！没有发现小权重问题顶点\")\n            print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n            cmds.select(clear=True)\n        \n    except Exception as e:\n        print(u\"检查过程中出错: {0}\".format(str(e)))\n        import traceback\n        traceback.print_exc()\n\n\ndef execute_check(max_influences_field):\n    \"\"\"\n    执行检查（UI回调函数）- 兼容旧版本\n    \"\"\"\n    execute_check_enhanced(max_influences_field, None)\n\n\ndef select_last_results():\n    \"\"\"\n    选择上次检查的结果顶点\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    if last_check_results:\n        select_problem_vertices(last_check_results)\n        print(u\"已选择影响数检查的问题顶点\")\n    elif last_small_weight_results:\n        select_small_weight_vertices(last_small_weight_results)\n        print(u\"已选择小权重检查的问题顶点\")\n    else:\n        print(u\"没有检查结果可选择，请先运行检查\")\n        cmds.select(clear=True)\n\n\ndef clean_last_results(show_progress=True):\n    \"\"\"\n    清理上次检查的结果\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    cleaned_count = 0\n    \n    try:\n        if last_check_results:\n            print(u\"\\n开始清理影响数问题顶点...\")\n            \n            # 获取最大影响数（从第一个顶点信息中获取）\n            max_influences = 4  # 默认值\n            for obj, vertices_info in last_check_results.items():\n                if vertices_info:\n                    max_influences = vertices_info[0].get('max_allowed', 4)\n                    break\n            \n            cleaned_count = clean_vertex_weights(last_check_results, max_influences, show_progress)\n            \n            if cleaned_count > 0:\n                print(u\"影响数问题清理完成！\")\n                # 清空结果，避免重复清理\n                last_check_results = {}\n            \n        elif last_small_weight_results:\n            print(u\"\\n开始清理小权重问题顶点...\")\n            cleaned_count = clean_small_weights(last_small_weight_results, show_progress)\n            \n            if cleaned_count > 0:\n                print(u\"小权重问题清理完成！\")\n                # 清空结果，避免重复清理\n                last_small_weight_results = {}\n        \n        else:\n            print(u\"没有检查结果可清理，请先运行检查\")\n            return\n        \n        if cleaned_count > 0:\n            print(u\"\\n建议: 清理完成后可以重新检查以确认结果\")\n        \n    except Exception as e:\n        print(u\"清理过程中出错: {0}\".format(str(e)))\n        import traceback\n        traceback.print_exc()\n\n\ndef main():\n    \"\"\"\n    主函数 - 显示UI\n    \"\"\"\n    print(u\"\\n启动蒙皮权重检查器 UI...\")\n    check_skin_weights_ui()\n\n\nif __name__ == \"__main__\":\n    main()\n\n\ndef quick_check_enhanced(max_influences=8, show_progress=True):\n    \"\"\"\n    快速检查当前选择的物体（增强版）\n    \n    Args:\n        max_influences (int): 最大允许的影响骨骼数量\n        show_progress (bool): 是否显示进度条\n    \"\"\"\n    global last_check_results, last_small_weight_results\n    \n    print(u\"\\n=== 快速检查模式 ===\")\n    print(u\"最大允许影响数: {0}\".format(max_influences))\n    \n    # 清空之前的结果\n    last_small_weight_results = {}\n    \n    start_time = time.time()\n    results = find_vertices_with_excessive_influences(max_influences, show_progress)\n    end_time = time.time()\n    \n    # 保存结果\n    last_check_results = results\n    \n    if results:\n        total_vertices = sum(len(vertices) for vertices in results.values())\n        print(u\"发现 {0} 个物体共 {1} 个问题顶点\".format(len(results), total_vertices))\n        print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n        select_problem_vertices(results)\n        return results\n    else:\n        print(u\"没有发现问题顶点\")\n        print(u\"检查耗时: {0:.2f} 秒\".format(end_time - start_time))\n        cmds.select(clear=True)\n        return {}\n\n\ndef quick_check(max_influences=8):\n    \"\"\"\n    快速检查当前选择的物体（兼容旧版本）\n    \n    Args:\n        max_influences (int): 最大允许的影响骨骼数量\n    \"\"\"\n    return quick_check_enhanced(max_influences, True)\n\n\n# 加载提示信息\nprint(u\"\\n蒙皮权重检查器已加载 (v3.2 高性能版 - Python 2兼容)\")\nprint(u\"使用方法:\")\nprint(u\"1. main() - 显示UI界面\")\nprint(u\"2. quick_check() - 快速检查当前选择的物体\")\nprint(u\"3. quick_check(6) - 检查影响超过6个骨骼的顶点\")\nprint(u\"4. clean_vertex_weights(results) - 清理问题顶点权重\")\nprint(u\"\\n性能优化特性:\")\nprint(u\"- 蒙皮簇缓存: 避免重复查找，提升检查速度\")\nprint(u\"- 批量处理: 大幅提升大模型处理效率\")\nprint(u\"- 智能进度显示: 减少界面刷新，提升响应速度\")\nprint(u\"- 内存优化: 降低大场景内存占用\")\nprint(u\"\\n功能特性:\")\nprint(u\"- 小权重检查: 检查权重值小于指定阈值的顶点\")\nprint(u\"- 支持两种检查模式: 影响数量检查 和 小权重检查\")\nprint(u\"- 智能清理: 根据检查类型自动选择清理方法\")\nprint(u\"\\n请先选择要检查的蒙皮物体，然后运行相应函数\")" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
