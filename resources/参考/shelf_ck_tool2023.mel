    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "ControllerTool" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "ControllerTool" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "ControllerTool" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "#\ntry:  \n    from importlib import reload\nexcept:\n    from imp import reload\nfinally:\n    pass\n\nimport sys\nif \"D:/ck/scripts box/jiaoben/ck_tool/MayaControllerTool 1.2\" not in sys.path:\n    sys.path.append(\"D:/ck/scripts box/jiaoben/ck_tool/MayaControllerTool 1.2\")\n\nimport MayaControllerTool.maya_controller_tool as pCtrl\nreload (pCtrl)\npCtrl.MayaControllerTool()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 40
        -enable 1
        -width 43
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "# -*- coding: utf-8 -*-\nu\"\"\"\n曲线工具整合\n集成所有曲线相关工具的UI界面\n适用于 Maya 2018-2020 (Python 2)\n\n功能:\n- 拆分曲线：将多形状曲线拆分为单独的变换节点\n- 结合曲线：将多个曲线合并为一个曲线\n- 曲线大小调整：调整曲线控制顶点大小\n- 曲线宽度调整：增加曲线显示宽度\n- Shape重命名：自动重命名曲线形状节点\n- 添加形状：将形状节点添加到目标物体\n- 物体中心创建曲线：基于选择物体中心创建曲线\n- 镜像曲线形状：沿X轴镜像曲线形状\n\"\"\"\n\nimport sys\nimport math\nimport logging\nimport random\nimport colorsys\nfrom functools import wraps\n\ntry:\n    from PySide2.QtWidgets import *\n    from PySide2.QtCore import *\n    from PySide2.QtGui import *\nexcept ImportError:\n    from PySide.QtGui import *\n    from PySide.QtCore import *\n\ntry:\n    import maya.cmds as cmds\n    import maya.mel as mel\n    import maya.OpenMayaUI as omui\nexcept ImportError:\n    print(u\"错误: 此工具需要在Maya环境中运行\")\n    sys.exit(1)\n\ntry:\n    from shiboken2 import wrapInstance\nexcept ImportError:\n    from shiboken import wrapInstance\n\n# Python2/3 basestring compatibility\ntry:\n    basestring\nexcept NameError:\n    basestring = (str, bytes)\n\n# Logging Setup\nlogging.basicConfig()\nlogger = logging.getLogger(__name__)\nlogger.setLevel(logging.INFO)\n\n# Constants\nCURVE_TYPE_NURBS = \"nurbsCurve\"\nCURVE_TYPE_BEZIER = \"bezierCurve\"\nCURVE_TYPES = [CURVE_TYPE_NURBS, CURVE_TYPE_BEZIER]\n\n\ndef get_maya_main_window():\n    \"\"\"获取Maya主窗口\"\"\"\n    main_window_ptr = omui.MQtUtil.mainWindow()\n    if main_window_ptr is not None:\n        return wrapInstance(int(main_window_ptr), QWidget)\n    return None\n\n\n# 全局撤销装饰器\ndef with_undo_support(func):\n    @wraps(func)\n    def wrapper(self, *args, **kwargs):\n        try:\n            cmds.undoInfo(openChunk=True)\n            result = func(self, *args, **kwargs)\n            if func.__name__ not in [\"show\", \"closeEvent\"]:\n                print(u\"'{}' 操作完成。按 Ctrl+Z 可撤销此操作。\".format(func.__name__))\n            return result\n        except Exception as e:\n            print(u\"'{}' 操作出错: {}\".format(func.__name__, e))\n            raise\n        finally:\n            cmds.undoInfo(closeChunk=True)\n    return wrapper\n\n\n# ==================== 工具函数 ====================\n\ndef get_short_name(obj_name):\n    \"\"\"获取对象的短名称\"\"\"\n    if not obj_name or not isinstance(obj_name, basestring):\n        return obj_name\n    return obj_name.split('|')[-1]\n\n\ndef _normalize_to_transform(node_path):\n    \"\"\"将shape路径标准化为transform路径\"\"\"\n    if not node_path or not isinstance(node_path, basestring) or not cmds.objExists(node_path):\n        return None\n    node_type = cmds.objectType(node_path)\n    if node_type in CURVE_TYPES:  # it's a shape, get its parent transform\n        parents = cmds.listRelatives(node_path, parent=True, fullPath=True) or []\n        return parents[0] if parents else None\n    # if it's already a transform, keep it\n    if node_type == 'transform':\n        return node_path\n    # could be an intermediate, try to get parent transform\n    parents = cmds.listRelatives(node_path, parent=True, fullPath=True) or []\n    return parents[0] if parents else None\n\n\ndef freeze_channels(obj_list):\n    \"\"\"冻结变换\"\"\"\n    if not obj_list:\n        return\n    try:\n        for obj in obj_list:\n            if cmds.objExists(obj):\n                cmds.makeIdentity(obj, apply=True, rotate=True, scale=True, translate=True)\n    except Exception as e:\n        logger.warning(u\"Failed to freeze transforms. Issue: {}\".format(str(e)))\n\n\n# ==================== 拆分曲线功能 ====================\n\ndef separate_curve_shapes_into_transforms(curve_name):\n    \"\"\"拆分曲线形状到独立变换节点\"\"\"\n    function_name = \"Separate Curves\"\n    try:\n        cmds.undoInfo(openChunk=True, chunkName=function_name)\n        nurbs_shapes = []\n        bezier_shapes = []\n        parent_transforms = []\n\n        transform_node = _normalize_to_transform(curve_name)\n        if not transform_node or not cmds.objExists(transform_node):\n            logger.warning('Unable to separate curve shapes. Missing provided curve: \"{0}\".'.format(curve_name))\n            return []\n\n        new_transforms = []\n\n        shapes = cmds.listRelatives(transform_node, shapes=True, fullPath=True) or []\n        for shape in shapes:\n            typ = cmds.objectType(shape)\n            if typ == CURVE_TYPE_BEZIER:\n                bezier_shapes.append(shape)\n            elif typ == CURVE_TYPE_NURBS:\n                nurbs_shapes.append(shape)\n\n        if not nurbs_shapes and not bezier_shapes:  # No valid shapes\n            logger.warning(\"Unable to separate curves. No valid shapes were found under the provided object.\")\n            return []\n\n        if len(shapes) == 1:  # Only one curve in provided object\n            logger.debug(\"Provided curve contains only one shape. Nothing to separate.\")\n            return [transform_node]\n\n        for obj in nurbs_shapes + bezier_shapes:\n            parent = cmds.listRelatives(obj, parent=True, fullPath=True) or []\n            for par in parent:\n                if par not in parent_transforms:\n                    parent_transforms.append(par)\n                cmds.makeIdentity(par, apply=True, rotate=True, scale=True, translate=True)\n            group_name = get_short_name(obj).replace(\"Shape\", \"\")\n            group = cmds.group(empty=True, world=True, name=group_name)\n            cmds.parent(obj, group, relative=True, shape=True)\n            new_transforms.append(group)\n\n        for obj in parent_transforms:\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n            if cmds.objExists(obj) and cmds.objectType(obj) == \"transform\" and len(shapes) == 0:\n                cmds.delete(obj)\n        return new_transforms\n    except Exception as e:\n        logger.warning(\"An error occurred when separating the curve. Issue: {0}\".format(e))\n        return []\n    finally:\n        cmds.undoInfo(closeChunk=True, chunkName=function_name)\n\n\ndef selected_curves_separate():\n    \"\"\"拆分选中的曲线\"\"\"\n    function_name = \"Separate Selected Curves\"\n    try:\n        cmds.undoInfo(openChunk=True, chunkName=function_name)\n        selection = cmds.ls(sl=True, long=True) or []\n\n        if len(selection) < 1:\n            logger.warning(\"You need to select at least one curve.\")\n            return []\n\n        parent_transforms = []\n        for node in selection:\n            transform = _normalize_to_transform(node)\n            if not transform:\n                logger.warning('Unable to separate \"{0}\". Node is invalid.'.format(node))\n                continue\n\n            nurbs_shapes = []\n            bezier_shapes = []\n            shapes = cmds.listRelatives(transform, shapes=True, fullPath=True) or []\n            for shape in shapes:\n                typ = cmds.objectType(shape)\n                if typ == CURVE_TYPE_BEZIER:\n                    bezier_shapes.append(shape)\n                elif typ == CURVE_TYPE_NURBS:\n                    nurbs_shapes.append(shape)\n\n            curve_shapes = nurbs_shapes + bezier_shapes\n            if len(curve_shapes) == 0:\n                logger.warning('Unable to separate \"{0}\". No valid shapes were found under this object.'.format(transform))\n            elif len(curve_shapes) > 1:\n                result = separate_curve_shapes_into_transforms(transform)\n                if result:\n                    parent_transforms.extend(result)\n            else:\n                cmds.warning(\"The selected curve contains only one shape.\")\n\n        if parent_transforms:\n            cmds.select(parent_transforms)\n        sys.stdout.write(\"\\n\" + str(len(parent_transforms)) + \" shapes extracted.\")\n        return parent_transforms\n    except Exception as e:\n        logger.warning(\"An error occurred when separating the curves. Issue: {0}\".format(e))\n        return []\n    finally:\n        cmds.undoInfo(closeChunk=True, chunkName=function_name)\n\n\n# ==================== 结合曲线功能 ====================\n\ndef combine_curves_list(curve_list, convert_bezier_to_nurbs=True):\n    \"\"\"结合曲线列表\"\"\"\n    function_name = \"Combine Curves List\"\n    try:\n        cmds.undoInfo(openChunk=True, chunkName=function_name)\n        nurbs_shapes = []\n        bezier_shapes = []\n        valid_curve_transforms = set()\n\n        for crv in curve_list:\n            shapes = cmds.listRelatives(crv, shapes=True, fullPath=True) or []\n            for shape in shapes:\n                if cmds.objectType(shape) == CURVE_TYPE_BEZIER:\n                    bezier_shapes.append(shape)\n                    valid_curve_transforms.add(crv)\n                if cmds.objectType(shape) == CURVE_TYPE_NURBS:\n                    nurbs_shapes.append(shape)\n                    valid_curve_transforms.add(crv)\n\n        if not nurbs_shapes and not bezier_shapes:  # No valid shapes\n            logger.warning(u\"Unable to combine curves. No valid shapes were found under the provided objects.\")\n            return\n\n        if len(curve_list) == 1:  # Only one curve in provided list\n            return curve_list[0]\n\n        if len(bezier_shapes) > 0 and convert_bezier_to_nurbs:\n            for bezier in bezier_shapes:\n                logger.debug(str(bezier))\n                cmds.select(bezier)\n                cmds.bezierCurveToNurbs()\n\n        freeze_channels(list(valid_curve_transforms))\n        # Re-parent Shapes\n        shapes = nurbs_shapes + bezier_shapes\n        group = cmds.group(empty=True, world=True, name=curve_list[0])\n        cmds.refresh()  # Without a refresh, Maya ignores the freeze operation\n        for shape in shapes:\n            cmds.select(clear=True)\n            cmds.parent(shape, group, relative=True, shape=True)\n        # Delete empty transforms\n        for transform in valid_curve_transforms:\n            children = cmds.listRelatives(transform, children=True) or []\n            if not children and cmds.objExists(transform):\n                cmds.delete(transform)\n        # Clean-up\n        combined_curve = cmds.rename(group, curve_list[0])\n        if cmds.objExists(combined_curve):\n            cmds.select(combined_curve)\n        return combined_curve\n    except Exception as exception:\n        logger.warning(u\"An error occurred when combining the curves. Issue: {}\".format(str(exception)))\n    finally:\n        cmds.undoInfo(closeChunk=True, chunkName=function_name)\n\n\ndef selected_curves_combine(convert_bezier_to_nurbs=False, show_bezier_conversion_dialog=True):\n    \"\"\"结合选中的曲线\"\"\"\n    errors = \"\"\n    function_name = \"Combine Selected Curves\"\n    try:\n        cmds.undoInfo(openChunk=True, chunkName=function_name)\n        selection = cmds.ls(sl=True, absoluteName=True)\n        nurbs_shapes = []\n        bezier_shapes = []\n        valid_curve_transforms = set()\n\n        if len(selection) < 2:\n            logger.warning(u\"You need to select at least two curves.\")\n            return\n\n        for obj in selection:\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n            for shape in shapes:\n                if cmds.objectType(shape) == CURVE_TYPE_BEZIER:\n                    bezier_shapes.append(shape)\n                    valid_curve_transforms.add(obj)\n                if cmds.objectType(shape) == CURVE_TYPE_NURBS:\n                    nurbs_shapes.append(shape)\n                    valid_curve_transforms.add(obj)\n\n        if not nurbs_shapes and not bezier_shapes:  # No valid shapes\n            logger.warning(u\"Unable to combine curves. No valid shapes were found under the provided objects.\")\n            return\n\n        if len(bezier_shapes) > 0:\n            if show_bezier_conversion_dialog and not convert_bezier_to_nurbs:\n                result = cmds.confirmDialog(title=u'Bezier Curves Found',\n                                          message=u'Bezier curves were found. Would you like to convert them to NURBS?',\n                                          button=[u'Yes', u'No'],\n                                          defaultButton=u'Yes',\n                                          cancelButton=u'No',\n                                          dismissString=u'No')\n                if result == u'Yes':\n                    convert_bezier_to_nurbs = True\n\n            if convert_bezier_to_nurbs:\n                for bezier in bezier_shapes:\n                    cmds.select(bezier)\n                    cmds.bezierCurveToNurbs()\n\n        freeze_channels(list(valid_curve_transforms))\n        # Re-parent Shapes\n        shapes = nurbs_shapes + bezier_shapes\n        group = cmds.group(empty=True, world=True, name=selection[0])\n        cmds.refresh()  # Without a refresh, Maya ignores the freeze operation\n        for shape in shapes:\n            cmds.select(clear=True)\n            cmds.parent(shape, group, relative=True, shape=True)\n        # Delete empty transforms\n        for transform in valid_curve_transforms:\n            children = cmds.listRelatives(transform, children=True) or []\n            if not children and cmds.objExists(transform):\n                cmds.delete(transform)\n        # Clean-up\n        combined_curve = cmds.rename(group, selection[0])\n        if cmds.objExists(combined_curve):\n            cmds.select(combined_curve)\n        return combined_curve\n    except Exception as e:\n        errors += str(e) + \"\\n\"\n        cmds.warning(u\"An error occurred when combining the curves. Open the script editor for more information.\")\n    finally:\n        cmds.undoInfo(closeChunk=True, chunkName=function_name)\n    if errors != \"\":\n        print(u\"######## Errors: ########\")\n        print(errors)\n\n\n# ==================== Shape重命名功能 ====================\n\ndef rename_curve_shapes(target_curves):\n    \"\"\"重命名曲线形状\"\"\"\n    renamed_count = 0\n\n    for curve in target_curves:\n        # 检查是否有shape且shape是nurbsCurve\n        shapes = cmds.listRelatives(curve, shapes=True, fullPath=True) or []\n        if not shapes:\n            continue\n\n        for index, shape in enumerate(shapes):\n            if cmds.nodeType(shape) != 'nurbsCurve':\n                continue\n\n            # 生成新名称，支持多shape编号\n            transform_name = curve.split('|')[-1]\n            if len(shapes) == 1:\n                new_shape_name = u\"{}_Shape\".format(transform_name)\n            else:\n                new_shape_name = u\"{}_Shape{}\".format(transform_name, index + 1)\n\n            # 避免重名\n            if cmds.objExists(new_shape_name):\n                cmds.warning(u\"{} 已存在，跳过重命名。\".format(new_shape_name))\n                continue\n\n            cmds.rename(shape, new_shape_name)\n            renamed_count += 1\n            print(u\"{} 重命名为 {}\".format(shape, new_shape_name))\n\n    cmds.inViewMessage(amg=u\"<hl>完成！共重命名 {} 个曲线shape。</hl>\".format(renamed_count), pos='midCenterTop', fade=True)\n\n\ndef auto_rename_all():\n    \"\"\"自动重命名所有曲线\"\"\"\n    # 查找场景内所有带 nurbsCurve 的 transform\n    all_curves = []\n    transforms = cmds.ls(type='transform', long=True) or []\n    for trans in transforms:\n        shapes = cmds.listRelatives(trans, shapes=True, fullPath=True) or []\n        if shapes:\n            for shape in shapes:\n                if cmds.nodeType(shape) == 'nurbsCurve':\n                    all_curves.append(trans)\n                    break\n    if not all_curves:\n        cmds.warning(u'场景中未找到曲线。')\n        return\n    rename_curve_shapes(all_curves)\n\n\ndef rename_selected():\n    \"\"\"重命名选中的曲线\"\"\"\n    selected = cmds.ls(selection=True, long=True) or []\n    if not selected:\n        cmds.warning(u'请先选择需要重命名的曲线。')\n        return\n\n    # 过滤选中的曲线\n    target_curves = []\n    for obj in selected:\n        shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n        if shapes:\n            for shape in shapes:\n                if cmds.nodeType(shape) == 'nurbsCurve':\n                    target_curves.append(obj)\n                    break\n\n    if not target_curves:\n        cmds.warning(u'选择的物体中没有有效的曲线。')\n        return\n\n    rename_curve_shapes(target_curves)\n\n\n# ==================== 添加形状功能 ====================\n\ndef reparent_shape_nodes():\n    \"\"\"重新父级形状节点\"\"\"\n    # 获取当前选择\n    selection = cmds.ls(selection=True, type=\"transform\") or []\n    if len(selection) < 2:\n        cmds.warning(u\"请至少选择两个物体：源物体和目标物体（最后选择的目标）\")\n        return\n\n    # 最后一个物体作为目标父节点\n    target_parent = selection[-1]\n    # 除最后一个外的所有物体作为源节点\n    source_objects = selection[:-1]\n\n    # 记录成功添加的形状节点数量\n    total_shapes_count = 0\n    success_count = 0\n\n    # 遍历源物体，复制它们的形状节点并添加到目标物体\n    for obj in source_objects:\n        shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n        if shapes:\n            try:\n                # 复制整个物体（包含形状节点）\n                duplicated_list = cmds.duplicate(obj, returnRootsOnly=True) or []\n                if not duplicated_list:\n                    cmds.warning(u\"复制物体 '{}' 失败：未返回副本\".format(obj))\n                    continue\n                duplicated_obj = duplicated_list[0]\n                # 获取复制出来的形状节点\n                dup_shapes = cmds.listRelatives(duplicated_obj, shapes=True, fullPath=True) or []\n                if dup_shapes:\n                    # 将复制的形状节点添加到目标物体下\n                    cmds.parent(dup_shapes, target_parent, shape=True, add=True)\n                    total_shapes_count += len(dup_shapes)\n                    success_count += 1\n                    print(u\"已从 {} 复制 {} 个形状节点到 {}\".format(obj, len(dup_shapes), target_parent))\n                # 删除复制出来的变换节点\n                cmds.delete(duplicated_obj)\n            except Exception as e:\n                cmds.warning(u\"复制物体 {} 的形状节点失败: {}\".format(obj, str(e)))\n                print(u\"错误详情: {}\".format(str(e)))\n        else:\n            cmds.warning(u\"物体 {} 下没有找到形状节点\".format(obj))\n\n    # 最终结果\n    if success_count > 0:\n        cmds.select(target_parent)\n        print(u\"操作完成：成功从 {} 个物体复制了 {} 个形状节点到 {}\".format(success_count, total_shapes_count, target_parent))\n    else:\n        cmds.warning(u\"没有成功添加任何形状节点\")\n\n\n# ==================== 物体中心创建曲线功能 ====================\n\ndef get_core():\n    \"\"\"获取选中物体的中心点\"\"\"\n    obj_lis = cmds.ls(sl=1, fl=1)\n\n    pos_lis = []\n    for obj in obj_lis:\n        pos_lis.append(cmds.xform(obj, ws=True, q=True, t=True))\n\n    crv = cmds.curve(d=1, p=pos_lis)\n    clst = cmds.cluster()\n    loc = cmds.spaceLocator()[0]\n    cmds.matchTransform(loc, clst)\n    pos = cmds.xform(loc, ws=1, q=1, t=1)\n    cmds.delete(clst, crv, loc)\n    return pos\n\n\ndef create_center_curve():\n    \"\"\"基于物体中心创建曲线\"\"\"\n    sel_lis = cmds.ls(sl=1, fl=1)\n    if not sel_lis:\n        cmds.warning(u\"请先选择物体！\")\n        return\n    \n    cv_lis = [get_core()]\n    cmds.select(sel_lis)\n    while True:\n        mel.eval('PolySelectTraverse 1;')\n        sel = cmds.ls(sl=1, fl=1)\n        obj = set(sel)-set(sel_lis)\n        obj = list(obj)\n        if obj:\n            cmds.select(obj)\n            cv_lis.append(get_core())\n            cmds.select(sel)\n            sel_lis = sel\n        else:\n            break\n\n    result_curve = cmds.curve(p=cv_lis)\n    print(u\"基于物体中心创建曲线: {}\".format(result_curve))\n    return result_curve\n\n\n# ==================== 镜像曲线形状功能 ====================\n\ndef mirror_curve_shape():\n    \"\"\"镜像曲线形状\"\"\"\n    # 打开撤销块\n    cmds.undoInfo(openChunk=True)\n    try:\n        # 获取选择的两个曲线对象\n        selection = cmds.ls(sl=True)\n        if len(selection) != 2:\n            cmds.warning(u'请选择两根需要镜像的曲线.')\n            return\n        \n        con, con_dist = selection\n    except ValueError:\n        cmds.warning(u'请选择两根需要镜像的曲线.')\n        return\n    finally:\n        # 如果发生异常，确保关闭撤销块\n        cmds.undoInfo(closeChunk=True)\n\n    # 打开新的撤销块以包含后续操作\n    cmds.undoInfo(openChunk=True)\n    try:\n        # 检查两曲线的控制点数量是否一致\n        if not cmds.getAttr(con + '.controlPoints', size=True) == cmds.getAttr(con_dist + '.controlPoints', size=True):\n            cmds.warning(u'所选控制器CV点的数量不相同.')\n            return\n\n        # 遍历控制点并进行镜像\n        for i in range(cmds.getAttr(con + '.controlPoints', size=True)):\n            # 获取源曲线控制点的位置\n            P = cmds.pointPosition(con + '.controlPoints[%s]' % i)\n            # 将目标曲线的控制点沿 X 轴镜像（X 取反，Y 和 Z 不变）\n            cmds.xform(con_dist + '.controlPoints[%s]' % i, t=(-1 * P[0], P[1], P[2]), ws=True)\n\n        print(u\"曲线形状已成功沿 X 轴镜像.\")\n    except Exception as e:\n        cmds.warning(u\"镜像曲线形状失败: %s\" % str(e))\n        raise  # 抛出异常以便调试\n    finally:\n        # 关闭撤销块\n        cmds.undoInfo(closeChunk=True)\n\n\n# ==================== 替换曲线形状功能 ====================\n\ndef replace_curve_shape():\n    \"\"\"替换曲线形状\"\"\"\n    selection = cmds.ls(sl=True)\n    \n    # 检查选择数量\n    if len(selection) != 2:\n        cmds.warning(u\"请先选择源曲线，再选择目标曲线（共2个对象）\")\n        return\n    \n    source_curve = selection[0]  # 源曲线（提供形状）\n    target_curve = selection[1]  # 目标曲线（形状被替换）\n    \n    print(u\"源曲线: {}\".format(source_curve))\n    print(u\"目标曲线: {}\".format(target_curve))\n    \n    try:\n        # 复制源曲线\n        cmds.select(source_curve, r=True)\n        temp_curve_list = cmds.duplicate(rr=True) or []\n        if not temp_curve_list:\n            cmds.warning(u\"复制源曲线失败\")\n            return\n        \n        temp_curve = temp_curve_list[0]\n        temp_curve = cmds.rename(temp_curve, target_curve + \"temp\")\n        \n        # 清理临时曲线的多余子节点\n        for i in range(12):\n            children = cmds.listRelatives(temp_curve, children=True) or []\n            if len(children) > 1:\n                cmds.select(temp_curve, r=True)\n                # 选择第一个子节点\n                if children:\n                    cmds.select(children[0], r=True)\n                    if cmds.objectType(children[0]) != \"nurbsCurve\":\n                        cmds.delete()\n        \n        # 重命名临时曲线的形状节点\n        children = cmds.listRelatives(temp_curve, children=True, fullPath=True) or []\n        if children:\n            cmds.select(children[0], r=True)\n            cmds.rename(children[0], target_curve + \"tempShape\")\n        \n        # 解锁临时曲线的变换属性\n        attrs = [\".tx\", \".ty\", \".tz\", \".rx\", \".ry\", \".rz\", \".sx\", \".sy\", \".sz\"]\n        for attr in attrs:\n            try:\n                cmds.setAttr(temp_curve + attr, lock=False)\n            except:\n                pass\n        \n        cmds.select(temp_curve, r=True)\n        shapes = cmds.listRelatives(temp_curve, shapes=True) or []\n        \n        # 如果临时曲线有父节点，移动到世界空间\n        parents = cmds.listRelatives(temp_curve, parent=True) or []\n        if parents:\n            cmds.select(temp_curve, r=True)\n            cmds.parent(world=True)\n        \n        # 创建临时组并对齐\n        cmds.select(clear=True)\n        temp_group = cmds.group(empty=True, name=target_curve + \"tempGrp\")\n        cmds.xform(temp_group, os=True, piv=[0, 0, 0])\n        \n        # 对齐临时组到目标曲线\n        cmds.select(temp_group, r=True)\n        cmds.select(temp_curve, add=True)\n        constraint = cmds.pointConstraint()\n        if constraint:\n            cmds.delete(constraint)\n        \n        # 获取目标曲线原始形状节点\n        old_shapes = cmds.listRelatives(target_curve, shapes=True) or []\n        \n        # 保持连接\n        for i, shape in enumerate(shapes):\n            if i < len(old_shapes):\n                # 保持可见性连接\n                try:\n                    input_v = cmds.listConnections(old_shapes[i] + \".v\", source=True, destination=False, plugs=True, skipConversionNodes=True) or []\n                    input_lodv = cmds.listConnections(old_shapes[i] + \".lodVisibility\", source=True, destination=False, plugs=True, skipConversionNodes=True) or []\n                    \n                    if input_v:\n                        cmds.connectAttr(input_v[0], shape + \".v\", force=True)\n                    if input_lodv:\n                        cmds.connectAttr(input_lodv[0], shape + \".lodVisibility\", force=True)\n                except:\n                    pass\n        \n        # 删除原始形状节点\n        if old_shapes:\n            cmds.select(old_shapes, r=True)\n            cmds.delete()\n        \n        # 将新形状节点父级到目标曲线\n        shapes = cmds.listRelatives(temp_curve, shapes=True) or []\n        for shape in shapes:\n            cmds.select(shape, r=True)\n            cmds.select(target_curve, add=True)\n            cmds.parent(relative=True, shape=True)\n        \n        # 清理临时对象\n        cmds.select(temp_group, r=True)\n        cmds.select(temp_curve, add=True)\n        cmds.delete()\n        \n        # 重命名新形状节点\n        new_shapes = cmds.listRelatives(target_curve, shapes=True) or []\n        for i, shape in enumerate(new_shapes):\n            cmds.select(shape, r=True)\n            cmds.rename(shape, target_curve + \"shape\" + str(i))\n        \n        print(u\"形状替换完成！\")\n        cmds.select(target_curve, r=True)\n        \n    except Exception as e:\n        cmds.warning(u\"替换曲线形状失败: {}\".format(str(e)))\n        print(u\"错误详情: {}\".format(str(e)))\n\n\n# ==================== 随机颜色功能 ====================\n\ndef get_object_type(obj):\n    \"\"\"获取物体类型\"\"\"\n    shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n    if not shapes:\n        # 可能是定位器或其他变换节点\n        node_type = cmds.nodeType(obj)\n        if node_type == 'locator':\n            return 'locator'\n        return 'transform'\n    \n    shape_type = cmds.nodeType(shapes[0])\n    if shape_type in ['mesh']:\n        return 'mesh'\n    elif shape_type in ['nurbsCurve']:\n        return 'curve'\n    elif shape_type in ['nurbsSurface']:\n        return 'surface'\n    elif shape_type in ['locator']:\n        return 'locator'\n    else:\n        return 'other'\n\n\ndef assign_random_colors():\n    \"\"\"为选中的物体赋予随机颜色材质，支持网格、曲线、曲面、定位器等多种类型\"\"\"\n    # 获取当前选中的物体\n    selected_objects = cmds.ls(selection=True)\n    \n    if not selected_objects:\n        print(u\"请先选择物体\")\n        return\n    \n    processed_count = 0\n    \n    for obj in selected_objects:\n        obj_type = get_object_type(obj)\n        \n        # 生成随机色相值\n        hue_random = random.random()\n        # 将HSV转换为RGB (饱和度0.8，明度0.9)\n        rgb_color = colorsys.hsv_to_rgb(hue_random, 0.8, 0.9)\n        \n        if obj_type == 'mesh':\n            # 网格物体使用Lambert材质\n            shader_name = cmds.shadingNode('lambert', asShader=True)\n            cmds.setAttr(shader_name + \".color\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n            \n            # 创建着色组\n            shading_group = cmds.sets(renderable=True, noSurfaceShader=True, empty=True, name=shader_name + \"SG\")\n            cmds.connectAttr(shader_name + \".outColor\", shading_group + \".surfaceShader\", force=True)\n            cmds.sets(obj, edit=True, forceElement=shading_group)\n            processed_count += 1\n            \n        elif obj_type == 'curve':\n            # 曲线物体直接设置颜色覆盖\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n            if shapes:\n                cmds.setAttr(shapes[0] + \".overrideEnabled\", 1)\n                cmds.setAttr(shapes[0] + \".overrideRGBColors\", 1)\n                cmds.setAttr(shapes[0] + \".overrideColorRGB\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n                processed_count += 1\n                \n        elif obj_type == 'surface':\n            # NURBS曲面使用Lambert材质\n            shader_name = cmds.shadingNode('lambert', asShader=True)\n            cmds.setAttr(shader_name + \".color\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n            \n            # 创建着色组\n            shading_group = cmds.sets(renderable=True, noSurfaceShader=True, empty=True, name=shader_name + \"SG\")\n            cmds.connectAttr(shader_name + \".outColor\", shading_group + \".surfaceShader\", force=True)\n            cmds.sets(obj, edit=True, forceElement=shading_group)\n            processed_count += 1\n            \n        elif obj_type == 'locator':\n            # 定位器设置颜色覆盖\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n            if shapes:\n                cmds.setAttr(shapes[0] + \".overrideEnabled\", 1)\n                cmds.setAttr(shapes[0] + \".overrideRGBColors\", 1)\n                cmds.setAttr(shapes[0] + \".overrideColorRGB\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n                processed_count += 1\n            else:\n                # 如果是变换节点本身是定位器\n                if cmds.nodeType(obj) == 'locator':\n                    cmds.setAttr(obj + \".overrideEnabled\", 1)\n                    cmds.setAttr(obj + \".overrideRGBColors\", 1)\n                    cmds.setAttr(obj + \".overrideColorRGB\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n                    processed_count += 1\n                    \n        else:\n            # 其他类型物体尝试设置颜色覆盖\n            try:\n                shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n                if shapes:\n                    cmds.setAttr(shapes[0] + \".overrideEnabled\", 1)\n                    cmds.setAttr(shapes[0] + \".overrideRGBColors\", 1)\n                    cmds.setAttr(shapes[0] + \".overrideColorRGB\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n                    processed_count += 1\n                else:\n                    print(u\"跳过不支持的物体类型: {0} ({1})\".format(obj, obj_type))\n            except:\n                print(u\"无法为物体设置颜色: {0}\".format(obj))\n    \n    # 清除选择\n    cmds.select(clear=True)\n    print(u\"已为 {0} 个物体赋予随机颜色\".format(processed_count))\n\n\n# ==================== 渐变颜色功能 ====================\n\ndef create_ramp_node():\n    \"\"\"创建或获取渐变节点\"\"\"\n    ramp_name = 'TEMPNODE_remapValue'\n    if not cmds.objExists(ramp_name):\n        cmds.createNode('remapValue', n=ramp_name)\n        cmds.setAttr(ramp_name + '.color[0].color_Position', 0.0)\n        cmds.setAttr(ramp_name + '.color[0].color_FloatValue', 1.0, 0.0, 0.0, type='double3')  # 红\n        cmds.setAttr(ramp_name + '.color[1].color_Position', 1.0)\n        cmds.setAttr(ramp_name + '.color[1].color_FloatValue', 0.0, 0.0, 1.0, type='double3')  # 蓝\n    return ramp_name\n\n\ndef open_ramp_editor():\n    \"\"\"打开渐变编辑器\"\"\"\n    try:\n        ramp_name = create_ramp_node()\n        mel.eval('editRampAttribute \"{}\"'.format(ramp_name + '.color'))\n        print(u'已打开渐变编辑器，请设置颜色')\n    except Exception as e:\n        print(u'打开编辑器失败：{}'.format(str(e)))\n\n\ndef apply_gradient_color():\n    \"\"\"应用渐变颜色\"\"\"\n    try:\n        sel = cmds.ls(sl=True)\n        if not sel:\n            print(u'请先选择物体再进行操作')\n            return\n\n        sel_size = len(sel)\n        if sel_size < 2:\n            print(u'请选择至少 2 个物体以获得渐变效果')\n            return\n\n        ramp_name = create_ramp_node()\n\n        for i, obj in enumerate(sel):\n            if sel_size == 1:\n                par_value = 0.5\n            else:\n                par_value = float(i) / float(sel_size - 1)\n\n            cmds.setAttr(ramp_name + '.inputValue', par_value)\n            rgb_value = cmds.getAttr(ramp_name + '.outColor')[0]\n            set_object_color(obj, rgb_value)\n\n        print(u'已为 {} 个物体应用渐变颜色'.format(sel_size))\n\n    except Exception as e:\n        print(u'应用颜色失败：{}'.format(str(e)))\n\n\ndef set_object_color(obj, rgb_color):\n    \"\"\"设置物体颜色\"\"\"\n    try:\n        # 默认设置Shape节点颜色\n        shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n        if shapes:\n            for shape in shapes:\n                cmds.setAttr(shape + '.overrideEnabled', True)\n                cmds.setAttr(shape + '.overrideRGBColors', True)\n                cmds.setAttr(shape + '.overrideColorRGB', rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n    except Exception as e:\n        print(u'设置物体 {} 颜色失败：{}'.format(obj, str(e)))\n\n\ndef reset_colors():\n    \"\"\"重置颜色\"\"\"\n    try:\n        sel = cmds.ls(sl=True)\n        if not sel:\n            print(u'请先选择要重置的物体')\n            return\n\n        for obj in sel:\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n            if shapes:\n                for shape in shapes:\n                    # 先将RGB模式改为索引模式\n                    cmds.setAttr(shape + '.overrideRGBColors', False)\n                    # 然后关闭启用覆盖\n                    cmds.setAttr(shape + '.overrideEnabled', False)\n            else:\n                # 如果没有形状节点，尝试直接在变换节点上设置\n                try:\n                    # 先将RGB模式改为索引模式\n                    cmds.setAttr(obj + '.overrideRGBColors', False)\n                    # 然后关闭启用覆盖\n                    cmds.setAttr(obj + '.overrideEnabled', False)\n                except:\n                    pass\n\n        print(u'已成功重置 {} 个物体的颜色'.format(len(sel)))\n\n    except Exception as e:\n        print(u'重置颜色失败：{}'.format(str(e)))\n\n\n# ==================== 曲线宽度功能 ====================\n\ndef increase_curve_width():\n    \"\"\"增加曲线宽度\"\"\"\n    selected = cmds.ls(selection=True)  # 获取选中的对象（可能是Transform节点）\n    if not selected:\n        cmds.warning(u\"请先选择曲线！\")\n        return\n    \n    shapes = cmds.listRelatives(selected, shapes=True) or []  # 获取Shape节点\n    curves = [s for s in shapes if cmds.objectType(s, isType='nurbsCurve')]\n    \n    if not curves:\n        cmds.warning(u\"选中的对象不是NURBS曲线！\")\n        return\n    \n    for curve in curves:\n        current_width = cmds.getAttr(curve + '.lineWidth')\n        new_width = current_width + 1\n        cmds.setAttr(curve + '.lineWidth', new_width)\n        print(u\"曲线 {} 的宽度已增加到: {}\".format(curve, new_width))\n\n\ndef decrease_curve_width():\n    \"\"\"减小曲线宽度\"\"\"\n    selected = cmds.ls(selection=True)  # 获取选中的对象（可能是Transform节点）\n    if not selected:\n        cmds.warning(u\"请先选择曲线！\")\n        return\n    \n    shapes = cmds.listRelatives(selected, shapes=True) or []  # 获取Shape节点\n    curves = [s for s in shapes if cmds.objectType(s, isType='nurbsCurve')]\n    \n    if not curves:\n        cmds.warning(u\"选中的对象不是NURBS曲线！\")\n        return\n    \n    for curve in curves:\n        current_width = cmds.getAttr(curve + '.lineWidth')\n        new_width = max(1, current_width - 1)  # 确保宽度不小于1\n        cmds.setAttr(curve + '.lineWidth', new_width)\n        print(u\"曲线 {} 的宽度已减小到: {}\".format(curve, new_width))\n\n\n# ==================== 主UI类 ====================\n\nclass CurveToolsIntegrated(QMainWindow):\n    \"\"\"曲线工具整合主窗口\"\"\"\n    \n    _instance = None\n\n    @classmethod\n    def get_instance(cls):\n        \"\"\"获取单例实例\"\"\"\n        if cls._instance is None:\n            cls._instance = CurveToolsIntegrated()\n        return cls._instance\n\n    def __init__(self):\n        super(CurveToolsIntegrated, self).__init__(parent=get_maya_main_window())\n        self.setWindowTitle(u\"曲线工具整合\")\n        self.setObjectName(\"CurveToolsIntegratedWindow\")\n        self.resize(350, 600)\n        \n        # 设置窗口标志\n        self.setWindowFlags(Qt.Window)\n        \n        # 初始化UI\n        self.init_ui()\n        \n        # 设置样式\n        self.setStyleSheet(\"\"\"\n            QMainWindow {\n                background-color: #3a3a3a;\n                color: #ffffff;\n            }\n            QLabel {\n                color: #ffffff;\n                font-size: 16px;\n            }\n            QPushButton {\n                background-color: #5a5a5a;\n                color: #ffffff;\n                border: 1px solid #7a7a7a;\n                border-radius: 3px;\n                padding: 8px;\n                font-size: 16px;\n                min-height: 20px;\n            }\n            QPushButton:hover {\n                background-color: #6a6a6a;\n            }\n            QPushButton:pressed {\n                background-color: #4a4a4a;\n            }\n            QDoubleSpinBox {\n                background-color: #5a5a5a;\n                color: #ffffff;\n                border: 1px solid #7a7a7a;\n                border-radius: 3px;\n                padding: 3px;\n                font-size: 16px;\n            }\n            QGroupBox {\n                color: #ffffff;\n                border: 2px solid #7a7a7a;\n                border-radius: 5px;\n                margin-top: 10px;\n                font-weight: bold;\n            }\n            QGroupBox::title {\n                subcontrol-origin: margin;\n                left: 10px;\n                padding: 0 5px 0 5px;\n            }\n        \"\"\")\n\n    def init_ui(self):\n        \"\"\"初始化用户界面\"\"\"\n        central_widget = QWidget()\n        self.setCentralWidget(central_widget)\n        \n        # 主布局\n        main_layout = QVBoxLayout(central_widget)\n        main_layout.setSpacing(15)\n        main_layout.setContentsMargins(15, 15, 15, 15)\n        \n        # 标题\n        title_label = QLabel(u\"曲线工具整合\")\n        title_label.setAlignment(Qt.AlignCenter)\n        title_label.setStyleSheet(\"font-size: 18px; font-weight: bold; margin-bottom: 10px;\")\n        main_layout.addWidget(title_label)\n        \n        # 曲线操作组\n        curve_ops_group = QGroupBox(u\"曲线操作\")\n        curve_ops_layout = QVBoxLayout(curve_ops_group)\n        curve_ops_layout.setSpacing(8)\n        \n        # 拆分和结合按钮\n        split_combine_layout = QHBoxLayout()\n        \n        split_btn = QPushButton(u\"拆分曲线\")\n        split_btn.setToolTip(u\"将多形状曲线拆分为单独的变换节点\")\n        split_btn.clicked.connect(self.split_curves)\n        split_combine_layout.addWidget(split_btn)\n        \n        combine_btn = QPushButton(u\"结合曲线\")\n        combine_btn.setToolTip(u\"将多个曲线合并为一个曲线\")\n        combine_btn.clicked.connect(self.combine_curves)\n        split_combine_layout.addWidget(combine_btn)\n        \n        curve_ops_layout.addLayout(split_combine_layout)\n        \n        # 添加形状和镜像按钮\n        shape_mirror_layout = QHBoxLayout()\n        \n        add_shape_btn = QPushButton(u\"添加形状\")\n        add_shape_btn.setToolTip(u\"将形状节点添加到目标物体\")\n        add_shape_btn.clicked.connect(self.add_shapes)\n        shape_mirror_layout.addWidget(add_shape_btn)\n        \n        mirror_btn = QPushButton(u\"镜像形状\")\n        mirror_btn.setToolTip(u\"沿X轴镜像曲线形状\")\n        mirror_btn.clicked.connect(self.mirror_shapes)\n        shape_mirror_layout.addWidget(mirror_btn)\n        \n        curve_ops_layout.addLayout(shape_mirror_layout)\n        \n        # 替换曲线形状按钮\n        replace_shape_btn = QPushButton(u\"替换曲线形状\")\n        replace_shape_btn.setToolTip(u\"用源曲线的形状替换目标曲线的形状\")\n        replace_shape_btn.clicked.connect(self.replace_curve_shape)\n        curve_ops_layout.addWidget(replace_shape_btn)\n        \n        # 创建曲线按钮\n        create_curve_btn = QPushButton(u\"物体中心创建曲线\")\n        create_curve_btn.setToolTip(u\"基于选择物体中心创建曲线\")\n        create_curve_btn.clicked.connect(self.create_center_curve)\n        curve_ops_layout.addWidget(create_curve_btn)\n        \n        main_layout.addWidget(curve_ops_group)\n        \n        # 曲线调整组\n        curve_adjust_group = QGroupBox(u\"曲线调整\")\n        curve_adjust_layout = QVBoxLayout(curve_adjust_group)\n        curve_adjust_layout.setSpacing(8)\n        \n        # 缩放倍率设置\n        scale_layout = QHBoxLayout()\n        scale_label = QLabel(u\"缩放倍率:\")\n        scale_layout.addWidget(scale_label)\n        \n        self.scale_factor_input = QDoubleSpinBox()\n        self.scale_factor_input.setRange(0.01, 100.0)\n        self.scale_factor_input.setValue(1.1)\n        self.scale_factor_input.setSingleStep(0.1)\n        self.scale_factor_input.setDecimals(2)\n        self.scale_factor_input.setToolTip(u\"设置每次缩放的倍率\")\n        scale_layout.addWidget(self.scale_factor_input)\n        \n        curve_adjust_layout.addLayout(scale_layout)\n        \n        # 大小调整按钮\n        size_layout = QHBoxLayout()\n        \n        scale_up_btn = QPushButton(u\"变大\")\n        scale_up_btn.setToolTip(u\"按设定倍率放大选中控制器的控制顶点\")\n        scale_up_btn.clicked.connect(self.scale_cv_handles_up)\n        size_layout.addWidget(scale_up_btn)\n        \n        scale_down_btn = QPushButton(u\"变小\")\n        scale_down_btn.setToolTip(u\"按设定倍率缩小选中控制器的控制顶点\")\n        scale_down_btn.clicked.connect(self.scale_cv_handles_down)\n        size_layout.addWidget(scale_down_btn)\n        \n        curve_adjust_layout.addLayout(size_layout)\n        \n        # 宽度调整按钮\n        width_layout = QHBoxLayout()\n        \n        width_up_btn = QPushButton(u\"增加宽度\")\n        width_up_btn.setToolTip(u\"增加曲线显示宽度\")\n        width_up_btn.clicked.connect(self.increase_curve_width)\n        width_layout.addWidget(width_up_btn)\n        \n        width_down_btn = QPushButton(u\"减小宽度\")\n        width_down_btn.setToolTip(u\"减小曲线显示宽度\")\n        width_down_btn.clicked.connect(self.decrease_curve_width)\n        width_layout.addWidget(width_down_btn)\n        \n        curve_adjust_layout.addLayout(width_layout)\n        \n        main_layout.addWidget(curve_adjust_group)\n        \n        # Shape重命名组\n        rename_group = QGroupBox(u\"Shape重命名\")\n        rename_layout = QVBoxLayout(rename_group)\n        rename_layout.setSpacing(8)\n        \n        # 重命名按钮\n        rename_layout_btns = QHBoxLayout()\n        \n        rename_selected_btn = QPushButton(u\"重命名选中\")\n        rename_selected_btn.setToolTip(u\"重命名选中曲线的形状节点\")\n        rename_selected_btn.clicked.connect(self.rename_selected_shapes)\n        rename_layout_btns.addWidget(rename_selected_btn)\n        \n        rename_all_btn = QPushButton(u\"重命名全部\")\n        rename_all_btn.setToolTip(u\"重命名场景中所有曲线的形状节点\")\n        rename_all_btn.clicked.connect(self.rename_all_shapes)\n        rename_layout_btns.addWidget(rename_all_btn)\n        \n        rename_layout.addLayout(rename_layout_btns)\n        \n        main_layout.addWidget(rename_group)\n        \n        # 说明文字\n        info_label = QLabel(u\"请选择相应的曲线对象后使用对应工具\")\n        info_label.setAlignment(Qt.AlignCenter)\n        info_label.setStyleSheet(\"font-size: 15px; color: #cccccc; margin-top: 10px;\")\n        main_layout.addWidget(info_label)\n        \n        # 颜色工具组\n        color_group = QGroupBox(u\"颜色工具\")\n        color_layout = QVBoxLayout(color_group)\n        color_layout.setSpacing(8)\n        \n        # 随机颜色和重置颜色按钮\n        color_layout_btns = QHBoxLayout()\n        \n        random_color_btn = QPushButton(u\"随机颜色\")\n        random_color_btn.setToolTip(u\"为选中物体赋予随机颜色\")\n        random_color_btn.clicked.connect(self.assign_random_colors)\n        color_layout_btns.addWidget(random_color_btn)\n        \n        reset_color_btn = QPushButton(u\"重置颜色\")\n        reset_color_btn.setToolTip(u\"重置选中物体的颜色\")\n        reset_color_btn.clicked.connect(self.reset_colors)\n        color_layout_btns.addWidget(reset_color_btn)\n        \n        color_layout.addLayout(color_layout_btns)\n        \n        # 渐变颜色按钮\n        gradient_layout = QHBoxLayout()\n        \n        open_ramp_btn = QPushButton(u\"打开渐变编辑器\")\n        open_ramp_btn.setToolTip(u\"打开渐变颜色编辑器\")\n        open_ramp_btn.clicked.connect(self.open_ramp_editor)\n        gradient_layout.addWidget(open_ramp_btn)\n        \n        apply_gradient_btn = QPushButton(u\"应用渐变\")\n        apply_gradient_btn.setToolTip(u\"为选中物体应用渐变颜色\")\n        apply_gradient_btn.clicked.connect(self.apply_gradient_color)\n        gradient_layout.addWidget(apply_gradient_btn)\n        \n        color_layout.addLayout(gradient_layout)\n        \n        # 颜色选择器按钮\n        color_picker_btn = QPushButton(u\"颜色选择器\")\n        color_picker_btn.setToolTip(u\"打开颜色选择器窗口\")\n        color_picker_btn.clicked.connect(self.open_color_picker)\n        color_layout.addWidget(color_picker_btn)\n        \n        main_layout.addWidget(color_group)\n        \n        # 添加弹性空间\n        main_layout.addStretch()\n\n    # ==================== 按钮响应函数 ====================\n    \n    @with_undo_support\n    def split_curves(self):\n        \"\"\"拆分曲线\"\"\"\n        try:\n            result = selected_curves_separate()\n            if result:\n                print(u\"成功拆分 {} 个曲线形状\".format(len(result)))\n            else:\n                print(u\"拆分操作未执行或无需拆分\")\n        except Exception as e:\n            cmds.warning(u\"拆分曲线失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def combine_curves(self):\n        \"\"\"结合曲线\"\"\"\n        try:\n            result = selected_curves_combine()\n            if result:\n                print(u\"成功结合曲线: {}\".format(result))\n        except Exception as e:\n            cmds.warning(u\"结合曲线失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def add_shapes(self):\n        \"\"\"添加形状\"\"\"\n        try:\n            reparent_shape_nodes()\n        except Exception as e:\n            cmds.warning(u\"添加形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def mirror_shapes(self):\n        \"\"\"镜像形状\"\"\"\n        try:\n            mirror_curve_shape()\n        except Exception as e:\n            cmds.warning(u\"镜像形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def create_center_curve(self):\n        \"\"\"创建中心曲线\"\"\"\n        try:\n            result = create_center_curve()\n            if result:\n                print(u\"成功创建中心曲线: {}\".format(result))\n        except Exception as e:\n            cmds.warning(u\"创建中心曲线失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def scale_cv_handles_up(self):\n        \"\"\"放大控制器的控制顶点\"\"\"\n        selected_controllers = cmds.ls(selection=True, type=\"transform\")\n        if not selected_controllers:\n            cmds.warning(u\"请至少选择一个控制器！\")\n            return\n\n        scale_factor = self.scale_factor_input.value()\n        for ctrl in selected_controllers:\n            shapes = cmds.listRelatives(ctrl, shapes=True, type=\"nurbsCurve\") or []\n            if shapes:\n                cvs = cmds.ls(\"{}.cv[*]\".format(ctrl), flatten=True)\n                if cvs:\n                    pivot = cmds.xform(ctrl, query=True, worldSpace=True, rotatePivot=True)\n                    for cv in cvs:\n                        pos = cmds.pointPosition(cv, world=True)\n                        vector = [pos[i] - pivot[i] for i in range(3)]\n                        scaled_vector = [v * scale_factor for v in vector]\n                        new_pos = [pivot[i] + scaled_vector[i] for i in range(3)]\n                        cmds.xform(cv, worldSpace=True, translation=new_pos)\n                print(u\"已将控制器 '{}' 的控制顶点按倍率 {} 放大\".format(ctrl, scale_factor))\n            else:\n                print(u\"警告: '{}' 不是NURBS曲线控制器，跳过处理\".format(ctrl))\n\n    @with_undo_support\n    def scale_cv_handles_down(self):\n        \"\"\"缩小控制器的控制顶点\"\"\"\n        selected_controllers = cmds.ls(selection=True, type=\"transform\")\n        if not selected_controllers:\n            cmds.warning(u\"请至少选择一个控制器！\")\n            return\n\n        scale_factor = 1.0 / self.scale_factor_input.value()\n        for ctrl in selected_controllers:\n            shapes = cmds.listRelatives(ctrl, shapes=True, type=\"nurbsCurve\") or []\n            if shapes:\n                cvs = cmds.ls(\"{}.cv[*]\".format(ctrl), flatten=True)\n                if cvs:\n                    pivot = cmds.xform(ctrl, query=True, worldSpace=True, rotatePivot=True)\n                    for cv in cvs:\n                        pos = cmds.pointPosition(cv, world=True)\n                        vector = [pos[i] - pivot[i] for i in range(3)]\n                        scaled_vector = [v * scale_factor for v in vector]\n                        new_pos = [pivot[i] + scaled_vector[i] for i in range(3)]\n                        cmds.xform(cv, worldSpace=True, translation=new_pos)\n                print(u\"已将控制器 '{}' 的控制顶点按倍率 {} 缩小\".format(ctrl, 1.0 / scale_factor))\n            else:\n                print(u\"警告: '{}' 不是NURBS曲线控制器，跳过处理\".format(ctrl))\n\n    @with_undo_support\n    def increase_curve_width(self):\n        \"\"\"增加曲线宽度\"\"\"\n        try:\n            increase_curve_width()\n        except Exception as e:\n            cmds.warning(u\"增加曲线宽度失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def decrease_curve_width(self):\n        \"\"\"减小曲线宽度\"\"\"\n        try:\n            decrease_curve_width()\n        except Exception as e:\n            cmds.warning(u\"减小曲线宽度失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def rename_selected_shapes(self):\n        \"\"\"重命名选中的形状\"\"\"\n        try:\n            rename_selected()\n        except Exception as e:\n            cmds.warning(u\"重命名选中形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def rename_all_shapes(self):\n        \"\"\"重命名所有形状\"\"\"\n        try:\n            auto_rename_all()\n        except Exception as e:\n            cmds.warning(u\"重命名所有形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def replace_curve_shape(self):\n        \"\"\"替换曲线形状\"\"\"\n        try:\n            replace_curve_shape()\n        except Exception as e:\n            cmds.warning(u\"替换曲线形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def assign_random_colors(self):\n        \"\"\"赋予随机颜色\"\"\"\n        try:\n            assign_random_colors()\n        except Exception as e:\n            cmds.warning(u\"赋予随机颜色失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def reset_colors(self):\n        \"\"\"重置颜色\"\"\"\n        try:\n            reset_colors()\n        except Exception as e:\n            cmds.warning(u\"重置颜色失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def open_ramp_editor(self):\n        \"\"\"打开渐变编辑器\"\"\"\n        try:\n            open_ramp_editor()\n        except Exception as e:\n            cmds.warning(u\"打开渐变编辑器失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def apply_gradient_color(self):\n        \"\"\"应用渐变颜色\"\"\"\n        try:\n            apply_gradient_color()\n        except Exception as e:\n            cmds.warning(u\"应用渐变颜色失败: {}\".format(str(e)))\n    \n    @with_undo_support\n    def open_color_picker(self):\n        \"\"\"打开颜色选择器\"\"\"\n        try:\n            self.create_color_picker_window()\n        except Exception as e:\n            cmds.warning(u\"打开颜色选择器失败: {}\".format(str(e)))\n    \n    def create_color_picker_window(self):\n        \"\"\"创建颜色选择器窗口\"\"\"\n        # 如果窗口已存在，删除它\n        if cmds.window('colorChangeWin', exists=True):\n            cmds.deleteUI('colorChangeWin')\n        \n        # 创建窗口\n        window = cmds.window('colorChangeWin', title=u'颜色选择器', widthHeight=(214, 134))\n        \n        # 创建网格布局，8列4行\n        grid_layout = cmds.gridLayout(numberOfColumns=8, cellWidthHeight=(24, 24))\n        \n        # 定义颜色数组\n        colors = [\n            # 第一行\n            (0.5, 0.5, 0.5), (0, 0, 0), (0.247, 0.247, 0.247), (0.498, 0.498, 0.498),\n            (0.608, 0, 0.157), (0, 0.16, 0.376), (0, 0, 1), (0, 0.275, 0.094),\n            # 第二行\n            (0.149, 0, 0.263), (0.78, 0, 0.78), (0.537, 0.278, 0.2), (0.243, 0.133, 0.121),\n            (0.6, 0.145, 0), (1, 0, 0), (0, 1, 0), (0, 0.2549, 0.6),\n            # 第三行\n            (1, 1, 1), (1, 1, 0), (0.388, 0.863, 1), (0.263, 1, 0.639),\n            (1, 0.686, 0.686), (0.89, 0.674, 0.474), (1, 1, 0.388), (0, 0.6, 0.329),\n            # 第四行\n            (0.627, 0.411, 0.188), (0.619, 0.627, 0.188), (0.408, 0.631, 0.188), (0.188, 0.631, 0.365),\n            (0.188, 0.627, 0.627), (0.188, 0.403, 0.627), (0.434, 0.188, 0.627), (0.627, 0.188, 0.411)\n        ]\n        \n        # 创建按钮\n        for i, color in enumerate(colors):\n            cmds.button(\n                label='',\n                width=20,\n                height=20,\n                backgroundColor=color,\n                command=lambda x, color_index=i: self.change_object_color(color_index)\n            )\n        \n        # 显示窗口\n        cmds.showWindow(window)\n    \n    def change_object_color(self, color_index):\n        \"\"\"改变选中物体的颜色\"\"\"\n        # 获取选中的物体\n        selected_objects = cmds.ls(selection=True)\n        \n        if not selected_objects:\n            print(u\"请先选择物体\")\n            return\n        \n        for obj in selected_objects:\n            node_type = cmds.nodeType(obj)\n            \n            if node_type == 'joint':\n                # 骨骼节点直接设置颜色覆盖\n                cmds.setAttr(\"{}.overrideEnabled\".format(obj), 1)\n                cmds.setAttr(\"{}.overrideColor\".format(obj), color_index)\n            else:\n                # 其他物体类型，获取形状节点\n                shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n                if shapes:\n                    for shape in shapes:\n                        cmds.setAttr(\"{}.overrideEnabled\".format(shape), 1)\n                        cmds.setAttr(\"{}.overrideColor\".format(shape), color_index)\n                else:\n                    # 如果没有形状节点，尝试直接在变换节点上设置\n                    try:\n                        cmds.setAttr(\"{}.overrideEnabled\".format(obj), 1)\n                        cmds.setAttr(\"{}.overrideColor\".format(obj), color_index)\n                    except:\n                        print(u\"无法为物体设置颜色: {}\".format(obj))\n        \n        print(u\"已为 {} 个物体设置颜色索引: {}\".format(len(selected_objects), color_index))\n\n    def closeEvent(self, event):\n        \"\"\"窗口关闭事件\"\"\"\n        # 清除实例引用\n        CurveToolsIntegrated._instance = None\n        event.accept()\n\n\ndef run_curve_tools_integrated():\n    \"\"\"运行曲线工具整合\"\"\"\n    try:\n        # 获取窗口实例\n        window = CurveToolsIntegrated.get_instance()\n        window.show()\n        window.raise_()\n        window.activateWindow()\n        return window\n    except Exception as e:\n        print(u\"运行曲线工具整合时出错: {}\".format(str(e)))\n        print(u\"请确保在Maya环境中运行此工具\")\n        return None\n\n\nif __name__ == \"__main__\":\n    try:\n        run_curve_tools_integrated()\n    except ImportError:\n        print(\"=\" * 50)\n        print(u\"错误: 此工具需要在Maya环境中运行\")\n        print(u\"请使用Maya的script editor或通过Maya的Python解释器运行此脚本\")\n        print(\"=\" * 50)\n    except Exception as e:\n        print(u\"工具启动失败: {}\".format(str(e)))\n        print(u\"请确保在Maya环境中运行此工具\")" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "曲线工具" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "曲线工具" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "D:/ck/scripts box/maya_PY2脚本转译/代码py2翻版/曲线工具/曲线工具/曲线.png" 
        -image1 "D:/ck/scripts box/maya_PY2脚本转译/代码py2翻版/曲线工具/曲线工具/曲线.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# -*- coding: utf-8 -*-\nu\"\"\"\n曲线工具整合\n集成所有曲线相关工具的UI界面\n适用于 Maya 2018-2020 (Python 2)\n\n功能:\n- 拆分曲线：将多形状曲线拆分为单独的变换节点\n- 结合曲线：将多个曲线合并为一个曲线\n- 曲线大小调整：调整曲线控制顶点大小\n- 曲线宽度调整：增加曲线显示宽度\n- Shape重命名：自动重命名曲线形状节点\n- 添加形状：将形状节点添加到目标物体\n- 物体中心创建曲线：基于选择物体中心创建曲线\n- 镜像曲线形状：沿X轴镜像曲线形状\n\"\"\"\n\nimport sys\nimport math\nimport logging\nimport random\nimport colorsys\nimport re\nfrom functools import wraps, partial\n\ntry:\n    from PySide2.QtWidgets import *\n    from PySide2.QtCore import *\n    from PySide2.QtGui import *\nexcept ImportError:\n    from PySide.QtGui import *\n    from PySide.QtCore import *\n\ntry:\n    import maya.cmds as cmds\n    import maya.mel as mel\n    import maya.OpenMayaUI as omui\nexcept ImportError:\n    print(u\"错误: 此工具需要在Maya环境中运行\")\n    sys.exit(1)\n\ntry:\n    from shiboken2 import wrapInstance\nexcept ImportError:\n    from shiboken import wrapInstance\n\n# Python2/3 basestring compatibility\ntry:\n    basestring\nexcept NameError:\n    basestring = (str, bytes)\n\n# Logging Setup\nlogging.basicConfig()\nlogger = logging.getLogger(__name__)\nlogger.setLevel(logging.INFO)\n\n# Constants\nCURVE_TYPE_NURBS = \"nurbsCurve\"\nCURVE_TYPE_BEZIER = \"bezierCurve\"\nCURVE_TYPES = [CURVE_TYPE_NURBS, CURVE_TYPE_BEZIER]\n\n# 控制控制台输出的详细程度\nVERBOSE = False\n\n\ndef get_maya_main_window():\n    \"\"\"获取Maya主窗口\"\"\"\n    main_window_ptr = omui.MQtUtil.mainWindow()\n    if main_window_ptr is not None:\n        return wrapInstance(int(main_window_ptr), QWidget)\n    return None\n\n\n# 全局撤销装饰器\ndef with_undo_support(func):\n    @wraps(func)\n    def wrapper(self, *args, **kwargs):\n        try:\n            cmds.undoInfo(openChunk=True)\n            result = func(self, *args, **kwargs)\n            if VERBOSE and func.__name__ not in [\"show\", \"closeEvent\"]:\n                print(u\"'{}' 操作完成。按 Ctrl+Z 可撤销此操作。\".format(func.__name__))\n            return result\n        except Exception as e:\n            cmds.warning(u\"'{}' 操作出错: {}\".format(func.__name__, e))\n            raise\n        finally:\n            cmds.undoInfo(closeChunk=True)\n    return wrapper\n\n\n# ==================== 工具函数 ====================\n\ndef get_short_name(obj_name):\n    \"\"\"获取对象的短名称\"\"\"\n    if not obj_name or not isinstance(obj_name, basestring):\n        return obj_name\n    return obj_name.split('|')[-1]\n\n\ndef _normalize_to_transform(node_path):\n    \"\"\"将shape路径标准化为transform路径\"\"\"\n    if not node_path or not isinstance(node_path, basestring) or not cmds.objExists(node_path):\n        return None\n    node_type = cmds.objectType(node_path)\n    if node_type in CURVE_TYPES:  # it's a shape, get its parent transform\n        parents = cmds.listRelatives(node_path, parent=True, fullPath=True) or []\n        return parents[0] if parents else None\n    # if it's already a transform, keep it\n    if node_type == 'transform':\n        return node_path\n    # could be an intermediate, try to get parent transform\n    parents = cmds.listRelatives(node_path, parent=True, fullPath=True) or []\n    return parents[0] if parents else None\n\n\ndef freeze_channels(obj_list):\n    \"\"\"冻结变换\"\"\"\n    if not obj_list:\n        return\n    try:\n        for obj in obj_list:\n            if cmds.objExists(obj):\n                cmds.makeIdentity(obj, apply=True, rotate=True, scale=True, translate=True)\n    except Exception as e:\n        logger.warning(u\"Failed to freeze transforms. Issue: {}\".format(str(e)))\n\n\n# ==================== 拆分曲线功能 ====================\n\ndef separate_curve_shapes_into_transforms(curve_name):\n    \"\"\"拆分曲线形状到独立变换节点\"\"\"\n    function_name = \"Separate Curves\"\n    try:\n        cmds.undoInfo(openChunk=True, chunkName=function_name)\n        nurbs_shapes = []\n        bezier_shapes = []\n        parent_transforms = []\n\n        transform_node = _normalize_to_transform(curve_name)\n        if not transform_node or not cmds.objExists(transform_node):\n            logger.warning('Unable to separate curve shapes. Missing provided curve: \"{0}\".'.format(curve_name))\n            return []\n\n        new_transforms = []\n\n        shapes = cmds.listRelatives(transform_node, shapes=True, fullPath=True) or []\n        for shape in shapes:\n            typ = cmds.objectType(shape)\n            if typ == CURVE_TYPE_BEZIER:\n                bezier_shapes.append(shape)\n            elif typ == CURVE_TYPE_NURBS:\n                nurbs_shapes.append(shape)\n\n        if not nurbs_shapes and not bezier_shapes:  # No valid shapes\n            logger.warning(\"Unable to separate curves. No valid shapes were found under the provided object.\")\n            return []\n\n        if len(shapes) == 1:  # Only one curve in provided object\n            logger.debug(\"Provided curve contains only one shape. Nothing to separate.\")\n            return [transform_node]\n\n        for obj in nurbs_shapes + bezier_shapes:\n            parent = cmds.listRelatives(obj, parent=True, fullPath=True) or []\n            for par in parent:\n                if par not in parent_transforms:\n                    parent_transforms.append(par)\n                cmds.makeIdentity(par, apply=True, rotate=True, scale=True, translate=True)\n            group_name = get_short_name(obj).replace(\"Shape\", \"\")\n            group = cmds.group(empty=True, world=True, name=group_name)\n            cmds.parent(obj, group, relative=True, shape=True)\n            new_transforms.append(group)\n\n        for obj in parent_transforms:\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n            if cmds.objExists(obj) and cmds.objectType(obj) == \"transform\" and len(shapes) == 0:\n                cmds.delete(obj)\n        return new_transforms\n    except Exception as e:\n        logger.warning(\"An error occurred when separating the curve. Issue: {0}\".format(e))\n        return []\n    finally:\n        cmds.undoInfo(closeChunk=True, chunkName=function_name)\n\n\ndef selected_curves_separate():\n    \"\"\"拆分选中的曲线\"\"\"\n    function_name = \"Separate Selected Curves\"\n    try:\n        cmds.undoInfo(openChunk=True, chunkName=function_name)\n        selection = cmds.ls(sl=True, long=True) or []\n\n        if len(selection) < 1:\n            logger.warning(\"You need to select at least one curve.\")\n            return []\n\n        parent_transforms = []\n        for node in selection:\n            transform = _normalize_to_transform(node)\n            if not transform:\n                logger.warning('Unable to separate \"{0}\". Node is invalid.'.format(node))\n                continue\n\n            nurbs_shapes = []\n            bezier_shapes = []\n            shapes = cmds.listRelatives(transform, shapes=True, fullPath=True) or []\n            for shape in shapes:\n                typ = cmds.objectType(shape)\n                if typ == CURVE_TYPE_BEZIER:\n                    bezier_shapes.append(shape)\n                elif typ == CURVE_TYPE_NURBS:\n                    nurbs_shapes.append(shape)\n\n            curve_shapes = nurbs_shapes + bezier_shapes\n            if len(curve_shapes) == 0:\n                logger.warning('Unable to separate \"{0}\". No valid shapes were found under this object.'.format(transform))\n            elif len(curve_shapes) > 1:\n                result = separate_curve_shapes_into_transforms(transform)\n                if result:\n                    parent_transforms.extend(result)\n            else:\n                cmds.warning(\"The selected curve contains only one shape.\")\n\n        if parent_transforms:\n            cmds.select(parent_transforms)\n        if VERBOSE:\n            sys.stdout.write(\"\\n\" + str(len(parent_transforms)) + \" shapes extracted.\")\n        return parent_transforms\n    except Exception as e:\n        logger.warning(\"An error occurred when separating the curves. Issue: {0}\".format(e))\n        return []\n    finally:\n        cmds.undoInfo(closeChunk=True, chunkName=function_name)\n\n\n# ==================== 结合曲线功能 ====================\n\ndef combine_curves_list(curve_list, convert_bezier_to_nurbs=True):\n    \"\"\"结合曲线列表\"\"\"\n    function_name = \"Combine Curves List\"\n    try:\n        cmds.undoInfo(openChunk=True, chunkName=function_name)\n        nurbs_shapes = []\n        bezier_shapes = []\n        valid_curve_transforms = set()\n\n        for crv in curve_list:\n            shapes = cmds.listRelatives(crv, shapes=True, fullPath=True) or []\n            for shape in shapes:\n                if cmds.objectType(shape) == CURVE_TYPE_BEZIER:\n                    bezier_shapes.append(shape)\n                    valid_curve_transforms.add(crv)\n                if cmds.objectType(shape) == CURVE_TYPE_NURBS:\n                    nurbs_shapes.append(shape)\n                    valid_curve_transforms.add(crv)\n\n        if not nurbs_shapes and not bezier_shapes:  # No valid shapes\n            logger.warning(u\"Unable to combine curves. No valid shapes were found under the provided objects.\")\n            return\n\n        if len(curve_list) == 1:  # Only one curve in provided list\n            return curve_list[0]\n\n        if len(bezier_shapes) > 0 and convert_bezier_to_nurbs:\n            for bezier in bezier_shapes:\n                logger.debug(str(bezier))\n                cmds.select(bezier)\n                cmds.bezierCurveToNurbs()\n\n        freeze_channels(list(valid_curve_transforms))\n        # Re-parent Shapes\n        shapes = nurbs_shapes + bezier_shapes\n        group = cmds.group(empty=True, world=True, name=curve_list[0])\n        cmds.refresh()  # Without a refresh, Maya ignores the freeze operation\n        for shape in shapes:\n            cmds.select(clear=True)\n            cmds.parent(shape, group, relative=True, shape=True)\n        # Delete empty transforms\n        for transform in valid_curve_transforms:\n            children = cmds.listRelatives(transform, children=True) or []\n            if not children and cmds.objExists(transform):\n                cmds.delete(transform)\n        # Clean-up\n        combined_curve = cmds.rename(group, curve_list[0])\n        if cmds.objExists(combined_curve):\n            cmds.select(combined_curve)\n        return combined_curve\n    except Exception as exception:\n        logger.warning(u\"An error occurred when combining the curves. Issue: {}\".format(str(exception)))\n    finally:\n        cmds.undoInfo(closeChunk=True, chunkName=function_name)\n\n\ndef selected_curves_combine(convert_bezier_to_nurbs=False, show_bezier_conversion_dialog=True):\n    \"\"\"结合选中的曲线\"\"\"\n    errors = \"\"\n    function_name = \"Combine Selected Curves\"\n    try:\n        cmds.undoInfo(openChunk=True, chunkName=function_name)\n        selection = cmds.ls(sl=True, absoluteName=True)\n        nurbs_shapes = []\n        bezier_shapes = []\n        valid_curve_transforms = set()\n\n        if len(selection) < 2:\n            logger.warning(u\"You need to select at least two curves.\")\n            return\n\n        for obj in selection:\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n            for shape in shapes:\n                if cmds.objectType(shape) == CURVE_TYPE_BEZIER:\n                    bezier_shapes.append(shape)\n                    valid_curve_transforms.add(obj)\n                if cmds.objectType(shape) == CURVE_TYPE_NURBS:\n                    nurbs_shapes.append(shape)\n                    valid_curve_transforms.add(obj)\n\n        if not nurbs_shapes and not bezier_shapes:  # No valid shapes\n            logger.warning(u\"Unable to combine curves. No valid shapes were found under the provided objects.\")\n            return\n\n        if len(bezier_shapes) > 0:\n            if show_bezier_conversion_dialog and not convert_bezier_to_nurbs:\n                result = cmds.confirmDialog(title=u'Bezier Curves Found',\n                                          message=u'Bezier curves were found. Would you like to convert them to NURBS?',\n                                          button=[u'Yes', u'No'],\n                                          defaultButton=u'Yes',\n                                          cancelButton=u'No',\n                                          dismissString=u'No')\n                if result == u'Yes':\n                    convert_bezier_to_nurbs = True\n\n            if convert_bezier_to_nurbs:\n                for bezier in bezier_shapes:\n                    cmds.select(bezier)\n                    cmds.bezierCurveToNurbs()\n\n        freeze_channels(list(valid_curve_transforms))\n        # Re-parent Shapes\n        shapes = nurbs_shapes + bezier_shapes\n        group = cmds.group(empty=True, world=True, name=selection[0])\n        cmds.refresh()  # Without a refresh, Maya ignores the freeze operation\n        for shape in shapes:\n            cmds.select(clear=True)\n            cmds.parent(shape, group, relative=True, shape=True)\n        # Delete empty transforms\n        for transform in valid_curve_transforms:\n            children = cmds.listRelatives(transform, children=True) or []\n            if not children and cmds.objExists(transform):\n                cmds.delete(transform)\n        # Clean-up\n        combined_curve = cmds.rename(group, selection[0])\n        if cmds.objExists(combined_curve):\n            cmds.select(combined_curve)\n        return combined_curve\n    except Exception as e:\n        errors += str(e) + \"\\n\"\n        cmds.warning(u\"An error occurred when combining the curves. Open the script editor for more information.\")\n    finally:\n        cmds.undoInfo(closeChunk=True, chunkName=function_name)\n    if errors != \"\":\n        print(u\"######## Errors: ########\")\n        print(errors)\n\n\n# ==================== Shape重命名功能 ====================\n\ndef rename_curve_shapes(target_curves):\n    \"\"\"重命名曲线形状\"\"\"\n    renamed_count = 0\n\n    for curve in target_curves:\n        # 检查是否有shape且shape是nurbsCurve\n        shapes = cmds.listRelatives(curve, shapes=True, fullPath=True) or []\n        if not shapes:\n            continue\n\n        for index, shape in enumerate(shapes):\n            if cmds.nodeType(shape) != 'nurbsCurve':\n                continue\n\n            # 生成新名称，支持多shape编号\n            transform_name = curve.split('|')[-1]\n            if len(shapes) == 1:\n                new_shape_name = u\"{}_Shape\".format(transform_name)\n            else:\n                new_shape_name = u\"{}_Shape{}\".format(transform_name, index + 1)\n\n            # 避免重名\n            if cmds.objExists(new_shape_name):\n                cmds.warning(u\"{} 已存在，跳过重命名。\".format(new_shape_name))\n                continue\n\n            cmds.rename(shape, new_shape_name)\n            renamed_count += 1\n            if VERBOSE:\n                print(u\"{} 重命名为 {}\".format(shape, new_shape_name))\n\n    # 使用视图消息显示重命名成功数量\n    if renamed_count > 0:\n        cmds.inViewMessage(amg=u\"<hl>完成！共重命名 {} 个曲线shape。</hl>\".format(renamed_count), pos='midCenterTop', fade=True)\n\n\ndef auto_rename_all():\n    \"\"\"自动重命名所有曲线\"\"\"\n    # 查找场景内所有带 nurbsCurve 的 transform\n    all_curves = []\n    transforms = cmds.ls(type='transform', long=True) or []\n    for trans in transforms:\n        shapes = cmds.listRelatives(trans, shapes=True, fullPath=True) or []\n        if shapes:\n            for shape in shapes:\n                if cmds.nodeType(shape) == 'nurbsCurve':\n                    all_curves.append(trans)\n                    break\n    if not all_curves:\n        cmds.warning(u'场景中未找到曲线。')\n        return\n    rename_curve_shapes(all_curves)\n\n\ndef rename_selected():\n    \"\"\"重命名选中的曲线\"\"\"\n    selected = cmds.ls(selection=True, long=True) or []\n    if not selected:\n        cmds.warning(u'请先选择需要重命名的曲线。')\n        return\n\n    # 过滤选中的曲线\n    target_curves = []\n    for obj in selected:\n        shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n        if shapes:\n            for shape in shapes:\n                if cmds.nodeType(shape) == 'nurbsCurve':\n                    target_curves.append(obj)\n                    break\n\n    if not target_curves:\n        cmds.warning(u'选择的物体中没有有效的曲线。')\n        return\n\n    rename_curve_shapes(target_curves)\n\n\n# ==================== 添加形状功能 ====================\n\ndef reparent_shape_nodes():\n    \"\"\"重新父级形状节点\"\"\"\n    # 获取当前选择\n    selection = cmds.ls(selection=True, type=\"transform\") or []\n    if len(selection) < 2:\n        cmds.warning(u\"请至少选择两个物体：源物体和目标物体（最后选择的目标）\")\n        return\n\n    # 最后一个物体作为目标父节点\n    target_parent = selection[-1]\n    # 除最后一个外的所有物体作为源节点\n    source_objects = selection[:-1]\n\n    # 记录成功添加的形状节点数量\n    total_shapes_count = 0\n    success_count = 0\n\n    # 遍历源物体，复制它们的形状节点并添加到目标物体\n    for obj in source_objects:\n        shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n        if shapes:\n            try:\n                # 复制整个物体（包含形状节点）\n                duplicated_list = cmds.duplicate(obj, returnRootsOnly=True) or []\n                if not duplicated_list:\n                    cmds.warning(u\"复制物体 '{}' 失败：未返回副本\".format(obj))\n                    continue\n                duplicated_obj = duplicated_list[0]\n                # 获取复制出来的形状节点\n                dup_shapes = cmds.listRelatives(duplicated_obj, shapes=True, fullPath=True) or []\n                if dup_shapes:\n                    # 将复制的形状节点添加到目标物体下\n                    cmds.parent(dup_shapes, target_parent, shape=True, add=True)\n                    total_shapes_count += len(dup_shapes)\n                    success_count += 1\n                    if VERBOSE:\n                        print(u\"已从 {} 复制 {} 个形状节点到 {}\".format(obj, len(dup_shapes), target_parent))\n                # 删除复制出来的变换节点\n                cmds.delete(duplicated_obj)\n            except Exception as e:\n                cmds.warning(u\"复制物体 {} 的形状节点失败: {}\".format(obj, str(e)))\n                if VERBOSE:\n                    print(u\"错误详情: {}\".format(str(e)))\n        else:\n            cmds.warning(u\"物体 {} 下没有找到形状节点\".format(obj))\n\n    # 最终结果\n    if success_count > 0:\n        cmds.select(target_parent)\n        if VERBOSE:\n            print(u\"操作完成：成功从 {} 个物体复制了 {} 个形状节点到 {}\".format(success_count, total_shapes_count, target_parent))\n    else:\n        cmds.warning(u\"没有成功添加任何形状节点\")\n\n\n# ==================== 物体中心创建曲线功能 ====================\n\ndef get_core():\n    \"\"\"获取选中物体的中心点\"\"\"\n    obj_lis = cmds.ls(sl=1, fl=1)\n\n    pos_lis = []\n    for obj in obj_lis:\n        pos_lis.append(cmds.xform(obj, ws=True, q=True, t=True))\n\n    crv = cmds.curve(d=1, p=pos_lis)\n    clst = cmds.cluster()\n    loc = cmds.spaceLocator()[0]\n    cmds.matchTransform(loc, clst)\n    pos = cmds.xform(loc, ws=1, q=1, t=1)\n    cmds.delete(clst, crv, loc)\n    return pos\n\n\ndef create_center_curve():\n    \"\"\"基于物体中心创建曲线\"\"\"\n    sel_lis = cmds.ls(sl=1, fl=1)\n    if not sel_lis:\n        cmds.warning(u\"请先选择物体！\")\n        return\n    \n    cv_lis = [get_core()]\n    cmds.select(sel_lis)\n    while True:\n        mel.eval('PolySelectTraverse 1;')\n        sel = cmds.ls(sl=1, fl=1)\n        obj = set(sel)-set(sel_lis)\n        obj = list(obj)\n        if obj:\n            cmds.select(obj)\n            cv_lis.append(get_core())\n            cmds.select(sel)\n            sel_lis = sel\n        else:\n            break\n\n    result_curve = cmds.curve(p=cv_lis)\n    if VERBOSE:\n        print(u\"基于物体中心创建曲线: {}\".format(result_curve))\n    return result_curve\n\n\n# ==================== 镜像曲线形状功能 ====================\n\ndef mirror_curve_shape():\n    \"\"\"镜像曲线形状\"\"\"\n    # 打开撤销块\n    cmds.undoInfo(openChunk=True)\n    try:\n        # 获取选择的两个曲线对象\n        selection = cmds.ls(sl=True)\n        if len(selection) != 2:\n            cmds.warning(u'请选择两根需要镜像的曲线.')\n            return\n        \n        con, con_dist = selection\n    except ValueError:\n        cmds.warning(u'请选择两根需要镜像的曲线.')\n        return\n    finally:\n        # 如果发生异常，确保关闭撤销块\n        cmds.undoInfo(closeChunk=True)\n\n    # 打开新的撤销块以包含后续操作\n    cmds.undoInfo(openChunk=True)\n    try:\n        # 检查两曲线的控制点数量是否一致\n        if not cmds.getAttr(con + '.controlPoints', size=True) == cmds.getAttr(con_dist + '.controlPoints', size=True):\n            cmds.warning(u'所选控制器CV点的数量不相同.')\n            return\n\n        # 遍历控制点并进行镜像\n        for i in range(cmds.getAttr(con + '.controlPoints', size=True)):\n            # 获取源曲线控制点的位置\n            P = cmds.pointPosition(con + '.controlPoints[%s]' % i)\n            # 将目标曲线的控制点沿 X 轴镜像（X 取反，Y 和 Z 不变）\n            cmds.xform(con_dist + '.controlPoints[%s]' % i, t=(-1 * P[0], P[1], P[2]), ws=True)\n\n        print(u\"曲线形状已成功沿 X 轴镜像.\")\n    except Exception as e:\n        cmds.warning(u\"镜像曲线形状失败: %s\" % str(e))\n        raise  # 抛出异常以便调试\n    finally:\n        # 关闭撤销块\n        cmds.undoInfo(closeChunk=True)\n\n\n# ==================== 替换曲线形状功能 ====================\n\ndef replace_curve_shape():\n    \"\"\"替换曲线形状（一对多版本）\"\"\"\n    try:\n        # 直接在Python中执行MEL代码\n        mel_code = '''\nglobal proc replaceShapeSimpleMulti() {\n    string $sel[] = `ls -sl`;\n\n    // 检查选择数量\n    if(size($sel) < 2){\n        error \"Please select source curve first, then one or more target curves.\";\n        return;\n    }\n\n    // 第一个是源曲线，其余是目标\n    string $sourceCurve = $sel[0];\n    string $targets[];\n    for($i = 1; $i < size($sel); $i++){\n        $targets[size($targets)] = $sel[$i];\n    }\n\n    print (\"Source curve: \" + $sourceCurve + \"\\\\n\");\n    print (\"Target curves: \" + stringArrayToString($targets, \", \") + \"\\\\n\");\n\n    // 获取源曲线 shape\n    string $srcShapes[] = `listRelatives -s -fullPath $sourceCurve`;\n    if(size($srcShapes) == 0){\n        error \"Source curve has no shape.\";\n        return;\n    }\n\n    // 循环每个目标曲线\n    for($t in $targets){\n        if(!`objExists $t`){\n            warning (\"Target curve does not exist: \" + $t);\n            continue;\n        }\n\n        print (\"--- Replacing shape for: \" + $t + \" ---\\\\n\");\n\n        // 复制源曲线\n        string $dup[] = `duplicate -rr $sourceCurve`;\n        string $tempCurve = rename($dup[0], ($t + \"_temp\"));\n\n        // 删除非 nurbsCurve 子节点\n        string $children[] = `listRelatives -c -fullPath $tempCurve`;\n        for($c in $children){\n            if(`objectType $c` != \"nurbsCurve\"){\n                delete $c;\n            }\n        }\n\n        // 移到世界空间\n        string $parent[] = `listRelatives -p $tempCurve`;\n        if(size($parent) > 0){\n            parent -world $tempCurve;\n        }\n\n        // 对齐位置\n        delete `pointConstraint $t $tempCurve`;\n\n        // 获取旧的 shape\n        string $oldShapes[] = `listRelatives -s -fullPath $t`;\n\n        // 记录可见性连接\n        for($ii=0; $ii<size($oldShapes); $ii++){\n            string $inputV[] = `listConnections -s 1 -d 0 -p 1 -scn 1 ($oldShapes[$ii] + \".v\")`;\n            string $inputLodV[] = `listConnections -s 1 -d 0 -p 1 -scn 1 ($oldShapes[$ii] + \".lodVisibility\")`;\n\n            // 删除旧的 shape\n            delete $oldShapes[$ii];\n\n            // 新 shape parent 过去\n            string $newShapes[] = `listRelatives -s -fullPath $tempCurve`;\n            for($ns in $newShapes){\n                parent -r -s $ns $t;\n                if(size($inputV) > 0)\n                    connectAttr -f $inputV[0] ($ns + \".v\");\n                if(size($inputLodV) > 0)\n                    connectAttr -f $inputLodV[0] ($ns + \".lodVisibility\");\n            }\n        }\n\n        // 删除临时 transform\n        delete $tempCurve;\n\n        // 重命名 shape 节点\n        string $newShapeList[] = `listRelatives -s -fullPath $t`;\n        for($i=0; $i<size($newShapeList); $i++){\n            rename $newShapeList[$i] ($t + \"Shape\" + $i);\n        }\n\n        print (\"Shape replaced for: \" + $t + \"\\\\n\");\n    }\n\n    print (\"All replacements completed!\\\\n\");\n}\n'''\n        # 执行MEL代码定义函数\n        mel.eval(mel_code)\n        # 调用函数\n        mel.eval('replaceShapeSimpleMulti();')\n        print(u\"形状替换完成！（一对多版本）\")\n    except Exception as e:\n        cmds.warning(u\"替换曲线形状失败: {}\".format(str(e)))\n\n\n# ==================== 随机颜色功能 ====================\n\ndef get_object_type(obj):\n    \"\"\"获取物体类型\"\"\"\n    shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n    if not shapes:\n        # 可能是定位器或其他变换节点\n        node_type = cmds.nodeType(obj)\n        if node_type == 'locator':\n            return 'locator'\n        return 'transform'\n    \n    shape_type = cmds.nodeType(shapes[0])\n    if shape_type in ['mesh']:\n        return 'mesh'\n    elif shape_type in ['nurbsCurve']:\n        return 'curve'\n    elif shape_type in ['nurbsSurface']:\n        return 'surface'\n    elif shape_type in ['locator']:\n        return 'locator'\n    else:\n        return 'other'\n\n\ndef assign_random_colors():\n    \"\"\"为选中的物体赋予随机颜色材质，支持网格、曲线、曲面、定位器等多种类型\"\"\"\n    # 获取当前选中的物体\n    selected_objects = cmds.ls(selection=True)\n    \n    if not selected_objects:\n        print(u\"请先选择物体\")\n        return\n    \n    processed_count = 0\n    \n    for obj in selected_objects:\n        obj_type = get_object_type(obj)\n        \n        # 生成随机色相值\n        hue_random = random.random()\n        # 将HSV转换为RGB (饱和度0.8，明度0.9)\n        rgb_color = colorsys.hsv_to_rgb(hue_random, 0.8, 0.9)\n        \n        if obj_type == 'mesh':\n            # 网格物体使用Lambert材质\n            shader_name = cmds.shadingNode('lambert', asShader=True)\n            cmds.setAttr(shader_name + \".color\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n            \n            # 创建着色组\n            shading_group = cmds.sets(renderable=True, noSurfaceShader=True, empty=True, name=shader_name + \"SG\")\n            cmds.connectAttr(shader_name + \".outColor\", shading_group + \".surfaceShader\", force=True)\n            cmds.sets(obj, edit=True, forceElement=shading_group)\n            processed_count += 1\n            \n        elif obj_type == 'curve':\n            # 曲线物体直接设置颜色覆盖（为所有 nurbsCurve 形状赋色）\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n            applied = False\n            for shape in shapes:\n                if cmds.nodeType(shape) == 'nurbsCurve':\n                    cmds.setAttr(shape + \".overrideEnabled\", 1)\n                    cmds.setAttr(shape + \".overrideRGBColors\", 1)\n                    cmds.setAttr(shape + \".overrideColorRGB\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n                    applied = True\n            if applied:\n                processed_count += 1\n                \n        elif obj_type == 'surface':\n            # NURBS曲面使用Lambert材质\n            shader_name = cmds.shadingNode('lambert', asShader=True)\n            cmds.setAttr(shader_name + \".color\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n            \n            # 创建着色组\n            shading_group = cmds.sets(renderable=True, noSurfaceShader=True, empty=True, name=shader_name + \"SG\")\n            cmds.connectAttr(shader_name + \".outColor\", shading_group + \".surfaceShader\", force=True)\n            cmds.sets(obj, edit=True, forceElement=shading_group)\n            processed_count += 1\n            \n        elif obj_type == 'locator':\n            # 定位器设置颜色覆盖（为所有形状赋色；若无形状则作用于变换节点）\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n            if shapes:\n                for shape in shapes:\n                    cmds.setAttr(shape + \".overrideEnabled\", 1)\n                    cmds.setAttr(shape + \".overrideRGBColors\", 1)\n                    cmds.setAttr(shape + \".overrideColorRGB\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n                processed_count += 1\n            else:\n                if cmds.nodeType(obj) == 'locator':\n                    cmds.setAttr(obj + \".overrideEnabled\", 1)\n                    cmds.setAttr(obj + \".overrideRGBColors\", 1)\n                    cmds.setAttr(obj + \".overrideColorRGB\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n                    processed_count += 1\n                    \n        else:\n            # 其他类型物体尝试设置颜色覆盖（为所有形状赋色）\n            try:\n                shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n                if shapes:\n                    for shape in shapes:\n                        cmds.setAttr(shape + \".overrideEnabled\", 1)\n                        cmds.setAttr(shape + \".overrideRGBColors\", 1)\n                        cmds.setAttr(shape + \".overrideColorRGB\", rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n                    processed_count += 1\n                else:\n                    print(u\"跳过不支持的物体类型: {0} ({1})\".format(obj, obj_type))\n            except:\n                print(u\"无法为物体设置颜色: {0}\".format(obj))\n    \n    # 清除选择\n    cmds.select(clear=True)\n    print(u\"已为 {0} 个物体赋予随机颜色\".format(processed_count))\n\n\n# 增强版：使用黄金比例生成颜色并缓存材质，支持mesh与nurbsSurface复用材质\ndef generate_golden_ratio_color():\n    golden_ratio = 0.61803398875\n    h = (random.random() + golden_ratio) % 1.0\n    s = random.uniform(0.4, 0.9)\n    v = random.uniform(0.5, 1.0)\n    r, g, b = colorsys.hsv_to_rgb(h, s, v)\n    return (round(r, 3), round(g, 3), round(b, 3))\n\n\ndef assign_random_colors_golden():\n    \"\"\"为选中的物体分配基于黄金比例的随机颜色（增强版）\"\"\"\n    selected_objects = cmds.ls(selection=True, long=True)\n    if not selected_objects:\n        cmds.warning(\"请先选择物体\")\n        return\n\n    processed_count = 0\n    shader_cache = {}\n\n    for obj in selected_objects:\n        shapes = cmds.listRelatives(obj, shapes=True, fullPath=True) or []\n        if not shapes:\n            continue\n\n        rgb = generate_golden_ratio_color()\n\n        # 若包含 mesh / nurbsSurface，则为这些 shape 绑定同一材质\n        has_surface_like = any(cmds.nodeType(s) in ['mesh', 'nurbsSurface'] for s in shapes)\n        if has_surface_like:\n            if rgb in shader_cache:\n                shading_group = shader_cache[rgb]\n            else:\n                shader_name = cmds.shadingNode('lambert', asShader=True, name=\"goldenColor_mat#\")\n                cmds.setAttr(shader_name + \".color\", *rgb, type=\"double3\")\n                shading_group = cmds.sets(renderable=True, noSurfaceShader=True, empty=True, name=shader_name + \"SG\")\n                cmds.connectAttr(shader_name + \".outColor\", shading_group + \".surfaceShader\", f=True)\n                shader_cache[rgb] = shading_group\n\n            for shape in shapes:\n                if cmds.nodeType(shape) in ['mesh', 'nurbsSurface']:\n                    cmds.sets(shape, e=True, forceElement=shading_group)\n                    processed_count += 1\n\n        # 对其他类型（如 nurbsCurve、locator）使用 override 颜色\n        for shape in shapes:\n            if cmds.nodeType(shape) not in ['mesh', 'nurbsSurface']:\n                try:\n                    cmds.setAttr(shape + \".overrideEnabled\", 1)\n                    cmds.setAttr(shape + \".overrideRGBColors\", 1)\n                    cmds.setAttr(shape + \".overrideColorRGB\", *rgb, type='double3')\n                    processed_count += 1\n                except:\n                    cmds.warning(\"无法设置颜色: {}\".format(shape))\n\n    cmds.select(clear=True)\n    if VERBOSE:\n        print(\"已为 {} 个 shape 赋予 Golden Ratio 随机颜色\".format(processed_count))\n\n\n# ==================== 渐变颜色功能 ====================\n\ndef create_ramp_node():\n    \"\"\"创建或获取渐变节点\"\"\"\n    ramp_name = 'TEMPNODE_remapValue'\n    if not cmds.objExists(ramp_name):\n        cmds.createNode('remapValue', n=ramp_name)\n        cmds.setAttr(ramp_name + '.color[0].color_Position', 0.0)\n        cmds.setAttr(ramp_name + '.color[0].color_FloatValue', 1.0, 0.0, 0.0, type='double3')  # 红\n        cmds.setAttr(ramp_name + '.color[1].color_Position', 1.0)\n        cmds.setAttr(ramp_name + '.color[1].color_FloatValue', 0.0, 0.0, 1.0, type='double3')  # 蓝\n    return ramp_name\n\n\ndef open_ramp_editor():\n    \"\"\"打开渐变编辑器\"\"\"\n    try:\n        ramp_name = create_ramp_node()\n        mel.eval('editRampAttribute \"{}\"'.format(ramp_name + '.color'))\n        print(u'已打开渐变编辑器，请设置颜色')\n    except Exception as e:\n        print(u'打开编辑器失败：{}'.format(str(e)))\n\n\ndef apply_gradient_color():\n    \"\"\"应用渐变颜色\"\"\"\n    try:\n        sel = cmds.ls(sl=True)\n        if not sel:\n            print(u'请先选择物体再进行操作')\n            return\n\n        sel_size = len(sel)\n        if sel_size < 2:\n            print(u'请选择至少 2 个物体以获得渐变效果')\n            return\n\n        ramp_name = create_ramp_node()\n\n        for i, obj in enumerate(sel):\n            if sel_size == 1:\n                par_value = 0.5\n            else:\n                par_value = float(i) / float(sel_size - 1)\n\n            cmds.setAttr(ramp_name + '.inputValue', par_value)\n            rgb_value = cmds.getAttr(ramp_name + '.outColor')[0]\n            set_object_color(obj, rgb_value)\n\n        print(u'已为 {} 个物体应用渐变颜色'.format(sel_size))\n\n    except Exception as e:\n        print(u'应用颜色失败：{}'.format(str(e)))\n\n\ndef set_object_color(obj, rgb_color):\n    \"\"\"设置物体颜色\"\"\"\n    try:\n        # 默认设置Shape节点颜色\n        shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n        if shapes:\n            for shape in shapes:\n                cmds.setAttr(shape + '.overrideEnabled', True)\n                cmds.setAttr(shape + '.overrideRGBColors', True)\n                cmds.setAttr(shape + '.overrideColorRGB', rgb_color[0], rgb_color[1], rgb_color[2], type='double3')\n    except Exception as e:\n        print(u'设置物体 {} 颜色失败：{}'.format(obj, str(e)))\n\n\ndef reset_colors():\n    \"\"\"重置颜色\"\"\"\n    try:\n        sel = cmds.ls(sl=True)\n        if not sel:\n            print(u'请先选择要重置的物体')\n            return\n\n        for obj in sel:\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n            if shapes:\n                for shape in shapes:\n                    # 先将RGB模式改为索引模式\n                    cmds.setAttr(shape + '.overrideRGBColors', False)\n                    # 然后关闭启用覆盖\n                    cmds.setAttr(shape + '.overrideEnabled', False)\n            else:\n                # 如果没有形状节点，尝试直接在变换节点上设置\n                try:\n                    # 先将RGB模式改为索引模式\n                    cmds.setAttr(obj + '.overrideRGBColors', False)\n                    # 然后关闭启用覆盖\n                    cmds.setAttr(obj + '.overrideEnabled', False)\n                except:\n                    pass\n\n        print(u'已成功重置 {} 个物体的颜色'.format(len(sel)))\n\n    except Exception as e:\n        print(u'重置颜色失败：{}'.format(str(e)))\n\n\n# ==================== 曲线宽度功能 ====================\n\ndef increase_curve_width():\n    \"\"\"增加曲线宽度\"\"\"\n    selected = cmds.ls(selection=True)  # 获取选中的对象（可能是Transform节点）\n    if not selected:\n        cmds.warning(u\"请先选择曲线！\")\n        return\n    \n    shapes = cmds.listRelatives(selected, shapes=True) or []  # 获取Shape节点\n    curves = [s for s in shapes if cmds.objectType(s, isType='nurbsCurve')]\n    \n    if not curves:\n        cmds.warning(u\"选中的对象不是NURBS曲线！\")\n        return\n    \n    for curve in curves:\n        current_width = cmds.getAttr(curve + '.lineWidth')\n        new_width = current_width + 1\n        cmds.setAttr(curve + '.lineWidth', new_width)\n        if VERBOSE:\n            print(u\"曲线 {} 的宽度已增加到: {}\".format(curve, new_width))\n\n\ndef decrease_curve_width():\n    \"\"\"减小曲线宽度\"\"\"\n    selected = cmds.ls(selection=True)  # 获取选中的对象（可能是Transform节点）\n    if not selected:\n        cmds.warning(u\"请先选择曲线！\")\n        return\n    \n    shapes = cmds.listRelatives(selected, shapes=True) or []  # 获取Shape节点\n    curves = [s for s in shapes if cmds.objectType(s, isType='nurbsCurve')]\n    \n    if not curves:\n        cmds.warning(u\"选中的对象不是NURBS曲线！\")\n        return\n    \n    for curve in curves:\n        current_width = cmds.getAttr(curve + '.lineWidth')\n        new_width = max(1, current_width - 1)  # 确保宽度不小于1\n        cmds.setAttr(curve + '.lineWidth', new_width)\n        print(u\"曲线 {} 的宽度已减小到: {}\".format(curve, new_width))\n\nTEXTGEN_NAME = u\"文本曲线生成器\"\nTEXTGEN_VERSION = \"1.0.0\"\nDEFAULT_TEXT_FONT = u\"华文中宋\"\nCURRENT_TEXT_FONT = {\"current_font\": DEFAULT_TEXT_FONT}\n\ndef parse_text_field_commas(text_field_data):\n    if len(text_field_data) <= 0:\n        return []\n    return [s for s in text_field_commas_split(text_field_data) if s != u\"\"]\n\ndef text_field_commas_split(text):\n    try:\n        return text.split(u\",\")\n    except Exception:\n        return [text]\n\ndef sanitize_maya_name(text):\n    if not isinstance(text, basestring):\n        text = unicode(text) if sys.version_info[0] == 2 else str(text)\n    base = []\n    for ch in text:\n        if (u'a' <= ch <= u'z' or u'A' <= ch <= u'Z' or u'0' <= ch <= u'9' or ch == u'_'):\n            base.append(ch)\n        elif ch in (u'-', u' '):\n            base.append(u'_')\n        else:\n            base.append(u'_')\n    name = u\"\".join(base).lower()\n    name = re.sub(u\"_+\", u\"_\", name).strip(u\"_\")\n    if not name:\n        name = u\"text\"\n    if name[0].isdigit():\n        name = u\"_\" + name\n    return name\n\ndef create_text(text, font):\n    if font == u\"\":\n        cmds.textCurves(ch=0, t=text, font=DEFAULT_TEXT_FONT)\n    else:\n        cmds.textCurves(ch=0, t=text, font=font)\n    cmds.ungroup()\n    cmds.ungroup()\n    curves = cmds.ls(sl=True)\n    cmds.makeIdentity(apply=True, t=1, r=1, s=1, n=0)\n    shapes = curves[1:]\n    cmds.select(shapes, r=True)\n    cmds.pickWalk(d=\"Down\")\n    cmds.select(curves[0], tgl=True)\n    cmds.parent(r=True, s=True)\n    cmds.pickWalk(d=\"up\")\n    cmds.delete(shapes)\n    cmds.xform(cp=True)\n    safe = sanitize_maya_name(text)\n    curve = cmds.rename(u\"{}_crv\".format(safe))\n    shape_list = cmds.listRelatives(curve, shapes=True) or []\n    for i, shp in enumerate(shape_list):\n        cmds.rename(shp, u\"{}_{}Shape\".format(curve, i + 1))\n    return cmds.ls(sl=True)[0]\n\ndef build_gui_generate_text_curve():\n    window_name = \"build_gui_generate_text_curve_standalone\"\n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name)\n    window_gui_generate_text_curve = cmds.window(\n        window_name,\n        title=TEXTGEN_NAME + u\"  (v\" + TEXTGEN_VERSION + u\")\",\n        titleBar=True,\n        mnb=False,\n        mxb=False,\n        sizeable=True,\n    )\n    cmds.window(window_name, e=True, s=True, wh=[1, 1])\n    content_main = cmds.columnLayout(adj=True)\n    title_bgc_color = (0.4, 0.4, 0.4)\n    cmds.separator(h=10, style=\"none\")\n    cmds.rowColumnLayout(nc=1, cw=[(1, 270)], cs=[(1, 10)], p=content_main)\n    cmds.rowColumnLayout(nc=3, cw=[(1, 10), (2, 200), (3, 50)], cs=[(1, 10), (2, 0), (3, 0)], p=content_main)\n    cmds.text(\" \", bgc=title_bgc_color)\n    cmds.text(TEXTGEN_NAME, bgc=title_bgc_color, fn=\"boldLabelFont\", align=\"left\")\n    cmds.button(l=u\"帮助\", bgc=title_bgc_color, c=lambda x: build_gui_help_generate_text_curve())\n    cmds.separator(h=10, style=\"none\", p=content_main)\n    body_column = cmds.rowColumnLayout(nc=1, cw=[(1, 260)], cs=[(1, 10)], p=content_main)\n    cmds.separator(h=7, style=\"none\", p=body_column)\n    cmds.rowColumnLayout(nc=2, cw=[(1, 80), (2, 170)], cs=[(1, 0), (2, 0)], p=body_column)\n    cmds.text(u\"当前字体:\")\n    font_button = cmds.button(h=17, l=DEFAULT_TEXT_FONT, c=lambda x: change_text_font())\n    cmds.rowColumnLayout(nc=1, cw=[(1, 260)], cs=[(1, 0)], p=body_column)\n    cmds.separator(h=15, p=body_column)\n    cmds.text(u\"文本:\", p=body_column)\n    desired_text = cmds.textField(p=body_column, text=u\"hello, world\", enterCommand=lambda x: generate_text_curve())\n    cmds.separator(h=10, style=\"none\", p=body_column)\n    cmds.button(p=body_column, l=u\"生成\", bgc=(0.6, 0.6, 0.6), c=lambda x: generate_text_curve())\n    cmds.separator(h=10, style=\"none\", p=content_main)\n    cmds.showWindow(window_gui_generate_text_curve)\n    cmds.window(window_name, e=True, s=False)\n    def generate_text_curve():\n        strings = parse_text_field_commas(cmds.textField(desired_text, q=True, text=True))\n        for string in strings:\n            create_text(string, CURRENT_TEXT_FONT.get(\"current_font\"))\n    def change_text_font():\n        new_font = cmds.fontDialog()\n        if new_font != u\"\":\n            CURRENT_TEXT_FONT[\"current_font\"] = new_font\n            cmds.button(font_button, e=True, label=new_font.split(\"|\")[0])\n\ndef build_gui_help_generate_text_curve():\n    window_name = \"build_gui_help_generate_text_curve_standalone\"\n    if cmds.window(window_name, exists=True):\n        cmds.deleteUI(window_name, window=True)\n    cmds.window(window_name, title=TEXTGEN_NAME + u\" Help\", mnb=False, mxb=False, s=True)\n    cmds.window(window_name, e=True, s=True, wh=[1, 1])\n    cmds.columnLayout(\"main_column\", p=window_name)\n    cmds.separator(h=12, style=\"none\")\n    cmds.rowColumnLayout(nc=1, cw=[(1, 310)], cs=[(1, 10)], p=\"main_column\")\n    cmds.rowColumnLayout(nc=1, cw=[(1, 300)], cs=[(1, 10)], p=\"main_column\")\n    cmds.text(TEXTGEN_NAME + u\" Help\", bgc=[0.4, 0.4, 0.4], fn=\"boldLabelFont\", align=\"center\")\n    cmds.separator(h=10, style=\"none\", p=\"main_column\")\n    cmds.rowColumnLayout(nc=1, cw=[(1, 300)], cs=[(1, 10)], p=\"main_column\")\n    cmds.text(l=u\"此脚本创建包含输入文本的合并曲线\", align=\"left\")\n    cmds.text(l=u\"来自文本字段。\", align=\"left\")\n    cmds.separator(h=15, style=\"none\")\n    cmds.text(l=u\"(所有形状都在一个变换节点下)\", align=\"center\")\n    cmds.separator(h=15, style=\"none\")\n    cmds.text(l=u\"您可以通过用逗号分隔来创建多个曲线\", align=\"left\")\n    cmds.text(l=u'使用逗号 \",\"。', align=\"left\")\n    cmds.separator(h=15, style=\"none\")\n    cmds.text(l=u\"当前字体:\", align=\"left\", fn=\"boldLabelFont\")\n    cmds.text(l=u\"点击右侧按钮更改字体。\", align=\"left\")\n    cmds.separator(h=15, style=\"none\")\n    cmds.rowColumnLayout(nc=1, cw=[(1, 300)], cs=[(1, 10)], p=\"main_column\")\n    cmds.separator(h=10, style=\"none\")\n    cmds.button(l=u\"确定\", h=30, c=lambda args: cmds.deleteUI(window_name))\n    cmds.separator(h=8, style=\"none\")\n\nclass ColorToolWindow(QMainWindow):\n    def __init__(self):\n        parent = get_maya_main_window()\n        super(ColorToolWindow, self).__init__(parent=parent)\n        self.setWindowTitle(u\"颜色工具\")\n        self.resize(420, 240)\n        if parent is not None:\n            self.setWindowFlags(Qt.Window)\n        self.color_rgb = [1.0, 1.0, 1.0]\n        self.preset_colors = [\n            (0.5, 0.5, 0.5), (0, 0, 0), (0.247, 0.247, 0.247), (0.498, 0.498, 0.498),\n            (0.608, 0, 0.157), (0, 0.16, 0.376), (0, 0, 1), (0, 0.275, 0.094),\n            (0.149, 0, 0.263), (0.78, 0, 0.78), (0.537, 0.278, 0.2), (0.243, 0.133, 0.121),\n            (0.6, 0.145, 0), (1, 0, 0), (0, 1, 0), (0, 0.2549, 0.6),\n            (1, 1, 1), (1, 1, 0), (0.388, 0.863, 1), (0.263, 1, 0.639),\n            (1, 0.686, 0.686), (0.89, 0.674, 0.474), (1, 1, 0.388), (0, 0.6, 0.329),\n            (0.627, 0.411, 0.188), (0.619, 0.627, 0.188), (0.408, 0.631, 0.188), (0.188, 0.631, 0.365),\n            (0.188, 0.627, 0.627), (0.188, 0.403, 0.627), (0.434, 0.188, 0.627), (0.627, 0.188, 0.411)\n        ]\n        self.init_ui()\n        self.update_color_preview()\n\n    def show(self):\n        if not self.isVisible():\n            super(ColorToolWindow, self).show()\n        else:\n            self.raise_()\n            self.activateWindow()\n\n    def init_ui(self):\n        central = QWidget()\n        layout = QVBoxLayout()\n        central.setLayout(layout)\n        self.setCentralWidget(central)\n\n        self.color_preview = QLabel()\n        self.color_preview.setFixedHeight(40)\n        self.color_preview.setAlignment(Qt.AlignCenter)\n        self.color_preview.mousePressEvent = lambda e: self.show_color_dialog()\n        layout.addWidget(self.color_preview)\n\n        row = QHBoxLayout()\n        self.choose_btn = QPushButton(u\"选择颜色\")\n        self.choose_btn.clicked.connect(self.show_color_dialog)\n        row.addWidget(self.choose_btn)\n        self.apply_btn = QPushButton(u\"应用到选中控制器\")\n        self.apply_btn.setEnabled(cmds is not None)\n        self.apply_btn.clicked.connect(self.apply_color_to_selection)\n        row.addWidget(self.apply_btn)\n        self.reset_btn = QPushButton(u\"重置颜色\")\n        self.reset_btn.setEnabled(cmds is not None)\n        self.reset_btn.clicked.connect(self.reset_color)\n        row.addWidget(self.reset_btn)\n        layout.addLayout(row)\n\n        grid = QGridLayout()\n        for i, rgb in enumerate(self.preset_colors):\n            r, g, b = [int(c * 255) for c in rgb]\n            btn = QPushButton()\n            btn.setFixedSize(24, 24)\n            btn.setStyleSheet(\"background-color: #{:02X}{:02X}{:02X}; border: 1px solid #666666;\".format(r, g, b))\n            btn.clicked.connect(partial(self.on_preset_clicked, rgb))\n            grid.addWidget(btn, i // 12, i % 12)\n        layout.addLayout(grid)\n\n    def rgb_to_hex(self, rgb):\n        r, g, b = [int(c * 255) for c in rgb]\n        return \"#{:02X}{:02X}{:02X}\".format(r, g, b)\n\n    def compute_text_color(self, r, g, b):\n        brightness = (0.299 * r + 0.587 * g + 0.114 * b) / 255\n        return \"#000000\" if brightness > 0.5 else \"#FFFFFF\"\n\n    def apply_preview_style(self, hex_color, text_color, border_css):\n        self.color_preview.setStyleSheet(\n            \"\"\"\n            background-color: {};\n            border: {};\n            border-radius: 5px;\n            color: {};\n            font-size: 12px;\n            text-align: center;\n            padding: 4px;\n            \"\"\".format(hex_color, border_css, text_color)\n        )\n\n    def update_color_preview(self):\n        hex_color = self.rgb_to_hex(self.color_rgb)\n        r, g, b = [int(c * 255) for c in self.color_rgb]\n        text_color = self.compute_text_color(r, g, b)\n        self.apply_preview_style(hex_color, text_color, \"1px solid #666666\")\n        self.color_preview.setText(hex_color)\n        self.color_preview.setToolTip(u\"RGB: {}, {}, {}\\n点击修改颜色\".format(r, g, b))\n\n    def set_color(self, rgb):\n        self.color_rgb = list(rgb)\n        self.update_color_preview()\n\n    def on_preset_clicked(self, rgb):\n        self.set_color(rgb)\n        if cmds:\n            self.apply_color_to_selection()\n\n    def _apply_qcolor(self, c):\n        self.color_rgb = [c.redF(), c.greenF(), c.blueF()]\n        self.update_color_preview()\n\n    def on_color_selected(self, c):\n        self._apply_qcolor(c)\n\n    def on_current_color_changed(self, c):\n        self._apply_qcolor(c)\n\n    def show_color_dialog(self):\n        dlg = getattr(self, \"_color_dlg\", None)\n        if dlg is None:\n            dlg = QColorDialog(QColor.fromRgbF(*self.color_rgb), self)\n            dlg.setOptions(QColorDialog.ShowAlphaChannel | QColorDialog.DontUseNativeDialog)\n            for i in range(min(10, len(self.preset_colors))):\n                r, g, b = self.preset_colors[i]\n                qcolor = QColor(int(r * 255), int(g * 255), int(b * 255))\n                dlg.setCustomColor(i, qcolor)\n            try:\n                dlg.colorSelected.connect(self.on_color_selected)\n                dlg.currentColorChanged.connect(self.on_current_color_changed)\n            except Exception:\n                pass\n            dlg.setModal(False)\n            dlg.setWindowModality(Qt.NonModal)\n            self._color_dlg = dlg\n        dlg.show()\n\n    @with_undo_support\n    def apply_color_to_selection(self):\n        if not cmds:\n            return\n        selected = cmds.ls(selection=True)\n        if not selected:\n            print(u\"请至少选择一个控制器\")\n            return\n        for ctrl in selected:\n            shapes = cmds.listRelatives(ctrl, shapes=True) or []\n            for shape in shapes:\n                cmds.setAttr(\"{}.overrideEnabled\".format(shape), 1)\n                cmds.setAttr(\"{}.overrideRGBColors\".format(shape), 1)\n                cmds.setAttr(\"{}.overrideColorRGB\".format(shape), *self.color_rgb)\n        print(u\"已应用颜色 RGB {}\".format(self.color_rgb))\n\n    @with_undo_support\n    def reset_color(self):\n        if not cmds:\n            return\n        selected_nodes = cmds.ls(selection=True, long=True)\n        if not selected_nodes:\n            print(u\"请至少选择一个控制器\")\n            return\n        shapes_to_reset = set()\n        for node in selected_nodes:\n            if cmds.objectType(node, isAType=\"shape\"):\n                shapes_to_reset.add(node)\n            else:\n                descendant_shapes = cmds.listRelatives(node, shapes=True, allDescendents=True, fullPath=True) or []\n                direct_shapes = cmds.listRelatives(node, shapes=True, fullPath=True) or []\n                for s in descendant_shapes + direct_shapes:\n                    shapes_to_reset.add(s)\n        reset_count = 0\n        for shape in shapes_to_reset:\n            try:\n                if cmds.attributeQuery(\"overrideRGBColors\", node=shape, exists=True):\n                    cmds.setAttr(\"{}.overrideRGBColors\".format(shape), 0)\n                if cmds.attributeQuery(\"overrideEnabled\", node=shape, exists=True):\n                    cmds.setAttr(\"{}.overrideEnabled\".format(shape), 0)\n                reset_count += 1\n            except Exception:\n                pass\n        print(u\"已重置 {} 个形状的颜色覆盖。\".format(reset_count))\n\n# ==================== 索引颜色选择器功能 ====================\n\ndef show_index_color_picker():\n    \"\"\"\n    创建颜色选择器窗口 (Index Color)\n    \"\"\"\n    # 如果窗口已存在，删除它\n    if cmds.window('colorChangeWin', exists=True):\n        cmds.deleteUI('colorChangeWin')\n    \n    # 创建窗口\n    window = cmds.window('colorChangeWin', title=u'索引颜色选择器', widthHeight=(320, 200))\n    \n    # 创建网格布局，8列4行\n    grid_layout = cmds.gridLayout(numberOfColumns=8, cellWidthHeight=(35, 35))\n    \n    # 定义颜色数组\n    colors = [\n        # 第一行\n        (0.5, 0.5, 0.5), (0, 0, 0), (0.247, 0.247, 0.247), (0.498, 0.498, 0.498),\n        (0.608, 0, 0.157), (0, 0.16, 0.376), (0, 0, 1), (0, 0.275, 0.094),\n        # 第二行\n        (0.149, 0, 0.263), (0.78, 0, 0.78), (0.537, 0.278, 0.2), (0.243, 0.133, 0.121),\n        (0.6, 0.145, 0), (1, 0, 0), (0, 1, 0), (0, 0.2549, 0.6),\n        # 第三行\n        (1, 1, 1), (1, 1, 0), (0.388, 0.863, 1), (0.263, 1, 0.639),\n        (1, 0.686, 0.686), (0.89, 0.674, 0.474), (1, 1, 0.388), (0, 0.6, 0.329),\n        # 第四行\n        (0.627, 0.411, 0.188), (0.619, 0.627, 0.188), (0.408, 0.631, 0.188), (0.188, 0.631, 0.365),\n        (0.188, 0.627, 0.627), (0.188, 0.403, 0.627), (0.434, 0.188, 0.627), (0.627, 0.188, 0.411)\n    ]\n    \n    # 创建按钮\n    for i, color in enumerate(colors):\n        cmds.button(\n            label='',\n            width=30,\n            height=30,\n            backgroundColor=color,\n            command=lambda x, color_index=i: apply_index_color_change(color_index)\n        )\n    \n    # 显示窗口\n    cmds.showWindow(window)\n\ndef apply_index_color_change(color_index):\n    \"\"\"\n    改变选中物体的颜色 (Index Color)\n    \"\"\"\n    # 获取选中的物体\n    selected_objects = cmds.ls(selection=True)\n    \n    if not selected_objects:\n        print(u\"请先选择物体\")\n        return\n    \n    for obj in selected_objects:\n        node_type = cmds.nodeType(obj)\n        \n        if node_type == 'joint':\n            # 骨骼节点直接设置颜色覆盖\n            cmds.setAttr(\"{}.overrideEnabled\".format(obj), 1)\n            cmds.setAttr(\"{}.overrideColor\".format(obj), color_index)\n        else:\n            # 其他物体类型，获取形状节点\n            shapes = cmds.listRelatives(obj, shapes=True, fullPath=True)\n            if shapes:\n                for shape in shapes:\n                    cmds.setAttr(\"{}.overrideEnabled\".format(shape), 1)\n                    cmds.setAttr(\"{}.overrideColor\".format(shape), color_index)\n            else:\n                # 如果没有形状节点，尝试直接在变换节点上设置\n                try:\n                    cmds.setAttr(\"{}.overrideEnabled\".format(obj), 1)\n                    cmds.setAttr(\"{}.overrideColor\".format(obj), color_index)\n                except:\n                    print(u\"无法为物体设置颜色: {}\".format(obj))\n    \n    print(u\"已为 {} 个物体设置颜色索引: {}\".format(len(selected_objects), color_index))\n\n# ==================== 主UI类 ====================\n\nclass CurveToolsIntegrated(QMainWindow):\n    \"\"\"曲线工具整合主窗口\"\"\"\n    \n    _instance = None\n\n    @classmethod\n    def get_instance(cls):\n        \"\"\"获取单例实例\"\"\"\n        if cls._instance is None:\n            cls._instance = CurveToolsIntegrated()\n        return cls._instance\n\n    def __init__(self):\n        super(CurveToolsIntegrated, self).__init__(parent=get_maya_main_window())\n        self.setWindowTitle(u\"曲线工具整合\")\n        self.setObjectName(\"CurveToolsIntegratedWindow\")\n        self.resize(175, 670)\n        \n        # 设置窗口标志\n        self.setWindowFlags(Qt.Window)\n        \n        # 初始化UI\n        self.init_ui()\n        \n        # 设置样式\n        self.setStyleSheet(\"\"\"\n            QMainWindow {\n                background-color: #3a3a3a;\n                color: #ffffff;\n            }\n            QLabel {\n                color: #ffffff;\n                font-size: 12px;\n            }\n            QPushButton {\n                background-color: #5a5a5a;\n                color: #ffffff;\n                border: 1px solid #7a7a7a;\n                border-radius: 3px;\n                padding: 4px;\n                font-size: 12px;\n                min-height: 10px;\n            }\n            QPushButton:hover {\n                background-color: #6a6a6a;\n            }\n            QPushButton:pressed {\n                background-color: #4a4a4a;\n            }\n            QDoubleSpinBox {\n                background-color: #5a5a5a;\n                color: #ffffff;\n                border: 1px solid #7a7a7a;\n                border-radius: 3px;\n                padding: 1px;\n                font-size: 12px;\n            }\n            QGroupBox {\n                color: #ffffff;\n                border: 2px solid #7a7a7a;\n                border-radius: 5px;\n                margin-top: 10px;\n                font-weight: bold;\n            }\n            QGroupBox::title {\n                subcontrol-origin: margin;\n                left: 10px;\n                padding: 0 5px 0 5px;\n            }\n        \"\"\")\n\n    def init_ui(self):\n        \"\"\"初始化用户界面\"\"\"\n        central_widget = QWidget()\n        self.setCentralWidget(central_widget)\n        \n        # 主布局\n        main_layout = QVBoxLayout(central_widget)\n        main_layout.setSpacing(8)\n        main_layout.setContentsMargins(8, 8, 8, 8)\n        \n        # 标题\n        title_label = QLabel(u\"曲线工具整合\")\n        title_label.setAlignment(Qt.AlignCenter)\n        title_label.setStyleSheet(\"font-size: 14px; font-weight: bold; margin-bottom: 5px;\")\n        main_layout.addWidget(title_label)\n        \n        # 曲线操作组\n        curve_ops_group = QGroupBox(u\"曲线操作\")\n        curve_ops_layout = QVBoxLayout(curve_ops_group)\n        curve_ops_layout.setSpacing(4)\n        \n        # 拆分和结合按钮\n        split_combine_layout = QHBoxLayout()\n        \n        split_btn = QPushButton(u\"拆分曲线\")\n        split_btn.setToolTip(u\"将多形状曲线拆分为单独的变换节点\")\n        split_btn.clicked.connect(self.split_curves)\n        split_combine_layout.addWidget(split_btn)\n        \n        combine_btn = QPushButton(u\"结合曲线\")\n        combine_btn.setToolTip(u\"将多个曲线合并为一个曲线\")\n        combine_btn.clicked.connect(self.combine_curves)\n        split_combine_layout.addWidget(combine_btn)\n        \n        curve_ops_layout.addLayout(split_combine_layout)\n        \n        # 添加形状和镜像按钮\n        shape_mirror_layout = QHBoxLayout()\n        \n        add_shape_btn = QPushButton(u\"添加形状\")\n        add_shape_btn.setToolTip(u\"将形状节点添加到目标物体\")\n        add_shape_btn.clicked.connect(self.add_shapes)\n        shape_mirror_layout.addWidget(add_shape_btn)\n        \n        mirror_btn = QPushButton(u\"镜像形状\")\n        mirror_btn.setToolTip(u\"沿X轴镜像曲线形状\")\n        mirror_btn.clicked.connect(self.mirror_shapes)\n        shape_mirror_layout.addWidget(mirror_btn)\n        \n        curve_ops_layout.addLayout(shape_mirror_layout)\n        \n        # 替换曲线形状按钮\n        replace_shape_btn = QPushButton(u\"替换曲线形状\")\n        replace_shape_btn.setToolTip(u\"用源曲线的形状替换多个目标曲线的形状（先选源，再选一个或多个目标）\")\n        replace_shape_btn.clicked.connect(self.replace_curve_shape)\n        curve_ops_layout.addWidget(replace_shape_btn)\n        \n        # 创建曲线按钮\n        create_curve_btn = QPushButton(u\"物体中心创建曲线\")\n        create_curve_btn.setToolTip(u\"基于选择物体中心创建曲线\")\n        create_curve_btn.clicked.connect(self.create_center_curve)\n        curve_ops_layout.addWidget(create_curve_btn)\n        \n        text_curve_btn = QPushButton(u\"生成文本曲线\")\n        text_curve_btn.setToolTip(u\"打开文本曲线生成器\")\n        text_curve_btn.clicked.connect(self.open_text_curve_generator)\n        curve_ops_layout.addWidget(text_curve_btn)\n        \n        main_layout.addWidget(curve_ops_group)\n        \n        # 曲线调整组\n        curve_adjust_group = QGroupBox(u\"曲线调整\")\n        curve_adjust_layout = QVBoxLayout(curve_adjust_group)\n        curve_adjust_layout.setSpacing(8)\n        \n        # 缩放倍率设置\n        scale_layout = QHBoxLayout()\n        scale_label = QLabel(u\"缩放倍率:\")\n        scale_layout.addWidget(scale_label)\n        \n        self.scale_factor_input = QDoubleSpinBox()\n        self.scale_factor_input.setRange(0.01, 100.0)\n        self.scale_factor_input.setValue(1.1)\n        self.scale_factor_input.setSingleStep(0.1)\n        self.scale_factor_input.setDecimals(2)\n        self.scale_factor_input.setToolTip(u\"设置每次缩放的倍率\")\n        scale_layout.addWidget(self.scale_factor_input)\n        \n        curve_adjust_layout.addLayout(scale_layout)\n        \n        # 大小调整按钮\n        size_layout = QHBoxLayout()\n        \n        scale_up_btn = QPushButton(u\"变大\")\n        scale_up_btn.setToolTip(u\"按设定倍率放大选中控制器的控制顶点\")\n        scale_up_btn.clicked.connect(self.scale_cv_handles_up)\n        size_layout.addWidget(scale_up_btn)\n        \n        scale_down_btn = QPushButton(u\"变小\")\n        scale_down_btn.setToolTip(u\"按设定倍率缩小选中控制器的控制顶点\")\n        scale_down_btn.clicked.connect(self.scale_cv_handles_down)\n        size_layout.addWidget(scale_down_btn)\n        \n        curve_adjust_layout.addLayout(size_layout)\n        \n        # 缩放模式选项（来自“曲线大小调整”工具）\n        mode_layout = QHBoxLayout()\n        self.local_scale_checkbox = QCheckBox(u\"使用形状局部中心缩放\")\n        self.local_scale_checkbox.setToolTip(u\"勾选时以每个形状的局部中心点为基准缩放，\\n不勾选时以控制器的轴心点为基准缩放\")\n        self.local_scale_checkbox.setChecked(False)\n        mode_layout.addWidget(self.local_scale_checkbox)\n        mode_layout.addStretch()\n        curve_adjust_layout.addLayout(mode_layout)\n        \n        # 宽度调整按钮\n        width_layout = QHBoxLayout()\n        \n        width_up_btn = QPushButton(u\"增加宽度\")\n        width_up_btn.setToolTip(u\"增加曲线显示宽度\")\n        width_up_btn.clicked.connect(self.increase_curve_width)\n        width_layout.addWidget(width_up_btn)\n        \n        width_down_btn = QPushButton(u\"减小宽度\")\n        width_down_btn.setToolTip(u\"减小曲线显示宽度\")\n        width_down_btn.clicked.connect(self.decrease_curve_width)\n        width_layout.addWidget(width_down_btn)\n        \n        curve_adjust_layout.addLayout(width_layout)\n        \n        main_layout.addWidget(curve_adjust_group)\n        \n        # Shape重命名组\n        rename_group = QGroupBox(u\"Shape重命名\")\n        rename_layout = QVBoxLayout(rename_group)\n        rename_layout.setSpacing(8)\n        \n        # 重命名按钮\n        rename_layout_btns = QHBoxLayout()\n        \n        rename_selected_btn = QPushButton(u\"重命名选中\")\n        rename_selected_btn.setToolTip(u\"重命名选中曲线的形状节点\")\n        rename_selected_btn.clicked.connect(self.rename_selected_shapes)\n        rename_layout_btns.addWidget(rename_selected_btn)\n        \n        rename_all_btn = QPushButton(u\"重命名全部\")\n        rename_all_btn.setToolTip(u\"重命名场景中所有曲线的形状节点\")\n        rename_all_btn.clicked.connect(self.rename_all_shapes)\n        rename_layout_btns.addWidget(rename_all_btn)\n        \n        rename_layout.addLayout(rename_layout_btns)\n        \n        main_layout.addWidget(rename_group)\n        \n        # 说明文字\n        info_label = QLabel(u\"请选择相应的曲线对象后使用对应工具\")\n        info_label.setAlignment(Qt.AlignCenter)\n        info_label.setStyleSheet(\"font-size: 15px; color: #cccccc; margin-top: 10px;\")\n        main_layout.addWidget(info_label)\n        \n        # 颜色工具组\n        color_group = QGroupBox(u\"颜色工具\")\n        color_layout = QVBoxLayout(color_group)\n        color_layout.setSpacing(8)\n        \n        # 随机颜色和重置颜色按钮\n        color_layout_btns = QHBoxLayout()\n        \n        random_color_btn = QPushButton(u\"随机颜色\")\n        random_color_btn.setToolTip(u\"为选中物体赋予随机颜色\")\n        random_color_btn.clicked.connect(self.assign_random_colors)\n        color_layout_btns.addWidget(random_color_btn)\n        \n        reset_color_btn = QPushButton(u\"重置颜色\")\n        reset_color_btn.setToolTip(u\"重置选中物体的颜色\")\n        reset_color_btn.clicked.connect(self.reset_colors)\n        color_layout_btns.addWidget(reset_color_btn)\n        \n        color_layout.addLayout(color_layout_btns)\n        \n        # 渐变颜色按钮\n        gradient_layout = QHBoxLayout()\n        \n        open_ramp_btn = QPushButton(u\"打开渐变编辑器\")\n        open_ramp_btn.setToolTip(u\"打开渐变颜色编辑器\")\n        open_ramp_btn.clicked.connect(self.open_ramp_editor)\n        gradient_layout.addWidget(open_ramp_btn)\n        \n        apply_gradient_btn = QPushButton(u\"应用渐变\")\n        apply_gradient_btn.setToolTip(u\"为选中物体应用渐变颜色\")\n        apply_gradient_btn.clicked.connect(self.apply_gradient_color)\n        gradient_layout.addWidget(apply_gradient_btn)\n        \n        color_layout.addLayout(gradient_layout)\n        \n        # Index Color Picker Button\n        index_color_btn = QPushButton(u\"索引颜色选择器\")\n        index_color_btn.setToolTip(u\"打开索引颜色选择器窗口\")\n        index_color_btn.clicked.connect(self.open_index_color_picker)\n        color_layout.addWidget(index_color_btn)\n\n        advanced_color_tool_btn = QPushButton(u\"高级颜色工具\")\n        advanced_color_tool_btn.setToolTip(u\"打开颜色工具窗口\")\n        advanced_color_tool_btn.clicked.connect(self.open_color_tool_window)\n        color_layout.addWidget(advanced_color_tool_btn)\n        \n        main_layout.addWidget(color_group)\n        \n        # 添加弹性空间\n        main_layout.addStretch()\n\n    # ==================== 按钮响应函数 ====================\n    \n    @with_undo_support\n    def split_curves(self):\n        \"\"\"拆分曲线\"\"\"\n        try:\n            result = selected_curves_separate()\n            if result:\n                if VERBOSE:\n                    print(u\"成功拆分 {} 个曲线形状\".format(len(result)))\n            else:\n                if VERBOSE:\n                    print(u\"拆分操作未执行或无需拆分\")\n        except Exception as e:\n            cmds.warning(u\"拆分曲线失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def combine_curves(self):\n        \"\"\"结合曲线\"\"\"\n        try:\n            result = selected_curves_combine()\n            if result:\n                if VERBOSE:\n                    print(u\"成功结合曲线: {}\".format(result))\n        except Exception as e:\n            cmds.warning(u\"结合曲线失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def add_shapes(self):\n        \"\"\"添加形状\"\"\"\n        try:\n            reparent_shape_nodes()\n        except Exception as e:\n            cmds.warning(u\"添加形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def mirror_shapes(self):\n        \"\"\"镜像形状\"\"\"\n        try:\n            mirror_curve_shape()\n        except Exception as e:\n            cmds.warning(u\"镜像形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def create_center_curve(self):\n        \"\"\"创建中心曲线\"\"\"\n        try:\n            result = create_center_curve()\n            if result:\n                if VERBOSE:\n                    print(u\"成功创建中心曲线: {}\".format(result))\n        except Exception as e:\n            cmds.warning(u\"创建中心曲线失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def scale_cv_handles_up(self):\n        \"\"\"放大控制器的控制顶点\"\"\"\n        selected_controllers = cmds.ls(selection=True, type=\"transform\")\n        if not selected_controllers:\n            cmds.warning(u\"请至少选择一个控制器！\")\n            return\n        \n        scale_factor = self.scale_factor_input.value()\n        use_local_center = getattr(self, 'local_scale_checkbox', None) and self.local_scale_checkbox.isChecked()\n        \n        for ctrl in selected_controllers:\n            # 获取所有的nurbsCurve形状节点\n            shapes = cmds.listRelatives(ctrl, shapes=True, type=\"nurbsCurve\") or []\n            if shapes:\n                # 遍历每个形状节点\n                for shape in shapes:\n                    # 获取该形状的所有控制顶点\n                    cvs = cmds.ls(\"{}.cv[*]\".format(shape), flatten=True)\n                    if cvs:\n                        # 根据选项选择缩放中心点\n                        if use_local_center:\n                            pivot = self.get_shape_local_center(shape)\n                        else:\n                            pivot = cmds.xform(ctrl, query=True, worldSpace=True, rotatePivot=True)\n                        \n                        for cv in cvs:\n                            pos = cmds.pointPosition(cv, world=True)\n                            vector = [pos[i] - pivot[i] for i in range(3)]\n                            scaled_vector = [v * scale_factor for v in vector]\n                            new_pos = [pivot[i] + scaled_vector[i] for i in range(3)]\n                            cmds.xform(cv, worldSpace=True, translation=new_pos)\n                \n                mode_text = u\"局部中心\" if use_local_center else u\"控制器轴心\"\n                if VERBOSE:\n                    print(u\"已将控制器 '{}' 的 {} 个形状节点的控制顶点按倍率 {} 放大（基于{}）\".format(ctrl, len(shapes), scale_factor, mode_text))\n            else:\n                cmds.warning(u\"'{}' 不是NURBS曲线控制器，跳过处理\".format(ctrl))\n\n    @with_undo_support\n    def scale_cv_handles_down(self):\n        \"\"\"缩小控制器的控制顶点\"\"\"\n        selected_controllers = cmds.ls(selection=True, type=\"transform\")\n        if not selected_controllers:\n            cmds.warning(u\"请至少选择一个控制器！\")\n            return\n        \n        scale_factor = 1.0 / self.scale_factor_input.value()\n        use_local_center = getattr(self, 'local_scale_checkbox', None) and self.local_scale_checkbox.isChecked()\n        \n        for ctrl in selected_controllers:\n            # 获取所有的nurbsCurve形状节点\n            shapes = cmds.listRelatives(ctrl, shapes=True, type=\"nurbsCurve\") or []\n            if shapes:\n                # 遍历每个形状节点\n                for shape in shapes:\n                    # 获取该形状的所有控制顶点\n                    cvs = cmds.ls(\"{}.cv[*]\".format(shape), flatten=True)\n                    if cvs:\n                        # 根据选项选择缩放中心点\n                        if use_local_center:\n                            pivot = self.get_shape_local_center(shape)\n                        else:\n                            pivot = cmds.xform(ctrl, query=True, worldSpace=True, rotatePivot=True)\n                        \n                        for cv in cvs:\n                            pos = cmds.pointPosition(cv, world=True)\n                            vector = [pos[i] - pivot[i] for i in range(3)]\n                            scaled_vector = [v * scale_factor for v in vector]\n                            new_pos = [pivot[i] + scaled_vector[i] for i in range(3)]\n                            cmds.xform(cv, worldSpace=True, translation=new_pos)\n                \n                mode_text = u\"局部中心\" if use_local_center else u\"控制器轴心\"\n                if VERBOSE:\n                    print(u\"已将控制器 '{}' 的 {} 个形状节点的控制顶点按倍率 {} 缩小（基于{}）\".format(ctrl, len(shapes), 1.0 / scale_factor, mode_text))\n            else:\n                cmds.warning(u\"'{}' 不是NURBS曲线控制器，跳过处理\".format(ctrl))\n\n    def get_shape_local_center(self, shape):\n        \"\"\"计算形状的局部中心点（所有CV的平均位置）\"\"\"\n        cvs = cmds.ls(\"{}.cv[*]\".format(shape), flatten=True)\n        if not cvs:\n            return [0, 0, 0]\n        \n        total_pos = [0, 0, 0]\n        for cv in cvs:\n            pos = cmds.pointPosition(cv, world=True)\n            for i in range(3):\n                total_pos[i] += pos[i]\n        \n        center = [total_pos[i] / len(cvs) for i in range(3)]\n        return center\n\n    @with_undo_support\n    def increase_curve_width(self):\n        \"\"\"增加曲线宽度\"\"\"\n        try:\n            increase_curve_width()\n        except Exception as e:\n            cmds.warning(u\"增加曲线宽度失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def decrease_curve_width(self):\n        \"\"\"减小曲线宽度\"\"\"\n        try:\n            decrease_curve_width()\n        except Exception as e:\n            cmds.warning(u\"减小曲线宽度失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def rename_selected_shapes(self):\n        \"\"\"重命名选中的形状\"\"\"\n        try:\n            rename_selected()\n        except Exception as e:\n            cmds.warning(u\"重命名选中形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def rename_all_shapes(self):\n        \"\"\"重命名所有形状\"\"\"\n        try:\n            auto_rename_all()\n        except Exception as e:\n            cmds.warning(u\"重命名所有形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def replace_curve_shape(self):\n        \"\"\"替换曲线形状\"\"\"\n        try:\n            replace_curve_shape()\n        except Exception as e:\n            cmds.warning(u\"替换曲线形状失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def assign_random_colors(self):\n        \"\"\"赋予随机颜色\"\"\"\n        try:\n            assign_random_colors_golden()\n        except Exception as e:\n            cmds.warning(u\"赋予随机颜色失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def reset_colors(self):\n        \"\"\"重置颜色\"\"\"\n        try:\n            reset_colors()\n        except Exception as e:\n            cmds.warning(u\"重置颜色失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def open_ramp_editor(self):\n        \"\"\"打开渐变编辑器\"\"\"\n        try:\n            open_ramp_editor()\n        except Exception as e:\n            cmds.warning(u\"打开渐变编辑器失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def apply_gradient_color(self):\n        \"\"\"应用渐变颜色\"\"\"\n        try:\n            apply_gradient_color()\n        except Exception as e:\n            cmds.warning(u\"应用渐变颜色失败: {}\".format(str(e)))\n    \n    @with_undo_support\n    def open_text_curve_generator(self):\n        try:\n            build_gui_generate_text_curve()\n        except Exception as e:\n            cmds.warning(u\"打开文本曲线生成器失败: {}\".format(str(e)))\n    \n    @with_undo_support\n    def open_index_color_picker(self):\n        try:\n            show_index_color_picker()\n        except Exception as e:\n            cmds.warning(u\"打开索引颜色选择器失败: {}\".format(str(e)))\n\n    @with_undo_support\n    def open_color_tool_window(self):\n        try:\n            if not hasattr(self, '_color_tool_window') or self._color_tool_window is None:\n                self._color_tool_window = ColorToolWindow()\n            self._color_tool_window.show()\n        except Exception as e:\n            cmds.warning(u\"打开颜色工具窗口失败: {}\".format(str(e)))\n\n    def closeEvent(self, event):\n        \"\"\"窗口关闭事件\"\"\"\n        # 清除实例引用\n        CurveToolsIntegrated._instance = None\n        event.accept()\n\n\ndef run_curve_tools_integrated():\n    \"\"\"运行曲线工具整合\"\"\"\n    try:\n        # 获取窗口实例\n        window = CurveToolsIntegrated.get_instance()\n        window.show()\n        window.raise_()\n        window.activateWindow()\n        return window\n    except Exception as e:\n        print(u\"运行曲线工具整合时出错: {}\".format(str(e)))\n        print(u\"请确保在Maya环境中运行此工具\")\n        return None\n\n\nif __name__ == \"__main__\":\n    try:\n        run_curve_tools_integrated()\n    except ImportError:\n        print(\"=\" * 50)\n        print(u\"错误: 此工具需要在Maya环境中运行\")\n        print(u\"请使用Maya的script editor或通过Maya的Python解释器运行此脚本\")\n        print(\"=\" * 50)\n    except Exception as e:\n        print(u\"工具启动失败: {}\".format(str(e)))\n        print(u\"请确保在Maya环境中运行此工具\")\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
