        -command "import maya.cmds as cmds\n\n\ndef mirror_push_settings(push_jnt):\n    \"\"\"\n    镜像推力关节的设置。\n\n    参数：\n        push_jnt (str): 左侧推力关节的名称。\n    \"\"\"\n    # 获取输入连接\n    input_nodes = cmds.listConnections(push_jnt, source=True, destination=False, plugs=False, type='remapValue')\n\n    if input_nodes:\n        for remap_node in input_nodes:\n            remap_mirror = remap_node.replace('_l_', '_r_')\n\n            # 获取并设置 inputMax 值\n            val = cmds.getAttr(remap_node + '.inputMax')\n            cmds.setAttr(remap_mirror + '.inputMax', val)\n\n            # 获取并设置 outputMax 值\n            val = cmds.getAttr(remap_node + '.outputMax')\n            if 'Dis' in remap_node:\n                val = -val\n            cmds.setAttr(remap_mirror + '.outputMax', val)\n\n\n# 获取所有左侧推力关节\npush_jnts = cmds.ls('jnt_l_*Push_???', type='joint')\nfor jnt in push_jnts:\n    mirror_push_settings(jnt)  # 使用正确的变量名\n\ncmds.confirmDialog(title=\"Success\", message=\"ok!\", button=[\"OK\"])\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "肌肉函数" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "肌肉函数" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "肌肉函数" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\n\ndef create_muscle_joint(blueprint_joint, parent_joint, driver_joint, position_override=None, up_vector=None,\n                        skip_axis=None, pos_limit=None, volume_y=0.5, volume_z=0.5, connect_driver=None,\n                        connect_attrs=None, connect_weight=1, mirror=True):\n    \"\"\"\n    create single chain aim constraint setup to simulate muscle behavior\n\n    Args:\n        blueprint_joint (str): muscle joint's blueprint, need to have a child joint and proper joint orientation\n        parent_joint (str): muscle joint setup's parent joint\n        driver_joint (str): driver joint for muscle behavior\n        position_override (str): if the muscle joint need to follow the other node's position, but keep the space under\n                                 the parent joint, then put the node name here.\n        up_vector (list): muscle joint's up vector, default is [0, 1, 0]\n        skip_axis (list): skip translation axis for aim target\n        pos_limit (list): aim target's translation limitation, the format is\n                          [[x_min, x_max], [y_min, y_max], [z_min, z_max]], use None if no limitation value,\n                          like [[-1, None], None, [None, 20]]\n        volume_y (float): scale volume on y axis\n        volume_z (float): scale volume on z axis\n        connect_driver (str): driver node name if need to connect attribute to aim target directly.\n                              some area like bicep works better this way\n        connect_attrs (list): driver and driven attributes to connect together\n        connect_weight (float): connection weight between driver and driven attributes\n        mirror (bool): mirror setup from left side to right\n    \"\"\"\n    # get name parts\n    name_parts = blueprint_joint.split('_')\n    side = name_parts[1]\n    description = name_parts[2]\n    index = int(name_parts[3])\n\n    # get end blueprint joint\n    blueprint_end = cmds.listRelatives(blueprint_joint, children=True, type='joint')[0]\n\n    # duplicate joints base on blueprint\n    muscle_jnt = cmds.duplicate(blueprint_joint, name=blueprint_joint.replace('bpJnt', 'jnt'))[0]\n    # get muscle end joint's full path since the duplications has the same name as blueprint end\n    muscle_end = cmds.listRelatives(muscle_jnt, children=True, fullPath=True)[0]\n    # rename so we will have unique name for muscle end joint\n    muscle_end = cmds.rename(muscle_end, blueprint_end.replace('bpJnt', 'jnt'))\n\n    # create muscle joint group to hold all nodes\n    muscle_grp = cmds.createNode('transform', name='grp_{}_{}RigNodes_{:03d}'.format(side, description, index))\n    # snap to muscle joint\n    cmds.matchTransform(muscle_grp, muscle_jnt, position=True, rotation=True)\n    # parent to parent joint\n    cmds.parent(muscle_grp, parent_joint)\n    # parent muscle joint to muscle group\n    cmds.parent(muscle_jnt, muscle_grp)\n\n    # constraint if have node name in position override\n    if position_override:\n        cmds.parentConstraint(position_override, muscle_jnt, maintainOffset=True, skipRotate=['x', 'y', 'z'])\n\n    # create aim target with groups\n    aim_target = cmds.spaceLocator(name='loc_{}_{}Target_{:03d}'.format(side, description, index))[0]\n    connect_target = cmds.createNode('transform', name=aim_target.replace('loc', 'connect'))\n    driven_target = cmds.createNode('transform', name=aim_target.replace('loc', 'driven'))\n    zero_target = cmds.createNode('transform', name=aim_target.replace('loc', 'zero'))\n\n    cmds.parent(aim_target, connect_target)\n    cmds.parent(connect_target, driven_target)\n    cmds.parent(driven_target, zero_target)\n\n    # create transform to represent aim target's position under muscle group\n    pos_target = cmds.createNode('transform', name='grp_{}_{}TargetPos_{:03d}'.format(side, description, index))\n    cmds.pointConstraint(aim_target, pos_target, maintainOffset=False)\n\n    # match aim target position to end joint\n    cmds.matchTransform(zero_target, muscle_end, position=True)\n    # match aim target rotation to muscle joint\n    cmds.matchTransform(zero_target, muscle_jnt, rotation=True)\n\n    # parent both under muscle group\n    cmds.parent(pos_target, zero_target, muscle_grp)\n\n    # hide locator\n    cmds.setAttr(aim_target + '.visibility', 0)\n\n    # create aim constraint\n    # get end joint translate X value, if it's greater than or equal to 0, aim vector is [1, 0, 0]\n    # otherwise it's [-1, 0, 0]\n    tx_val = cmds.getAttr(muscle_end + '.translateX')\n    if tx_val >= 0:\n        aim_vector = [1, 0, 0]\n    else:\n        aim_vector = [-1, 0, 0]\n\n    if not up_vector:\n        up_vector = [0, 1, 0]\n\n    cmds.aimConstraint(aim_target, muscle_jnt, aimVector=aim_vector, upVector=up_vector, worldUpType='none',\n                       maintainOffset=False)\n\n    # parent constraint aim target's driven group with driver joint\n    if skip_axis:\n        skip_translate = skip_axis\n    else:\n        skip_translate = 'none'\n    cmds.parentConstraint(driver_joint, driven_target, maintainOffset=True, skipTranslate=skip_translate,\n                          skipRotate=['x', 'y', 'z'])\n\n    # connect attribute for aim target's connect group\n    if connect_driver and connect_attrs:\n        mult = cmds.createNode('multDoubleLinear',\n                               name='mult_{}_{}TargetDriver_{:03d}'.format(side, description, index))\n        cmds.connectAttr('{}.{}'.format(connect_driver, connect_attrs[0]), mult + '.input1')\n        cmds.setAttr(mult + '.input2', connect_weight)\n        cmds.connectAttr(mult + '.output', '{}.{}'.format(connect_target, connect_attrs[1]))\n\n    # set pos limitation\n    if pos_limit:\n        pos_info = {}\n        for axis, limits in zip(['x', 'y', 'z'], pos_limit):\n            # [[x_min, x_max], [y_min, y_max], [z_min, z_max]]\n            # x, [x_min, x_max]/None\n            if limits:\n                enable_limits = [False, False]\n                limits_values = [-100, 100]\n                if limits[0] is not None:\n                    enable_limits[0] = True\n                    limits_values[0] = limits[0]\n                if limits[1] is not None:\n                    enable_limits[1] = True\n                    limits_values[1] = limits[1]\n                pos_info.update({'enable_' + axis: enable_limits,\n                                 'limit_' + axis: limits_values})\n\n        cmds.transformLimits(driven_target, translationX=pos_info.get('limit_x', [-100, 100]),\n                             enableTranslationX=pos_info.get('enable_x', [False, False]),\n                             translationY=pos_info.get('limit_y', [-100, 100]),\n                             enableTranslationY=pos_info.get('enable_y', [False, False]),\n                             translationZ=pos_info.get('limit_z', [-100, 100]),\n                             enableTranslationZ=pos_info.get('enable_z', [False, False]))\n\n    # add stretch\n    # add distance node between muscle joint and target transform\n    dis_node = cmds.createNode('distanceBetween', name='dis_{}_{}Stretch_{:03d}'.format(side, description, index))\n    cmds.connectAttr(muscle_jnt + '.translate', dis_node + '.point1')\n    cmds.connectAttr(pos_target + '.translate', dis_node + '.point2')\n    # get distance value\n    dis_val = cmds.getAttr(dis_node + '.distance')\n\n    # use multiply divide node to get stretch ratio\n    div_node = cmds.createNode('multiplyDivide', name='div_{}_{}StretchRatio_{:03d}'.format(side, description, index))\n    cmds.setAttr(div_node + '.operation', 2)\n    cmds.connectAttr(dis_node + '.distance', div_node + '.input1X')\n    cmds.setAttr(div_node + '.input2X', dis_val)\n\n    # connect stretch ratio to muscle joint's scale X\n    cmds.connectAttr(div_node + '.outputX', muscle_jnt + '.scaleX')\n\n    # add stretch volume\n    # add volume attributes to control the behavior\n    cmds.addAttr(muscle_jnt, longName='volumeY', attributeType='float', defaultValue=volume_y, keyable=True)\n    cmds.addAttr(muscle_jnt, longName='volumeZ', attributeType='float', defaultValue=volume_z, keyable=True)\n    # use power to get volume values, in order to do this, we need reverse the stretch ratio\n    cmds.setAttr(div_node + '.input1Y', dis_val)\n    cmds.connectAttr(dis_node + '.distance', div_node + '.input2Y')\n    # create power node\n    power_node = cmds.createNode('multiplyDivide', name='power_{}_{}StretchVol_{:03d}'.format(side, description, index))\n    cmds.setAttr(power_node + '.operation', 3)\n    cmds.connectAttr(div_node + '.outputY', power_node + '.input1Y')\n    cmds.connectAttr(div_node + '.outputY', power_node + '.input1Z')\n    cmds.connectAttr(muscle_jnt + '.volumeY', power_node + '.input2Y')\n    cmds.connectAttr(muscle_jnt + '.volumeZ', power_node + '.input2Z')\n    # connect back scale YZ\n    cmds.connectAttr(power_node + '.outputY', muscle_jnt + '.scaleY')\n    cmds.connectAttr(power_node + '.outputZ', muscle_jnt + '.scaleZ')\n\n    # check if need mirror\n    if mirror and side == 'l':\n        # get mirrored pos limitation, because the translation values are opposite,\n        # left side's max value multiply -1 will be right side's min value\n        # left's min value multiply -1 will be right's max value\n        pos_limit_mirror = []\n        if pos_limit:\n            for limits in pos_limit:\n                if limits:\n                    limits_mirror = [None, None]\n                    if limits[0] is not None:\n                        limits_mirror[1] = -limits[0]\n                    if limits[1] is not None:\n                        limits_mirror[0] = -limits[1]\n                    pos_limit_mirror.append(limits_mirror)\n                else:\n                    pos_limit_mirror.append(None)\n\n        # get mirrored position override\n        position_override_mirror = None\n        if position_override:\n            position_override_mirror = position_override.replace('_l_', '_r_')\n\n        # get mirrored connect driver\n        connect_driver_mirror = None\n        if connect_driver:\n            connect_driver_mirror = connect_driver.replace('_l_', '_r_')\n\n        # mirror blueprints\n        cmds.mirrorJoint(blueprint_joint, mirrorYZ=True, mirrorBehavior=True, searchReplace=['_l_', '_r_'])\n\n        # create muscle joint base on mirrored blueprint\n        create_muscle_joint(blueprint_joint.replace('_l_', '_r_'), parent_joint.replace('_l_', '_r_'),\n                            driver_joint.replace('_l_', '_r_'), position_override=position_override_mirror,\n                            up_vector=up_vector, skip_axis=skip_axis, pos_limit=pos_limit_mirror,\n                            volume_y=volume_y, volume_z=volume_z, connect_driver=connect_driver_mirror,\n                            connect_attrs=connect_attrs, connect_weight=connect_weight, mirror=False)\n\n\ncmds.confirmDialog(title=\"Success\", message=\"ok!\", button=[\"OK\"])" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "肌肉运行参数" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "肌肉运行参数" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "肌肉运行参数" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "# coding=utf-8\nfrom collections import OrderedDict\n\n\nmuscle_joints_info = OrderedDict()\nmuscle_joints_info.update({\n                           # neck\n                           'bpJnt_l_sternocleidomastoid_001': {'parent_joint': 'jnt_m_headLocal_001',  # 头部关节\n                                                               'driver_joint': 'jnt_m_sternum_001',\n                                                               'volume_y': 1,\n                                                               'volume_z': 1,\n                                                               'mirror': True},\n\n                           'bpJnt_l_sternocleidomastoid_002': {'parent_joint': 'jnt_m_headLocal_001',\n                                                               'driver_joint': 'jnt_l_clavicle_001',\n                                                               'volume_y': 1,\n                                                               'volume_z': 1,\n                                                               'mirror': True},\n\n                           'bpJnt_m_sternohyoid_001': {'parent_joint': 'jnt_m_headLocal_001',\n                                                       'driver_joint': 'jnt_m_sternum_001',\n                                                       'volume_y': 1,\n                                                       'volume_z': 1,\n                                                       'mirror': True},\n\n                           # back body\n                           'bpJnt_l_trapezius_001': {'parent_joint': 'jnt_m_headLocal_001',\n                                                     'driver_joint': 'jnt_l_scapula_001',\n                                                     'volume_y': 1,\n                                                     'volume_z': 1,\n                                                     'mirror': True},\n\n                           'bpJnt_l_trapezius_002': {'parent_joint': 'jnt_m_spine_006',\n                                                     'driver_joint': 'jnt_l_scapula_001',\n                                                     'volume_y': 1,\n                                                     'volume_z': 1,\n                                                     'mirror': True},\n\n                           'bpJnt_l_trapezius_003': {'parent_joint': 'jnt_m_spine_005',\n                                                     'driver_joint': 'jnt_l_scapula_001',\n                                                     'volume_y': 1,\n                                                     'volume_z': 1,\n                                                     'mirror': True},\n\n                           'bpJnt_l_latissimusDorsi_001': {'parent_joint': 'jnt_m_spine_002',\n                                                           'driver_joint': 'jnt_l_upperArmTwist_001',  # 大臂Twist第一个关节\n                                                           'volume_y': 1,\n                                                           'volume_z': 1,\n                                                           'mirror': True},\n\n                           # chest\n                           'bpJnt_l_pectoralis_001': {'parent_joint': 'jnt_l_clavicle_001',\n                                                      'driver_joint': 'jnt_l_upperArmTwist_001',\n                                                      'volume_y': 1,\n                                                      'volume_z': 1,\n                                                      'pos_limit': [None, [0, None], None],\n                                                      'mirror': True},\n\n                           'bpJnt_l_pectoralis_002': {'parent_joint': 'jnt_m_sternum_001',\n                                                      'driver_joint': 'jnt_l_upperArmTwist_001',\n                                                      'volume_y': 1,\n                                                      'volume_z': 1,\n                                                      'pos_limit': [None, [-5, None], None],\n                                                      'mirror': True},\n\n                           'bpJnt_l_pectoralis_003': {'parent_joint': 'jnt_m_sternum_001',\n                                                      'driver_joint': 'jnt_l_upperArmTwist_001',\n                                                      'volume_y': 1,\n                                                      'volume_z': 1,\n                                                      'pos_limit': [None, [-5, None], None],\n                                                      'mirror': True},\n\n                          # lower body\n                          'bpJnt_l_externalOblique_001': {'parent_joint': 'jnt_m_pelvisIkLocal_001',  # 胯部关节\n                                                          'driver_joint': 'jnt_l_ribA_002',\n                                                          'volume_y': 0,\n                                                          'volume_z': 0,\n                                                          'mirror': True},\n\n                          'bpJnt_l_externalOblique_002': {'parent_joint': 'jnt_m_pelvisIkLocal_001',\n                                                          'driver_joint': 'jnt_l_ribB_003',\n                                                          'volume_y': 0.5,\n                                                          'volume_z': 0,\n                                                          'mirror': True},\n\n                          'bpJnt_m_rectusAbdominis_001': {'parent_joint': 'jnt_m_pelvisIkLocal_001',\n                                                          'driver_joint': 'jnt_m_sternum_001',\n                                                          'volume_y': 1,\n                                                          'volume_z': 0,\n                                                          'mirror': False},\n\n                          # scapula\n                          'bpJnt_l_infraspinatus_001': {'parent_joint': 'jnt_l_scapula_001',\n                                                        'driver_joint': 'jnt_l_upperArmTwist_001',\n                                                        'volume_y': 1,\n                                                        'volume_z': 1,\n                                                        'mirror': True},\n\n                          'bpJnt_l_teresMajor_001': {'parent_joint': 'jnt_l_scapula_001',\n                                                     'driver_joint': 'jnt_l_upperArmTwist_001',\n                                                     'volume_y': 1,\n                                                     'volume_z': 1,\n                                                     'mirror': True},\n\n                          # shoulder\n                          'bpJnt_l_deltoid_001': {'parent_joint': 'jnt_l_clavicle_001',\n                                                  'driver_joint': 'jnt_l_upperArmTwist_001',\n                                                  'volume_y': 0.5,\n                                                  'volume_z': 0.5,\n                                                  'mirror': True},\n\n                          'bpJnt_l_deltoid_002': {'parent_joint': 'jnt_l_scapula_001',\n                                                  'driver_joint': 'jnt_l_upperArmTwist_001',\n                                                  'volume_y': 0.5,\n                                                  'volume_z': 0.5,\n                                                  'mirror': True},\n\n                          'bpJnt_l_deltoid_003': {'parent_joint': 'jnt_l_scapula_001',\n                                                  'driver_joint': 'jnt_l_upperArmTwist_001',\n                                                  'volume_y': 0.5,\n                                                  'volume_z': 0.5,\n                                                  'mirror': True},\n\n                          # upper arm\n                          'bpJnt_l_bicepsBrachii_001': {'parent_joint': 'jnt_l_upperArmTwist_001',\n                                                        'driver_joint': 'jnt_l_upperArmTwist_005',\n                                                        'connect_driver': 'jnt_l_elbow_001',\n                                                        'connect_attrs': ['rotateY', 'translateX'],\n                                                        'connect_weight': 0.150,\n                                                        'volume_y': 2.5,\n                                                        'volume_z': 2.5,\n                                                        'mirror': True},\n\n                          'bpJnt_l_tricepsBrachii_001': {'parent_joint': 'jnt_l_upperArmTwist_001',\n                                                         'driver_joint': 'jnt_l_upperArmTwist_005',\n                                                         'connect_driver': 'jnt_l_elbow_001',\n                                                         'connect_attrs': ['rotateY', 'translateX'],\n                                                         'connect_weight': -0.03,\n                                                         'volume_y': 2,\n                                                         'volume_z': 2,\n                                                         'mirror': True},\n\n                          'bpJnt_l_brachialis_001': {'parent_joint': 'jnt_l_upperArmTwist_002',\n                                                     'driver_joint': 'jnt_l_upperArmTwist_005',\n                                                     'connect_driver': 'jnt_l_elbow_001',\n                                                     'volume_y': 2,\n                                                     'volume_z': 2,\n                                                     'connect_attrs': ['rotateY', 'translateX'],\n                                                     'connect_weight': 0.1,\n                                                     'mirror': True},\n\n                          # elbow arm\n                          'bpJnt_l_brachioradialis_001': {'parent_joint': 'jnt_l_elbowTwist_001',  # 小臂Twist第一个关节\n                                                          'driver_joint': 'jnt_l_elbowTwist_005',\n                                                          'position_override': 'jnt_l_upperArmTwist_005',\n                                                          'volume_y': 2,\n                                                          'volume_z': 2,\n                                                          'mirror': True},\n\n                          'bpJnt_l_extensorCarpiRadialisLongus_001': {'parent_joint': 'jnt_l_elbowTwist_001',\n                                                                      'driver_joint': 'jnt_l_wrist_001',\n                                                                      'volume_y': 1,\n                                                                      'volume_z': 1,\n                                                                      'pos_limit': [None, [0, None], None],\n                                                                      'mirror': True},\n\n                          'bpJnt_l_flexorCarpiRadialis_001': {'parent_joint': 'jnt_l_elbowTwist_001',\n                                                              'driver_joint': 'jnt_l_wrist_001',\n                                                              'volume_y': 1,\n                                                              'volume_z': 1,\n                                                              'pos_limit': [None, [0, None], None],\n                                                              'mirror': True},\n\n                          # pelvis\n                          'bpJnt_l_gluteusMedius_001': {'parent_joint': 'jnt_m_pelvisIkLocal_001',\n                                                        'driver_joint': 'jnt_l_upperLegTwist_001',  # 大腿Twist第一关节\n                                                        'volume_y': 1,\n                                                        'volume_z': 0,\n                                                        'mirror': True},\n\n                          'bpJnt_l_gluteusMaximus_001': {'parent_joint': 'jnt_m_pelvisIkLocal_001',\n                                                         'driver_joint': 'jnt_l_upperLegTwist_001',\n                                                         'volume_y': 1,\n                                                         'volume_z': 1,\n                                                         'mirror': True},\n\n                          # upper leg\n                          'bpJnt_l_rectusFemoris_001': {'parent_joint': 'jnt_l_upperLegTwist_001',\n                                                        'driver_joint': 'jnt_l_upperLegTwist_005',\n                                                        'connect_driver': 'jnt_l_knee_001',\n                                                        'volume_y': 1,\n                                                        'volume_z': 1,\n                                                        'connect_attrs': ['rotateZ', 'translateX'],\n                                                        'connect_weight': -0.05,\n                                                        'mirror': True},\n\n                          'bpJnt_l_vastusLateralis_001': {'parent_joint': 'jnt_l_upperLegTwist_001',\n                                                          'driver_joint': 'jnt_l_upperLegTwist_005',\n                                                          'connect_driver': 'jnt_l_knee_001',\n                                                          'volume_y': 1,\n                                                          'volume_z': 1,\n                                                          'connect_attrs': ['rotateZ', 'translateX'],\n                                                          'connect_weight': -0.05,\n                                                          'mirror': True},\n\n                          'bpJnt_l_semitendinosus_001': {'parent_joint': 'jnt_l_upperLegTwist_001',\n                                                         'driver_joint': 'jnt_l_upperLegTwist_005',\n                                                         'connect_driver': 'jnt_l_knee_001',\n                                                         'volume_y': 2,\n                                                         'volume_z': 2,\n                                                         'connect_attrs': ['rotateZ', 'translateX'],\n                                                         'connect_weight': 0.1,\n                                                         'mirror': True},\n\n                          'bpJnt_l_bicepsFemoris_001': {'parent_joint': 'jnt_l_upperLegTwist_001',\n                                                        'driver_joint': 'jnt_l_upperLegTwist_005',\n                                                        'connect_driver': 'jnt_l_knee_001',\n                                                        'volume_y': 2,\n                                                        'volume_z': 2,\n                                                        'connect_attrs': ['rotateZ', 'translateX'],\n                                                        'connect_weight': 0.1,\n                                                        'mirror': True},\n\n                          'bpJnt_l_adductorLongus_001': {'parent_joint': 'jnt_m_pelvisIkLocal_001',\n                                                         'driver_joint': 'jnt_l_upperLegTwist_003',\n                                                         'volume_y': 1,\n                                                         'volume_z': 1,\n                                                         'mirror': True},\n\n                          'bpJnt_l_gracilis_001': {'parent_joint': 'jnt_m_pelvisIkLocal_001',\n                                                   'driver_joint': 'jnt_l_upperLegTwist_005',\n                                                   'volume_y': 1,\n                                                   'volume_z': 1,\n                                                   'mirror': True},\n\n                          # lower leg\n                          'bpJnt_l_extensorDigitorumLongus_001': {'parent_joint': 'jnt_l_kneeTwist_001',  # 小腿Twist第一关节\n                                                                  'driver_joint': 'jnt_l_ankle_001',\n                                                                  'volume_y': 1,\n                                                                  'volume_z': 1,\n                                                                  'pos_limit': [None, [0, None], None],\n                                                                  'mirror': True},\n\n                          'bpJnt_l_achillesTendon_001': {'parent_joint': 'jnt_l_kneeTwist_003',\n                                                         'driver_joint': 'jnt_l_ankle_001',\n                                                         'volume_y': 0,\n                                                         'volume_z': 0,\n                                                         'pos_limit': [None, [0, None], None],\n                                                         'mirror': True}})\n\nmuscle_joints_info.update({\n                          'bpJnt_l_gastrocnemius_001': {'parent_joint': 'jnt_l_kneeTwist_001',\n                                                        'driver_joint': 'jnt_l_achillesTendon_001',\n                                                        'volume_y': 2,\n                                                        'volume_z': 2,\n                                                        'mirror': True},\n\n                          'bpJnt_l_gastrocnemius_002': {'parent_joint': 'jnt_l_kneeTwist_001',\n                                                        'driver_joint': 'jnt_l_achillesTendon_001',\n                                                        'volume_y': 2,\n                                                        'volume_z': 2,\n                                                        'mirror': True}})\n\nfor bp_jnt, muscle_data in muscle_joints_info.items():\n    parent_jnt = muscle_data.get('parent_joint', None)\n    driver_jnt = muscle_data.get('driver_joint', None)\n    position_override = muscle_data.get('position_override', None)\n    up_vector = muscle_data.get('up_vector', None)\n    skip_axis = muscle_data.get('skip_axis', None)\n    pos_limit = muscle_data.get('pos_limit', None)\n    volume_y = muscle_data.get('volume_y', 0.5)\n    volume_z = muscle_data.get('volume_z', 0.5)\n    connect_driver = muscle_data.get('connect_driver', None)\n    connect_attrs = muscle_data.get('connect_attrs', None)\n    connect_weight = muscle_data.get('connect_weight', 1)\n    mirror = muscle_data.get('mirror', True)\n\n    create_muscle_joint(bp_jnt, parent_jnt, driver_jnt, position_override=position_override, up_vector=up_vector,\n                        skip_axis=skip_axis, pos_limit=pos_limit, volume_y=volume_y, volume_z=volume_z,\n                        connect_driver=connect_driver, connect_attrs=connect_attrs, connect_weight=connect_weight,\n                        mirror=mirror)\n\ncmds.confirmDialog(title=\"Success\", message=\"ok!\", button=[\"OK\"])\n" 
