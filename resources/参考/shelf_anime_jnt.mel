        -command "import maya.cmds as cmds\n\nbp_jnts = cmds.listRelatives('grp_m_muscleJointsBlueprints_001')\n\njnts = []\n\nfor bp in bp_jnts:\n\tj = bp.replace('bpJnt', 'jnt')\n\tjnts.append(j)\n\tif '_l_' in j:\n\t\t\tj_r = j.replace('_l_', '_r_')\n\t\t\tjnts.append(j_r)\n\t\t\ncmds.select(jnts)" 
