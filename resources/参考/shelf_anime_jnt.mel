global proc shelf_anime_jnt () {
    global string $gBuffStr;
    global string $gBuffStr0;
    global string $gBuffStr1;


    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "一键动力学依次选择骨骼" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "一键动力学" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "一键动力学" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\n\ncmds.loadPlugin(\"boneDynamicsNode.mll\", qt=True)\n\ndef create_dynamics_node(\n        bone, \n        end, \n        scalable=False, \n        target_bone=None, \n        offset_node=None, \n        colliders=[],\n        visualize=True,\n        additional_force_node=None, \n        additional_force_init_vec=[0,0,-1]\n    ):\n\n    if not bone in cmds.listRelatives(end, p=True):\n        print(\"Exit: {} is not {}'s parent.\".format(bone, end))\n        return\n    \n    boneDynamicsNode = cmds.createNode(\"boneDynamicsNode\")\n\n    cmds.connectAttr('time1.outTime', boneDynamicsNode + '.time', force=True)\n    cmds.connectAttr(bone + '.translate', boneDynamicsNode + '.boneTranslate', f=True)\n    cmds.connectAttr(bone + '.parentMatrix[0]', boneDynamicsNode + '.boneParentMatrix', f=True)\n    cmds.connectAttr(bone + '.parentInverseMatrix[0]', boneDynamicsNode + '.boneParentInverseMatrix', f=True)\n    cmds.connectAttr(bone + '.jointOrient', boneDynamicsNode + '.boneJointOrient', f=True)\n    cmds.connectAttr(end + '.translate', boneDynamicsNode + '.endTranslate', f=True)\n\n    cmds.connectAttr(boneDynamicsNode + '.outputRotate', bone + '.rotate', f=True)\n    \n    if scalable:\n        cmds.connectAttr(bone + '.scale', boneDynamicsNode + '.boneScale', f=True)\n        cmds.connectAttr(bone + '.inverseScale', boneDynamicsNode + '.boneInverseScale', f=True)\n        cmds.connectAttr(end + '.scale', boneDynamicsNode + '.endScale', f=True)\n\n    if target_bone:\n        if cmds.objExists(target_bone):\n            cmds.connectAttr(target_bone + '.rotate', boneDynamicsNode + '.rotationOffset', f=True)\n\n    if offset_node:\n        if cmds.objExists(offset_node):\n            cmds.connectAttr(offset_node + '.worldMatrix[0]', boneDynamicsNode + '.offsetMatrix', f=True)\n\n    if additional_force_node:\n        if cmds.objExists(additional_force_node):\n            vp = cmds.listConnections(additional_force_node + '.worldMatrix[0]', s=False, d=True, type='vectorProduct')\n            if vp:\n                vp = vp[0]\n            else:\n                vp = cmds.createNode('vectorProduct')\n                cmds.setAttr(vp + '.operation', 3)\n                cmds.setAttr(vp + '.input1', additional_force_init_vec[0], additional_force_init_vec[1], additional_force_init_vec[2], type='double3')\n                cmds.setAttr(vp + '.normalizeOutput', 1)\n                cmds.connectAttr(additional_force_node + '.worldMatrix[0]', vp + '.matrix', f=True)\n            cmds.connectAttr(vp + '.output', boneDynamicsNode + '.additionalForce', f=True)\n                \n    if visualize:\n        # angle limit\n        angle_cone = cmds.createNode(\"implicitCone\")\n        angle_cone_tm = cmds.listRelatives(angle_cone, p=True)[0]\n        angle_cone_ro = cmds.createNode(\"transform\", n=\"{}_cone_ro\".format(bone))\n        angle_cone_root = cmds.createNode(\"transform\", n=\"{}_cone_root\".format(bone))\n        cmds.setAttr(angle_cone_tm + '.ry', -90)\n        cmds.parent(angle_cone_tm, angle_cone_ro, r=True)\n        cmds.parent(angle_cone_ro, angle_cone_root, r=True)\n        bone_parent = cmds.listRelatives(bone, p=True)\n        if bone_parent:\n            cmds.parent(angle_cone_root, bone_parent[0], r=True)\n        cmds.connectAttr(boneDynamicsNode + '.boneTranslate', angle_cone_root + '.translate', f=True)\n        cmds.connectAttr(boneDynamicsNode + '.boneJointOrient', angle_cone_root + '.rotate', f=True)\n        cmds.connectAttr(boneDynamicsNode + '.rotationOffset', angle_cone_ro + '.rotate', f=True)\n        cmds.connectAttr(boneDynamicsNode + '.enableAngleLimit', angle_cone_root + '.v', f=True)\n        cmds.connectAttr(boneDynamicsNode + '.angleLimit', angle_cone + '.coneAngle', f=True)\n        cmds.setAttr(angle_cone + '.coneCap', 2)\n        cmds.setAttr(angle_cone_tm + '.overrideEnabled', 1)\n        cmds.setAttr(angle_cone_tm + '.overrideDisplayType', 2)\n\n        # collision radius\n        radius_sphere = cmds.createNode(\"implicitSphere\")\n        cmds.connectAttr(boneDynamicsNode + '.radius', radius_sphere + '.radius', f=True)\n        radius_sphere_tm = cmds.listRelatives(radius_sphere, p=True)[0]\n        cmds.parent(radius_sphere_tm, end, r=True)\n        cmds.setAttr(radius_sphere_tm + '.overrideEnabled', 1)\n        cmds.setAttr(radius_sphere_tm + '.overrideDisplayType', 2)\n        cmds.connectAttr(boneDynamicsNode + '.iterations', radius_sphere_tm + '.v', f=True)\n    \n    sphere_col_idx = 0\n    capsule_col_idx = 0\n    iplane_col_idx = 0\n    mesh_col_idx = 0\n\n    for col in colliders:\n        \n        if not cmds.objExists(col):\n            print(\"Skip: {} is not found.\".format(col))\n            continue\n\n        if not cmds.attributeQuery('colliderType', n=col, ex=True):\n            col_shape = cmds.listRelatives(col, s=True, f=True)\n            if col_shape:\n                if cmds.nodeType(col_shape[0]) == 'mesh':\n                    cmds.connectAttr(col_shape[0] + '.worldMesh[0]', boneDynamicsNode + '.meshCollider[{}]'.format(mesh_col_idx), f=True)\n                    mesh_col_idx += 1\n                    continue\n            print(\"Skip: {} has no 'colliderType' attribute.\".format(col))\n            continue\n\n        colliderType = cmds.getAttr(col + '.colliderType')\n        \n        if colliderType == 'sphere':\n            cmds.connectAttr(col + \".worldMatrix[0]\", boneDynamicsNode + \".sphereCollider[{}].sphereColMatrix\".format(sphere_col_idx), f=True)\n            cmds.connectAttr(col + \".radius\", boneDynamicsNode + \".sphereCollider[{}].sphereColRadius\".format(sphere_col_idx), f=True)\n            sphere_col_idx += 1\n        \n        elif colliderType in ['capsule', 'capsule2']:\n            radius_attr_a = \".radius\" if colliderType == 'capsule' else \".radiusA\"\n            radius_attr_b = \".radius\" if colliderType == 'capsule' else \".radiusB\"\n            a = cmds.listConnections(col + '.sphereA', d=0)[0]\n            b = cmds.listConnections(col + '.sphereB', d=0)[0]\n            cmds.connectAttr(a + \".worldMatrix[0]\", boneDynamicsNode + \".capsuleCollider[{}].capsuleColMatrixA\".format(capsule_col_idx), f=True)\n            cmds.connectAttr(b + \".worldMatrix[0]\", boneDynamicsNode + \".capsuleCollider[{}].capsuleColMatrixB\".format(capsule_col_idx), f=True)\n            cmds.connectAttr(col + radius_attr_a, boneDynamicsNode + \".capsuleCollider[{}].capsuleColRadiusA\".format(capsule_col_idx), f=True)\n            cmds.connectAttr(col + radius_attr_b, boneDynamicsNode + \".capsuleCollider[{}].capsuleColRadiusB\".format(capsule_col_idx), f=True)\n            capsule_col_idx += 1\n        \n        elif colliderType == 'infinitePlane':\n            cmds.connectAttr(col + \".worldMatrix[0]\", boneDynamicsNode + \".infinitePlaneCollider[{}].infinitePlaneColMatrix\".format(iplane_col_idx), f=True)\n            iplane_col_idx += 1\n\n    return boneDynamicsNode\n\nif __name__ == \"__main__\":\n    \n    # Select in order from root to tip of the joint-chain.\n    joints = cmds.ls(sl=True)\n    \n    # Enable per-section scaling.\n    scalable = True\n    \n    # Place the collider created by expcol as a child of 'collider_grp'.\n    colliders = []\n    if cmds.objExists(\"collider_grp\"):\n        colliders = cmds.ls(cmds.listRelatives(\"collider_grp\", c=True), tr=True)\n    \n    # Duplicate the joint-chain to be simulated and add '_target' to the postfix.\n    target_bone_postfix = \"_target\"\n    \n    # Name of the node to offset the transform.\n    offset_node_name = \"offset\"\n\n    # Node name that controls the direction of additional force\n    additional_force_node_name = \"wind\"\n    \n    # ---------------------------------------------------\n\n    set_name = \"boneDynamicsNodeSet\"\n    if not cmds.objExists(set_name):\n        cmds.select(cl=True)\n        cmds.sets(name=set_name)\n\n    for bone, end in zip(joints[:-1], joints[1:]):\n        boneDynamicsNode = create_dynamics_node(\n            bone, \n            end,\n            scalable=scalable, \n            target_bone=bone+target_bone_postfix, \n            offset_node=offset_node_name, \n            colliders=colliders,\n            visualize=True,\n            additional_force_node=additional_force_node_name,\n            additional_force_init_vec=[0, 0, -1]\n        )\n\n        if boneDynamicsNode:\n            cmds.sets(boneDynamicsNode, addElement=set_name)" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "动力学" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "动力学" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "动力学" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\n\ncmds.loadPlugin(\"boneDynamicsNode.mll\", qt=True)\n\ndef create_dynamics_node(bone, end):\n\n    if not bone in cmds.listRelatives(end, p=True):\n        print(\"Exit: {} is not {}'s parent.\".format(bone, end))\n        return\n\n    boneDynamicsNode = cmds.createNode(\"boneDynamicsNode\")\n\n    cmds.connectAttr('time1.outTime', boneDynamicsNode + '.time', force=True)\n    cmds.connectAttr(bone + '.translate', boneDynamicsNode + '.boneTranslate', f=True)\n    cmds.connectAttr(bone + '.parentMatrix[0]', boneDynamicsNode + '.boneParentMatrix', f=True)\n    cmds.connectAttr(bone + '.parentInverseMatrix[0]', boneDynamicsNode + '.boneParentInverseMatrix', f=True)\n    cmds.connectAttr(bone + '.jointOrient', boneDynamicsNode + '.boneJointOrient', f=True)\n    cmds.connectAttr(end + '.translate', boneDynamicsNode + '.endTranslate', f=True)\n\n    cmds.connectAttr(boneDynamicsNode + '.outputRotate', bone + '.rotate', f=True)\n\n    return boneDynamicsNode\n\nif __name__ == \"__main__\":\n    \n    # Select in order from root to tip of the joint-chain\n    joints = cmds.ls(sl=True)\n\n    # ---------------------------------------------------\n\n    set_name = \"boneDynamicsNodeSet\"\n    if not cmds.objExists(set_name):\n        cmds.select(cl=True)\n        cmds.sets(name=set_name)\n\n    for bone, end in zip(joints[:-1], joints[1:]):\n        boneDynamicsNode = create_dynamics_node(bone, end)\n        cmds.sets(boneDynamicsNode, addElement=set_name)" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "动力学连接" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "动力学连接" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "动力学连接" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\n\ndef orient_const_with_pair_blend(master, slave, switch=None):\n    cons = cmds.orientConstraint(master, slave, mo=True)[0]\n    pb = cmds.createNode('pairBlend')\n    \n    if switch:\n        cmds.connectAttr(switch, '{}.weight'.format(pb), f=True)\n        \n    # 使用正确的大小写 'X', 'Y', 'Z'\n    for at in 'XYZ':\n        cmds.connectAttr('{}.constraintRotate{}'.format(cons, at), '{}.inRotate{}2'.format(pb, at), f=True)\n        cmds.connectAttr('{}.outRotate{}'.format(pb, at), '{}.rotate{}'.format(slave, at), f=True)\n       \nif __name__ == \"__main__\":\n    sel = cmds.ls(sl=True)\n    orient_const_with_pair_blend(sel[0], sel[1], \"rig.Dynamics_Intensity\") # 替换引号里的内容（创建属性）" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "碰撞" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "碰撞" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "碰撞体" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from expcol import collider\n\ncollider.iplane()   # Infinite Plane\ncollider.sphere()   # Sphere\ncollider.capsule()  # Capsule\ncollider.capsule2() # Capsule2 (radius individually)\ncollider.cuboid()   # Cuboid" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "连接碰撞" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "连接碰撞" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "连接碰撞" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\n\ndef connect_to_bone_dynamics(bone_dynamics_node, selected_object, collider_index):\n    # 检查物体是否存在\n    if not cmds.objExists(selected_object):\n        print(\"Error: {} does not exist.\".format(selected_object))\n        return\n\n    # 验证节点类型\n    if not cmds.nodeType(bone_dynamics_node) == 'boneDynamicsNode':\n        print(\"Error: {} is not a valid boneDynamicsNode.\".format(bone_dynamics_node))\n        return\n\n    # 连接物体的 worldMatrix 到 boneDynamicsNode 的 Sphere Collider Matrix\n    cmds.connectAttr(selected_object + '.worldMatrix[0]', \n                     '{}.sphereCollider[{}].sphereColMatrix'.format(bone_dynamics_node, collider_index), \n                     force=True)\n\n    # 连接物体的 radius 属性（如果存在）到 Sphere Collider Radius\n    if cmds.attributeQuery('radius', node=selected_object, exists=True):\n        cmds.connectAttr(selected_object + '.radius', \n                         '{}.sphereCollider[{}].sphereColRadius'.format(bone_dynamics_node, collider_index), \n                         force=True)\n    else:\n        print(\"Warning: {} does not have a 'radius' attribute.\".format(selected_object))\n\n\n# 获取当前选择的对象\nselected_objects = cmds.ls(selection=True)\n\n# 检查是否选择了多个节点和物体\nif len(selected_objects) < 2:\n    print(\"Please select at least one boneDynamicsNode and one target object.\")\nelse:\n    # 过滤出所有的 boneDynamicsNode 节点\n    bone_dynamics_nodes = [node for node in selected_objects if cmds.nodeType(node) == 'boneDynamicsNode']\n    # 过滤出所有其他目标物体\n    target_objects = [obj for obj in selected_objects if cmds.nodeType(obj) != 'boneDynamicsNode']\n\n    # 检查是否有足够的节点和物体\n    if not bone_dynamics_nodes:\n        print(\"No boneDynamicsNode nodes selected.\")\n    elif not target_objects:\n        print(\"No target objects selected.\")\n    else:\n        # 遍历每一个 boneDynamicsNode 节点\n        for bone_dynamics_node in bone_dynamics_nodes:\n            # 遍历每一个选中的物体\n            for obj in target_objects:\n                # 检查 boneDynamicsNode 的 sphereCollider 的数量\n                collider_count = cmds.getAttr('{}.sphereCollider'.format(bone_dynamics_node), size=True)\n                \n                if collider_count > 0:\n                    # 假设我们连接到第一个 Collider\n                    for collider_index in range(collider_count):\n                        connect_to_bone_dynamics(bone_dynamics_node, obj, collider_index)\n                else:\n                    print(\"Error: No sphere colliders available in {}.\".format(bone_dynamics_node))" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "骨骼的名字必须是bone_side(m/l/r)_描述_编号，样条线的名字必须是side(m/l/r)_描述或编号" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "ui" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "ui" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\nimport importlib\nfrom dynamics_scripts_ui.main import main_ui as dy\ndy.main()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "手指属性" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "手指属性" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "手指属性" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\n# get finger names\nfinger_names = ['thumb', 'index', 'middle', 'ring', 'pinky']\n\n# get digit names\ndigit_names = {'thumb': ['metacarpal', 'base', 'tip']}\n\n# get curl multiple values\ncurl_mult_values = {'thumb': [-3, -5, -7],\n                    'index': [0, -7.5, -10.5, -8],\n                    'middle': [0, -7.5, -10.5, -8],\n                    'ring': [0, -7.5, -10.5, -8],\n                    'pinky': [0, -7.5, -10.5, -8]}\n\n# loop into each side\nfor side in 'lr':\n    # get hand pose ctrl\n    pose_ctrl = 'ctrl_{}_handPose_001'.format(side)\n    # loop into each finger, and add curl attr\n    for finger in finger_names:\n        cmds.addAttr(pose_ctrl, longName=finger + 'Curl', attributeType='float', keyable=True, minValue=0, maxValue=10)\n        curl_attr = '{}.{}Curl'.format(pose_ctrl, finger)\n\n        # get curl values\n        curl_values = curl_mult_values[finger]\n        # get digit names\n        finger_digits = digit_names.get(finger, ['metacarpal', 'base', 'mid', 'tip'])\n        # loop into each digit and connect the curl\n        for digit, val in zip(finger_digits, curl_values):\n            offset_name = 'offset_{}_{}{}_001'.format(side, finger, digit.title())\n\n            if val:\n                # create multiply node\n                mult_node = cmds.createNode('multDoubleLinear',\n                                            name='mult_{}_{}{}Curl_001'.format(side, finger, digit.title()))\n                # connect driver attr\n                cmds.connectAttr(curl_attr, mult_node + '.input1')\n                # set curl value\n                cmds.setAttr(mult_node + '.input2', val)\n\n                # connect output to offset group's rotateZ\n                cmds.connectAttr(mult_node + '.output', offset_name + '.rotateZ')\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "手指pose" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "手指pose" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "手指pose" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\ndef create_hand_pose_ui():\n    # 检查窗口是否已存在，避免重复创建\n    if cmds.window(\"handPoseUI\", exists=True):\n        cmds.deleteUI(\"handPoseUI\")\n    \n    # 创建窗口\n    window = cmds.window(\"handPoseUI\", title=\"Hand Pose Tool\", widthHeight=(400, 350))\n    \n    # 创建主布局\n    cmds.columnLayout(adjustableColumn=True)\n    \n    # 创建“Create Hand Pose”按钮，始终位于最上面\n    cmds.button(label=\"Create Hand Pose\", command=lambda _: create_hand_pose(\n        pose_name=cmds.textField(pose_name_field, query=True, text=True),\n        mirror_right=cmds.checkBox(mirror_checkbox, query=True, value=True),\n        finger_mirrors={finger: cmds.checkBox(cb, query=True, value=True) \n                        for finger, cb in finger_mirror_checkboxes.items()},\n        joint_mirrors={finger: {joint: cmds.checkBox(cb, query=True, value=True) \n                                for joint, cb in joint_mirror_checkboxes[finger].items()} \n                       for finger in joint_mirror_checkboxes}\n    ))\n\n    # 属性名称输入框\n    cmds.text(label=\"Pose Attribute Name:\")\n    pose_name_field = cmds.textField(placeholderText=\"Enter pose name, e.g., spread\")\n    \n    # 是否翻转右手的复选框\n    mirror_checkbox = cmds.checkBox(label=\"Mirror Right Side (Multiply by -1) for All Fingers\", value=True,\n                                    changeCommand=lambda _: update_finger_mirror_controls(mirror_checkbox, finger_mirror_checkboxes, joint_mirror_checkboxes))\n    \n    # 折叠框布局\n    frame = cmds.frameLayout(label=\"Finger and Joint Controls\", collapsable=True, collapse=True)\n    cmds.columnLayout(adjustableColumn=True, parent=frame)\n    \n    # 创建每个手指和每个关节的翻转开关\n    finger_mirror_checkboxes = {}\n    joint_mirror_checkboxes = {}\n    \n    for finger in ['thumb', 'index', 'middle', 'ring', 'pinky']:\n        # 手指翻转控制\n        finger_mirror_checkboxes[finger] = cmds.checkBox(label=f\"Mirror {finger.capitalize()} Finger\", value=True, enable=False)\n        # 每个手指的每个关节都需要有一个翻转开关\n        joint_mirror_checkboxes[finger] = {}\n        for joint in ['metacarpal', 'base', 'mid', 'tip']:\n            joint_mirror_checkboxes[finger][joint] = cmds.checkBox(label=f\"Mirror {finger.capitalize()} {joint.capitalize()} Joint\", value=True, enable=False)\n    \n    # 显示窗口\n    cmds.showWindow(window)\n\ndef update_finger_mirror_controls(mirror_checkbox, finger_mirror_checkboxes, joint_mirror_checkboxes):\n    # 获取 Mirror Right Side 复选框的状态\n    mirror_right = cmds.checkBox(mirror_checkbox, query=True, value=True)\n    \n    # 根据复选框状态更新每个手指和关节的翻转开关\n    for finger in finger_mirror_checkboxes:\n        cmds.checkBox(finger_mirror_checkboxes[finger], edit=True, enable=not mirror_right, value=mirror_right)\n        for joint in joint_mirror_checkboxes[finger]:\n            cmds.checkBox(joint_mirror_checkboxes[finger][joint], edit=True, enable=not mirror_right, value=mirror_right)\n\ndef create_hand_pose(pose_name, mirror_right, finger_mirrors, joint_mirrors):\n    if not pose_name:  # 验证输入的属性名\n        cmds.warning(\"Please provide a valid pose name!\")\n        return\n\n    # 定义手指和指节名称\n    finger_names = ['thumb', 'index', 'middle', 'ring', 'pinky']\n    digit_names = ['metacarpal', 'base', 'mid', 'tip']\n    \n    # 左右手的姿态控制器\n    pose_ctrl_left = 'ctrl_l_handPose_001'\n    pose_ctrl_right = 'ctrl_r_handPose_001'\n    \n    # 为姿态控制器添加自定义属性\n    for pose_ctrl in [pose_ctrl_left, pose_ctrl_right]:\n        if not cmds.objExists(f\"{pose_ctrl}.{pose_name}\"):\n            cmds.addAttr(pose_ctrl, longName=pose_name, attributeType='float', minValue=0, maxValue=10, keyable=True)\n    \n    # 遍历每个手指和指节\n    for finger in finger_names:\n        for digit in digit_names:\n            ctrl_name = 'ctrl_l_{}{}_001'.format(finger, digit.title())\n            if cmds.objExists(ctrl_name):  # 检查控制器是否存在\n                connect_group_left = ctrl_name.replace('ctrl', 'connect')\n                connect_group_right = connect_group_left.replace('_l_', '_r_')\n                \n                for attr in ['rotateX', 'rotateY', 'rotateZ']:\n                    val = cmds.getAttr('{}.{}'.format(ctrl_name, attr))\n                    if val != 0:  # 跳过值为0的属性\n                        # 左手驱动关键帧\n                        cmds.setDrivenKeyframe('{}.{}'.format(connect_group_left, attr),\n                                               currentDriver='{}.{}'.format(pose_ctrl_left, pose_name),\n                                               driverValue=10, value=val)\n                        cmds.setDrivenKeyframe('{}.{}'.format(connect_group_left, attr),\n                                               currentDriver='{}.{}'.format(pose_ctrl_left, pose_name),\n                                               driverValue=0, value=0)\n                        \n                        # 判断是否为右手，若是，是否需要乘以-1\n                        right_value = -val if (mirror_right or finger_mirrors[finger] or joint_mirrors[finger][digit]) else val\n                        cmds.setDrivenKeyframe('{}.{}'.format(connect_group_right, attr),\n                                               currentDriver='{}.{}'.format(pose_ctrl_right, pose_name),\n                                               driverValue=10, value=right_value)\n                        cmds.setDrivenKeyframe('{}.{}'.format(connect_group_right, attr),\n                                               currentDriver='{}.{}'.format(pose_ctrl_right, pose_name),\n                                               driverValue=0, value=0)\n                        \n                        # 将控制器属性值归零\n                        cmds.setAttr('{}.{}'.format(ctrl_name, attr), 0)\n\n    cmds.confirmDialog(title=\"Success\", message=\"Hand pose created successfully!\", button=[\"OK\"])\n\n# 启动UI\ncreate_hand_pose_ui()\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "修型骨" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "修型骨" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "修型骨" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "pythonFamily.png" 
        -image1 "pythonFamily.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "import maya.cmds as cmds\n\n\ndef avg_joint(drivers, weight=0.5):\n    \"\"\"\n    create average joint between drivers\n\n    Args:\n        drivers (list): driver joints, the average joint will be parented to the first driver\n        weight (float): weight blend between drivers\n\n    Returns:\n        avg_jnt(str): average joint's name\n    \"\"\"\n    # get name parts\n    name_parts = drivers[0].split('_')\n    # create average joint\n    avg_jnt = cmds.createNode('joint', name=drivers[0].replace(name_parts[2], name_parts[2] + 'Avg'))\n    # snap to driver's position\n    cmds.matchTransform(avg_jnt, drivers[0], position=True)\n    # do a temp orient constraint to get average orientation\n    cons_node = cmds.orientConstraint(drivers, avg_jnt, maintainOffset=False)[0]\n    cmds.setAttr(cons_node + '.interpType', 2)\n    cmds.setAttr('{}.{}W0'.format(cons_node, drivers[0]), weight)\n    cmds.setAttr('{}.{}W1'.format(cons_node, drivers[1]), 1 - weight)\n    # delete orient constraint node\n    cmds.delete(cons_node)\n    # freeze transformation to bake the orientation to joint orient\n    cmds.makeIdentity(avg_jnt, apply=True, translate=True, rotate=True, scale=True)\n    # parent to driver node\n    cmds.parent(avg_jnt, drivers[0])\n\n    # do orient constraint to drive the avg joint\n    cons_node = cmds.orientConstraint(drivers, avg_jnt, maintainOffset=False)[0]\n    cmds.setAttr(cons_node + '.interpType', 2)\n    cmds.setAttr('{}.{}W0'.format(cons_node, drivers[0]), weight)\n    cmds.setAttr('{}.{}W1'.format(cons_node, drivers[1]), 1 - weight)\n\n    # return the average joint name\n    return avg_jnt\n\n\ndef add_push_joint(avg_jnt, driver_axis='z', distance_axis='y', scale_axis='x', driver_value=60, distance_value=5,\n                   scale_value=0.2):\n    \"\"\"\n    add push joint to existing average joint\n\n    Args:\n        avg_jnt (str): average joint's name\n        driver_axis (str): driver rotation axis\n        distance_axis (str): pushing axis\n        scale_axis (str): scale axis\n        driver_value (float): driver rotation maximum value\n        distance_value (float): maximum pushing value\n        scale_value (float): maximum scaling value\n\n    Returns:\n        push_jnt (str): push joint's name\n    \"\"\"\n    # get name parts\n    name_parts = avg_jnt.split('_')\n    name_side = name_parts[1]\n    name_description = name_parts[2] + 'Push'\n    name_index = int(name_parts[3])\n\n    # create push joint\n    push_jnt = cmds.createNode('joint', name='jnt_{}_{}_{:03d}'.format(name_side, name_description, name_index))\n    # snap to average joint position and freeze transformation\n    cmds.matchTransform(push_jnt, avg_jnt, position=True, rotation=True)\n    cmds.makeIdentity(push_jnt, apply=True, translate=True, rotate=True, scale=True)\n    cmds.parent(push_jnt, avg_jnt)\n\n    # add remap value node to drive the push distance\n    remap_dis = cmds.createNode('remapValue', name='remap_{}_{}Dis_{:03d}'.format(name_side, name_description,\n                                                                                  name_index))\n    # connect driver attr to remap node and set range\n    cmds.connectAttr('{}.rotate{}'.format(avg_jnt, driver_axis.upper()), remap_dis + '.inputValue')\n    cmds.setAttr(remap_dis + '.inputMin', 0)\n    cmds.setAttr(remap_dis + '.inputMax', driver_value)\n    cmds.setAttr(remap_dis + '.outputMin', 0)\n    cmds.setAttr(remap_dis + '.outputMax', distance_value)\n    cmds.connectAttr(remap_dis + '.outValue', '{}.translate{}'.format(push_jnt, distance_axis.upper()))\n\n    # add remap value node to drive the scale\n    remap_scl = cmds.createNode('remapValue', name='remap_{}_{}Scl_{:03d}'.format(name_side, name_description,\n                                                                                  name_index))\n    # connect driver attr to remap node and set range\n    cmds.connectAttr('{}.rotate{}'.format(avg_jnt, driver_axis.upper()), remap_scl + '.inputValue')\n    cmds.setAttr(remap_scl + '.inputMin', 0)\n    cmds.setAttr(remap_scl + '.inputMax', driver_value)\n    cmds.setAttr(remap_scl + '.outputMin', 1)\n    cmds.setAttr(remap_scl + '.outputMax', scale_value)\n    cmds.connectAttr(remap_scl + '.outValue', '{}.scale{}'.format(push_jnt, scale_axis.upper()))\n\n    # return push joint's name\n    return push_jnt\n\n\navg_jnt_info = {'jnt_l_elbow_001': {'driver': 'jnt_l_upperArm_001',\n                                    'weight': 0.5,\n                                    'driver_axis': 'y',\n                                    'distance_axis': 'z',\n                                    'scale_axis': 'x',\n                                    'driver_value': 60,\n                                    'distance_value': -8,\n                                    'scale_value': 0.2},\n\n                'jnt_l_wrist_001': {'driver': 'jnt_l_elbowTwist_005',  # 修改为 jnt_l_elbowTwist_005\n                                    'weight': 0.5,\n                                    'push': False},\n\n                'jnt_l_knee_001': {'driver': 'jnt_l_upperLeg_001',\n                                   'weight': 0.5,\n                                   'driver_axis': 'z',\n                                   'distance_axis': 'y',\n                                   'scale_axis': 'x',\n                                   'driver_value': 60,\n                                   'distance_value': 8,\n                                   'scale_value': 0.2},\n\n                'jnt_l_ankle_001': {'driver': 'jnt_l_elbowTwist_005',  # 修改为 jnt_l_elbowTwist_005\n                                    'weight': 0.5,\n                                    'push': False},\n\n                'jnt_l_ball_001': {'driver': 'jnt_l_ankle_001',\n                                   'weight': 0.5,\n                                   'push': False}}\n\n# Add finger joints\nfor finger in ['thumb', 'index', 'middle', 'ring', 'pinky']:\n    for digit in ['base', 'mid', 'tip']:\n        jnt = 'jnt_l_{}{}_001'.format(finger, digit.title())\n        if cmds.objExists(jnt):\n            parent_jnt = cmds.listRelatives(jnt, parent=True)[0]\n            avg_jnt_info.update({jnt: {'driver': parent_jnt,\n                                       'weight': 0.5,\n                                       'driver_axis': 'z',\n                                       'distance_axis': 'y',\n                                       'scale_axis': 'x',\n                                       'driver_value': 45,\n                                       'distance_value': 1.5,\n                                       'scale_value': 0.2}})\n\n# Create average joints and add push joints\nfor jnt, jnt_info in avg_jnt_info.items():\n    avg_jnt_left = avg_joint([jnt, jnt_info['driver']], weight=jnt_info['weight'])\n    avg_jnt_right = avg_joint([jnt.replace('_l_', '_r_'), jnt_info['driver'].replace('_l_', '_r_')],\n                              weight=jnt_info['weight'])\n\n    push = jnt_info.get('push', True)\n    if push:\n        add_push_joint(avg_jnt_left, driver_axis=jnt_info['driver_axis'], distance_axis=jnt_info['distance_axis'],\n                       scale_axis=jnt_info['scale_axis'], driver_value=jnt_info['driver_value'],\n                       distance_value=jnt_info['distance_value'], scale_value=jnt_info['scale_value'])\n\n        add_push_joint(avg_jnt_right, driver_axis=jnt_info['driver_axis'], distance_axis=jnt_info['distance_axis'],\n                       scale_axis=jnt_info['scale_axis'], driver_value=jnt_info['driver_value'],\n                       distance_value=-jnt_info['distance_value'], scale_value=jnt_info['scale_value']) \n\ncmds.confirmDialog(title=\"Success\", message=\"Hand pose created successfully!\", button=[\"OK\"])\n" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
