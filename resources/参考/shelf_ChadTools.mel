($lowResswGeo[$lsg]+\"_SW.continuity\");\n    connectAttr ($highRes+\"Shape.keepBorder\") ($lowResswGeo[$lsg]+\"_SW.keepBorder\");\n    connectAttr ($highRes+\"Shape.keepHardEdge\") ($lowResswGeo[$lsg]+\"_SW.keepHardEdge\");\n    connectAttr ($highRes+\"Shape.propagateEdgeHardness\") ($lowResswGeo[$lsg]+\"_SW.propagateEdgeHardness\");\n    connectAttr ($highRes+\"Shape.smoothUVs\") ($lowResswGeo[$lsg]+\"_SW.smoothUVs\");\n    connectAttr ($highRes+\"Shape.worldMesh[0]\") ($lowResswGeo[$lsg]+\"_SW.targetGeom\");\n    setAttr ($lowResswGeo[$lsg]+\"_SW.projection\") 4;    \n    DeleteHistory;\n    string $lowResBindJnt = substituteAllString($lowResswGeo[$lsg], \"_lowRes_geo\", \"\");\n    select -r $lowResswGeo[$lsg];\n    select -add $lowResBindJnt;\n    \n   skinCluster -n ($highRes+\"_skinClu\") -tsb ;\n}\n}\n\nreshapeWin;\n" 
