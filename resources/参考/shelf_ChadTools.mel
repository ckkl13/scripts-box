2 0 -0.398354 -p 0 0 -0.398354 -p 0 0 0.5 -p 0 0 0 -p -0.5 0 0 -p 0.5 0 0 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 -k 49 -k 50 -k 51 -k 52 -k 53 -k 54 -k 55 ;\n\n\nselect -r drv_local_ctrl.cv[0:52] ;\nscale -r -ocp 4 4 4;\n\nselect -r drv_world_ctrl.cv[0:55] ;\nscale -r -ocp 6 6 6;\n\ngroup -n drv_root_ctrl_offset drv_root_ctrl;\ngroup -n drv_local_ctrl_offset drv_local_ctrl;\ngroup -n drv_world_ctrl_offset drv_world_ctrl;\n\nparent drv_root_ctrl_offset drv_local_ctrl;\nparent drv_local_ctrl_offset drv_world_ctrl;\n\nparent drv_world_ctrl_offset drv_ctrl_grp;\nparent drv_sub_ctrl_grp drv_head_ctrl_grp drv_inner_ctrl_grp drv_root_ctrl;\n\nparentConstraint drv_root_ctrl drv_geo;\nparentConstraint drv_root_ctrl drv_curBaseWire;\nscaleConstraint drv_root_ctrl drv_rig_grp;\n\nselect -r (\"drv_*_fol_joint_ctrl.cv[0:120]\");\nscale -r -ocp 0.5 0.5 0.5;\n\n\ndelete (\"drv_latic_*_clu_ctrl_offset\");\n}\n\n\n\n\n/////////////////////////////////////////////////////////////create str grp//////////////////////////////////////////////////////////////////\nglobal proc CrtRibbon(string $newname,int $delt,int $ctrlnum,int $faceunm){\n\n   string $l[] = `ls \"drv_str_grp\" `;\n    if (size($l) == 0) {\n        string $md[] = `ls \"drv_cur_md\" `;\n        if(size($md) == 1){\n            delete drv_cur_md;\n            }\n       string $fmd[] = `ls \"drv_cur_F_md\" `;\n        if(size($fmd) == 1){\n            delete drv_cur_F_md;\n            }\n       \n       createdrv1($ctrlnum,$faceunm);\n       select -r drv_str_grp ;\n       duplicate -rr -renameChildren -un-n drv_str_grp1;\n       select -hi drv_str_grp1;\n       searchReplaceNames \"drv\" $newname \"hierarchy\";\n       searchReplaceNames \"_geo1\" \"_geo\" \"hierarchy\";\n       searchReplaceNames \"_grp1\" \"_grp\" \"hierarchy\";\n       searchReplaceNames \"_ctrl1\" \"_ctrl\" \"hierarchy\";\n       searchReplaceNames \"_offset1\" \"_offset\" \"hierarchy\";\n       searchReplaceNames \"_pcon1\" \"_pcon\" \"hierarchy\";\n       searchReplaceNames \"_pConst1\" \"_pConst\" \"hierarchy\";\n       searchReplaceNames \"_sConst1\" \"_sConst\" \"hierarchy\";\n       searchReplaceNames \"_ocon1\" \"_ocon\" \"hierarchy\";\n       searchReplaceNames \"_fol1\" \"_fol\" \"hierarchy\";\n       searchReplaceNames \"_joint1\" \"_joint\" \"hierarchy\";\n       searchReplaceNames \"_clu1\" \"_clu\" \"hierarchy\";\n       searchReplaceNames \"_cur1\" \"_cur\" \"hierarchy\";\n       searchReplaceNames \"_curBaseWire1\" \"_curBaseWire\" \"hierarchy\";\n\n    }\n    else{\n       select -r drv_str_grp ;\n       duplicate -rr -renameChildren -un-n drv_str_grp1;\n       select -r drv_str_grp1;\n       searchReplaceNames \"drv\" $newname \"hierarchy\";\n       searchReplaceNames \"_geo1\" \"_geo\" \"hierarchy\";\n       searchReplaceNames \"_grp1\" \"_grp\" \"hierarchy\";\n       searchReplaceNames \"_ctrl1\" \"_ctrl\" \"hierarchy\";\n       searchReplaceNames \"_offset1\" \"_offset\" \"hierarchy\";\n       searchReplaceNames \"_pcon1\" \"_pcon\" \"hierarchy\";\n       searchReplaceNames \"_pConst1\" \"_pConst\" \"hierarchy\";\n       searchReplaceNames \"_sConst1\" \"_sConst\" \"hierarchy\";\n       searchReplaceNames \"_ocon1\" \"_ocon\" \"hierarchy\";\n       searchReplaceNames \"_fol1\" \"_fol\" \"hierarchy\";\n       searchReplaceNames \"_joint1\" \"_joint\" \"hierarchy\";\n       searchReplaceNames \"_clu1\" \"_clu\" \"hierarchy\";\n       searchReplaceNames \"_cur1\" \"_cur\" \"hierarchy\";\n       searchReplaceNames \"_curBaseWire1\" \"_curBaseWire\" \"hierarchy\";\n}\nif($delt==0){\n    delete drv_curbase_curinfo;\n    delete drv_cur_curinfo;\n    delete drv_str_grp;\n\n    }\n}\n \n \nglobal proc insertMidJoints(string $rotJnt, string $endJnt,int $JNum){\nstring $born[]=`ls - sl`;\nint $n = $JNum;\nint $max = $n +1;\nfor($i=0;$i<$n;$i++){\n    string $new = substituteAllString($rotJnt, \"joint\", \"\");\n\n    duplicate -rc  -n ($new+($i+1)+\"_sub_joint\") $rotJnt ;\n    delete `listRelatives -c ($new+($i+1)+\"_sub_joint\")`;\n    pointConstraint -n ($new+($i+1)+\"_sub_jointPcont\") $rotJnt $endJnt ($new+($i+1)+\"_sub_joint\");\n    setAttr (($new+($i+1)+\"_sub_jointPcont.\")+$rotJnt+\"W0\") ($max-$i-1);\n    setAttr (($new+($i+1)+\"_sub_jointPcont.\")+$endJnt+\"W1\") ($i+1); \n    delete (\"*_sub_jointPcont\");\n    if ($i ==0){\n    parent ($new+\"1_sub_joint\") $rotJnt;\n    }\n    if ($i >0){\n    parent ($new+($i+1)+\"_sub_joint\") ($new+($i)+\"_sub_joint\");\n    }\n    if ($i == ($n-1)){\n    parent $endJnt ($new+($i+1)+\"_sub_joint\");\n    }\n}\n}\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "global proc CurIFCtrlWin(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"LocatorsOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -bgc 0.08 0.02 0.13 -title \"Create IKFK ctrl setup based on the curve\" -widthHeight 150 50 $mygui;  \n frameLayout  -label \"Select the curve\" -collapsable 0 -bgc 0.35 0.35 0.1; \ntextFieldButtonGrp -bgc 0.234 0 0 -hlc 1 0 0 -label \"Select the curve\"\n-text \"\"\n-buttonLabel \"base_curve\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_org()\" attr_name;\n\n\nframeLayout -label \"Create ctrls and joints based on the curve\" -collapsable 0 -bgc 0.35 0.35 0.1; \n   text -l \"Please type in the number you want.\";\n   rowLayout;\n\n\t\t\ttextFieldButtonGrp -bgc 0.234 0 0 -hlc 1 0 0 -label \"ctrl account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonLabel \"create locators\"\n\t\t\t-buttonCommand \"curveIFSetup(`textFieldGrp  -query -text attr_name`,`textFieldButtonGrp -query -text joint_number`)\"  joint_number;\n\n\n\n\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\n\nglobal proc curveIFSetup(string $cur, int $locNum){\nfor($i=0;$i<$locNum;$i++){\n   spaceLocator -n ($cur+\"_\"+($i+1)+\"_loc\")-p 0 0 0;\n   \n    select -tgl $cur;\npathAnimation -n ($cur+\"_\"+($i+1)+\"_loc_path\") -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 1 -endTimeU 1;\nselectKey -add -k -t 1 -t 1 ($cur+\"_\"+($i+1)+\"_loc_path_uValue\");\ncutKey -animation keys -clear;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_path.allCoordinates\") ($cur+\"_\"+($i+1)+\"_loc.translate\");\ndelete `listConnections -t \"addDoubleLinear\"`;\nCBdeleteConnection ($cur+\"_\"+($i+1)+\"_loc.rx\");\nCBdeleteConnection ($cur+\"_\"+($i+1)+\"_loc.ry\");\nCBdeleteConnection ($cur+\"_\"+($i+1)+\"_loc.rz\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc.rx\") 0;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc.ry\") 0;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc.rz\") 0;\nshadingNode -asUtility multiplyDivide -n ($cur+\"_\"+($i+1)+\"_loc_md\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.operation\") 2;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input2X\") ($locNum-1);\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input1X\") $i;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_md.outputX\") ($cur+\"_\"+($i+1)+\"_loc_path.uValue\");\ndelete ($cur+\"_\"+($i+1)+\"_loc_md\");\n\n}\ngroup -n ($cur+\"_\"+\"loc_grp\") -em;\nparent ($cur+\"_\"+\"*_loc\") ($cur+\"_\"+\"loc_grp\") ;\nselect -r ($cur+\"_\"+\"*_loc\");\nctrlsFuns;\ngroup -n ($cur+\"_IK_ctrl_grp\") -em;\nparent ($cur+\"_\"+\"*_loc_IK_ctrl_offset\")($cur+\"_IK_ctrl_grp\") ;\nselect ($cur+\"_\"+\"*_loc_IK_ctrl_offset\") ($cur+\"_\"+\"*_loc_FK_ctrl_NULL\");\nsearchReplaceNames \"_loc\" \"\" \"hierarchy\";\nsetAttr ($cur+\"_\"+\"loc_grp.v\") 0;\nselect -cl;\n/*************************************************************************create joints*********************************************************************************************************/\n\njoint -n dup_joint;\n\nfor ($j=0;$j<$locNum;$j++){\n\tduplicate  -n ($cur+\"_\"+($j+1)+\"_joint\") dup_joint;\n\tif ($j>0){\n\t\tparent ($cur+\"_\"+($j+1)+\"_joint\") ($cur+\"_\"+$j+\"_joint\");\n\t\tsetAttr ($cur+\"_\"+($j+1)+\"_joint.translateX\") 1;\n\t\t}\n\t\n}\ndelete dup_joint;\n\n/*************************************************************************create rotate cards*********************************************************************************************************/\nselect -hi ($cur+\"_\"+\"1_joint\") ;\nstring $born[]=`ls -sl`;\nfor($b=0;$b<$locNum;$b++){\n\tpolyPlane -w 1 -h 1 -sx 1 -sy 1  -n ($born[$b]+\"_rot_geo\");\t\n\tmove -rpr -0.5 0 0 (($born[$b]+\"_rot_geo\")+\".scalePivot\") (($born[$b]+\"_rot_geo\")+\".rotatePivot\");\n\tdelete `parentConstraint  $born[$b] ($born[$b]+\"_rot_geo\")`;\n\t\n\tspaceLocator -n ($born[$b]+\"_rot_loc\");\n\tdelete`parentConstraint $born[$b] ($born[$b]+\"_rot_loc\")`;\t\n\t\n    shadingNode -asUtility distanceBetween -n ($born[$b]+\"_dist\");\n    if($b>0){\n\t\tconnectAttr (($born[$b]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point1\");\n\t\tconnectAttr (($born[$b-1]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point2\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tselect -r (\"*_rot_geo\");\n\t\tmakeIdentity -apply true -t 0 -r 0 -s 1 -n 0 -pn 1 ;    \n\t\tparent ($born[$b]+\"_rot_geo\") ($born[$b-1]+\"_rot_geo\");\n\t\t\n\t\t}\n\t\n    \n    pointConstraint -n ($born[$b]+\"_rotptcon\") ($born[$b]+\"_rot_geo\") $born[$b];\t\n\tconnectAttr (($born[$b]+\"_rot_geo\")+\".rotate\") ($born[$b]+\".jointOrient\");\n\tstring $opsit = substituteAllString($born[$b], \"joint\", \"loc\");\n\tstring $opsit1 = substituteAllString($born[$b+1], \"joint\", \"loc\");\n\tdelete `pointConstraint $opsit ($born[$b]+\"_rot_geo\")`;\n\tif($b<($locNum-1)){\n\ndelete `aimConstraint -offset 0 0 0 -weight 1 -aimVector 1 0 0 -upVector 0 1 0 -worldUpType \"vector\" -worldUpVector 0 1 0 $opsit1 ($born[$b]+\"_rot_geo\")`;\n\t}\n\n}\t\n\ndelete (\"*_rot_loc\");\ndelete (\"*_rotptcon*\");\ndelete (\"*_rot_geo*\");\n\n\nselect -hi ($cur+\"_\"+\"1_joint\") ;\nstring $bornCont[]=`ls -sl`;\nfor($bc=0;$bc<$locNum;$bc++){\n    string $FKCtrls = substituteAllString($bornCont[$bc], \"_joint\", \"_FK_sub_ctrl\");\n    parentConstraint -n($bornCont[$bc]+\"_pCont\") $FKCtrls $bornCont[$bc];\n}\n\n\ngroup -n ($cur+\"_joint_grp\") -em;\nparent ($cur+\"_1_joint\") ($cur+\"_joint_grp\");\n\ngroup -n ($cur+\"_FK_ctrl_grp\") -em;\nparent ($cur+\"_1_FK_ctrl_NULL\") ($cur+\"_FK_ctrl_grp\");\n\ngroup -n ($cur+\"_ctrl_grp\") -em;\n\n\ngroup -n ($cur+\"_setup_grp\") -em;\nparent ($cur+\"_joint_grp\") ($cur+\"_1_loc_FK_drv\") ($cur+\"_loc_grp\") $cur ($cur+\"_setup_grp\");\nsetAttr ($cur+\"_1_loc_FK_drv.v\") 0;\nsetAttr ($cur+\"_\"+\"loc_grp.inheritsTransform\") 0;\n\n\ncurve -n ($cur+\"_ctrl\") -d 1 -p -0.5 0.5 -0.5 -p -0.5 0.5 0.5 -p 0.5 0.5 0.5 -p 0.5 0.5 -0.5 -p -0.5 0.5 -0.5 -p -0.5 -0.5 -0.5 -p -0.5 -0.5 0.5 -p 0.5 -0.5 0.5 -p 0.5 -0.5 -0.5 -p -0.5 -0.5 -0.5 -p -0.5 0.5 -0.5 -p 0.5 0.5 -0.5 -p 0.5 -0.5 -0.5 -p 0.5 -0.5 0.5 -p 0.5 0.5 0.5 -p -0.5 0.5 0.5 -p -0.5 -0.5 0.5 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 ;\nrename `listRelatives -c` ($cur+\"_ctrlShape\");\ndelete `pointConstraint ($cur+\"_1_loc_FK_drv\") ($cur+\"_ctrl\")`;\ngroup -n ($cur+\"_ctrl_offset\") -em;\ndelete `parentConstraint ($cur+\"_ctrl\") ($cur+\"_ctrl_offset\")`;\nparent ($cur+\"_ctrl\") ($cur+\"_ctrl_offset\");\nparent ($cur+\"_ctrl_offset\") ($cur+\"_ctrl_grp\");\nparent ($cur+\"_FK_ctrl_grp\") ($cur+\"_IK_ctrl_grp\") ($cur+\"_ctrl\");\nscaleConstraint -n($cur+\"_ctrl_sCont\") -mo ($cur+\"_ctrl\") ($cur+\"_setup_grp\");\nparentConstraint  -n($cur+\"_ctrl_pCont\") -mo ($cur+\"_ctrl\") ($cur+\"_setup_grp\");\n\nselect -r ($cur+\"_*_loc\");\nstring $locRot[] = `ls - sl`;\nfor($ls=0;$ls<size($locRot);$ls++){\n    orientConstraint -n ( $locRot[$ls]+\"_oCont\")($cur+\"_ctrl\") $locRot[$ls] ;\n    }\n\n}\n\n\n\n/***********************************************************************++++++++******************************************************************************************************************************/    \n/***********************************************************************FK Ctrl******************************************************************************************************************************/    \n\nglobal proc ctrlsFuns(){\nstring $IKCtrls[] = `ls - sl`;\nfor($ikc=0;$ikc<size($IKCtrls);$ikc++){\n/***********************************************************************FK Ctrl******************************************************************************************************************************/    \n    curve -n ($IKCtrls[$ikc]+\"_IK_ctrl\") -d 1 -p -1 0 -1 -p -1 0 1 -p 1 0 1 -p 1 0 -1 -p -1 0 -1 -k 0 -k 1 -k 2 -k 3 -k 4 ;\n    rename `listRelatives -c` ($IKCtrls[$ikc]+\"_IK_ctrlShape\");\n    delete `parentConstraint $IKCtrls[$ikc] ($IKCtrls[$ikc]+\"_IK_ctrl\")`;\n    group -n ($IKCtrls[$ikc]+\"_IK_ctrl_offset\") -em;\n    delete `parentConstraint ($IKCtrls[$ikc]+\"_IK_ctrl\") ($IKCtrls[$ikc]+\"_IK_ctrl_offset\")`;\n    parent($IKCtrls[$ikc]+\"_IK_ctrl\") ($IKCtrls[$ikc]+\"_IK_ctrl_offset\");\n    duplicate -rr -n ($IKCtrls[$ikc]+\"_IK_sub_ctrl\") ($IKCtrls[$ikc]+\"_IK_ctrl\");\n    \n    int $degree = `getAttr (($IKCtrls[$ikc]+\"_IK_sub_ctrl\")+\".degree\")`;\n    int $spans = `getAttr (($IKCtrls[$ikc]+\"_IK_sub_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym (($IKCtrls[$ikc]+\"_IK_sub_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    parent ($IKCtrls[$ikc]+\"_IK_sub_ctrl\") ($IKCtrls[$ikc]+\"_IK_ctrl\");\n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on ($IKCtrls[$ikc]+\"_IK_ctrl\");\n    connectAttr (($IKCtrls[$ikc]+\"_IK_ctrl\")+\".subCtrl\") (($IKCtrls[$ikc]+\"_IK_sub_ctrlShape\")+\".v\");\n    setAttr -k 0 -channelBox true (($IKCtrls[$ikc]+\"_IK_ctrl\")+\".subCtrl\");\n/***********************************************************************FK Ctrl******************************************************************************************************************************/    \n    parentConstraint -n (($IKCtrls[$ikc]+\"_IK_pCont\"))$IKCtrls[$ikc] ($IKCtrls[$ikc]+\"_IK_ctrl_offset\");\n    \n    curve -n ($IKCtrls[$ikc]+\"_FK_ctrl\") -d 1 -p 0 1 0 -p 0.5 0.866025 0 -p 0.866025 0.5 0 -p 1 0 0 -p 0.866025 -0.5 0 -p 0.5 -0.866025 0 -p 0 -1 0 -p 0.353553 -0.866025 0.353553 -p 0.612372 -0.5 0.612372 -p 0.707107 0 0.707107 -p 0.612372 0.5 0.612372 -p 0.353553 0.866025 0.353553 -p 0 1 0 -p 0 0.866025 0.5 -p 0 0.5 0.866025 -p 0 0 1 -p 0 -0.5 0.866025 -p 0 -0.866025 0.5 -p 0 -1 0 -p -0.353553 -0.866025 0.353553 -p -0.612372 -0.5 0.612372 -p -0.707107 0 0.707107 -p -0.612372 0.5 0.612372 -p -0.353553 0.866025 0.353553 -p 0 1 0 -p -0.5 0.866025 0 -p -0.866025 0.5 0 -p -1 0 0 -p -0.866025 -0.5 0 -p -0.5 -0.866025 0 -p 0 -1 0 -p -0.353553 -0.866025 -0.353553 -p -0.612372 -0.5 -0.612372 -p -0.707107 0 -0.707107 -p -0.612372 0.5 -0.612372 -p -0.353553 0.866025 -0.353553 -p 0 1 0 -p 0 0.866025 -0.5 -p 0 0.5 -0.866025 -p 0 0 -1 -p 0 -0.5 -0.866025 -p 0 -0.866025 -0.5 -p 0 -1 0 -p 0.353553 -0.866025 -0.353553 -p 0.612372 -0.5 -0.612372 -p 0.707107 0 -0.707107 -p 0.612372 0.5 -0.612372 -p 0.353553 0.866025 -0.353553 -p 0 1 0 -p 0.5 0.866025 0 -p 0.353553 0.866025 -0.353553 -p 0 0.866025 -0.5 -p -0.353553 0.866025 -0.353553 -p -0.5 0.866025 0 -p -0.353553 0.866025 0.353553 -p 0 0.866025 0.5 -p 0.353553 0.866025 0.353553 -p 0.5 0.866025 0 -p 0.866025 0.5 0 -p 0.612372 0.5 -0.612372 -p 0 0.5 -0.866025 -p -0.612372 0.5 -0.612372 -p -0.866025 0.5 0 -p -0.612372 0.5 0.612372 -p 0 0.5 0.866025 -p 0.612372 0.5 0.612372 -p 0.866025 0.5 0 -p 1 0 0 -p 0.707107 0 -0.707107 -p 0 0 -1 -p -0.707107 0 -0.707107 -p -1 0 0 -p -0.707107 0 0.707107 -p 0 0 1 -p 0.707107 0 0.707107 -p 1 0 0 -p 0.866025 -0.5 0 -p 0.612372 -0.5 -0.612372 -p 0 -0.5 -0.866025 -p -0.612372 -0.5 -0.612372 -p -0.866025 -0.5 0 -p -0.612372 -0.5 0.612372 -p 0 -0.5 0.866025 -p 0.612372 -0.5 0.612372 -p 0.866025 -0.5 0 -p 0.5 -0.866025 0 -p 0.353553 -0.866025 -0.353553 -p 0 -0.866025 -0.5 -p -0.353553 -0.866025 -0.353553 -p -0.5 -0.866025 0 -p -0.353553 -0.866025 0.353553 -p 0 -0.866025 0.5 -p 0.353553 -0.866025 0.353553 -p 0.5 -0.866025 0 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 -k 49 -k 50 -k 51 -k 52 -k 53 -k 54 -k 55 -k 56 -k 57 -k 58 -k 59 -k 60 -k 61 -k 62 -k 63 -k 64 -k 65 -k 66 -k 67 -k 68 -k 69 -k 70 -k 71 -k 72 -k 73 -k 74 -k 75 -k 76 -k 77 -k 78 -k 79 -k 80 -k 81 -k 82 -k 83 -k 84 -k 85 -k 86 -k 87 -k 88 -k 89 -k 90 -k 91 -k 92 -k 93 ;\n    rename `listRelatives -c` ($IKCtrls[$ikc]+\"_FK_ctrlShape\");\n\n    delete `parentConstraint $IKCtrls[$ikc] ($IKCtrls[$ikc]+\"_FK_ctrl\")`;\n    group -n ($IKCtrls[$ikc]+\"_FK_ctrl_offset\") -em;\n    delete `parentConstraint ($IKCtrls[$ikc]+\"_FK_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl_offset\")`;\n    group -n ($IKCtrls[$ikc]+\"_FK_ctrl_NULL\") -em;\n    delete `parentConstraint ($IKCtrls[$ikc]+\"_FK_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl_NULL\")`;\n    parent($IKCtrls[$ikc]+\"_FK_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl_offset\");\n    parent($IKCtrls[$ikc]+\"_FK_ctrl_offset\") ($IKCtrls[$ikc]+\"_FK_ctrl_NULL\");\n    duplicate -rr -n ($IKCtrls[$ikc]+\"_FK_sub_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl\");\n    \n    int $degree1 = `getAttr (($IKCtrls[$ikc]+\"_FK_sub_ctrl\")+\".degree\")`;\n    int $spans1 = `getAttr (($IKCtrls[$ikc]+\"_FK_sub_ctrl\")+\".spans\")`;\n    int $max1 = ($degree1+$spans1)-1;\n\tselect -r -sym (($IKCtrls[$ikc]+\"_FK_sub_ctrl\")+\".cv[0:\"+$max1+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    parent ($IKCtrls[$ikc]+\"_FK_sub_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl\");\n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on ($IKCtrls[$ikc]+\"_FK_ctrl\");\n    connectAttr (($IKCtrls[$ikc]+\"_FK_ctrl\")+\".subCtrl\") (($IKCtrls[$ikc]+\"_FK_sub_ctrlShape\")+\".v\");\n    setAttr -k 0 -channelBox true (($IKCtrls[$ikc]+\"_FK_ctrl\")+\".subCtrl\");    \n    if($ikc>0){\n    parent ($IKCtrls[$ikc]+\"_FK_ctrl_NULL\") ($IKCtrls[$ikc-1]+\"_FK_ctrl\");\n    }\n/***********************************************************************connect attrs******************************************************************************************************************************/    \ngroup -n ($IKCtrls[$ikc]+\"_FK_drv\") -em;\nparentConstraint ($IKCtrls[$ikc]+\"_IK_sub_ctrl\") ($IKCtrls[$ikc]+\"_FK_drv\");\nif($ikc>0){\n    parent ($IKCtrls[$ikc]+\"_FK_drv\") ($IKCtrls[$ikc-1]+\"_FK_drv\");\n    }\n\nconnectAttr ($IKCtrls[$ikc]+\"_FK_drv.translate\") ($IKCtrls[$ikc]+\"_FK_ctrl_NULL.translate\");\nconnectAttr ($IKCtrls[$ikc]+\"_FK_drv.rotate\") ($IKCtrls[$ikc]+\"_FK_ctrl_NULL.rotate\");\n\n}\n}\nCurIFCtrlWin;" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "global proc CurIFCtrlWin(){\nstring $chlist[] = (`ls  -sl`);\nstri..." 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "CurIFCtrlSetup" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "global proc CurIFCtrlWin(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"LocatorsOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -bgc 0.08 0.02 0.13 -title \"Create IKFK ctrl setup based on the curve\" -widthHeight 150 50 $mygui;  \n frameLayout  -label \"Select the curve\" -collapsable 0 -bgc 0.35 0.35 0.1; \ntextFieldButtonGrp -bgc 0.234 0 0 -hlc 1 0 0 -label \"Select the curve\"\n-text \"\"\n-buttonLabel \"BASE CURVE\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_org()\" attr_name;\n\n\nframeLayout -label \"Create ctrls and joints based on the curve\" -collapsable 0 -bgc 0.35 0.35 0.1; \n   text -l \"Please type in the number you want.\";\n   rowLayout;\n\n\t\t\ttextFieldButtonGrp -bgc 0.234 0 0 -hlc 1 0 0 -label \"ctrl account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonLabel \"CREATE\"\n\t\t\t-buttonCommand \"curveIFSetup(`textFieldGrp  -query -text attr_name`,`textFieldButtonGrp -query -text joint_number`)\"  joint_number;\n\n\n\n\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\n\nglobal proc curveIFSetup(string $cur, int $locNum){\nfor($i=0;$i<$locNum;$i++){\n   spaceLocator -n ($cur+\"_\"+($i+1)+\"_loc\")-p 0 0 0;\n   \n    select -tgl $cur;\npathAnimation -n ($cur+\"_\"+($i+1)+\"_loc_path\") -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 1 -endTimeU 1;\nselectKey -add -k -t 1 -t 1 ($cur+\"_\"+($i+1)+\"_loc_path_uValue\");\ncutKey -animation keys -clear;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_path.allCoordinates\") ($cur+\"_\"+($i+1)+\"_loc.translate\");\ndelete `listConnections -t \"addDoubleLinear\"`;\nCBdeleteConnection ($cur+\"_\"+($i+1)+\"_loc.rx\");\nCBdeleteConnection ($cur+\"_\"+($i+1)+\"_loc.ry\");\nCBdeleteConnection ($cur+\"_\"+($i+1)+\"_loc.rz\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc.rx\") 0;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc.ry\") 0;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc.rz\") 0;\nshadingNode -asUtility multiplyDivide -n ($cur+\"_\"+($i+1)+\"_loc_md\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.operation\") 2;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input2X\") ($locNum-1);\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input1X\") $i;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_md.outputX\") ($cur+\"_\"+($i+1)+\"_loc_path.uValue\");\ndelete ($cur+\"_\"+($i+1)+\"_loc_md\");\n\n}\ngroup -n ($cur+\"_\"+\"loc_grp\") -em;\nparent ($cur+\"_\"+\"*_loc\") ($cur+\"_\"+\"loc_grp\") ;\nselect -r ($cur+\"_\"+\"*_loc\");\nctrlsFuns;\ngroup -n ($cur+\"_IK_ctrl_grp\") -em;\nparent ($cur+\"_\"+\"*_loc_IK_ctrl_offset\")($cur+\"_IK_ctrl_grp\") ;\nselect ($cur+\"_\"+\"*_loc_IK_ctrl_offset\") ($cur+\"_\"+\"*_loc_FK_ctrl_NULL\");\nsearchReplaceNames \"_loc\" \"\" \"hierarchy\";\nsetAttr ($cur+\"_\"+\"loc_grp.v\") 0;\nselect -cl;\n/*************************************************************************create joints*********************************************************************************************************/\n\njoint -n dup_joint;\n\nfor ($j=0;$j<$locNum;$j++){\n\tduplicate  -n ($cur+\"_\"+($j+1)+\"_joint\") dup_joint;\n\tif ($j>0){\n\t\tparent ($cur+\"_\"+($j+1)+\"_joint\") ($cur+\"_\"+$j+\"_joint\");\n\t\tsetAttr ($cur+\"_\"+($j+1)+\"_joint.translateX\") 1;\n\t\t}\n\t\n}\ndelete dup_joint;\n\n/*************************************************************************create rotate cards*********************************************************************************************************/\nselect -hi ($cur+\"_\"+\"1_joint\") ;\nstring $born[]=`ls -sl`;\nfor($b=0;$b<$locNum;$b++){\n\tpolyPlane -w 1 -h 1 -sx 1 -sy 1  -n ($born[$b]+\"_rot_geo\");\t\n\tmove -rpr -0.5 0 0 (($born[$b]+\"_rot_geo\")+\".scalePivot\") (($born[$b]+\"_rot_geo\")+\".rotatePivot\");\n\tdelete `parentConstraint  $born[$b] ($born[$b]+\"_rot_geo\")`;\n\t\n\tspaceLocator -n ($born[$b]+\"_rot_loc\");\n\tdelete`parentConstraint $born[$b] ($born[$b]+\"_rot_loc\")`;\t\n\t\n    shadingNode -asUtility distanceBetween -n ($born[$b]+\"_dist\");\n    if($b>0){\n\t\tconnectAttr (($born[$b]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point1\");\n\t\tconnectAttr (($born[$b-1]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point2\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tselect -r (\"*_rot_geo\");\n\t\tmakeIdentity -apply true -t 0 -r 0 -s 1 -n 0 -pn 1 ;    \n\t\tparent ($born[$b]+\"_rot_geo\") ($born[$b-1]+\"_rot_geo\");\n\t\t\n\t\t}\n\t\n    \n    pointConstraint -n ($born[$b]+\"_rotptcon\") ($born[$b]+\"_rot_geo\") $born[$b];\t\n\tconnectAttr (($born[$b]+\"_rot_geo\")+\".rotate\") ($born[$b]+\".jointOrient\");\n\tstring $opsit = substituteAllString($born[$b], \"joint\", \"loc\");\n\tstring $opsit1 = substituteAllString($born[$b+1], \"joint\", \"loc\");\n\tdelete `pointConstraint $opsit ($born[$b]+\"_rot_geo\")`;\n\tif($b<($locNum-1)){\n\ndelete `aimConstraint -offset 0 0 0 -weight 1 -aimVector 1 0 0 -upVector 0 1 0 -worldUpType \"vector\" -worldUpVector 0 1 0 $opsit1 ($born[$b]+\"_rot_geo\")`;\n\t}\n\n}\t\n\ndelete (\"*_rot_loc\");\ndelete (\"*_rotptcon*\");\ndelete (\"*_rot_geo*\");\n\n\nselect -hi ($cur+\"_\"+\"1_joint\") ;\nstring $bornCont[]=`ls -sl`;\nfor($bc=0;$bc<$locNum;$bc++){\n    string $FKCtrls = substituteAllString($bornCont[$bc], \"_joint\", \"_FK_sub_ctrl\");\n    parentConstraint -n($bornCont[$bc]+\"_pCont\") $FKCtrls $bornCont[$bc];\n}\n\n\ngroup -n ($cur+\"_joint_grp\") -em;\nparent ($cur+\"_1_joint\") ($cur+\"_joint_grp\");\n\ngroup -n ($cur+\"_FK_ctrl_grp\") -em;\nparent ($cur+\"_1_FK_ctrl_NULL\") ($cur+\"_FK_ctrl_grp\");\n\ngroup -n ($cur+\"_ctrl_grp\") -em;\n\n\ngroup -n ($cur+\"_setup_grp\") -em;\nparent ($cur+\"_joint_grp\") ($cur+\"_1_loc_FK_drv\") ($cur+\"_loc_grp\") $cur ($cur+\"_setup_grp\");\nsetAttr ($cur+\"_1_loc_FK_drv.v\") 0;\nsetAttr ($cur+\"_\"+\"loc_grp.inheritsTransform\") 0;\n\n\ncurve -n ($cur+\"_ctrl\") -d 1 -p -0.5 0.5 -0.5 -p -0.5 0.5 0.5 -p 0.5 0.5 0.5 -p 0.5 0.5 -0.5 -p -0.5 0.5 -0.5 -p -0.5 -0.5 -0.5 -p -0.5 -0.5 0.5 -p 0.5 -0.5 0.5 -p 0.5 -0.5 -0.5 -p -0.5 -0.5 -0.5 -p -0.5 0.5 -0.5 -p 0.5 0.5 -0.5 -p 0.5 -0.5 -0.5 -p 0.5 -0.5 0.5 -p 0.5 0.5 0.5 -p -0.5 0.5 0.5 -p -0.5 -0.5 0.5 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 ;\nrename `listRelatives -c` ($cur+\"_ctrlShape\");\ndelete `pointConstraint ($cur+\"_1_loc_FK_drv\") ($cur+\"_ctrl\")`;\ngroup -n ($cur+\"_ctrl_offset\") -em;\ndelete `parentConstraint ($cur+\"_ctrl\") ($cur+\"_ctrl_offset\")`;\nparent ($cur+\"_ctrl\") ($cur+\"_ctrl_offset\");\nparent ($cur+\"_ctrl_offset\") ($cur+\"_ctrl_grp\");\nparent ($cur+\"_FK_ctrl_grp\") ($cur+\"_IK_ctrl_grp\") ($cur+\"_ctrl\");\nscaleConstraint -n($cur+\"_ctrl_sCont\") -mo ($cur+\"_ctrl\") ($cur+\"_setup_grp\");\nparentConstraint  -n($cur+\"_ctrl_pCont\") -mo ($cur+\"_ctrl\") ($cur+\"_setup_grp\");\n\nselect -r ($cur+\"_*_loc\");\nstring $locRot[] = `ls - sl`;\nfor($ls=0;$ls<size($locRot);$ls++){\n    orientConstraint -n ( $locRot[$ls]+\"_oCont\")($cur+\"_ctrl\") $locRot[$ls] ;\n    }\n\n}\n\n\n\n/***********************************************************************++++++++******************************************************************************************************************************/    \n/***********************************************************************FK Ctrl******************************************************************************************************************************/    \n\nglobal proc ctrlsFuns(){\nstring $IKCtrls[] = `ls - sl`;\nfor($ikc=0;$ikc<size($IKCtrls);$ikc++){\n/***********************************************************************FK Ctrl******************************************************************************************************************************/    \n    curve -n ($IKCtrls[$ikc]+\"_IK_ctrl\") -d 1 -p -1 0 -1 -p -1 0 1 -p 1 0 1 -p 1 0 -1 -p -1 0 -1 -k 0 -k 1 -k 2 -k 3 -k 4 ;\n    rename `listRelatives -c` ($IKCtrls[$ikc]+\"_IK_ctrlShape\");\n    delete `parentConstraint $IKCtrls[$ikc] ($IKCtrls[$ikc]+\"_IK_ctrl\")`;\n    group -n ($IKCtrls[$ikc]+\"_IK_ctrl_offset\") -em;\n    delete `parentConstraint ($IKCtrls[$ikc]+\"_IK_ctrl\") ($IKCtrls[$ikc]+\"_IK_ctrl_offset\")`;\n    parent($IKCtrls[$ikc]+\"_IK_ctrl\") ($IKCtrls[$ikc]+\"_IK_ctrl_offset\");\n    duplicate -rr -n ($IKCtrls[$ikc]+\"_IK_sub_ctrl\") ($IKCtrls[$ikc]+\"_IK_ctrl\");\n    \n    int $degree = `getAttr (($IKCtrls[$ikc]+\"_IK_sub_ctrl\")+\".degree\")`;\n    int $spans = `getAttr (($IKCtrls[$ikc]+\"_IK_sub_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym (($IKCtrls[$ikc]+\"_IK_sub_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    parent ($IKCtrls[$ikc]+\"_IK_sub_ctrl\") ($IKCtrls[$ikc]+\"_IK_ctrl\");\n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on ($IKCtrls[$ikc]+\"_IK_ctrl\");\n    connectAttr (($IKCtrls[$ikc]+\"_IK_ctrl\")+\".subCtrl\") (($IKCtrls[$ikc]+\"_IK_sub_ctrlShape\")+\".v\");\n    setAttr -k 0 -channelBox true (($IKCtrls[$ikc]+\"_IK_ctrl\")+\".subCtrl\");\n/***********************************************************************FK Ctrl******************************************************************************************************************************/    \n    parentConstraint -n (($IKCtrls[$ikc]+\"_IK_pCont\"))$IKCtrls[$ikc] ($IKCtrls[$ikc]+\"_IK_ctrl_offset\");\n    \n    curve -n ($IKCtrls[$ikc]+\"_FK_ctrl\") -d 1 -p 0 1 0 -p 0.5 0.866025 0 -p 0.866025 0.5 0 -p 1 0 0 -p 0.866025 -0.5 0 -p 0.5 -0.866025 0 -p 0 -1 0 -p 0.353553 -0.866025 0.353553 -p 0.612372 -0.5 0.612372 -p 0.707107 0 0.707107 -p 0.612372 0.5 0.612372 -p 0.353553 0.866025 0.353553 -p 0 1 0 -p 0 0.866025 0.5 -p 0 0.5 0.866025 -p 0 0 1 -p 0 -0.5 0.866025 -p 0 -0.866025 0.5 -p 0 -1 0 -p -0.353553 -0.866025 0.353553 -p -0.612372 -0.5 0.612372 -p -0.707107 0 0.707107 -p -0.612372 0.5 0.612372 -p -0.353553 0.866025 0.353553 -p 0 1 0 -p -0.5 0.866025 0 -p -0.866025 0.5 0 -p -1 0 0 -p -0.866025 -0.5 0 -p -0.5 -0.866025 0 -p 0 -1 0 -p -0.353553 -0.866025 -0.353553 -p -0.612372 -0.5 -0.612372 -p -0.707107 0 -0.707107 -p -0.612372 0.5 -0.612372 -p -0.353553 0.866025 -0.353553 -p 0 1 0 -p 0 0.866025 -0.5 -p 0 0.5 -0.866025 -p 0 0 -1 -p 0 -0.5 -0.866025 -p 0 -0.866025 -0.5 -p 0 -1 0 -p 0.353553 -0.866025 -0.353553 -p 0.612372 -0.5 -0.612372 -p 0.707107 0 -0.707107 -p 0.612372 0.5 -0.612372 -p 0.353553 0.866025 -0.353553 -p 0 1 0 -p 0.5 0.866025 0 -p 0.353553 0.866025 -0.353553 -p 0 0.866025 -0.5 -p -0.353553 0.866025 -0.353553 -p -0.5 0.866025 0 -p -0.353553 0.866025 0.353553 -p 0 0.866025 0.5 -p 0.353553 0.866025 0.353553 -p 0.5 0.866025 0 -p 0.866025 0.5 0 -p 0.612372 0.5 -0.612372 -p 0 0.5 -0.866025 -p -0.612372 0.5 -0.612372 -p -0.866025 0.5 0 -p -0.612372 0.5 0.612372 -p 0 0.5 0.866025 -p 0.612372 0.5 0.612372 -p 0.866025 0.5 0 -p 1 0 0 -p 0.707107 0 -0.707107 -p 0 0 -1 -p -0.707107 0 -0.707107 -p -1 0 0 -p -0.707107 0 0.707107 -p 0 0 1 -p 0.707107 0 0.707107 -p 1 0 0 -p 0.866025 -0.5 0 -p 0.612372 -0.5 -0.612372 -p 0 -0.5 -0.866025 -p -0.612372 -0.5 -0.612372 -p -0.866025 -0.5 0 -p -0.612372 -0.5 0.612372 -p 0 -0.5 0.866025 -p 0.612372 -0.5 0.612372 -p 0.866025 -0.5 0 -p 0.5 -0.866025 0 -p 0.353553 -0.866025 -0.353553 -p 0 -0.866025 -0.5 -p -0.353553 -0.866025 -0.353553 -p -0.5 -0.866025 0 -p -0.353553 -0.866025 0.353553 -p 0 -0.866025 0.5 -p 0.353553 -0.866025 0.353553 -p 0.5 -0.866025 0 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 -k 49 -k 50 -k 51 -k 52 -k 53 -k 54 -k 55 -k 56 -k 57 -k 58 -k 59 -k 60 -k 61 -k 62 -k 63 -k 64 -k 65 -k 66 -k 67 -k 68 -k 69 -k 70 -k 71 -k 72 -k 73 -k 74 -k 75 -k 76 -k 77 -k 78 -k 79 -k 80 -k 81 -k 82 -k 83 -k 84 -k 85 -k 86 -k 87 -k 88 -k 89 -k 90 -k 91 -k 92 -k 93 ;\n    rename `listRelatives -c` ($IKCtrls[$ikc]+\"_FK_ctrlShape\");\n\n    delete `parentConstraint $IKCtrls[$ikc] ($IKCtrls[$ikc]+\"_FK_ctrl\")`;\n    group -n ($IKCtrls[$ikc]+\"_FK_ctrl_offset\") -em;\n    delete `parentConstraint ($IKCtrls[$ikc]+\"_FK_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl_offset\")`;\n    group -n ($IKCtrls[$ikc]+\"_FK_ctrl_NULL\") -em;\n    delete `parentConstraint ($IKCtrls[$ikc]+\"_FK_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl_NULL\")`;\n    parent($IKCtrls[$ikc]+\"_FK_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl_offset\");\n    parent($IKCtrls[$ikc]+\"_FK_ctrl_offset\") ($IKCtrls[$ikc]+\"_FK_ctrl_NULL\");\n    duplicate -rr -n ($IKCtrls[$ikc]+\"_FK_sub_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl\");\n    \n    int $degree1 = `getAttr (($IKCtrls[$ikc]+\"_FK_sub_ctrl\")+\".degree\")`;\n    int $spans1 = `getAttr (($IKCtrls[$ikc]+\"_FK_sub_ctrl\")+\".spans\")`;\n    int $max1 = ($degree1+$spans1)-1;\n\tselect -r -sym (($IKCtrls[$ikc]+\"_FK_sub_ctrl\")+\".cv[0:\"+$max1+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    parent ($IKCtrls[$ikc]+\"_FK_sub_ctrl\") ($IKCtrls[$ikc]+\"_FK_ctrl\");\n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on ($IKCtrls[$ikc]+\"_FK_ctrl\");\n    connectAttr (($IKCtrls[$ikc]+\"_FK_ctrl\")+\".subCtrl\") (($IKCtrls[$ikc]+\"_FK_sub_ctrlShape\")+\".v\");\n    setAttr -k 0 -channelBox true (($IKCtrls[$ikc]+\"_FK_ctrl\")+\".subCtrl\");    \n    if($ikc>0){\n    parent ($IKCtrls[$ikc]+\"_FK_ctrl_NULL\") ($IKCtrls[$ikc-1]+\"_FK_ctrl\");\n    }\n/***********************************************************************connect attrs******************************************************************************************************************************/    \ngroup -n ($IKCtrls[$ikc]+\"_FK_drv\") -em;\nparentConstraint ($IKCtrls[$ikc]+\"_IK_sub_ctrl\") ($IKCtrls[$ikc]+\"_FK_drv\");\nif($ikc>0){\n    parent ($IKCtrls[$ikc]+\"_FK_drv\") ($IKCtrls[$ikc-1]+\"_FK_drv\");\n    }\n\nconnectAttr ($IKCtrls[$ikc]+\"_FK_drv.translate\") ($IKCtrls[$ikc]+\"_FK_ctrl_NULL.translate\");\nconnectAttr ($IKCtrls[$ikc]+\"_FK_drv.rotate\") ($IKCtrls[$ikc]+\"_FK_ctrl_NULL.rotate\");\n\n}\n}\nCurIFCtrlWin;" 
