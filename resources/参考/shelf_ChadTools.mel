61 0 0 -p 1.161337 0 0 -p 1.072936 0 -0.444424 -p 1.667474 0 -0.690689 -p 1.27623 0 -1.276228 -p 0.821189 0 -0.821188 -p 0.444425 0 -1.072935 -p 0.690691 0 -1.667474 -p 9.14414e-07 0 -1.804861 -p 5.88379e-07 0 -1.161337 -p 0.444425 0 -1.072935 -p 0.821189 0 -0.821188 -p 1.072936 0 -0.444424 -p 1.161337 0 0 -p 1.072935 0 0.444424 -p 0.821188 0 0.821188 -p 0.444424 0 1.072935 -p -1.73053e-07 0 1.161337 -p -0.444424 0 1.072935 -p -0.821188 0 0.821188 -p -1.072936 0 0.444424 -p -1.161337 0 -4.15326e-07 -p -1.072935 0 -0.444424 -p -0.821188 0 -0.821188 -p -0.444424 0 -1.072936 -p 5.88379e-07 0 -1.161337 -p -1.73053e-07 0 1.161337 -p 0 0 0 -p -1.161337 0 -4.15326e-07 -p 0 0 0 -p 1.161337 0 0 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 -k 49 -k 50 -k 51 -k 52 -k 53 -k 54 -k 55 -k 56 -k 57 -k 58 -k 59 -k 60 -k 61 -k 62 -k 63 -k 64 -k 65 -k 66 -k 67 -k 68 -k 69 -k 70 ;\nrename `listRelatives -c -type \"shape\"` root_ctrlShape;\n\n    int $degree1 = `getAttr root_ctrl.degree`;\n    int $spans1 = `getAttr root_ctrl.spans`;\n    int $max1 = ($degree1+$spans1)-1;\n\tselect -r -sym root_ctrl.cv[0:$max1] ;\n    scale -r -ocp 0.15 0.15 0.15;\n    select -cl;\n\n\nduplicate -rc -n root_sub_ctrl root_ctrl;\n rename `listRelatives -c -type \"shape\" root_ctrl` root_sub_ctrlShape;\n    \n    \n    int $degree = `getAttr root_sub_ctrl.degree`;\n    int $spans = `getAttr root_sub_ctrl.spans`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym root_sub_ctrl.cv[0:$max] ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n\n\n    parent root_sub_ctrl root_ctrl;\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on root_ctrl;\n    \n    connectAttr root_ctrl.subCtrl root_sub_ctrlShape.v;\n    \n    setAttr -k 0 -channelBox true root_ctrl.subCtrl;\n    \ngroup -n root_ctrl_offset -em;\nparent root_ctrl root_ctrl_offset;\n    \nparent root_ctrl_offset local_ctrl;\nparent local_ctrl_offset world_ctrl;    \nparent world_ctrl_offset ctrl_grp;\nselect -r root_sub_ctrl.cv[0:70] root_ctrl|root_sub_ctrlShape.cv[0:70] world_ctrlShape.cv[0:55] local_ctrlShape.cv[0:52] ;\n\nscale -r 15 15 15 ;   \nselect -cl;\n    \njoint -p 0 0 0 -n root_joint;\nparentConstraint -n root_PaCont root_sub_ctrl root_joint;\nparent root_joint bind_joint_grp;\n\naddAttr -ln \"geoResulation\" -nn \"Geo Resulation\" -at \"enum\" -en \"High:Low:\"  world_ctrl;\nsetAttr -e-keyable true world_ctrl.geoResulation;    \n    \nshadingNode -asUtility condition -n highRes_vis_cond;   \nshadingNode -asUtility condition -n lowRes_vis_cond;     \n    \nsetAttr \"highRes_vis_cond.colorIfTrueR\" 1;\nsetAttr \"highRes_vis_cond.colorIfFalseR\" 0;\nsetAttr \"lowRes_vis_cond.secondTerm\" 1;\nsetAttr \"lowRes_vis_cond.colorIfTrueR\" 1;\nsetAttr \"lowRes_vis_cond.colorIfFalseR\" 0;   \nconnectAttr  world_ctrl.geoResulation highRes_vis_cond.firstTerm;\nconnectAttr  world_ctrl.geoResulation lowRes_vis_cond.firstTerm;\nconnectAttr highRes_vis_cond.outColorR high.visibility;\nconnectAttr lowRes_vis_cond.outColorR low.visibility;\nselect -cl;\n}   \n    \n\nglobal proc create3Dctrl(){\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){\n    curve -n ($born[$i]+\"_ctrl\") -d 1 -p -1 0.234239 -3.57628e-07 -p -0.92388 0.234239 0.382683 -p -0.707107 0.234239 0.707107 -p -0.382684 0.234239 0.923879 -p -1.49012e-07 0.234239 1 -p 0.382683 0.234239 0.92388 -p 0.707107 0.234239 0.707107 -p 0.92388 0.234239 0.382683 -p 1 0.234239 0 -p 0.92388 0.234239 -0.382683 -p 0.707107 0.234239 -0.707106 -p 0.382684 0.234239 -0.923879 -p 5.06639e-07 0.234239 -1 -p -0.382683 0.234239 -0.92388 -p -0.707106 0.234239 -0.707107 -p -0.923879 0.234239 -0.382684 -p -1 0.234239 -3.57628e-07 -p -1 -0.234239 -3.57628e-07 -p -0.92388 -0.234239 0.382683 -p -0.707107 -0.234239 0.707107 -p -0.382684 -0.234239 0.923879 -p -1.49012e-07 -0.234239 1 -p 0.382683 -0.234239 0.92388 -p 0.707107 -0.234239 0.707107 -p 0.92388 -0.234239 0.382683 -p 1 -0.234239 0 -p 0.92388 -0.234239 -0.382683 -p 0.707107 -0.234239 -0.707106 -p 0.382684 -0.234239 -0.923879 -p 5.06639e-07 -0.234239 -1 -p -0.382683 -0.234239 -0.92388 -p -0.707106 -0.234239 -0.707107 -p -0.923879 -0.234239 -0.382684 -p -1 -0.234239 -3.57628e-07 -p -0.92388 -0.234239 0.382683 -p -0.707107 -0.234239 0.707107 -p -0.382684 -0.234239 0.923879 -p -1.49012e-07 -0.234239 1 -p -1.49012e-07 0.234239 1 -p 0.382683 0.234239 0.92388 -p 0.707107 0.234239 0.707107 -p 0.92388 0.234239 0.382683 -p 1 0.234239 0 -p 1 -0.234239 0 -p 0.92388 -0.234239 -0.382683 -p 0.707107 -0.234239 -0.707106 -p 0.382684 -0.234239 -0.923879 -p 5.06639e-07 -0.234239 -1 -p 5.06639e-07 0.234239 -1 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 ;\n    rename `listRelatives -c -type \"shape\"` ($born[$i]+\"_ctrlShape\");\n    group -n ($born[$i]+\"_ctrl_offset\") -em;\n    delete `parentConstraint ($born[$i]+\"_ctrl\") ($born[$i]+\"_ctrl_offset\")`;\n    parent ($born[$i]+\"_ctrl\") ($born[$i]+\"_ctrl_offset\");\n\n    delete `parentConstraint $born[$i] ($born[$i]+\"_ctrl_offset\")`;\n\n    \n    \n     duplicate -rc -n ($born[$i]+\"_sub_ctrl\") ($born[$i]+\"_ctrl\");\n rename `listRelatives -c -type \"shape\" ($born[$i]+\"_sub_ctrl\")` ($born[$i]+\"_sub_ctrlShape\");\n    \n    \n    int $degree = `getAttr (($born[$i]+\"_sub_ctrl\")+\".degree\")`;\n    int $spans = `getAttr (($born[$i]+\"_sub_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym (($born[$i]+\"_sub_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n\n\n    parent ($born[$i]+\"_sub_ctrl\") ($born[$i]+\"_ctrl\");\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on ($born[$i]+\"_ctrl\");\n    \n    connectAttr (($born[$i]+\"_ctrl\")+\".subCtrl\") (($born[$i]+\"_sub_ctrlShape\")+\".v\");\n    \n    setAttr -k 0 -channelBox true (($born[$i]+\"_ctrl\")+\".subCtrl\");\n        parentConstraint ($born[$i]+\"_sub_ctrl\") $born[$i] ;\n}\n}\n\n\n\nglobal proc delRotCds(){\ndelete (\"*_rotptcon*\");\ndelete (\"*_rot_geo*\");\n}\n\nglobal proc addRotCds(){\nstring $born[]=`ls -sl`;\nfor($i=0;$i<size($born);$i++){\n\tpolyPlane -w 1 -h 1 -sx 1 -sy 1  -n ($born[$i]+\"_rot_geo\");\t\n\tmove -rpr -0.5 0 0 (($born[$i]+\"_rot_geo\")+\".scalePivot\") (($born[$i]+\"_rot_geo\")+\".rotatePivot\");\n\tdelete `parentConstraint  $born[$i] ($born[$i]+\"_rot_geo\")`;\n\t\n\tspaceLocator -n ($born[$i]+\"_rot_loc\");\n\tdelete`parentConstraint $born[$i] ($born[$i]+\"_rot_loc\")`;\t\n\t\n    shadingNode -asUtility distanceBetween -n ($born[$i]+\"_dist\");\n    if($i>0){\n\t\tconnectAttr (($born[$i]+\"_rot_loc\")+\".translate\") (($born[$i]+\"_dist\")+\".point1\");\n\t\tconnectAttr (($born[$i-1]+\"_rot_loc\")+\".translate\") (($born[$i]+\"_dist\")+\".point2\");\n\t\tconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleX\");\n\t\tconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleY\");\n\t\tconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tdisconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleX\");\n\t\tdisconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleY\");\n\t\tdisconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tselect -r (\"*_rot_geo\");\n\t\tmakeIdentity -apply true -t 0 -r 0 -s 1 -n 0 -pn 1 ;    \n\t\tparent ($born[$i]+\"_rot_geo\") ($born[$i-1]+\"_rot_geo\");\n\t\t\n\t\t}\n\n\t    if($i==(size($born)-1)){\n\t    \t\tsetAttr (($born[$i]+\"_rot_geo\")+\".rotateX\") 0;\n\t\t\t\tsetAttr (($born[$i]+\"_rot_geo\")+\".rotateY\") 0;\n\t\t\t\tsetAttr (($born[$i]+\"_rot_geo\")+\".rotateZ\") 0;\n\t    }\n    \n    pointConstraint -n ($born[$i]+\"_rotptcon\") ($born[$i]+\"_rot_geo\") $born[$i];\t\n\tconnectAttr (($born[$i]+\"_rot_geo\")+\".rotate\") ($born[$i]+\".jointOrient\");\n\n}\n\t\n\n\tdelete (\"*_rot_loc\");\n\n}\n\n\n\nglobal proc addIFGRP(){\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){\n    string $GRPnam = substituteAllString($born[$i], \"attr_ctrl\", \"\");\n    group -n ($GRPnam+\"FK_ctrl_grp\") -em;\n    group -n ($GRPnam+\"IK_ctrl_grp\") -em;\n    group -n ($GRPnam+\"ctrl_grp\") -em;\n    parent ($GRPnam+\"FK_ctrl_grp\") ($GRPnam+\"ctrl_grp\");\n    parent ($GRPnam+\"IK_ctrl_grp\") ($GRPnam+\"ctrl_grp\");\n    shadingNode -asUtility reverse -n ($GRPnam+\"FK_rev\");\nconnectAttr ($born[$i]+\".ikfk\") ($GRPnam+\"IK_ctrl_grp.v\");\nconnectAttr ($born[$i]+\".ikfk\") ($GRPnam+\"FK_rev.inputX\");\nconnectAttr ($GRPnam+\"FK_rev.outputX\") ($GRPnam+\"FK_ctrl_grp.v\");\n\n   } \n}\n\n\nglobal proc AddIFAttr(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\naddAttr -ln \"ikfk\" -nn \"Ikfk\" -at long  -min 0 -max 1 -dv 0 -k on $item;\n}\n}\n\n\n\n\nglobal proc setDrivenKeyforIFAttr(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tstring $IFJointp = substituteAllString($item, \"joint\", \"joint_pcont\");\n\tstring $IFJointpiattr = substituteAllString($item, \"joint\", \"IK_jointW0\");\n\tstring $IFJointpfattr = substituteAllString($item, \"joint\", \"FK_jointW1\");\n\t\n\tsetAttr \"nurbsCircle1.ikfk\" 1;\n\tsetAttr ($IFJointp+\".\"+$IFJointpiattr) 1;\n\tsetAttr ($IFJointp+\".\"+$IFJointpfattr) 0;\n\t\n\tsetDrivenKeyframe -currentDriver nurbsCircle1.ikfk ($IFJointp+\".\"+$IFJointpiattr);\n\tsetDrivenKeyframe -currentDriver nurbsCircle1.ikfk ($IFJointp+\".\"+$IFJointpfattr);\n\t\n\tsetAttr \"nurbsCircle1.ikfk\" 0;\n\tsetAttr ($IFJointp+\".\"+$IFJointpiattr) 0;\n\tsetAttr ($IFJointp+\".\"+$IFJointpfattr) 1;\n\t\n\tsetDrivenKeyframe -currentDriver nurbsCircle1.ikfk ($IFJointp+\".\"+$IFJointpiattr);\n\tsetDrivenKeyframe -currentDriver nurbsCircle1.ikfk ($IFJointp+\".\"+$IFJointpfattr);\n\t}\n}\n\n\nglobal proc subCtrls(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tstring $subnam = substituteAllString($item, \"ctrl\", \"sub\");\t\n    duplicate -rr -n ($subnam+\"_ctrl\") $item;\n    \n    int $degree = `getAttr (($subnam+\"_ctrl\")+\".degree\")`;\n    int $spans = `getAttr (($subnam+\"_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym (($subnam+\"_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n    parent ($subnam+\"_ctrl\") $item;\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on $item;\n    \n    connectAttr ($item+\".subCtrl\") (($subnam+\"_ctrlShape\")+\".v\");\n    \n    setAttr -k 0 -channelBox true ($item+\".subCtrl\");\n}\n\n}\n\nglobal proc addOffset(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tgroup -n ($item + \"_offset\") -em;\n\tdelete `parentConstraint $item ($item + \"_offset\")`;\n\tparent $item ($item + \"_offset\");\n}\n}\n\nglobal proc createIFJoints(){\nstring $cop[]=`ls -sl`;\nfor($c=0;$c<size($cop);$c++){\n        select -hi $cop[$c];        \n       duplicate -rr -renameChildren -un;\n       select -hi ($cop[$c]+\"1\");       \n        string $born[]=`ls -sl`;\n        for($i=0;$i<size($born);$i++){\n            string $Istill = substituteAllString($born[$i], \"joint1\", \"IK\");\n            rename ($born[$i]) ($Istill+\"_joint\");\n            }\n       select -hi $cop[$c];        \n       duplicate -rr -renameChildren -un;\n        select -hi ($cop[$c]+\"1\");    \n             \n        string $sel[]=`ls -sl`;\n        for($f=0;$f<size($sel);$f++){\n            string $Fstill = substituteAllString($sel[$f], \"joint1\", \"FK\");\n            rename ($sel[$f]) ($Fstill+\"_joint\");\n            }\n        \n}\n        \n}\nglobal proc connectIFJoints(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tstring $IKJoint = substituteAllString($item, \"joint\", \"IK_joint\");\n\tstring $FKJoint = substituteAllString($item, \"joint\", \"FK_joint\");\n\n\tparentConstraint -n ($item+\"_pcont\") $IKJoint $FKJoint $item;\n\t\n\t}\n}\n\n\n\n\n\n\n\n\n\n\n\n\n\n" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "chadTools" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "chadTools" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "ChadtoolBoxes;\nglobal proc ChadtoolBoxes(){\n\nif ( `window -exists cTWindow3` ) {\n deleteUI cTWindow3;\n}\nwindow -bgc 0.08 0.02 0.13 -t \"chad's rig tool v1.0\" -dockCorner \"topLeft\" \"left\" -dockStation -nestedDockingEnabled true  cTWindow3 ;\n\n\nframeLayout  -label \" please choose the tools that you need\" -collapsable 1 -bgc 0.35 0.35 0.1 ;\n \n   \n   rowColumnLayout -numberOfColumns 2;\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Create master group\" -c \"masterWin\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Add Subctrls\" -c \"subCtrls\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Add offset\" -c \"addOffset\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Create IKFK Joints\" -c \"createIFJoints\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Connect IKFK Joints\" -c \"connectIFJoints\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Switch IF Joints\" -c \"setDrivenKeyforIFAttr\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Add IF attribute\" -c \"AddIFAttr\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Add IF groups\" -c \"addIFGRP\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Add Orient joint geos\" -c \"addRotCds\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Delete Orient joint geos\" -c \"delRotCds\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Create 3D ctrl\" -c \"create3Dctrl\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Create cube ctrl\" -c \"cubectrls\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"ZeroOut all ctrls\" -c \"zeroOut\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Lock all the scales\" -c \"lockScaleVAttrs\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Create locator based on selected objects\" -c \"createLocs\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Create locator in mid of two objects\" -c \"midLocators\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"create clu based on curve\" -c \"curveClu\"; \n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Pivot Ctrl tool\" -c \"SpivotCtrlTool\";   \n  button -bgc 0.234 0 0 -hlc 1 0 0 -l \"CleanUp names\" -c \"nameclear\"; \n  \n    setParent ..;\n   setParent ..;\nframeLayout  -label \" facial rig tools\" -collapsable 1 -bgc 0.35 0.35 0.1 ;\n \n   \n   rowColumnLayout -numberOfColumns 2 ;\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Mirror Blendshapes\" -c \"BSTarget_mirror\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Add prefix to BS target\" -c \"addBStargetPrefix\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Copy skinweights \" -c \"CopySkinningWeights\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Add single BS\" -c \"addBSBasedOnObj\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Create follow geos\" -c \"CrtFollowGeos\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Reconnect the attrs with Lctrl\" -c \"connectLctrl\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Reconnect V attrs with Lctrl\" -c \"reconnectV\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Reconnect all the constraints\" -c \"reconnectConstraints\"; \n   \n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Zero out the end joint\" -c \"zerooutEndJnt\";\n   \n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Add trans offset group\" -c \"addTrans\";\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Double sides FK ctrls\" -c \"FFK\";\n       setParent ..;\n   setParent ..;\n   \nframeLayout  -label \" other tools\" -collapsable 1 -bgc 0.35 0.35 0.1 ;  \n\n    rowColumnLayout -numberOfColumns 2 ;\n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Rename tool\" -c \"Renmaer\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Curve tool\" -c \"CurTools\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Attribute share tool\" -c \"G_share_attr\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Soft selection to culter tool\" -c \"SftToClu\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"Insert joints tool\" -c \"ChadJointInsert\"; \n    \n\n  \n    setParent ..;\n   setParent ..;\n \nshowWindow cTWindow3;\nwindow -e -width 150 cTWindow3;\n}\n\nglobal proc nameclear(){\nsearchReplaceNames \"grp1\" \"grp\" \"hierarchy\" ;\nsearchReplaceNames \"offset1\" \"offset\" \"hierarchy\" ;\nsearchReplaceNames \"ctrl1\" \"ctrl\" \"hierarchy\" ;\nsearchReplaceNames \"cur1\" \"cur\" \"hierarchy\" ;\nsearchReplaceNames \"clu1\" \"clu\" \"hierarchy\" ;\nsearchReplaceNames \"loc1\" \"loc\" \"hierarchy\";\nsearchReplaceNames \"geo1\" \"geo\" \"hierarchy\";\nsearchReplaceNames \"joint1\" \"joint\" \"hierarchy\";\nsearchReplaceNames \"setup1\" \"setup\" \"hierarchy\";\n//searchReplaceNames \"_L_\" \"_R_\" \"hierarchy\";\nsearchReplaceNames \"ikh1\" \"ikh\" \"hierarchy\";\n}\n\nglobal proc reconnectConstraints(){\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){\n    parentConstraint -mo ($born[$i]+\"_sub_ctrl\") $born[$i];\n}\n}\n\nglobal proc ChadJointInsert()\n{\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"Chad_insert_joint\";\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"insert the joints\" -widthHeight 400 200 $mygui;  \nframeLayout\n   -label \"get the root joint\";\n  columnLayout -adj 1;\n \ntextFieldButtonGrp -label \"get the root joint\"\n-text \"\"\n-buttonLabel \"root joint\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\nframeLayout\n   -label \"get the end joint\";\n  columnLayout -adj 1;\n \ntextFieldButtonGrp -label \"get the end joint\"\n-text \"\"\n-buttonLabel \"end joint\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_tgr()\" attr_name1;\nsetParent ..;\nsetParent ..;\nframeLayout\n-label \"insert the joints\";\n       textFieldButtonGrp -label \"joint account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonLabel \"insert joints\"\n\t\t\t-buttonCommand \"insertMidJoints(`textFieldButtonGrp -query -text attr_name`,`textFieldButtonGrp -query -text attr_name1`,`textFieldButtonGrp -query -text joint_number`)\"  joint_number;\n       \n        separator -visible 0;\n        setParent ..;\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 150 $mygui;\n}\n\n\nglobal proc get_org()\n{\nstring $orglist[] = `ls -sl`;\nstring $orgobjname =$orglist[0];\nstring $orgbuffer[] ;\ntokenize $orgobjname \"|\" $orgbuffer ;\nint $org_arraysize = size($orgbuffer);\nif ($org_arraysize >1)\n{\ntextFieldButtonGrp -edit -text $orgbuffer[1] attr_name;\n            }\nelse\n{\ntextFieldButtonGrp -edit -text $orgbuffer[0] attr_name;\n            }\n}\n\nglobal proc get_tgr()\n{\nstring $tgrlist[] = `ls -sl`;\nstring $tgrobjname =$tgrlist[0];\nstring $tgrbuffer[] ;\ntokenize $tgrobjname \"|\" $tgrbuffer ;\nint $tgr_arraysize = size($tgrbuffer);\nif ($tgr_arraysize >1)\n{\ntextFieldButtonGrp -edit -text $tgrbuffer[1] attr_name1;\n            }\nelse\n{\ntextFieldButtonGrp -edit -text $tgrbuffer[0] attr_name1;\n            }\n}\n\n\n\nglobal proc insertMidJoints(string $rotJnt, string $endJnt,int $JNum){\nstring $born[]=`ls - sl`;\nint $n = $JNum;\nint $max = $n +1;\nfor($i=0;$i<$n;$i++){\n    string $new = substituteAllString($rotJnt, \"joint\", \"\");\n\n    duplicate -rc  -n ($new+($i+1)+\"_sub_joint\") $rotJnt ;\n    delete `listRelatives -c ($new+($i+1)+\"_sub_joint\")`;\n    pointConstraint -n ($new+($i+1)+\"_sub_jointPcont\") $rotJnt $endJnt ($new+($i+1)+\"_sub_joint\");\n    setAttr (($new+($i+1)+\"_sub_jointPcont.\")+$rotJnt+\"W0\") ($max-$i-1);\n    setAttr (($new+($i+1)+\"_sub_jointPcont.\")+$endJnt+\"W1\") ($i+1); \n    delete (\"*_sub_jointPcont\");\n    if ($i ==0){\n    parent ($new+\"1_sub_joint\") $rotJnt;\n    }\n    if ($i >0){\n    parent ($new+($i+1)+\"_sub_joint\") ($new+($i)+\"_sub_joint\");\n    }\n    if ($i == ($n-1)){\n    parent $endJnt ($new+($i+1)+\"_sub_joint\");\n    }\n}\n}\n\n\n\n\n\n\n\n\n\n\n\nglobal proc SpivotCtrlTool(){\t\nstring $curs[]= `ls-sl`;\nfor ($crs=0;$crs<size($curs);$crs++){\n\tstring $povitnam = substituteAllString($curs[$crs], \"ctrl\", \"\");\n\tstring $subcur[] = `listRelatives -c $curs[$crs]`;\n\tstring $oldoffset[] = `listRelatives -p $curs[$crs]`;\n\t\n\tduplicate -po -n ($povitnam+\"pivot_ctrl_offset\") $oldoffset;\n\tduplicate -po -n ($povitnam+\"neg_offset\") $oldoffset;\n\tparent ($povitnam+\"neg_offset\") ($povitnam+\"pivot_ctrl_offset\");\n\t\n\tduplicate  -n ($povitnam+\"pivot_ctrl\") $subcur[1];\n\tparent ($povitnam+\"pivot_ctrl\") ($povitnam+\"neg_offset\") ;\n\t\t\n\tint $degree = `getAttr (($povitnam+\"pivot_ctrl\")+\".degree\")`;\n    int $spans = `getAttr (($povitnam+\"pivot_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym (($povitnam+\"pivot_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    move -r -os -wd 0 2 0 ;\n    select -cl;\n    \n    parent ($povitnam+\"pivot_ctrl_offset\") $subcur[1];\n    \n    duplicate -po -n ($curs[$crs]+\"_pivot\") $oldoffset;\n    parent ($curs[$crs]+\"_pivot\") $oldoffset;\n    parent $curs[$crs] ($curs[$crs]+\"_pivot\");\n    \n    connectAttr  (($povitnam+\"pivot_ctrl\")+\".translate\") (($curs[$crs]+\"_pivot\")+\".translate\");\n    \n    shadingNode -asUtility multiplyDivide -n ($povitnam+\"pivot_mlt\");\n    connectAttr  (($povitnam+\"pivot_ctrl\")+\".translate\") (($povitnam+\"pivot_mlt\")+\".input1\");\n    setAttr (($povitnam+\"pivot_mlt\")+\".input2X\") -1;\n    setAttr (($povitnam+\"pivot_mlt\")+\".input2Y\") -1;\n    setAttr (($povitnam+\"pivot_mlt\")+\".input2Z\") -1;\n    \n    connectAttr (($povitnam+\"pivot_mlt\")+\".output\") (($povitnam+\"neg_offset\")+\".translate\") ;\n    \n    setAttr -lock true -keyable false -channelBox false (($povitnam+\"pivot_ctrl\")+\".rx\");\n\tsetAttr -lock true -keyable false -channelBox false (($povitnam+\"pivot_ctrl\")+\".ry\");\n\tsetAttr -lock true -keyable false -channelBox false (($povitnam+\"pivot_ctrl\")+\".rz\");\n\tsetAttr -lock true -keyable false -channelBox false (($povitnam+\"pivot_ctrl\")+\".sx\");\n\tsetAttr -lock true -keyable false -channelBox false (($povitnam+\"pivot_ctrl\")+\".sy\");\n\tsetAttr -lock true -keyable false -channelBox false (($povitnam+\"pivot_ctrl\")+\".sz\");\n\tsetAttr -lock true -keyable false -channelBox false (($povitnam+\"pivot_ctrl\")+\".v\");\n    \n\n    addAttr -ln \"pivtCtrl\" -nn \"Pivt Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on $curs[$crs];\n    \n\tconnectAttr ($curs[$crs]+\".pivtCtrl\") (($povitnam+\"pivot_ctrlShape\")+\".v\");\n    setAttr -k 0 -channelBox true ($curs[$crs]+\".pivtCtrl\");\n\t}\n}\nglobal proc curveClu(){\t\n\tstring $curve[] = `ls-sl`;\n\tfor ($c=0;$c<size($curve);$c++){\n\t\tint $degree = `getAttr ($curve[$c]+\".degree\")`;\n    \tint $spans = `getAttr ($curve[$c]+\".spans\")`;\n   \t\tint $max = ($degree+$spans)-1;\n   \t\t\n    string $clu[]=`select -r -sym ($curve[$c]+\".cv[0:\"+$max+\"]\")`;\n    \tfor($i=0;$i<($degree+$spans);$i++){  \n\n\t\t\tint $k = $i+1;\n        \tcluster  ($curve[$c]+\".cv[\"+$i+\"]\") ;\n\t\t\tif($k<10){\n        \trename  ($curve[$c]+\"_0\"+$k+\"_clu\");\n\t\t\t}\n\t\t\tif($k>=10){\n        \trename  ($curve[$c]+\"_\"+$k+\"_clu\");\n\t\t\t}\n    \t}\n    group -n ($curve[$c]+\"_clu_grp\") ($curve[$c]+\"*_clu\");\n    }\n}\n\nglobal proc SftToClu(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"softselectTOCluster\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"convert your soft selection to cluster\" -widthHeight 200 50 $mygui;  \n\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"select the point with softselect\" -collapsable 1 ; \n   text -l \"Please select the point with softselect and type in name that you want\";\n   columnLayout;\n            textFieldGrp\n            -label \"cluster name:\"\n            -text \"\"\n\n            attr_name;\n\n\n\n\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"create ctrl\" -c \"stcTool(`textFieldGrp  -query -text attr_name`)\";\n\n   setParent ..;\n   setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\nglobal proc stcTool(string $nam){\n//??mesh???\n   string $selVtx[] = `ls -sl -fl`;\n   $selVtxPP = `pointPosition -w $selVtx[0]`;\n   string $selShape[] = `listRelatives -p $selVtx[0]`;\n   string $selMesh[] = `listRelatives -p $selShape[0]`;\n   $numVtx = `polyEvaluate -v $selMesh[0]`;\n   float $oldVtxPP[] = {};\n   float $newVtxPP[] = {};\n   string $subCtr = substituteAllString($selVtx[0], ($selMesh[0] + \".vtx[\"), \"\");\n   string $subCtr1 = substituteAllString($subCtr, \"]\", \"\");\n//????????????????\n      for ($i = 0;$i<$numVtx[0]; $i++)\n       {\n        $vtxBeforeMove = `pointPosition -w ($selMesh[0] + \".vtx[\" + $i + \"]\")`;\n        $oldVtxPP[$i] = $vtxBeforeMove[0] ;\n       }\n//??????X????????????????\n    move -r 1 0 0 ;\n      for ($i = 0;$i<$numVtx[0]; $i++)\n       {\n        $vtxAfterMove = `pointPosition -w ($selMesh[0] + \".vtx[\" + $i + \"]\")`;\n        $newVtxPP[$i] =  $vtxAfterMove[0] ;\n       }\n//????????????\n    move -r -1 0 0 ;\n//?????????????,????????????\n    $cluster = `cluster -n ($selMesh[0]+\"_\"+$subCtr1+\"_cluster\") -rel -en 1 $selMesh`;\n    move $selVtxPP[0] $selVtxPP[1] $selVtxPP[2] ($cluster[1] + \".scalePivot\") ($cluster[1] + \".rotatePivot\");\n    setAttr ($cluster[1] + \"Shape.origin\") $selVtxPP[0] $selVtxPP[1] $selVtxPP[2];\n//????????????,??????????\n      for ($i = 0;$i<$numVtx[0]; $i++)\n      {\n      $eachVtxPPValue[$i] = $newVtxPP[$i] - $oldVtxPP[$i];\n      percent -v $eachVtxPPValue[$i] $cluster[0] ($selMesh[0] + \".vtx\" + \"[\" +$i+ \"]\");\n      }\n//??????0????\n string $clusterSet[] = `listConnections -s 0 -t \"objectSet\" $cluster[0]`;\n for ($i = 0;$i<$numVtx[0]; $i++)\n {\n  float $temp[]  = `percent -q -v $cluster[0] ($selMesh[0] + \".vtx\" + \"[\" +$i+ \"]\")`;\n  if( 0 == $temp[0])\n     {\n   sets -rm $clusterSet[0] ($selMesh[0] + \".vtx\" + \"[\" +$i+ \"]\");\n  }\n }\n  curve -n (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\") -d 1 -p -0.5 0.5 -0.5 -p -0.5 0.5 0.5 -p 0.5 0.5 0.5 -p 0.5 0.5 -0.5 -p -0.5 0.5 -0.5 -p -0.5 -0.5 -0.5 -p -0.5 -0.5 0.5 -p 0.5 -0.5 0.5 -p 0.5 -0.5 -0.5 -p -0.5 -0.5 -0.5 -p -0.5 0.5 -0.5 -p 0.5 0.5 -0.5 -p 0.5 -0.5 -0.5 -p 0.5 -0.5 0.5 -p 0.5 0.5 0.5 -p -0.5 0.5 0.5 -p -0.5 -0.5 0.5 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 ;\n    rename `listRelatives -c -type \"shape\"` (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrlShape\");\n    group -n (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\") -em;\n    delete `parentConstraint (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\")`;\n    parent (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\");\n\n    delete `parentConstraint ($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\")`;\n\n    \n    \n     duplicate -rc -n (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\");\n rename `listRelatives -c -type \"shape\" (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\")` (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrlShape\");\n    \n    \n    int $degree = `getAttr ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\")+\".degree\")`;\n    int $spans = `getAttr ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n select -r -sym ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n\n\n    parent (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\");\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\");\n    \n    connectAttr ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\")+\".subCtrl\") ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrlShape\")+\".v\");\n    \n    setAttr -k 0 -channelBox true ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\")+\".subCtrl\");\n       parentConstraint (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\") ($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\") ;\n\n\nrename ($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\") ($nam+\"_clu\");\nrename (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\") ($nam+\"_ctrl\");\nrename (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\") ($nam+\"_sub_ctrl\");\nrename (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\") ($nam+\"_ctrl_offset\");\nsetAttr ($nam+\"_clu.v\") 0;\n\n}\n\n\n\n\nglobal proc G_share_attr()\n{\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"G_IK_FK\"; \n\t\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"Sharing Attr\" -widthHeight 400 200 $mygui;   \nframeLayout \n\t\t-borderStyle \"in\" \n\t    -label \"select the shape node\";\n\t  \t\tcolumnLayout -adj 1;\n\t  \n\t\t\ttextFieldButtonGrp -label \"shared_attr_shape\"\n\t\t\t-text \"\"\n\t\t\t-buttonLabel \"Get_selection\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonCommand \"get_attr()\" attr_name;\n\t\t\tsetParent ..;\n\t\tsetParent ..;\n\t\t\nframeLayout\n\t-label \"buttons to add or remove\";\t\n        rowColumnLayout -numberOfColumns 4\n            -columnWidth 1 70\n            -columnWidth 2 70\n            -columnWidth 3 70\n            -columnWidth 4 70;\n            \n        separator -visible 0 -height 10; separator -visible 0;    separator -visible 0;        separator -visible 0; \n        separator -visible 0; \n        button -label \"add\" -command \"G_add()\";\n\t\tbutton -label \"remove\" -command \"G_remove()\";                  \n        separator -visible 0;\n        setParent ..;\n\t\tsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\nglobal proc get_attr()\n{\n\tstring $mylist[] = `ls -sl`;\n\t\n\tstring $objname =$mylist[0];\n\t\n\tstring $buffer[] ;\n\ttokenize $objname \"|\" $buffer ;\n\tint $arraysize = size($buffer);\n\t\tif ($arraysize >1)\n\t\t\t{\n\t\t\t\ttextFieldButtonGrp -edit -text $buffer[1] attr_name;\n            }\n\t\t\telse\n\t\t\t{\n\t\t\t\ttextFieldButtonGrp -edit -text $buffer[0] attr_name;\n            }\n\t\n\t\n}\n\nglobal proc G_add()\n{\n\tstring $attname = (`textFieldButtonGrp -query -text attr_name`);\n\tstring $mylist[] = `ls -sl`;\n\t\n\tfor ($myitems in $mylist)\n\t\t{\n\t\t\n\t\tinstance  -name \"temp_bob\" $attname;\n\t\t\n\t\tselect -r \"temp_bob\";\n\t\tselect -replace (\"temp_bob|\" + $attname);\n\t\tselect -add\t$myitems;\n\t\tparent -r -s;   \n\t\tdelete \"temp_bob\"; \n        }\n}\nglobal proc G_remove()\n{\n\tstring $attname = (`textFieldButtonGrp -query -text attr_name`);\n\tstring $mylist[] = `ls -sl`;\n\t\n\t\n\tfor ($myitems in $mylist)\n\t\t{\n\t\tif ($myitems == $attname)\n\t\t\t{\n\t\t\tselect $myitems;\n\t\t\tparent -s -rm;\t\n            }\n\t\telse\n\t\t\t{\n\t\t\t  if (`objExists ($myitems +\"|\"+$attname)`)\n\t\t\t  \t{\n\t\t\t  \tselect ($myitems +\"|\"+$attname);\n\t\t\t\tparent -s -rm; \n\t\t\t\t}\n\t\t\t\n        \t}\n\t\t\t\t\n        }\n\t\n}\n\n\nglobal proc CurTools(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"toolsForCur\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"curve tool box v01\" -widthHeight 300 50 $mygui;  \n\nframeLayout\n-label \"tools for curs\";\n        rowColumnLayout -numberOfColumns 1\n            -columnWidth 1 300\n            -columnWidth 2 300\n            -columnWidth 3 300;\n           \n        button -bgc 0.234 0 0 -hlc 1 0 0 -label \"create locators based on the curve\" -command \"locatorsOnCur()\";\n\n        button -bgc 0.234 0 0 -hlc 1 0 0 -label \"create joints based on the curve\" -command \"jointsOnCur()\";  \n\n        button -bgc 0.234 0 0 -hlc 1 0 0 -label \"create splineIk based on the curve\" -command \"spIKCur()\";      \n\n              \n        separator -visible 0;\n        setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\nglobal proc get_org()\n{\nstring $orglist[] = `ls -sl`;\nstring $orgobjname =$orglist[0];\nstring $orgbuffer[] ;\ntokenize $orgobjname \"|\" $orgbuffer ;\nint $org_arraysize = size($orgbuffer);\nif ($org_arraysize >1)\n{\ntextFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -edit -text $orgbuffer[1] attr_name;\n            }\nelse\n{\ntextFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -edit -text $orgbuffer[0] attr_name;\n            }\n}\n\n\n\n\nglobal proc spIKCur(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"IKOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"build the splineIK with curve\" -widthHeight 400 200 $mygui;  \n\ntextFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -label \"get the curve\"\n-text \"\"\n-button -bgc 0.234 0 0 -hlc 1 0 0Label \"base_curve\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-button -bgc 0.234 0 0 -hlc 1 0 0Command \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"create joints based on the curve\" -collapsable 1 ; \n   text -l \"Please type in the number you want.\";\n   rowLayout;\n\n\t\t\ttextFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -label \"joint account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-button -bgc 0.234 0 0 -hlc 1 0 0Label \"create joints\"\n\t\t\t-button -bgc 0.234 0 0 -hlc 1 0 0Command \"spikOnCur(`textFieldGrp  -query -text attr_name`,`textFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -query -text joint_number`)\"  joint_number;\n\n   setParent ..;\n  setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\n\n\n\n\n\n\nglobal proc spikOnCur(string $cur, int $locNum){\nfor($i=0;$i<$locNum;$i++){\n   spaceLocator -n ($cur+\"_\"+($i+1)+\"_loc\")-p 0 0 0;\n   \n    select -tgl $cur;\npathAnimation -n ($cur+\"_\"+($i+1)+\"_loc_path\") -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 1 -endTimeU 1;\nselectKey -add -k -t 1 -t 1 ($cur+\"_\"+($i+1)+\"_loc_path_uValue\");\ncutKey -animation keys -clear;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_path.allCoordinates\") ($cur+\"_\"+($i+1)+\"_loc.translate\");\ndelete `listConnections -t \"addDoubleLinear\"`;\n\nshadingNode -asUtility multiplyDivide -n ($cur+\"_\"+($i+1)+\"_loc_md\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.operation\") 2;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input2X\") ($locNum-1);\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input1X\") $i;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_md.outputX\") ($cur+\"_\"+($i+1)+\"_loc_path.uValue\");\ndelete ($cur+\"_\"+($i+1)+\"_loc_md\");\n\n}\ngroup -n ($cur+\"_\"+\"loc_grp\") -em;\nparent ($cur+\"_\"+\"*_loc\") ($cur+\"_\"+\"loc_grp\") ;\nselect -cl;\n/*************************************************************************create joints*********************************************************************************************************/\n\njoint -n dup_joint;\n\nfor ($j=0;$j<$locNum;$j++){\n\tduplicate  -n ($cur+\"_\"+($j+1)+\"_joint\") dup_joint;\n\tif ($j>0){\n\t\tparent ($cur+\"_\"+($j+1)+\"_joint\") ($cur+\"_\"+$j+\"_joint\");\n\t\tsetAttr ($cur+\"_\"+($j+1)+\"_joint.translateX\") 1;\n\t\t}\n\t\n}\ndelete dup_joint;\n\n/*************************************************************************create rotate cards*********************************************************************************************************/\nselect -hi ($cur+\"_\"+\"1_joint\") ;\nstring $born[]=`ls -sl`;\nfor($b=0;$b<$locNum;$b++){\n\tpolyPlane -w 1 -h 1 -sx 1 -sy 1  -n ($born[$b]+\"_rot_geo\");\t\n\tmove -rpr -0.5 0 0 (($born[$b]+\"_rot_geo\")+\".scalePivot\") (($born[$b]+\"_rot_geo\")+\".rotatePivot\");\n\tdelete `parentConstraint  $born[$b] ($born[$b]+\"_rot_geo\")`;\n\t\n\tspaceLocator -n ($born[$b]+\"_rot_loc\");\n\tdelete`parentConstraint $born[$b] ($born[$b]+\"_rot_loc\")`;\t\n\t\n    shadingNode -asUtility distanceBetween -n ($born[$b]+\"_dist\");\n    if($b>0){\n\t\tconnectAttr (($born[$b]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point1\");\n\t\tconnectAttr (($born[$b-1]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point2\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tselect -r (\"*_rot_geo\");\n\t\tmakeIdentity -apply true -t 0 -r 0 -s 1 -n 0 -pn 1 ;    \n\t\tparent ($born[$b]+\"_rot_geo\") ($born[$b-1]+\"_rot_geo\");\n\t\t\n\t\t}\n\t\n    \n    pointConstraint -n ($born[$b]+\"_rotptcon\") ($born[$b]+\"_rot_geo\") $born[$b];\t\n\tconnectAttr (($born[$b]+\"_rot_geo\")+\".rotate\") ($born[$b]+\".jointOrient\");\n\tstring $opsit = substituteAllString($born[$b], \"joint\", \"loc\");\n\tstring $opsit1 = substituteAllString($born[$b+1], \"joint\", \"loc\");\n\tdelete `pointConstraint $opsit ($born[$b]+\"_rot_geo\")`;\n\tif($b<($locNum-1)){\n\ndelete `aimConstraint -offset 0 0 0 -weight 1 -aimVector 1 0 0 -upVector 0 1 0 -worldUpType \"vector\" -worldUpVector 0 1 0 $opsit1 ($born[$b]+\"_rot_geo\")`;\n\t}\n\n}\t\ndelete ($cur+\"_\"+\"loc_grp\");\ndelete (\"*_rot_loc\");\ndelete (\"*_rotptcon*\");\ndelete (\"*_rot_geo*\");\n\nselect -r ($cur+\"_1_joint\") ;\nselect -tgl ($cur+\"_\"+$locNum+\"_joint\") ;\nselect -tgl $cur ;\nikHandle -n ($cur+\"_SpIkh\") -sol ikSplineSolver -ccv false -pcv false;\n}\n\n\n\n\n\nglobal proc locatorsOnCur(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"LocatorsOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"Locators on curve\" -widthHeight 400 200 $mygui;  \n\ntextFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -label \"get the curve\"\n-text \"\"\n-button -bgc 0.234 0 0 -hlc 1 0 0Label \"base_curve\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-button -bgc 0.234 0 0 -hlc 1 0 0Command \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"create locators based on the curve\" -collapsable 1 ; \n   text -l \"Please type in the number you want.\";\n   rowLayout;\n\n\t\t\ttextFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -label \"locator account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-button -bgc 0.234 0 0 -hlc 1 0 0Label \"create locators\"\n\t\t\t-button -bgc 0.234 0 0 -hlc 1 0 0Command \"LocOnCur(`textFieldGrp  -query -text attr_name`,`textFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -query -text joint_number`)\"  joint_number;\n\n   setParent ..;\n  setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\n\n\n\n\n\n\nglobal proc LocOnCur(string $cur, int $locNum){\nfor($i=0;$i<$locNum;$i++){\n   spaceLocator -n ($cur+\"_\"+($i+1)+\"_loc\")-p 0 0 0;\n   \n    select -tgl $cur;\npathAnimation -n ($cur+\"_\"+($i+1)+\"_loc_path\") -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 1 -endTimeU 1;\nselectKey -add -k -t 1 -t 1 ($cur+\"_\"+($i+1)+\"_loc_path_uValue\");\ncutKey -animation keys -clear;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_path.allCoordinates\") ($cur+\"_\"+($i+1)+\"_loc.translate\");\ndelete `listConnections -t \"addDoubleLinear\"`;\n\nshadingNode -asUtility multiplyDivide -n ($cur+\"_\"+($i+1)+\"_loc_md\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.operation\") 2;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input2X\") ($locNum-1);\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input1X\") $i;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_md.outputX\") ($cur+\"_\"+($i+1)+\"_loc_path.uValue\");\ndelete ($cur+\"_\"+($i+1)+\"_loc_md\");\n\n}\ngroup -n ($cur+\"_\"+\"loc_grp\") -em;\nparent ($cur+\"_\"+\"*_loc\") ($cur+\"_\"+\"loc_grp\") ;\n\n\n}\n\n\n\n\nglobal proc jointsOnCur(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"JointsOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"joints on curve\" -widthHeight 400 200 $mygui;  \n\ntextFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -label \"get the curve\"\n-text \"\"\n-button -bgc 0.234 0 0 -hlc 1 0 0Label \"base_curve\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-button -bgc 0.234 0 0 -hlc 1 0 0Command \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"create joints based on the curve\" -collapsable 1 ; \n   text -l \"Please type in the number you want.\";\n   rowLayout;\n\n\t\t\ttextFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -label \"joint account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-button -bgc 0.234 0 0 -hlc 1 0 0Label \"create joints\"\n\t\t\t-button -bgc 0.234 0 0 -hlc 1 0 0Command \"jointOnCur(`textFieldGrp  -query -text attr_name`,`textFieldbutton -bgc 0.234 0 0 -hlc 1 0 0Grp -query -text joint_number`)\"  joint_number;\n\n   setParent ..;\n  setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\n\n\n\n\n\n\nglobal proc jointOnCur(string $cur, int $locNum){\nfor($i=0;$i<$locNum;$i++){\n   spaceLocator -n ($cur+\"_\"+($i+1)+\"_loc\")-p 0 0 0;\n   \n    select -tgl $cur;\npathAnimation -n ($cur+\"_\"+($i+1)+\"_loc_path\") -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 1 -endTimeU 1;\nselectKey -add -k -t 1 -t 1 ($cur+\"_\"+($i+1)+\"_loc_path_uValue\");\ncutKey -animation keys -clear;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_path.allCoordinates\") ($cur+\"_\"+($i+1)+\"_loc.translate\");\ndelete `listConnections -t \"addDoubleLinear\"`;\n\nshadingNode -asUtility multiplyDivide -n ($cur+\"_\"+($i+1)+\"_loc_md\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.operation\") 2;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input2X\") ($locNum-1);\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input1X\") $i;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_md.outputX\") ($cur+\"_\"+($i+1)+\"_loc_path.uValue\");\ndelete ($cur+\"_\"+($i+1)+\"_loc_md\");\n\n}\ngroup -n ($cur+\"_\"+\"loc_grp\") -em;\nparent ($cur+\"_\"+\"*_loc\") ($cur+\"_\"+\"loc_grp\") ;\nselect -cl;\n/*************************************************************************create joints*********************************************************************************************************/\n\njoint -n dup_joint;\n\nfor ($j=0;$j<$locNum;$j++){\n\tduplicate  -n ($cur+\"_\"+($j+1)+\"_joint\") dup_joint;\n\tif ($j>0){\n\t\tparent ($cur+\"_\"+($j+1)+\"_joint\") ($cur+\"_\"+$j+\"_joint\");\n\t\tsetAttr ($cur+\"_\"+($j+1)+\"_joint.translateX\") 1;\n\t\t}\n\t\n}\ndelete dup_joint;\n\n/*************************************************************************create rotate cards*********************************************************************************************************/\nselect -hi ($cur+\"_\"+\"1_joint\") ;\nstring $born[]=`ls -sl`;\nfor($b=0;$b<$locNum;$b++){\n\tpolyPlane -w 1 -h 1 -sx 1 -sy 1  -n ($born[$b]+\"_rot_geo\");\t\n\tmove -rpr -0.5 0 0 (($born[$b]+\"_rot_geo\")+\".scalePivot\") (($born[$b]+\"_rot_geo\")+\".rotatePivot\");\n\tdelete `parentConstraint  $born[$b] ($born[$b]+\"_rot_geo\")`;\n\t\n\tspaceLocator -n ($born[$b]+\"_rot_loc\");\n\tdelete`parentConstraint $born[$b] ($born[$b]+\"_rot_loc\")`;\t\n\t\n    shadingNode -asUtility distanceBetween -n ($born[$b]+\"_dist\");\n    if($b>0){\n\t\tconnectAttr (($born[$b]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point1\");\n\t\tconnectAttr (($born[$b-1]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point2\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tselect -r (\"*_rot_geo\");\n\t\tmakeIdentity -apply true -t 0 -r 0 -s 1 -n 0 -pn 1 ;    \n\t\tparent ($born[$b]+\"_rot_geo\") ($born[$b-1]+\"_rot_geo\");\n\t\t\n\t\t}\n\t\n    \n    pointConstraint -n ($born[$b]+\"_rotptcon\") ($born[$b]+\"_rot_geo\") $born[$b];\t\n\tconnectAttr (($born[$b]+\"_rot_geo\")+\".rotate\") ($born[$b]+\".jointOrient\");\n\tstring $opsit = substituteAllString($born[$b], \"joint\", \"loc\");\n\tstring $opsit1 = substituteAllString($born[$b+1], \"joint\", \"loc\");\n\tdelete `pointConstraint $opsit ($born[$b]+\"_rot_geo\")`;\n\tif($b<($locNum-1)){\n\ndelete `aimConstraint -offset 0 0 0 -weight 1 -aimVector 1 0 0 -upVector 0 1 0 -worldUpType \"vector\" -worldUpVector 0 1 0 $opsit1 ($born[$b]+\"_rot_geo\")`;\n\t}\n\n}\t\ndelete ($cur+\"_\"+\"loc_grp\");\ndelete (\"*_rot_loc\");\ndelete (\"*_rotptcon*\");\ndelete (\"*_rot_geo*\");\n\n}\n\n\n\n\nglobal proc Renmaer(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"IKOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"rename the objects that you selected\" -widthHeight 200 50 $mygui;  \n\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"rename the objects that you selected\" -collapsable 1 ; \n   text -l \"Please type in object name that you want.\";\n   columnLayout;\n            textFieldGrp\n            -label \"object name:\"\n            -text \"\"\n\n            attr_name;\n\n     text -l \"Please type in object type.\";     \n     columnLayout;  \n            textFieldGrp\n            -label \"object type:\"\n            -text \"\"\n\n            attr_name1;\n\n\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"rename\" -c \"RenameTool(`textFieldGrp  -query -text attr_name`,`textFieldGrp  -query -text attr_name1`)\";\n\n   setParent ..;\n   setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\nglobal proc RenameTool(string $nam, string $type){\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){\n    int $n = $i+1;\n    if($n<=9){\n        rename $born[$i] ($nam+\"_0\"+$n+\"_\"+$type);\n        }\n    if($n>9){\n        rename $born[$i] ($nam+\"_\"+$n+\"_\"+$type);\n        }\n}\n}\n\n\n\n\nglobal proc FFK(){\n\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){\n    curve -n ($born[$i]+\"_ctrl\") -d 1 -p -1 0.234239 -3.57628e-07 -p -0.92388 0.234239 0.382683 -p -0.707107 0.234239 0.707107 -p -0.382684 0.234239 0.923879 -p -1.49012e-07 0.234239 1 -p 0.382683 0.234239 0.92388 -p 0.707107 0.234239 0.707107 -p 0.92388 0.234239 0.382683 -p 1 0.234239 0 -p 0.92388 0.234239 -0.382683 -p 0.707107 0.234239 -0.707106 -p 0.382684 0.234239 -0.923879 -p 5.06639e-07 0.234239 -1 -p -0.382683 0.234239 -0.92388 -p -0.707106 0.234239 -0.707107 -p -0.923879 0.234239 -0.382684 -p -1 0.234239 -3.57628e-07 -p -1 -0.234239 -3.57628e-07 -p -0.92388 -0.234239 0.382683 -p -0.707107 -0.234239 0.707107 -p -0.382684 -0.234239 0.923879 -p -1.49012e-07 -0.234239 1 -p 0.382683 -0.234239 0.92388 -p 0.707107 -0.234239 0.707107 -p 0.92388 -0.234239 0.3826