.436514 0 -0.436514 -p -0.473538 0 -0.378831 -p -0.5 0 -0.3 -p -0.5 0 0 -p -0.5 0 0.3 -p -0.473538 0 0.378831 -p -0.436514 0 0.436514 -p -0.378831 0 0.473538 -p -0.3 0 0.5 -p 0 0 0.5 -p 0.3 0 0.5 -p 0.378831 0 0.473538 -p 0.436514 0 0.436514 -p 0.473538 0 0.378831 -p 0.5 0 0.3 -p 0.5 0 0 -p 0.5 0 -0.3 -p 0.473538 0 -0.378831 -p 0.436514 0 -0.436514 -p 0.378831 0 -0.473538 -p 0.3 0 -0.5 -p 0 0 -0.5 -p 0 0 -0.398354 -p 0.239013 0 -0.398354 -p 0.301818 0 -0.377272 -p 0.347775 0 -0.347775 -p 0.377272 0 -0.301818 -p 0.398354 0 -0.239013 -p 0.398354 0 0 -p 0.398354 0 0.159342 -p 0.398354 0 0.239013 -p 0.377272 0 0.301818 -p 0.347775 0 0.347775 -p 0.301818 0 0.377272 -p 0.239013 0 0.398354 -p 0 0 0.398354 -p -0.239013 0 0.398354 -p -0.301818 0 0.377272 -p -0.347775 0 0.347775 -p -0.377272 0 0.301818 -p -0.398354 0 0.239013 -p -0.398354 0 0 -p -0.398354 0 -0.239013 -p -0.377272 0 -0.301818 -p -0.347775 0 -0.347775 -p -0.301818 0 -0.377272 -p -0.239013 0 -0.398354 -p -0.159342 0 -0.398354 -p 0 0 -0.398354 -p 0 0 0.5 -p 0 0 0 -p -0.5 0 0 -p 0.5 0 0 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 -k 49 -k 50 -k 51 -k 52 -k 53 -k 54 -k 55 ;\n\n\nselect -r drv_local_ctrl.cv[0:52] ;\nscale -r -ocp 4 4 4;\n\nselect -r drv_world_ctrl.cv[0:55] ;\nscale -r -ocp 6 6 6;\n\ngroup -n drv_root_ctrl_offset drv_root_ctrl;\ngroup -n drv_local_ctrl_offset drv_local_ctrl;\ngroup -n drv_world_ctrl_offset drv_world_ctrl;\n\nparent drv_root_ctrl_offset drv_local_ctrl;\nparent drv_local_ctrl_offset drv_world_ctrl;\n\nparent drv_world_ctrl_offset drv_ctrl_grp;\nparent drv_sub_ctrl_grp drv_head_ctrl_grp drv_inner_ctrl_grp drv_root_ctrl;\n\nparentConstraint drv_root_ctrl drv_geo;\nparentConstraint drv_root_ctrl drv_curBaseWire;\nscaleConstraint drv_root_ctrl drv_rig_grp;\n\nselect -r (\"drv_*_fol_joint_ctrl.cv[0:120]\");\nscale -r -ocp 0.5 0.5 0.5;\n\n\ndelete (\"drv_latic_*_clu_ctrl_offset\");\n}\n\n\n\n\n/////////////////////////////////////////////////////////////create str grp//////////////////////////////////////////////////////////////////\nglobal proc CrtRibbon(string $newname,int $delt,int $ctrlnum,int $faceunm){\n\n   string $l[] = `ls \"drv_str_grp\" `;\n    if (size($l) == 0) {\n        string $md[] = `ls \"drv_cur_md\" `;\n        if(size($md) == 1){\n            delete drv_cur_md;\n            }\n       string $fmd[] = `ls \"drv_cur_F_md\" `;\n        if(size($fmd) == 1){\n            delete drv_cur_F_md;\n            }\n       \n       createdrv1($ctrlnum,$faceunm);\n       select -r drv_str_grp ;\n       duplicate -rr -renameChildren -un-n drv_str_grp1;\n       select -hi drv_str_grp1;\n       searchReplaceNames \"drv\" $newname \"hierarchy\";\n       searchReplaceNames \"_geo1\" \"_geo\" \"hierarchy\";\n       searchReplaceNames \"_grp1\" \"_grp\" \"hierarchy\";\n       searchReplaceNames \"_ctrl1\" \"_ctrl\" \"hierarchy\";\n       searchReplaceNames \"_offset1\" \"_offset\" \"hierarchy\";\n       searchReplaceNames \"_pcon1\" \"_pcon\" \"hierarchy\";\n       searchReplaceNames \"_pConst1\" \"_pConst\" \"hierarchy\";\n       searchReplaceNames \"_sConst1\" \"_sConst\" \"hierarchy\";\n       searchReplaceNames \"_ocon1\" \"_ocon\" \"hierarchy\";\n       searchReplaceNames \"_fol1\" \"_fol\" \"hierarchy\";\n       searchReplaceNames \"_joint1\" \"_joint\" \"hierarchy\";\n       searchReplaceNames \"_clu1\" \"_clu\" \"hierarchy\";\n       searchReplaceNames \"_cur1\" \"_cur\" \"hierarchy\";\n       searchReplaceNames \"_curBaseWire1\" \"_curBaseWire\" \"hierarchy\";\n\n    }\n    else{\n       select -r drv_str_grp ;\n       duplicate -rr -renameChildren -un-n drv_str_grp1;\n       select -r drv_str_grp1;\n       searchReplaceNames \"drv\" $newname \"hierarchy\";\n       searchReplaceNames \"_geo1\" \"_geo\" \"hierarchy\";\n       searchReplaceNames \"_grp1\" \"_grp\" \"hierarchy\";\n       searchReplaceNames \"_ctrl1\" \"_ctrl\" \"hierarchy\";\n       searchReplaceNames \"_offset1\" \"_offset\" \"hierarchy\";\n       searchReplaceNames \"_pcon1\" \"_pcon\" \"hierarchy\";\n       searchReplaceNames \"_pConst1\" \"_pConst\" \"hierarchy\";\n       searchReplaceNames \"_sConst1\" \"_sConst\" \"hierarchy\";\n       searchReplaceNames \"_ocon1\" \"_ocon\" \"hierarchy\";\n       searchReplaceNames \"_fol1\" \"_fol\" \"hierarchy\";\n       searchReplaceNames \"_joint1\" \"_joint\" \"hierarchy\";\n       searchReplaceNames \"_clu1\" \"_clu\" \"hierarchy\";\n       searchReplaceNames \"_cur1\" \"_cur\" \"hierarchy\";\n       searchReplaceNames \"_curBaseWire1\" \"_curBaseWire\" \"hierarchy\";\n}\nif($delt==0){\n    delete drv_curbase_curinfo;\n    delete drv_cur_curinfo;\n    delete drv_str_grp;\n\n    }\n}\n \n \nglobal proc insertMidJoints(string $rotJnt, string $endJnt,int $JNum){\nstring $born[]=`ls - sl`;\nint $n = $JNum;\nint $max = $n +1;\nfor($i=0;$i<$n;$i++){\n    string $new = substituteAllString($rotJnt, \"joint\", \"\");\n\n    duplicate -rc  -n ($new+($i+1)+\"_sub_joint\") $rotJnt ;\n    delete `listRelatives -c ($new+($i+1)+\"_sub_joint\")`;\n    pointConstraint -n ($new+($i+1)+\"_sub_jointPcont\") $rotJnt $endJnt ($new+($i+1)+\"_sub_joint\");\n    setAttr (($new+($i+1)+\"_sub_jointPcont.\")+$rotJnt+\"W0\") ($max-$i-1);\n    setAttr (($new+($i+1)+\"_sub_jointPcont.\")+$endJnt+\"W1\") ($i+1); \n    delete (\"*_sub_jointPcont\");\n    if ($i ==0){\n    parent ($new+\"1_sub_joint\") $rotJnt;\n    }\n    if ($i >0){\n    parent ($new+($i+1)+\"_sub_joint\") ($new+($i)+\"_sub_joint\");\n    }\n    if ($i == ($n-1)){\n    parent $endJnt ($new+($i+1)+\"_sub_joint\");\n    }\n}\n}\n" 
