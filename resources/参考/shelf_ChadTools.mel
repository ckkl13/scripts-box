pans`;\n    int $max2 = ($degree2+$spans2)-1;\n\tselect -r -sym local_ctrl.cv[0:$max2] ;\n    scale -r -ocp 0.6 0.6 0.6;\n    select -cl;\ngroup -n local_ctrl_offset -em;\nparent local_ctrl local_ctrl_offset;\n\ncurve -n root_ctrl -d 1 -p 9.14414e-07 0 -1.804861 -p -0.69069 0 -1.667474 -p -1.276228 0 -1.276229 -p -1.667474 0 -0.690691 -p -1.804861 0 -6.45469e-07 -p -1.667474 0 0.69069 -p -1.276229 0 1.276228 -p -0.690691 0 1.667474 -p -2.68945e-07 0 1.804861 -p 0.69069 0 1.667474 -p 1.276228 0 1.276229 -p 1.667474 0 0.69069 -p 1.804861 0 0 -p 1.667474 0 -0.690689 -p 1.27623 0 -1.276228 -p 0.690691 0 -1.667474 -p 9.14414e-07 0 -1.804861 -p 5.88379e-07 0 -1.161337 -p -0.444424 0 -1.072936 -p -0.69069 0 -1.667474 -p -1.276228 0 -1.276229 -p -0.821188 0 -0.821188 -p -1.072935 0 -0.444424 -p -1.667474 0 -0.690691 -p -1.804861 0 -6.45469e-07 -p -1.161337 0 -4.15326e-07 -p -1.072936 0 0.444424 -p -1.667474 0 0.69069 -p -1.276229 0 1.276228 -p -0.821188 0 0.821188 -p -0.444424 0 1.072935 -p -0.690691 0 1.667474 -p -2.68945e-07 0 1.804861 -p -1.73053e-07 0 1.161337 -p 0.444424 0 1.072935 -p 0.69069 0 1.667474 -p 1.276228 0 1.276229 -p 0.821188 0 0.821188 -p 1.072935 0 0.444424 -p 1.667474 0 0.69069 -p 1.804861 0 0 -p 1.161337 0 0 -p 1.072936 0 -0.444424 -p 1.667474 0 -0.690689 -p 1.27623 0 -1.276228 -p 0.821189 0 -0.821188 -p 0.444425 0 -1.072935 -p 0.690691 0 -1.667474 -p 9.14414e-07 0 -1.804861 -p 5.88379e-07 0 -1.161337 -p 0.444425 0 -1.072935 -p 0.821189 0 -0.821188 -p 1.072936 0 -0.444424 -p 1.161337 0 0 -p 1.072935 0 0.444424 -p 0.821188 0 0.821188 -p 0.444424 0 1.072935 -p -1.73053e-07 0 1.161337 -p -0.444424 0 1.072935 -p -0.821188 0 0.821188 -p -1.072936 0 0.444424 -p -1.161337 0 -4.15326e-07 -p -1.072935 0 -0.444424 -p -0.821188 0 -0.821188 -p -0.444424 0 -1.072936 -p 5.88379e-07 0 -1.161337 -p -1.73053e-07 0 1.161337 -p 0 0 0 -p -1.161337 0 -4.15326e-07 -p 0 0 0 -p 1.161337 0 0 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 -k 49 -k 50 -k 51 -k 52 -k 53 -k 54 -k 55 -k 56 -k 57 -k 58 -k 59 -k 60 -k 61 -k 62 -k 63 -k 64 -k 65 -k 66 -k 67 -k 68 -k 69 -k 70 ;\nrename `listRelatives -c -type \"shape\"` root_ctrlShape;\n\n    int $degree1 = `getAttr root_ctrl.degree`;\n    int $spans1 = `getAttr root_ctrl.spans`;\n    int $max1 = ($degree1+$spans1)-1;\n\tselect -r -sym root_ctrl.cv[0:$max1] ;\n    scale -r -ocp 0.15 0.15 0.15;\n    select -cl;\n\n\nduplicate -rc -n root_sub_ctrl root_ctrl;\n rename `listRelatives -c -type \"shape\" root_ctrl` root_sub_ctrlShape;\n    \n    \n    int $degree = `getAttr root_sub_ctrl.degree`;\n    int $spans = `getAttr root_sub_ctrl.spans`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym root_sub_ctrl.cv[0:$max] ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n\n\n    parent root_sub_ctrl root_ctrl;\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on root_ctrl;\n    \n    connectAttr root_ctrl.subCtrl root_sub_ctrlShape.v;\n    \n    setAttr -k 0 -channelBox true root_ctrl.subCtrl;\n    \ngroup -n root_ctrl_offset -em;\nparent root_ctrl root_ctrl_offset;\n    \nparent root_ctrl_offset local_ctrl;\nparent local_ctrl_offset world_ctrl;    \nparent world_ctrl_offset ctrl_grp;\nselect -r root_sub_ctrl.cv[0:70] root_ctrl|root_sub_ctrlShape.cv[0:70] world_ctrlShape.cv[0:55] local_ctrlShape.cv[0:52] ;\n\nscale -r 15 15 15 ;   \nselect -cl;\n    \njoint -p 0 0 0 -n root_joint;\nparentConstraint -n root_PaCont root_sub_ctrl root_joint;\nparent root_joint bind_joint_grp;\n\naddAttr -ln \"geoResulation\" -nn \"Geo Resulation\" -at \"enum\" -en \"High:Low:\"  world_ctrl;\nsetAttr -e-keyable true world_ctrl.geoResulation;    \n    \nshadingNode -asUtility condition -n highRes_vis_cond;   \nshadingNode -asUtility condition -n lowRes_vis_cond;     \n    \nsetAttr \"highRes_vis_cond.colorIfTrueR\" 1;\nsetAttr \"highRes_vis_cond.colorIfFalseR\" 0;\nsetAttr \"lowRes_vis_cond.secondTerm\" 1;\nsetAttr \"lowRes_vis_cond.colorIfTrueR\" 1;\nsetAttr \"lowRes_vis_cond.colorIfFalseR\" 0;   \nconnectAttr  world_ctrl.geoResulation highRes_vis_cond.firstTerm;\nconnectAttr  world_ctrl.geoResulation lowRes_vis_cond.firstTerm;\nconnectAttr highRes_vis_cond.outColorR high.visibility;\nconnectAttr lowRes_vis_cond.outColorR low.visibility;\nselect -cl;\n}      \n    \n\nglobal proc create3Dctrl(){\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){\n    curve -n ($born[$i]+\"_ctrl\") -d 1 -p -1 0.234239 -3.57628e-07 -p -0.92388 0.234239 0.382683 -p -0.707107 0.234239 0.707107 -p -0.382684 0.234239 0.923879 -p -1.49012e-07 0.234239 1 -p 0.382683 0.234239 0.92388 -p 0.707107 0.234239 0.707107 -p 0.92388 0.234239 0.382683 -p 1 0.234239 0 -p 0.92388 0.234239 -0.382683 -p 0.707107 0.234239 -0.707106 -p 0.382684 0.234239 -0.923879 -p 5.06639e-07 0.234239 -1 -p -0.382683 0.234239 -0.92388 -p -0.707106 0.234239 -0.707107 -p -0.923879 0.234239 -0.382684 -p -1 0.234239 -3.57628e-07 -p -1 -0.234239 -3.57628e-07 -p -0.92388 -0.234239 0.382683 -p -0.707107 -0.234239 0.707107 -p -0.382684 -0.234239 0.923879 -p -1.49012e-07 -0.234239 1 -p 0.382683 -0.234239 0.92388 -p 0.707107 -0.234239 0.707107 -p 0.92388 -0.234239 0.382683 -p 1 -0.234239 0 -p 0.92388 -0.234239 -0.382683 -p 0.707107 -0.234239 -0.707106 -p 0.382684 -0.234239 -0.923879 -p 5.06639e-07 -0.234239 -1 -p -0.382683 -0.234239 -0.92388 -p -0.707106 -0.234239 -0.707107 -p -0.923879 -0.234239 -0.382684 -p -1 -0.234239 -3.57628e-07 -p -0.92388 -0.234239 0.382683 -p -0.707107 -0.234239 0.707107 -p -0.382684 -0.234239 0.923879 -p -1.49012e-07 -0.234239 1 -p -1.49012e-07 0.234239 1 -p 0.382683 0.234239 0.92388 -p 0.707107 0.234239 0.707107 -p 0.92388 0.234239 0.382683 -p 1 0.234239 0 -p 1 -0.234239 0 -p 0.92388 -0.234239 -0.382683 -p 0.707107 -0.234239 -0.707106 -p 0.382684 -0.234239 -0.923879 -p 5.06639e-07 -0.234239 -1 -p 5.06639e-07 0.234239 -1 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 ;\n    rename `listRelatives -c -type \"shape\"` ($born[$i]+\"_ctrlShape\");\n    group -n ($born[$i]+\"_ctrl_offset\") -em;\n    delete `parentConstraint ($born[$i]+\"_ctrl\") ($born[$i]+\"_ctrl_offset\")`;\n    parent ($born[$i]+\"_ctrl\") ($born[$i]+\"_ctrl_offset\");\n\n    delete `parentConstraint $born[$i] ($born[$i]+\"_ctrl_offset\")`;\n\n    \n    \n     duplicate -rc -n ($born[$i]+\"_sub_ctrl\") ($born[$i]+\"_ctrl\");\n rename `listRelatives -c -type \"shape\" ($born[$i]+\"_sub_ctrl\")` ($born[$i]+\"_sub_ctrlShape\");\n    \n    \n    int $degree = `getAttr (($born[$i]+\"_sub_ctrl\")+\".degree\")`;\n    int $spans = `getAttr (($born[$i]+\"_sub_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym (($born[$i]+\"_sub_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n\n\n    parent ($born[$i]+\"_sub_ctrl\") ($born[$i]+\"_ctrl\");\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on ($born[$i]+\"_ctrl\");\n    \n    connectAttr (($born[$i]+\"_ctrl\")+\".subCtrl\") (($born[$i]+\"_sub_ctrlShape\")+\".v\");\n    \n    setAttr -k 0 -channelBox true (($born[$i]+\"_ctrl\")+\".subCtrl\");\n        parentConstraint ($born[$i]+\"_sub_ctrl\") $born[$i] ;\n}\n}\n\n\n\nglobal proc delRotCds(){\ndelete (\"*_rotptcon*\");\ndelete (\"*_rot_geo*\");\n}\n\nglobal proc addRotCds(){\nstring $born[]=`ls -sl`;\nfor($i=0;$i<size($born);$i++){\n\tpolyPlane -w 1 -h 1 -sx 1 -sy 1  -n ($born[$i]+\"_rot_geo\");\t\n\tmove -rpr -0.5 0 0 (($born[$i]+\"_rot_geo\")+\".scalePivot\") (($born[$i]+\"_rot_geo\")+\".rotatePivot\");\n\tdelete `parentConstraint  $born[$i] ($born[$i]+\"_rot_geo\")`;\n\t\n\tspaceLocator -n ($born[$i]+\"_rot_loc\");\n\tdelete`parentConstraint $born[$i] ($born[$i]+\"_rot_loc\")`;\t\n\t\n    shadingNode -asUtility distanceBetween -n ($born[$i]+\"_dist\");\n    if($i>0){\n\t\tconnectAttr (($born[$i]+\"_rot_loc\")+\".translate\") (($born[$i]+\"_dist\")+\".point1\");\n\t\tconnectAttr (($born[$i-1]+\"_rot_loc\")+\".translate\") (($born[$i]+\"_dist\")+\".point2\");\n\t\tconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleX\");\n\t\tconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleY\");\n\t\tconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tdisconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleX\");\n\t\tdisconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleY\");\n\t\tdisconnectAttr (($born[$i]+\"_dist\")+\".distance\") (($born[$i-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tselect -r (\"*_rot_geo\");\n\t\tmakeIdentity -apply true -t 0 -r 0 -s 1 -n 0 -pn 1 ;    \n\t\tparent ($born[$i]+\"_rot_geo\") ($born[$i-1]+\"_rot_geo\");\n\t\t\n\t\t}\n\n\t    if($i==(size($born)-1)){\n\t    \t\tsetAttr (($born[$i]+\"_rot_geo\")+\".rotateX\") 0;\n\t\t\t\tsetAttr (($born[$i]+\"_rot_geo\")+\".rotateY\") 0;\n\t\t\t\tsetAttr (($born[$i]+\"_rot_geo\")+\".rotateZ\") 0;\n\t    }\n    \n    pointConstraint -n ($born[$i]+\"_rotptcon\") ($born[$i]+\"_rot_geo\") $born[$i];\t\n\tconnectAttr (($born[$i]+\"_rot_geo\")+\".rotate\") ($born[$i]+\".jointOrient\");\n\n}\n\t\n\n\tdelete (\"*_rot_loc\");\n\n}\n\n\n\nglobal proc addIFGRP(){\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){\n    string $GRPnam = substituteAllString($born[$i], \"attr_ctrl\", \"\");\n    group -n ($GRPnam+\"FK_ctrl_grp\") -em;\n    group -n ($GRPnam+\"IK_ctrl_grp\") -em;\n    group -n ($GRPnam+\"ctrl_grp\") -em;\n    parent ($GRPnam+\"FK_ctrl_grp\") ($GRPnam+\"ctrl_grp\");\n    parent ($GRPnam+\"IK_ctrl_grp\") ($GRPnam+\"ctrl_grp\");\n    shadingNode -asUtility reverse -n ($GRPnam+\"FK_rev\");\nconnectAttr ($born[$i]+\".ikfk\") ($GRPnam+\"IK_ctrl_grp.v\");\nconnectAttr ($born[$i]+\".ikfk\") ($GRPnam+\"FK_rev.inputX\");\nconnectAttr ($GRPnam+\"FK_rev.outputX\") ($GRPnam+\"FK_ctrl_grp.v\");\n\n   } \n}\n\n\nglobal proc AddIFAttr(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\naddAttr -ln \"ikfk\" -nn \"Ikfk\" -at long  -min 0 -max 1 -dv 0 -k on $item;\n}\n}\n\n\n\n\nglobal proc setDrivenKeyforIFAttr(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tstring $IFJointp = substituteAllString($item, \"joint\", \"joint_pcont\");\n\tstring $IFJointpiattr = substituteAllString($item, \"joint\", \"IK_jointW0\");\n\tstring $IFJointpfattr = substituteAllString($item, \"joint\", \"FK_jointW1\");\n\t\n\tsetAttr \"nurbsCircle1.ikfk\" 1;\n\tsetAttr ($IFJointp+\".\"+$IFJointpiattr) 1;\n\tsetAttr ($IFJointp+\".\"+$IFJointpfattr) 0;\n\t\n\tsetDrivenKeyframe -currentDriver nurbsCircle1.ikfk ($IFJointp+\".\"+$IFJointpiattr);\n\tsetDrivenKeyframe -currentDriver nurbsCircle1.ikfk ($IFJointp+\".\"+$IFJointpfattr);\n\t\n\tsetAttr \"nurbsCircle1.ikfk\" 0;\n\tsetAttr ($IFJointp+\".\"+$IFJointpiattr) 0;\n\tsetAttr ($IFJointp+\".\"+$IFJointpfattr) 1;\n\t\n\tsetDrivenKeyframe -currentDriver nurbsCircle1.ikfk ($IFJointp+\".\"+$IFJointpiattr);\n\tsetDrivenKeyframe -currentDriver nurbsCircle1.ikfk ($IFJointp+\".\"+$IFJointpfattr);\n\t}\n}\n\n\nglobal proc subCtrls(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tstring $subnam = substituteAllString($item, \"ctrl\", \"sub\");\t\n    duplicate -rr -n ($subnam+\"_ctrl\") $item;\n    \n    int $degree = `getAttr (($subnam+\"_ctrl\")+\".degree\")`;\n    int $spans = `getAttr (($subnam+\"_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym (($subnam+\"_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n    parent ($subnam+\"_ctrl\") $item;\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on $item;\n    \n    connectAttr ($item+\".subCtrl\") (($subnam+\"_ctrlShape\")+\".v\");\n    \n    setAttr -k 0 -channelBox true ($item+\".subCtrl\");\n}\n\n}\n\nglobal proc addOffset(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tgroup -n ($item + \"_offset\") -em;\n\tdelete `parentConstraint $item ($item + \"_offset\")`;\n\tparent $item ($item + \"_offset\");\n}\n}\n\nglobal proc createIFJoints(){\nstring $cop[]=`ls -sl`;\nfor($c=0;$c<size($cop);$c++){\n        select -hi $cop[$c];        \n       duplicate -rr -renameChildren -un;\n       select -hi ($cop[$c]+\"1\");       \n        string $born[]=`ls -sl`;\n        for($i=0;$i<size($born);$i++){\n            string $Istill = substituteAllString($born[$i], \"joint1\", \"IK\");\n            rename ($born[$i]) ($Istill+\"_joint\");\n            }\n       select -hi $cop[$c];        \n       duplicate -rr -renameChildren -un;\n        select -hi ($cop[$c]+\"1\");    \n             \n        string $sel[]=`ls -sl`;\n        for($f=0;$f<size($sel);$f++){\n            string $Fstill = substituteAllString($sel[$f], \"joint1\", \"FK\");\n            rename ($sel[$f]) ($Fstill+\"_joint\");\n            }\n        \n}\n        \n}\nglobal proc connectIFJoints(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tstring $IKJoint = substituteAllString($item, \"joint\", \"IK_joint\");\n\tstring $FKJoint = substituteAllString($item, \"joint\", \"FK_joint\");\n\n\tparentConstraint -n ($item+\"_pcont\") $IKJoint $FKJoint $item;\n\t\n\t}\n}\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "toolBoxes;\nglobal proc toolBoxes(){\n\nif ( `window -exists Window1` ) {\n deleteUI Window1;\n}\nwindow -bgc 0.08 0.02 0.13 -t \"chad's rig box v1.0\"   Window1 ;\n\n\nframeLayout  -label \" please choose the tools that you need\" -collapsable 1 -bgc 0.35 0.35 0.1 ;\n\n\n    rowColumnLayout -numberOfColumns 2 ;\n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"character autorig\" -c \"importAutoRig\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"rig tool box\" -c \"importRigTools\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"create ctrl tool\" -c \"createCtrlTools\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"replace ctrl shape\" -c \"replaceWin\"; \n    setParent ..;\n   setParent ..;\n \nshowWindow Window1;\nwindow -e Window1;\n}\n\nglobal proc importAutoRig(){\nstring $aRpath = dirname(`file -q -sceneName`);\nstring $aRpathF = substituteAllString($aRpath, \"scenes\", \"autoRigSetup\");\nfile -import -type \"mayaAscii\"  -ignoreVersion -ra true -mergeNamespacesOnClash true -namespace \":\" -options \"v=0;\"  -pr ($aRpathF+\"/atuoRig 4.0_pro.mel\");\n}\n\n\nglobal proc importRigTools(){\nstring $rTpath = dirname(`file -q -sceneName`);\nstring $rTpathF = substituteAllString($rTpath, \"scenes\", \"autoRigSetup\");\nfile -import -type \"mayaAscii\"  -ignoreVersion -ra true -mergeNamespacesOnClash true -namespace \":\" -options \"v=0;\"  -pr ($rTpathF+\"/ChadTools.mel\");\n}\n\n\nglobal proc createCtrlTools(){\nstring $rTpath = dirname(`file -q -sceneName`);\nstring $rTpathF = substituteAllString($rTpath, \"scenes\", \"autoRigSetup\");\nfile -import -type \"mayaAscii\"  -ignoreVersion -ra true -mergeNamespacesOnClash true -namespace \":\" -options \"v=0;\"  -pr ($rTpathF+\"/createCtrlTool.mel\");\n}\n\nglobal proc replaceWin(){\nstring $rTpath = dirname(`file -q -sceneName`);\nstring $rTpathF = substituteAllString($rTpath, \"scenes\", \"autoRigSetup\");\nfile -import -type \"mayaAscii\"  -ignoreVersion -ra true -mergeNamespacesOnClash true -namespace \":\" -options \"v=0;\"  -pr ($rTpathF+\"/ChadShapeReplaceTools.mel\");\n}" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "ChadBox" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -imageOverlayLabel "ChadBox" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "commandButton.png" 
        -image1 "commandButton.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "toolBoxes;\nglobal proc toolBoxes(){\n\nif ( `window -exists Window1` ) {\n deleteUI Window1;\n}\nwindow -bgc 0.08 0.02 0.13 -t \"chad's rig box v1.0\"   Window1 ;\n\n\nframeLayout  -label \" please choose the tools that you need\" -collapsable 1 -bgc 0.35 0.35 0.1 ;\n\n\n    rowColumnLayout -numberOfColumns 2 ;\n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"character autorig\" -c \"importAutoRig\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"rig tool box\" -c \"importRigTools\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"create ctrl tool\" -c \"createCtrlTools\"; \n    button -bgc 0.234 0 0 -hlc 1 0 0 -l \"replace ctrl shape\" -c \"replaceWin\"; \n    setParent ..;\n   setParent ..;\n \nshowWindow Window1;\nwindow -e Window1;\n}\n\nglobal proc importAutoRig(){\nstring $aRpath = dirname(`file -q -sceneName`);\nstring $aRpathF = substituteAllString($aRpath, \"scenes\", \"autoRigSetup\");\nfile -import -type \"mayaAscii\"  -ignoreVersion -ra true -mergeNamespacesOnClash true -namespace \":\" -options \"v=0;\"  -pr ($aRpathF+\"/atuoRig 4.0_pro.mel\");\n}\n\n\nglobal proc importRigTools(){\nstring $rTpath = dirname(`file -q -sceneName`);\nstring $rTpathF = substituteAllString($rTpath, \"scenes\", \"autoRigSetup\");\nfile -import -type \"mayaAscii\"  -ignoreVersion -ra true -mergeNamespacesOnClash true -namespace \":\" -options \"v=0;\"  -pr ($rTpathF+\"/ChadTools.mel\");\n}\n\n\nglobal proc createCtrlTools(){\nstring $rTpath = dirname(`file -q -sceneName`);\nstring $rTpathF = substituteAllString($rTpath, \"scenes\", \"autoRigSetup\");\nfile -import -type \"mayaAscii\"  -ignoreVersion -ra true -mergeNamespacesOnClash true -namespace \":\" -options \"v=0;\"  -pr ($rTpathF+\"/createCtrlTool.mel\");\n}\n\nglobal proc replaceWin(){\nstring $rTpath = dirname(`file -q -sceneName`);\nstring $rTpathF = substituteAllString($rTpath, \"scenes\", \"autoRigSetup\");\nfile -import -type \"mayaAscii\"  -ignoreVersion -ra true -mergeNamespacesOnClash true -namespace \":\" -options \"v=0;\"  -pr ($rTpathF+\"/ChadShapeReplaceTools.mel\");\n}" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "\nstring $cop[]=`ls -sl`;\nfor($c=0;$c<size($cop);$c++){\n/*******************************************************************************create IK joints*********************************************************************************************/     \n       select -hi $cop[$c];    \n       duplicate -rr -renameChildren -un;  \n        string $born[]=`ls -sl`;\n        for($i=0;$i<size($born);$i++){\n            string $Istill = substituteAllString($born[$i], \"joint1\", \"IK\");\n            rename ($born[$i]) ($Istill+\"_joint\");\n            }\n/*******************************************************************************create FK joints*********************************************************************************************/                \n                      \n       select -hi $cop[$c];        \n       duplicate -rr -renameChildren -un;      \n        string $sel[]=`ls -sl`;\n        for($f=0;$f<size($sel);$f++){\n            string $Fstill = substituteAllString($sel[$f], \"joint1\", \"FK\");\n            rename ($sel[$f]) ($Fstill+\"_joint\");\n            }\n            \n/*******************************************************************************create drv joints*********************************************************************************************/     \n       select -hi $cop[$c];    \n       duplicate -rr -renameChildren -un;  \n        string $born1[]=`ls -sl`;\n        for($i1=0;$i1<size($born1);$i1++){\n            string $drv = substituteAllString($born1[$i1], \"joint1\", \"drv\");\n            rename ($born1[$i1]) ($drv+\"_joint\");\n            }\n/*******************************************************************************create top joints*********************************************************************************************/     \n       select -hi $cop[$c];    \n       duplicate -rr -renameChildren -un;  \n        string $bornt[]=`ls -sl`;\n        for($t=0;$t<size($bornt);$t++){\n            string $tdrv = substituteAllString($bornt[$t], \"joint1\", \"top\");\n            rename ($bornt[$t]) ($tdrv+\"_joint\");\n            }    \n/*******************************************************************************create top joints*********************************************************************************************/     \n       select -hi $cop[$c];    \n       duplicate -rr -renameChildren -un;  \n        string $bornf[]=`ls -sl`;\n        for($f=0;$f<size($bornf);$f++){\n            string $fdrv = substituteAllString($bornf[$f], \"joint1\", \"F\");\n            rename ($bornf[$f]) ($fdrv+\"_joint\");\n            }                \n        \n/*******************************************************************************FK ctrls*********************************************************************************************/     \nselect -hi $cop[$c]; \nstring $FKctrls[] = `ls -sl`;\nfor($FKct=0;$FKct<size($FKctrls);$FKct++){\n    string $FKctrlCrt = substituteAllString($FKctrls[$FKct], \"joint\", \"FK_joint\");\n    FKCtrl($FKctrlCrt);\n}\nselect -hi $cop[$c]; \nstring $FKctrlOfset[] = `ls -sl`;\nfor($FKctO=0;$FKctO<size($FKctrlOfset);$FKctO++){\n      if($FKctO>0){\n    string $FKSubctrl = substituteAllString($FKctrlOfset[$FKctO-1] , \"joint\", \"FK_joint_sub_ctrl\");\n    string $FKCurOfset = substituteAllString($FKctrlOfset[$FKctO] , \"joint\", \"FK_joint_ctrl_offset\");\n  \n   parent $FKCurOfset $FKSubctrl;\n   }\n}\nstring $FKCtrlGrp = substituteAllString($cop[$c] , \"_joint\", \"\");\ngroup -n ($FKCtrlGrp+\"_FK_ctrl_grp\") -em;\nparent ($FKCtrlGrp+\"_FK_joint_ctrl_offset\")  ($FKCtrlGrp+\"_FK_ctrl_grp\") ;\n\n\n/*******************************************************************************IK ctrls*********************************************************************************************/     \nselect -hi $cop[$c]; \nstring $IKctrls1[] = `ls -sl`;\n\nstring $IKRootCrt = substituteAllString($IKctrls1[0], \"joint\", \"IK_joint\");\nstring $IKEndCrt = substituteAllString($IKctrls1[(size($IKctrls1)-1)], \"joint\", \"IK_joint\");\nstring $IKMidCrt = substituteAllString($IKctrls1[((size($IKctrls1)-1)/2)], \"joint\", \"IK_joint\");\nstring $prefix = substituteAllString($IKctrls1[0], \"_01_joint\", \"\");\n\nikHandle -n ($IKEndCrt+\"_ikh\") -sj $IKRootCrt -ee $IKEndCrt -sol ikRPsolver;\nIKCtrl($IKRootCrt,$prefix);\nIKHCtrl(($IKEndCrt+\"_ikh\"),$prefix);\nstring $IKEJnt = substituteAllString($IKctrls1[(size($IKctrls1)-1)], \"joint\", \"IK_joint\");\norientConstraint -n ($prefix+\"_IK_OCont\")  -mo ($prefix+\"_IK_sub_ctrl\")  $IKEJnt;\nPVCtrl($IKMidCrt,$prefix,($IKEndCrt+\"_ikh\"));\n\n   spaceLocator -n ($IKctrls1[0]+\"_loc\");\n   delete ` parentConstraint  $IKctrls1[0] ($IKctrls1[0]+\"_loc\")`;\n   spaceLocator -n ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc\");\n   delete ` parentConstraint  $IKctrls1[((size($IKctrls1)-1)/2)] ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc\")`;\n   string $locR = substituteAllString($IKctrls1[0], \"joint\", \"IK_joint\");\n   string $locM = substituteAllString($IKctrls1[((size($IKctrls1)-1)/2)], \"joint\", \"IK_joint\");\n parent ($IKctrls1[0]+\"_loc\") $locR;\n  parent ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc\") $locM ;\nselect -r ($IKctrls1[0]+\"_loc\");\nselect -add  ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc\");\nstring $pcon1[] = `ls -sl`;\nfor ($m=0;$m<size($pcon1);$m++){\n\tgroup -n ($pcon1[$m] + \"_offset\") -em;\n\tdelete `parentConstraint $pcon1[$m] ($pcon1[$m] + \"_offset\")`;\n\tparent $pcon1[$m] ($pcon1[$m] + \"_offset\");\n}\n\nshadingNode -n DistBTL_dist -asUtility distanceBetween;\nconnectAttr ($IKctrls1[0]+\"_loc_offset.translate\") DistBTL_dist.point1;\nconnectAttr ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc_offset.translate\") DistBTL_dist.point2;\n   float $d = `getAttr \"DistBTL_dist.distance\"`;\n   float $Fd = $d*-1;\n   float $FL = `getAttr ($IKctrls1[0]+\"_loc_offset.translateZ\")`;\n   float $BL = `getAttr ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc_offset.translateZ\")`;\n   \n   float $BLR = `getAttr ($IKctrls1[0]+\".jointOrientX\")`;\n   \n   \n   if($BL- $FL<=0 ){\n       if($BLR <=90 && $BLR>=-90){\n           setAttr ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc.translateZ\") $Fd;\n           }\n       if($BLR >90 || $BLR<-90){\n           setAttr ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc.translateZ\") $d;\n           }\n       }\n       \n       \n\n   if($BL- $FL>0 ){\n       if($BLR <=90 && $BLR>=-90){\n           setAttr ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc.translateZ\") $d;\n           }\n       if($BLR >90 || $BLR<-90){\n           setAttr ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc.translateZ\") $Fd;\n           }\n       }\n       \n\n\n\n\ngroup -n ($prefix+\"_pv_ctrl_offset_trans\") -em;\ndelete `parentConstraint ($prefix+\"_pv_ctrl_offset\") ($prefix+\"_pv_ctrl_offset_trans\")`;\nparent ($prefix+\"_pv_ctrl_offset\") ($prefix+\"_pv_ctrl_offset_trans\");\n\nparent -w ($prefix+\"_pv_ctrl_offset\") ;\nsetAttr ($prefix+\"_pv_ctrl_offset.rotateX\") 0;\nsetAttr ($prefix+\"_pv_ctrl_offset.rotateY\") 0;\nsetAttr ($prefix+\"_pv_ctrl_offset.rotateZ\") 0;\n\nparent -w ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc\");\ndelete `pointConstraint ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc\") ($prefix+\"_pv_ctrl_offset\")`;\ndelete ($prefix+\"_pv_ctrl_offset_trans\") ;\ndelete ($IKctrls1[0]+\"_loc\");\ndelete ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc\") ;\ndelete ($IKctrls1[0]+\"_loc_offset\");\ndelete ($IKctrls1[((size($IKctrls1)-1)/2)]+\"_loc_offset\") ;\n\n\n\nstring $IKCtrlGrp = substituteAllString($cop[$c] , \"_joint\", \"\");\ngroup -n ($IKCtrlGrp+\"_IK_ctrl_grp\") -em;\nparent ($prefix+\"_IK_ctrl_offset\")($prefix+\"_root_ctrl_offset\") ($prefix+\"_pv_ctrl_offset\")($IKCtrlGrp+\"_IK_ctrl_grp\");\n\n\nstring $DjntR = substituteAllString($IKctrls1[0], \"joint\", \"drv_joint\");\nstring $DjntM = substituteAllString($IKctrls1[((size($IKctrls1)-1)/2)], \"joint\", \"drv_joint\");\ndelete `listRelatives -c $DjntM `;\n\nselect $DjntR;\nselect $DjntM;\nikHandle -n ($prefix+\"_drv_ikh\") -sol ikSCsolver ;\ngroup -n ($prefix+\"_drv_ikh_grp\") -em;\nparent ($prefix+\"_drv_ikh\") ($prefix+\"_drv_ikh_grp\");\n\npointConstraint $IKctrls1[0] $DjntR;\npointConstraint $IKctrls1[((size($IKctrls1)-1)/2)] ($prefix+\"_drv_ikh\");\n            \n/*******************************************************************************connect ik fk joints*********************************************************************************************/            \n       select -hi $cop[$c];  \n       string $num[]=`ls-sl`;   \n          for($ifk=0;$ifk<size($num);$ifk++){\n                string $IKstill = substituteAllString($num[$ifk], \"joint\", \"IK_joint\");\n                string $FKstill = substituteAllString($num[$ifk], \"joint\", \"FK_joint\");\n                parentConstraint -n ($num[$ifk]+\"_pcont\") $IKstill $FKstill $num[$ifk];   \n               } \n               \n/*******************************************************************************attr ctrl*********************************************************************************************/\n        string $atc = substituteAllString($cop[$c], \"joint\", \"attr_ctrl\");\n       circle -n $atc -c 0 0 0 -nr 0 0 1 -sw 360 -r 1 -d 1 -ut 0 -tol 0.01 -s 4 -ch 1;\n       group -n ($atc+\"_offset\");\n      delete ` pointConstraint  $IKctrls1[(size($IKctrls1)-1)] ($atc+\"_offset\")`;\n      delete ` orientConstraint  -o 90 0 0 $IKctrls1[(size($IKctrls1)-1)] ($atc+\"_offset\")`;\n      group -n ($atc+\"_offset_trans\") -em;\n      delete ` parentConstraint  $IKctrls1[(size($IKctrls1)-1)] ($atc+\"_offset_trans\")`;\n      parent ($atc+\"_offset\") ($atc+\"_offset_trans\");\n   if($BL- $FL<=0 ){\n       if($BLR <=90 && $BLR>=-90){\n           setAttr ($atc+\"_offset.translateZ\") ($Fd/4);\n           }\n              if($BLR >90 || $BLR<-90){\n          setAttr ($atc+\"_offset.translateZ\") ($d/4);\n           }\n       }\n       \n   if($BL- $FL>0 ){\n       if($BLR <=90 && $BLR>=-90){\n           setAttr ($atc+\"_offset.translateZ\") ($Fd/4);\n           }\n       if($BLR >90 || $BLR<-90){\n           setAttr ($atc+\"_offset.translateZ\") ($d/4);\n           }\n       }\n\n       \n       parent -w ($atc+\"_offset\");\n       delete ($atc+\"_offset_trans\");\n      parentConstraint -mo -n ($atc+\"_offset_pcont\") $IKctrls1[(size($IKctrls1)-1)] ($atc+\"_offset\");\n      addAttr -ln \"ikfk\" -nn \"Ikfk\" -at long  -min 0 -max 1 -dv 0 -k on $atc;\n      \n    setAttr -lock true -keyable false -channelBox false ($atc+\".tx\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".ty\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".tz\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".rx\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".ry\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".rz\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".sx\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".sy\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".sz\");\n    setAttr -lock true -keyable false -channelBox false ($atc+\".v\");\n    \n /*******************************************************************************connect attrs*********************************************************************************************/     \nselect -hi $cop[$c];  \nstring $pcon[] = `ls -sl`;\nfor($ifCont=0;$ifCont<size($num);$ifCont++){\n\tstring $IFJointp = substituteAllString($pcon[$ifCont], \"joint\", \"joint_pcont\");\n\tstring $IFJointpiattr = substituteAllString($pcon[$ifCont], \"joint\", \"IK_jointW0\");\n\tstring $IFJointpfattr = substituteAllString($pcon[$ifCont], \"joint\", \"FK_jointW1\");\n\t\n\tsetAttr ($atc+\".ikfk\") 1;\n\tsetAttr ($IFJointp+\".\"+$IFJointpiattr) 1;\n\tsetAttr ($IFJointp+\".\"+$IFJointpfattr) 0;\n\t\n\tsetDrivenKeyframe -currentDriver ($atc+\".ikfk\") ($IFJointp+\".\"+$IFJointpiattr);\n\tsetDrivenKeyframe -currentDriver ($atc+\".ikfk\") ($IFJointp+\".\"+$IFJointpfattr);\n\t\n\tsetAttr ($atc+\".ikfk\") 0;\n\tsetAttr ($IFJointp+\".\"+$IFJointpiattr) 0;\n\tsetAttr ($IFJointp+\".\"+$IFJointpfattr) 1;\n\t\n\tsetDrivenKeyframe -currentDriver ($atc+\".ikfk\") ($IFJointp+\".\"+$IFJointpiattr);\n\tsetDrivenKeyframe -currentDriver ($atc+\".ikfk\") ($IFJointp+\".\"+$IFJointpfattr);\n\t\n}\n\n/*******************************************************************************create groups*********************************************************************************************/     \n\ngroup -n ($FKCtrlGrp+\"_ctrl_grp\") -em;\nparent ($FKCtrlGrp+\"_FK_ctrl_grp\") ($IKCtrlGrp+\"_IK_ctrl_grp\") ($IKCtrlGrp+\"_attr_ctrl_offset\") ($FKCtrlGrp+\"_ctrl_grp\");\ngroup -n ($FKCtrlGrp+\"_ikh_grp\") -em;\nparent ($IKEndCrt+\"_ikh\") ($FKCtrlGrp+\"_ikh_grp\");\ngroup -n ($FKCtrlGrp+\"_IKFK_joint_grp\") -em;\nparent ($FKCtrlGrp+\"_IK_joint\") ($FKCtrlGrp+\"_FK_joint\") ($FKCtrlGrp+\"_IKFK_joint_grp\");\n\ngroup -n ($FKCtrlGrp+\"_setup\") -em;\nsetAttr ($FKCtrlGrp+\"_setup.v\") 0;\nparent ($FKCtrlGrp+\"_ikh_grp\") ($FKCtrlGrp+\"_IKFK_joint_grp\") ($FKCtrlGrp+\"_setup\");\n\n\n/*******************************************************************************connect the IF ctrl V*********************************************************************************************/   \nshadingNode -asUtility reverse -n ($FKCtrlGrp+\"_FK_rev\");\nconnectAttr ($FKCtrlGrp+\"_attr_ctrl.ikfk\") ($FKCtrlGrp+\"_IK_ctrl_grp.v\");\nconnectAttr ($FKCtrlGrp+\"_attr_ctrl.ikfk\") ($FKCtrlGrp+\"_FK_rev.inputX\");\nconnectAttr ($FKCtrlGrp+\"_FK_rev.outputX\") ($FKCtrlGrp+\"_FK_ctrl_grp.v\");\n\n\nstring $drv0Jnt = substituteAllString($IKctrls1[0], \"joint\", \"drv_joint\");\nstring $topRJnt = substituteAllString($IKctrls1[0], \"joint\", \"top_joint\");\nstring $topEJnt = substituteAllString($IKctrls1[(size($IKctrls1)-1)], \"joint\", \"top_joint\");\nstring $topMJnt = substituteAllString($IKctrls1[((size($IKctrls1)-1)/2)], \"joint\", \"top_joint\");\nstring $topRPrefix = substituteAllString($topRJnt, \"joint\", \"\");\nstring $topMPrefix = substituteAllString($topMJnt, \"joint\", \"\");\n\n\ninsertMidJoints($topRJnt,$topMJnt,3);\ninsertMidJoints($topMJnt,$topEJnt,3);\n\nCrtRibbon(($prefix+\"_T\"),0,5,5);\nCrtRibbon(($prefix+\"_D\"),0,5,5);\n\nparentConstraint $drv0Jnt $topRJnt;\nparentConstraint $IKctrls1[(size($IKctrls1)-1)] $topEJnt;\nparentConstraint $IKctrls1[((size($IKctrls1)-1)/2)] $topMJnt;\n\n\n\npointConstraint  $drv0Jnt ($prefix+\"_T_str_grp\");\norientConstraint -n ($prefix+\"_T_str_Ocont\") $drv0Jnt ($prefix+\"_T_str_grp\");\npointConstraint $IKctrls1[((size($IKctrls1)-1)/2)] ($prefix+\"_D_str_grp\");\norientConstraint -n ($prefix+\"_D_str_Ocont\") $IKctrls1[((size($IKctrls1)-1)/2)] ($prefix+\"_D_str_grp\");\n\nif($BLR>90 || $BLR <-90){\n    setAttr ($prefix+\"_T_str_Ocont.offsetZ\") 180;\n    setAttr ($prefix+\"_D_str_Ocont.offsetZ\") 180;\n    }\npointConstraint $IKctrls1[((size($IKctrls1)-1)/2)] ($prefix+\"_T_base_ctrl\");\npointConstraint $IKctrls1[(size($IKctrls1)-1)] ($prefix+\"_D_base_ctrl\");\n\n/*******************************************************************************create the elbow loc and rot loc*********************************************************************************************/   \nspaceLocator -n ($prefix+\"_elbow_loc\");\nspaceLocator -n ($prefix+\"_elbowRot_loc\");\ndelete`parentConstraint $IKctrls1[((size($IKctrls1)-1)/2)] ($prefix+\"_elbow_loc\")`;\ndelete`parentConstraint $IKctrls1[((size($IKctrls1)-1)/2)] ($prefix+\"_elbowRot_loc\")`;\n\ngroup -n ($prefix+\"_elbowRot_loc_offset\") -em;\ndelete `parentConstraint ($prefix+\"_elbowRot_loc\") ($prefix+\"_elbowRot_loc_offset\")`;\nparent ($prefix+\"_elbowRot_loc\") ($prefix+\"_elbowRot_loc_offset\") ;\n\nparent ($prefix+\"_elbow_loc\") $IKctrls1[((size($IKctrls1)-1)/2)] ;\nparentConstraint ($prefix+\"_elbow_loc\") ($prefix+\"_elbowRot_loc\");\n\n\n/*******************************************************************************create the twist loc and rot loc*********************************************************************************************/   \nspaceLocator -n ($prefix+\"_twrist_loc\");\nspaceLocator -n ($prefix+\"_twristRot_loc\");\ndelete`parentConstraint $IKctrls1[(size($IKctrls1)-1)] ($prefix+\"_twrist_loc\")`;\ndelete`parentConstraint $IKctrls1[(size($IKctrls1)-1)] ($prefix+\"_twristRot_loc\")`;\n\ngroup -n ($prefix+\"_twristRot_loc_offset\") -em;\ndelete `parentConstraint ($prefix+\"_twristRot_loc\") ($prefix+\"_twristRot_loc_offset\")`;\nparent ($prefix+\"_twristRot_loc\") ($prefix+\"_twristRot_loc_offset\") ;\n\nparent ($prefix+\"_twrist_loc\") $IKctrls1[(size($IKctrls1)-1)] ;\nparentConstraint ($prefix+\"_twrist_loc\") ($prefix+\"_twristRot_loc\");\n\ngroup -n ($prefix+\"_Rot_loc_grp\") -em;\n\nparent ($prefix+\"_twristRot_loc_offset\") ($prefix+\"_elbowRot_loc_offset\") ($prefix+\"_Rot_loc_grp\");\nparent ($prefix+\"_Rot_loc_grp\") ($FKCtrlGrp+\"_setup\");\n\n\n\nif($BLR>90 || $BLR <-90){\nshadingNode -n ($prefix+\"_elbowRot_md\") -asUtility multiplyDivide;\nsetAttr ($prefix+\"_elbowRot_md.input2X\") -1;\nconnectAttr ($prefix+\"_elbowRot_loc.rx\") ($prefix+\"_elbowRot_md.input1X\");\nconnectAttr ($prefix+\"_elbowRot_md.outputX\") ($prefix+\"_T_base_ctrl.rx\");\n\nshadingNode -n ($prefix+\"_twristRot_md\") -asUtility multiplyDivide;\nsetAttr ($prefix+\"_twristRot_md.input2X\") -1;\nconnectAttr ($prefix+\"_twristRot_loc.rx\") ($prefix+\"_twristRot_md.input1X\");\nconnectAttr ($prefix+\"_twristRot_md.outputX\") ($prefix+\"_D_base_ctrl.rx\");\n}\n\nif($BLR<=90 && $BLR >=-90){\nconnectAttr ($prefix+\"_elbowRot_loc.rx\") ($prefix+\"_T_base_ctrl.rx\");\nconnectAttr ($prefix+\"_twristRot_loc.rx\") ($prefix+\"_D_base_ctrl.rx\");\n}\n\nselect -r ($topRPrefix+\"*_sub_joint\");\n\nfor($T=1;$T<4;$T++){\n    parentConstraint -mo ($prefix+\"_T_\"+$T+\"_fol_joint\") ($topRPrefix+$T+\"_sub_joint\");\n}\n\nselect -r ($topMPrefix+\"*_sub_joint\");\n\nfor($D=1;$D<4;$D++){\n    parentConstraint -mo ($prefix+\"_D_\"+$D+\"_fol_joint\") ($topMPrefix+$D+\"_sub_joint\");\n}\n\nselect -hi $topRJnt;\nselect -d (\"*_parentConstraint1\");\nstring $bornBind[]=`ls - sl`;\nfor($bd=0;$bd<size($bornBind);$bd++){\n\tint $b = $bd+1;\n\tif($b<10){\n\t\trename $bornBind[$bd] ($prefix+\"_0\"+$b+\"_bind_joint\");\n\t}\n\t\tif($b>=10){\n\t\trename $bornBind[$bd] ($prefix+\"_\"+$b+\"_bind_joint\");\n\t}\n}\n\n\n\ngroup -n ($prefix+\"_str_grp\") -em;\nparent ($prefix+\"_D_str_grp\") ($prefix+\"_T_str_grp\") ($prefix+\"_str_grp\");\nparent ($prefix+\"_str_grp\") ($FKCtrlGrp+\"_setup\"); \n\nparent ($prefix+\"_drv_ikh_grp\") ($FKCtrlGrp+\"_ikh_grp\");\n\ngroup -n ($prefix+\"_drvJoint_grp\") -em;\nparent ($prefix+\"_01_drv_joint\") ($prefix+\"_01_joint\") ($prefix+\"_drvJoint_grp\");\nparent ($prefix+\"_drvJoint_grp\") ($FKCtrlGrp+\"_setup\"); \n\n\n/*******************************************************************************ik str*********************************************************************************************/    \nselect -hi $IKRootCrt;\nselect -d (\"effector*\");\nselect -d (\"*Constraint1\");\nselect -d (\"*OCont\");\nstring $bornl[]=`ls -sl`;\nfor($lo=0;$lo<size($bornl);$lo++){\n    spaceLocator -n ($prefix+\"_\"+$lo+\"_str_loc\");\n   delete` pointConstraint  $bornl[$lo] ($prefix+\"_\"+$lo+\"_str_loc\")`;\n\t\n}\n\nvector $shoulder = `xform -q -ws -t ($prefix+\"_0_str_loc\")`;\nvector $elbow = `xform -q -ws -t ($prefix+\"_1_str_loc\")`;\nvector $twrist = `xform -q -ws -t ($prefix+\"_2_str_loc\")`;\ncurve -n ($prefix+\"_0_str_cur\") -d 1 -p ($shoulder.x) ($shoulder.y) ($shoulder.z)  -p ($elbow.x) ($elbow.y) ($elbow.z)  -p ($twrist.x) ($twrist.y) ($twrist.z)  -k 0 -k 1 -k 2 ;\nselect `listRelatives -type \"shape\" ($prefix+\"_0_str_cur\")` ;\nrename ($prefix+\"_0_str_curShape\");\n\ndelete ($prefix+\"_*_str_loc\");\n\nspaceLocator -n ($prefix+\"_root_loc\");\npointConstraint ($prefix+\"_root_sub_ctrl\") ($prefix+\"_root_loc\");\n\nspaceLocator -n ($prefix+\"_IK_loc\");\npointConstraint ($prefix+\"_IK_sub_ctrl\") ($prefix+\"_IK_loc\");\n\ngroup -n ($prefix+\"_str_loc_grp\") -em;\nparent ($prefix+\"_root_loc\") ($prefix+\"_IK_loc\") ($prefix+\"_str_loc_grp\");\n\n\naddAttr -ln \"stretch\" -nn \"Stretch\" -at long  -min 0 -max 1 -dv 0 -k 1 ($prefix+\"_IK_ctrl\");\n\nshadingNode -n ($prefix+\"_str_dist\") -asUtility distanceBetween;\nshadingNode -n ($prefix+\"_str_cif\") -asUtility curveInfo;\nshadingNode -n ($prefix+\"_str_md\") -asUtility multiplyDivide;\nsetAttr ($prefix+\"_str_md.operation\") 2;\n\n\nconnectAttr ($prefix+\"_root_loc.translate\") ($prefix+\"_str_dist.point1\");\nconnectAttr ($prefix+\"_IK_loc.translate\") ($prefix+\"_str_dist.point2\");\n\nconnectAttr ($prefix+\"_0_str_curShape.worldSpace[0]\") ($prefix+\"_str_cif.inputCurve\");\n\nconnectAttr ($prefix+\"_str_dist.distance\") ($prefix+\"_str_md.input1X\");\nconnectAttr ($prefix+\"_str_cif.arcLength\") ($prefix+\"_str_md.input2X\");\n\nshadingNode -n ($prefix+\"_ctrl_cond\") -asUtility condition;\n\nsetAttr ($prefix+\"_ctrl_cond.secondTerm\") 1;\nsetAttr ($prefix+\"_ctrl_cond.colorIfTrueR\") 1;\nsetAttr ($prefix+\"_ctrl_cond.colorIfFalseR\") 0;\nconnectAttr ($prefix+\"_IK_ctrl.stretch\") ($prefix+\"_ctrl_cond.firstTerm\");\n\n\n\nshadingNode -n ($prefix+\"_str_cond\") -asUtility condition;\nsetAttr ($prefix+\"_str_cond.operation\") 2;\nsetAttr ($prefix+\"_str_cond.secondTerm\") 1;\nsetAttr ($prefix+\"_str_cond.colorIfTrueR\") 1;\nsetAttr ($prefix+\"_str_cond.colorIfFalseR\") 0;\n\nconnectAttr ($prefix+\"_str_md.outputX\") ($prefix+\"_str_cond.firstTerm\");\n\nshadingNode -n ($prefix+\"_str_pma\")-asUtility plusMinusAverage;\nconnectAttr  ($prefix+\"_str_cond.outColorR\") ($prefix+\"_str_pma.input1D[0]\");\nconnectAttr  ($prefix+\"_ctrl_cond.outColorR\") ($prefix+\"_str_pma.input1D[1]\");\n\n\nshadingNode -n ($prefix+\"_cond\") -asUtility condition;\nsetAttr ($prefix+\"_cond.secondTerm\") 2;\nconnectAttr ($prefix+\"_str_pma.output1D\") ($prefix+\"_cond.firstTerm\");\nconnectAttr ($prefix+\"_str_md.outputX\") ($prefix+\"_cond.colorIfTrueR\");\nconnectAttr ($prefix+\"_cond.outColorR\") ($prefix+\"_01_IK_joint.scaleX\");\nconnectAttr($prefix+\"_cond.outColorR\") ($prefix+\"_02_IK_joint.scaleX\");\n\ngroup -n ($prefix+\"_str_cur_grp\") ($prefix+\"_0_str_cur\");\nparent ($prefix+\"_str_cur_grp\") ($FKCtrlGrp+\"_setup\"); \nparent ($prefix+\"_str_loc_grp\") ($FKCtrlGrp+\"_setup\"); \n\n\nsetAttr ($prefix+\"_D_str_grp.scaleX\") ($d/24);\nsetAttr ($prefix+\"_D_str_grp.scaleY\") ($d/24);\nsetAttr ($prefix+\"_D_str_grp.scaleZ\") ($d/24);\n\n\nsetAttr ($prefix+\"_T_str_grp.scaleX\") ($d/24);\nsetAttr ($prefix+\"_T_str_grp.scaleY\") ($d/24);\nsetAttr ($prefix+\"_T_str_grp.scaleZ\") ($d/24);\nprint $d;\n\ndelete ($prefix+\"_str_grp\");\n\n\nparentConstraint -mo ($prefix+\"_01_drv_joint\") ($prefix+\"_01_F_joint\");\nparentConstraint -mo ($prefix+\"_02_joint\") ($prefix+\"_02_F_joint\");\nparentConstraint -mo ($prefix+\"_03_joint\") ($prefix+\"_03_F_joint\");\n\nshadingNode -n ($prefix+\"_02_md\") -asUtility multiplyDivide;\nconnectAttr ($prefix+\"_02_F_joint.rotateX\") ($prefix+\"_02_md.input1X\");\nconnectAttr ($prefix+\"_02_F_joint.rotateX\") ($prefix+\"_02_md.input1Y\");\nconnectAttr ($prefix+\"_02_F_joint.rotateX\") ($prefix+\"_02_md.input1Z\");\n\nsetAttr ($prefix+\"_02_md.input2X\") 0.125;\nsetAttr ($prefix+\"_02_md.input2Y\") 0.25;\nsetAttr ($prefix+\"_02_md.input2Z\") 0.375;\n\nconnectAttr ($prefix+\"_02_md.outputX\") ($prefix+\"_02_bind_joint.rotateX\");\nconnectAttr ($prefix+\"_02_md.outputY\") ($prefix+\"_03_bind_joint.rotateX\");\nconnectAttr ($prefix+\"_02_md.outputZ\") ($prefix+\"_04_bind_joint.rotateX\");\n\nshadingNode -n ($prefix+\"_02_f_pma\") -asUtility plusMinusAverage;\nshadingNode -n ($prefix+\"_02_t_md\") -asUtility multiplyDivide;\nshadingNode -n ($prefix+\"_02_s_pma\") -asUtility plusMinusAverage;\n\nconnectAttr ($prefix+\"_02_F_joint.translateX\") ($prefix+\"_02_f_pma.input1D[0]\");\nsetAttr ($prefix+\"_02_f_pma.operation\") 2;\nsetAttr ($prefix+\"_02_t_md.operation\") 2;\nsetAttr ($prefix+\"_02_t_md.input2X\") 4;\n\nconnectAttr ($prefix+\"_02_f_pma.output1D\")  ($prefix+\"_02_t_md.input1X\");\nconnectAttr  ($prefix+\"_02_t_md.outputX\") ($prefix+\"_02_s_pma.input1D[0]\");\n\nfloat $armTt = `getAttr ($prefix+\"_02_F_joint.translateX\")`;\nfloat $armTst = `getAttr ($prefix+\"_02_bind_joint.translateX\")`;\n\nsetAttr ($prefix+\"_02_s_pma.input1D[1]\") $armTst;\nsetAttr ($prefix+\"_02_f_pma.input1D[1]\") $armTt;\n\nconnectAttr ($prefix+\"_02_s_pma.output1D\") ($prefix+\"_02_bind_joint.translateX\");\nconnectAttr ($prefix+\"_02_s_pma.output1D\") ($prefix+\"_03_bind_joint.translateX\");\nconnectAttr ($prefix+\"_02_s_pma.output1D\") ($prefix+\"_04_bind_joint.translateX\");\n\n\n\nshadingNode -n ($prefix+\"_03_md\") -asUtility multiplyDivide;\nconnectAttr ($prefix+\"_03_F_joint.rotateX\") ($prefix+\"_03_md.input1X\");\nconnectAttr ($prefix+\"_03_F_joint.rotateX\") ($prefix+\"_03_md.input1Y\");\nconnectAttr ($prefix+\"_03_F_joint.rotateX\") ($prefix+\"_03_md.input1Z\");\n\nsetAttr ($prefix+\"_03_md.input2X\") 0.125;\nsetAttr ($prefix+\"_03_md.input2Y\") 0.25;\nsetAttr ($prefix+\"_03_md.input2Z\") 0.375;\n\nconnectAttr ($prefix+\"_03_md.outputX\") ($prefix+\"_06_bind_joint.rotateX\");\nconnectAttr ($prefix+\"_03_md.outputY\") ($prefix+\"_07_bind_joint.rotateX\");\nconnectAttr ($prefix+\"_03_md.outputZ\") ($prefix+\"_08_bind_joint.rotateX\");\n\nshadingNode -n ($prefix+\"_03_f_pma\") -asUtility plusMinusAverage;\nshadingNode -n ($prefix+\"_03_t_md\") -asUtility multiplyDivide;\nshadingNode -n ($prefix+\"_03_s_pma\") -asUtility plusMinusAverage;\n\nconnectAttr ($prefix+\"_03_F_joint.translateX\") ($prefix+\"_03_f_pma.input1D[0]\");\nsetAttr ($prefix+\"_03_f_pma.operation\") 2;\nsetAttr ($prefix+\"_03_t_md.operation\") 2;\nsetAttr ($prefix+\"_03_t_md.input2X\") 4;\n\nconnectAttr ($prefix+\"_03_f_pma.output1D\")  ($prefix+\"_03_t_md.input1X\");\nconnectAttr  ($prefix+\"_03_t_md.outputX\") ($prefix+\"_03_s_pma.input1D[0]\");\n\nfloat $armTt = `getAttr ($prefix+\"_03_F_joint.translateX\")`;\nfloat $armTst = `getAttr ($prefix+\"_06_bind_joint.translateX\")`;\n\nsetAttr ($prefix+\"_03_s_pma.input1D[1]\") $armTst;\nsetAttr ($prefix+\"_03_f_pma.input1D[1]\") $armTt;\n\nconnectAttr ($prefix+\"_03_s_pma.output1D\") ($prefix+\"_06_bind_joint.translateX\");\nconnectAttr ($prefix+\"_03_s_pma.output1D\") ($prefix+\"_07_bind_joint.translateX\");\nconnectAttr ($prefix+\"_03_s_pma.output1D\") ($prefix+\"_08_bind_joint.translateX\");\n\nparent ($prefix+\"_01_F_joint\") ($prefix+\"_drvJoint_grp\");\n}\n\n/*******************************************************************************function*********************************************************************************************/     \nglobal proc FKCtrl(string $FKjnt){\nselect -r $FKjnt;\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){\n    curve -n ($born[$i]+\"_ctrl\") -d 1 -p 0.223758 1 0 -p 0.223758 0.866025 0.5 -p 0.223758 0.5 0.866025 -p 0.223758 0 1 -p 0.223758 -0.5 0.866025 -p 0.223758 -0.866025 0.5 -p 0.223758 -1 0 -p 0.223758 -0.866025 -0.5 -p 0.223758 -0.5 -0.866025 -p 0.223758 0 -1 -p 0.223758 0.5 -0.866025 -p 0.223758 0.866025 -0.5 -p 0.223758 1 0 -p -0.223758 1 0 -p -0.223758 0.866025 0.5 -p -0.223758 0.5 0.866025 -p -0.223758 0 1 -p 0.223758 0 1 -p -0.223758 0 1 -p -0.223758 -0.5 0.866025 -p -0.223758 -0.866025 0.5 -p -0.223758 -1 0 -p 0.223758 -1 0 -p -0.223758 -1 0 -p -0.223758 -0.866025 -0.5 -p -0.223758 -0.5 -0.866025 -p -0.223758 0 -1 -p 0.223758 0 -1 -p -0.223758 0 -1 -p -0.223758 0.5 -0.866025 -p -0.223758 0.866025 -0.5 -p -0.223758 1 0 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 ;\n    rename `listRelatives -c -type \"shape\"` ($born[$i