        -annotation "global proc CurTools(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"toolsForCur\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"tools for curve\" -widthHeight 300 50 $mygui;  \n\nframeLayout\n-label \"tools for curs\";\n        rowColumnLayout -numberOfColumns 1\n            -columnWidth 1 300\n            -columnWidth 2 300\n            -columnWidth 3 300;\n           \n        button -label \"create locators based on the curve\" -command \"locatorsOnCur()\";\n\n        button -label \"create joints based on the curve\" -command \"jointsOnCur()\";  \n\n        button -label \"create splineIk based on the curve\" -command \"spIKCur()\";      \n\n              \n        separator -visible 0;\n        setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\nglobal proc get_org()\n{\nstring $orglist[] = `ls -sl`;\nstring $orgobjname =$orglist[0];\nstring $orgbuffer[] ;\ntokenize $orgobjname \"|\" $orgbuffer ;\nint $org_arraysize = size($orgbuffer);\nif ($org_arraysize >1)\n{\ntextFieldButtonGrp -edit -text $orgbuffer[1] attr_name;\n            }\nelse\n{\ntextFieldButtonGrp -edit -text $orgbuffer[0] attr_name;\n            }\n}\n\n\n\n\nglobal proc spIKCur(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"IKOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"build the splineIK with curve\" -widthHeight 400 200 $mygui;  \n\ntextFieldButtonGrp -label \"get the curve\"\n-text \"\"\n-buttonLabel \"base_curve\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"create joints based on the curve\" -collapsable 1 ; \n   text -l \"Please type in the number you want.\";\n   rowLayout;\n\n\t\t\ttextFieldButtonGrp -label \"joint account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonLabel \"create joints\"\n\t\t\t-buttonCommand \"jointOnCur(`textFieldGrp  -query -text attr_name`,`textFieldButtonGrp -query -text joint_number`)\"  joint_number;\n\n   setParent ..;\n  setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\n\n\n\n\n\n\nglobal proc jointOnCur(string $cur, int $locNum){\nfor($i=0;$i<$locNum;$i++){\n   spaceLocator -n ($cur+\"_\"+($i+1)+\"_loc\")-p 0 0 0;\n   \n    select -tgl $cur;\npathAnimation -n ($cur+\"_\"+($i+1)+\"_loc_path\") -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 1 -endTimeU 1;\nselectKey -add -k -t 1 -t 1 ($cur+\"_\"+($i+1)+\"_loc_path_uValue\");\ncutKey -animation keys -clear;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_path.allCoordinates\") ($cur+\"_\"+($i+1)+\"_loc.translate\");\ndelete `listConnections -t \"addDoubleLinear\"`;\n\nshadingNode -asUtility multiplyDivide -n ($cur+\"_\"+($i+1)+\"_loc_md\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.operation\") 2;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input2X\") ($locNum-1);\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input1X\") $i;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_md.outputX\") ($cur+\"_\"+($i+1)+\"_loc_path.uValue\");\ndelete ($cur+\"_\"+($i+1)+\"_loc_md\");\n\n}\ngroup -n ($cur+\"_\"+\"loc_grp\") -em;\nparent ($cur+\"_\"+\"*_loc\") ($cur+\"_\"+\"loc_grp\") ;\nselect -cl;\n/*************************************************************************create joints*********************************************************************************************************/\n\njoint -n dup_joint;\n\nfor ($j=0;$j<$locNum;$j++){\n\tduplicate  -n ($cur+\"_\"+($j+1)+\"_joint\") dup_joint;\n\tif ($j>0){\n\t\tparent ($cur+\"_\"+($j+1)+\"_joint\") ($cur+\"_\"+$j+\"_joint\");\n\t\tsetAttr ($cur+\"_\"+($j+1)+\"_joint.translateX\") 1;\n\t\t}\n\t\n}\ndelete dup_joint;\n\n/*************************************************************************create rotate cards*********************************************************************************************************/\nselect -hi ($cur+\"_\"+\"1_joint\") ;\nstring $born[]=`ls -sl`;\nfor($b=0;$b<$locNum;$b++){\n\tpolyPlane -w 1 -h 1 -sx 1 -sy 1  -n ($born[$b]+\"_rot_geo\");\t\n\tmove -rpr -0.5 0 0 (($born[$b]+\"_rot_geo\")+\".scalePivot\") (($born[$b]+\"_rot_geo\")+\".rotatePivot\");\n\tdelete `parentConstraint  $born[$b] ($born[$b]+\"_rot_geo\")`;\n\t\n\tspaceLocator -n ($born[$b]+\"_rot_loc\");\n\tdelete`parentConstraint $born[$b] ($born[$b]+\"_rot_loc\")`;\t\n\t\n    shadingNode -asUtility distanceBetween -n ($born[$b]+\"_dist\");\n    if($b>0){\n\t\tconnectAttr (($born[$b]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point1\");\n\t\tconnectAttr (($born[$b-1]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point2\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tselect -r (\"*_rot_geo\");\n\t\tmakeIdentity -apply true -t 0 -r 0 -s 1 -n 0 -pn 1 ;    \n\t\tparent ($born[$b]+\"_rot_geo\") ($born[$b-1]+\"_rot_geo\");\n\t\t\n\t\t}\n\t\n    \n    pointConstraint -n ($born[$b]+\"_rotptcon\") ($born[$b]+\"_rot_geo\") $born[$b];\t\n\tconnectAttr (($born[$b]+\"_rot_geo\")+\".rotate\") ($born[$b]+\".jointOrient\");\n\tstring $opsit = substituteAllString($born[$b], \"joint\", \"loc\");\n\tstring $opsit1 = substituteAllString($born[$b+1], \"joint\", \"loc\");\n\tdelete `pointConstraint $opsit ($born[$b]+\"_rot_geo\")`;\n\tif($b<($locNum-1)){\n\ndelete `aimConstraint -offset 0 0 0 -weight 1 -aimVector 1 0 0 -upVector 0 1 0 -worldUpType \"vector\" -worldUpVector 0 1 0 $opsit1 ($born[$b]+\"_rot_geo\")`;\n\t}\n\n}\t\ndelete ($cur+\"_\"+\"loc_grp\");\ndelete (\"*_rot_loc\");\ndelete (\"*_rotptcon*\");\ndelete (\"*_rot_geo*\");\n\nselect -r ($cur+\"_1_joint\") ;\nselect -tgl ($cur+\"_\"+$locNum+\"_joint\") ;\nselect -tgl $cur ;\nikHandle -n ($cur+\"_SpIkh\") -sol ikSplineSolver -ccv false -pcv false;\n}\n\n\n\n\n\nglobal proc locatorsOnCur(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"LocatorsOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"Locators on curve\" -widthHeight 400 200 $mygui;  \n\ntextFieldButtonGrp -label \"get the curve\"\n-text \"\"\n-buttonLabel \"base_curve\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"create locators based on the curve\" -collapsable 1 ; \n   text -l \"Please type in the number you want.\";\n   rowLayout;\n\n\t\t\ttextFieldButtonGrp -label \"locator account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonLabel \"create locators\"\n\t\t\t-buttonCommand \"jointOnCur(`textFieldGrp  -query -text attr_name`,`textFieldButtonGrp -query -text joint_number`)\"  joint_number;\n\n   setParent ..;\n  setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\n\n\n\n\n\n\nglobal proc jointOnCur(string $cur, int $locNum){\nfor($i=0;$i<$locNum;$i++){\n   spaceLocator -n ($cur+\"_\"+($i+1)+\"_loc\")-p 0 0 0;\n   \n    select -tgl $cur;\npathAnimation -n ($cur+\"_\"+($i+1)+\"_loc_path\") -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 1 -endTimeU 1;\nselectKey -add -k -t 1 -t 1 ($cur+\"_\"+($i+1)+\"_loc_path_uValue\");\ncutKey -animation keys -clear;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_path.allCoordinates\") ($cur+\"_\"+($i+1)+\"_loc.translate\");\ndelete `listConnections -t \"addDoubleLinear\"`;\n\nshadingNode -asUtility multiplyDivide -n ($cur+\"_\"+($i+1)+\"_loc_md\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.operation\") 2;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input2X\") ($locNum-1);\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input1X\") $i;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_md.outputX\") ($cur+\"_\"+($i+1)+\"_loc_path.uValue\");\ndelete ($cur+\"_\"+($i+1)+\"_loc_md\");\n\n}\ngroup -n ($cur+\"_\"+\"loc_grp\") -em;\nparent ($cur+\"_\"+\"*_loc\") ($cur+\"_\"+\"loc_grp\") ;\n\n\n}\n\n\n\n\nglobal proc jointsOnCur(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"JointsOnCurve\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"joints on curve\" -widthHeight 400 200 $mygui;  \n\ntextFieldButtonGrp -label \"get the curve\"\n-text \"\"\n-buttonLabel \"base_curve\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"create joints based on the curve\" -collapsable 1 ; \n   text -l \"Please type in the number you want.\";\n   rowLayout;\n\n\t\t\ttextFieldButtonGrp -label \"joint account:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonLabel \"create joints\"\n\t\t\t-buttonCommand \"jointOnCur(`textFieldGrp  -query -text attr_name`,`textFieldButtonGrp -query -text joint_number`)\"  joint_number;\n\n   setParent ..;\n  setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\n\n\n\n\n\n\nglobal proc jointOnCur(string $cur, int $locNum){\nfor($i=0;$i<$locNum;$i++){\n   spaceLocator -n ($cur+\"_\"+($i+1)+\"_loc\")-p 0 0 0;\n   \n    select -tgl $cur;\npathAnimation -n ($cur+\"_\"+($i+1)+\"_loc_path\") -fractionMode true -follow true -followAxis x -upAxis y -worldUpType \"vector\" -worldUpVector 0 1 0 -inverseUp false -inverseFront false -bank false -startTimeU 1 -endTimeU 1;\nselectKey -add -k -t 1 -t 1 ($cur+\"_\"+($i+1)+\"_loc_path_uValue\");\ncutKey -animation keys -clear;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_path.allCoordinates\") ($cur+\"_\"+($i+1)+\"_loc.translate\");\ndelete `listConnections -t \"addDoubleLinear\"`;\n\nshadingNode -asUtility multiplyDivide -n ($cur+\"_\"+($i+1)+\"_loc_md\");\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.operation\") 2;\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input2X\") ($locNum-1);\nsetAttr ($cur+\"_\"+($i+1)+\"_loc_md.input1X\") $i;\nconnectAttr ($cur+\"_\"+($i+1)+\"_loc_md.outputX\") ($cur+\"_\"+($i+1)+\"_loc_path.uValue\");\ndelete ($cur+\"_\"+($i+1)+\"_loc_md\");\n\n}\ngroup -n ($cur+\"_\"+\"loc_grp\") -em;\nparent ($cur+\"_\"+\"*_loc\") ($cur+\"_\"+\"loc_grp\") ;\nselect -cl;\n/*************************************************************************create joints*********************************************************************************************************/\n\njoint -n dup_joint;\n\nfor ($j=0;$j<$locNum;$j++){\n\tduplicate  -n ($cur+\"_\"+($j+1)+\"_joint\") dup_joint;\n\tif ($j>0){\n\t\tparent ($cur+\"_\"+($j+1)+\"_joint\") ($cur+\"_\"+$j+\"_joint\");\n\t\tsetAttr ($cur+\"_\"+($j+1)+\"_joint.translateX\") 1;\n\t\t}\n\t\n}\ndelete dup_joint;\n\n/*************************************************************************create rotate cards*********************************************************************************************************/\nselect -hi ($cur+\"_\"+\"1_joint\") ;\nstring $born[]=`ls -sl`;\nfor($b=0;$b<$locNum;$b++){\n\tpolyPlane -w 1 -h 1 -sx 1 -sy 1  -n ($born[$b]+\"_rot_geo\");\t\n\tmove -rpr -0.5 0 0 (($born[$b]+\"_rot_geo\")+\".scalePivot\") (($born[$b]+\"_rot_geo\")+\".rotatePivot\");\n\tdelete `parentConstraint  $born[$b] ($born[$b]+\"_rot_geo\")`;\n\t\n\tspaceLocator -n ($born[$b]+\"_rot_loc\");\n\tdelete`parentConstraint $born[$b] ($born[$b]+\"_rot_loc\")`;\t\n\t\n    shadingNode -asUtility distanceBetween -n ($born[$b]+\"_dist\");\n    if($b>0){\n\t\tconnectAttr (($born[$b]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point1\");\n\t\tconnectAttr (($born[$b-1]+\"_rot_loc\")+\".translate\") (($born[$b]+\"_dist\")+\".point2\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleX\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleY\");\n\t\tdisconnectAttr (($born[$b]+\"_dist\")+\".distance\") (($born[$b-1]+\"_rot_geo\")+\".scaleZ\");\n\t\tselect -r (\"*_rot_geo\");\n\t\tmakeIdentity -apply true -t 0 -r 0 -s 1 -n 0 -pn 1 ;    \n\t\tparent ($born[$b]+\"_rot_geo\") ($born[$b-1]+\"_rot_geo\");\n\t\t\n\t\t}\n\t\n    \n    pointConstraint -n ($born[$b]+\"_rotptcon\") ($born[$b]+\"_rot_geo\") $born[$b];\t\n\tconnectAttr (($born[$b]+\"_rot_geo\")+\".rotate\") ($born[$b]+\".jointOrient\");\n\tstring $opsit = substituteAllString($born[$b], \"joint\", \"loc\");\n\tstring $opsit1 = substituteAllString($born[$b+1], \"joint\", \"loc\");\n\tdelete `pointConstraint $opsit ($born[$b]+\"_rot_geo\")`;\n\tif($b<($locNum-1)){\n\ndelete `aimConstraint -offset 0 0 0 -weight 1 -aimVector 1 0 0 -upVector 0 1 0 -worldUpType \"vector\" -worldUpVector 0 1 0 $opsit1 ($born[$b]+\"_rot_geo\")`;\n\t}\n\n}\t\ndelete ($cur+\"_\"+\"loc_grp\");\ndelete (\"*_rot_loc\");\ndelete (\"*_rotptcon*\");\ndelete (\"*_rot_geo*\");\n\n}\n\nCurTools();" 
