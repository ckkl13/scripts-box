        -annotation "\nstring $lowJnr[] = `ls - sl`;\nfor($lj=0;$lj<(size($lowJnr)-1);$lj++){\n    polyCylinder -n ($lowJnr[$lj]+\"_lowRes_geo\") -r 1 -h 2 -sx 12 -sy 6 -sz 1 -ax 0 1 0 -rcp 0 -cuv 3 -ch 1;\n    move -r 0 -1 0 ($lowJnr[$lj]+\"_lowRes_geo.scalePivot\") ($lowJnr[$lj]+\"_lowRes_geo.rotatePivot\") ; \n    delete ($lowJnr[$lj]+\"_lowRes_geo.f[72:95]\") ;\n    \n\n    delete `pointConstraint -n ($lowJnr[$lj]+\"_lowRes_poCont\") $lowJnr[$lj] ($lowJnr[$lj]+\"_lowRes_geo\")`;\n    delete `aimConstraint -offset 0 0 0 -weight 1 -aimVector 0 1 0 -upVector 1 1 0 -worldUpType \"vector\" -worldUpVector 0 1 0 $lowJnr[$lj+1] ($lowJnr[$lj]+\"_lowRes_geo\")`;\n    spaceLocator -n ($lowJnr[$lj]+\"_lowRes_loc\");\n    spaceLocator -n ($lowJnr[$lj+1]+\"_lowRes_loc\");\n    delete`pointConstraint $lowJnr[$lj] ($lowJnr[$lj]+\"_lowRes_loc\")`;\n    delete`pointConstraint $lowJnr[$lj+1] ($lowJnr[$lj+1]+\"_lowRes_loc\")`;\n    \n    shadingNode -n ($lowJnr[$lj]+\"_lowRes_dist\") -asUtility distanceBetween;\n    connectAttr ($lowJnr[$lj]+\"_lowRes_loc.translate\") ($lowJnr[$lj]+\"_lowRes_dist.point1\");\n    connectAttr ($lowJnr[$lj+1]+\"_lowRes_loc.translate\") ($lowJnr[$lj]+\"_lowRes_dist.point2\");\n    float $lowDist = `getAttr ($lowJnr[$lj]+\"_lowRes_dist.distance\")`;\n    setAttr ($lowJnr[$lj]+\"_lowRes_geo.sy\") ($lowDist/2);\n\n    \n    delete ($lowJnr[$lj]+\"_lowRes_dist\");\n    delete ($lowJnr[$lj]+\"_lowRes_loc\");\n    delete ($lowJnr[$lj+1]+\"_lowRes_loc\");\n\n    select -r $lowJnr[$lj];\n    select -add ($lowJnr[$lj]+\"_lowRes_geo\");\n    SmoothBindSkin ;\n    }\n" 
