        -command "global proc masterWin(){\n\nif ( `window -exists MyWindow` ) {\n deleteUI MyWindow;\n}\nwindow -t \"create the master\"  MyWindow;\n \n\n\n\n frameLayout -label \"create Master\" -collapsable 1 ; \n   text -l \"Please type in the master name you want.\";\n   rowLayout;\n\n\t\t\ttextFieldButtonGrp -label \"Master Name:\"\n\t\t\t-text \"\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonLabel \"Create Master\"\n\t\t\t-buttonCommand \"masterCrt(`textFieldButtonGrp -query -text master_name`)\" master_name;\n\n   setParent ..;\n  setParent ..;\n  \n\nshowWindow MyWindow;\nwindow  -e -widthHeight 300 100 MyWindow;\n}\nglobal proc masterCrt(string $mnam){\ngroup -n ($mnam+\"_master\") -em;\ngroup -n mdl_grp -em;\ngroup -n rig_grp -em;\ngroup -n high -em;\ngroup -n low -em;\ngroup -n ctrl_grp -em;\ngroup -n bind_grp -em;\ngroup -n bind_joint_grp -em;\ngroup -n setups_grp -em;\ngroup -n extra_grp -em;\nparent high low mdl_grp;\nparent bind_joint_grp bind_grp;\nparent bind_grp setups_grp extra_grp rig_grp;\nparent mdl_grp rig_grp ctrl_grp ($mnam+\"_master\");\n\ncreateDisplayLayer -noRecurse -name ($mnam+\"_geo_layer\") mdl_grp;\ncreateDisplayLayer -noRecurse -name ($mnam+\"_ctrl_layer\")  ctrl_grp;\n\ncurve -n world_ctrl -d 1 -p 0 0 -0.5 -p -0.3 0 -0.5 -p -0.378831 0 -0.473538 -p -0.436514 0 -0.436514 -p -0.473538 0 -0.378831 -p -0.5 0 -0.3 -p -0.5 0 0 -p -0.5 0 0.3 -p -0.473538 0 0.378831 -p -0.436514 0 0.436514 -p -0.378831 0 0.473538 -p -0.3 0 0.5 -p 0 0 0.5 -p 0.3 0 0.5 -p 0.378831 0 0.473538 -p 0.436514 0 0.436514 -p 0.473538 0 0.378831 -p 0.5 0 0.3 -p 0.5 0 0 -p 0.5 0 -0.3 -p 0.473538 0 -0.378831 -p 0.436514 0 -0.436514 -p 0.378831 0 -0.473538 -p 0.3 0 -0.5 -p 0 0 -0.5 -p 0 0 -0.398354 -p 0.239013 0 -0.398354 -p 0.301818 0 -0.377272 -p 0.347775 0 -0.347775 -p 0.377272 0 -0.301818 -p 0.398354 0 -0.239013 -p 0.398354 0 0 -p 0.398354 0 0.159342 -p 0.398354 0 0.239013 -p 0.377272 0 0.301818 -p 0.347775 0 0.347775 -p 0.301818 0 