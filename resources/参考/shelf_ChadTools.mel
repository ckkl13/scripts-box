        -annotation "global proc BSTarget_mirror()\n{\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"G_IK_FK\";\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"Mirror BS traget\" -widthHeight 400 200 $mygui;  \nframeLayout\n   -label \"get the base geo\";\n  columnLayout -adj 1;\n \ntextFieldButtonGrp -label \"get the base geo\"\n-text \"\"\n-buttonLabel \"base_geo\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\nframeLayout\n   -label \"get the target node\";\n  columnLayout -adj 1;\n \ntextFieldButtonGrp -label \"get the target\"\n-text \"\"\n-buttonLabel \"BSTarget\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_tgr()\" attr_name1;\nsetParent ..;\nsetParent ..;\nframeLayout\n-label \"mirror the BS traget\";\n        rowColumnLayout -numberOfColumns 4\n            -columnWidth 1 70\n            -columnWidth 2 70\n            -columnWidth 3 70\n            -columnWidth 4 70;\n           \n        separator -visible 0 -height 10; separator -visible 0;    separator -visible 0;        separator -visible 0;\n        separator -visible 0;\n        button -label \"L_to_R\" -command \"mirror_LtoR()\";\nbutton -label \"R_to_L\" -command \"mirror_RtoL()\";                  \n        separator -visible 0;\n        setParent ..;\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\nglobal proc get_org()\n{\nstring $orglist[] = `ls -sl`;\nstring $orgobjname =$orglist[0];\nstring $orgbuffer[] ;\ntokenize $orgobjname \"|\" $orgbuffer ;\nint $org_arraysize = size($orgbuffer);\nif ($org_arraysize >1)\n{\ntextFieldButtonGrp -edit -text $orgbuffer[1] attr_name;\n            }\nelse\n{\ntextFieldButtonGrp -edit -text $orgbuffer[0] attr_name;\n            }\n}\n\nglobal proc get_tgr()\n{\nstring $tgrlist[] = `ls -sl`;\nstring $tgrobjname =$tgrlist[0];\nstring $tgrbuffer[] ;\ntokenize $tgrobjname \"|\" $tgrbuffer ;\nint $tgr_arraysize = size($tgrbuffer);\nif ($tgr_arraysize >1)\n{\ntextFieldButtonGrp -edit -text $tgrbuffer[1] attr_name1;\n            }\nelse\n{\ntextFieldButtonGrp -edit -text $tgrbuffer[0] attr_name1;\n            }\n}\n\nglobal proc mirror_LtoR()\n{\n    string $attname = (`textFieldButtonGrp -query -text attr_name`);\n    string $attname1 = (`textFieldButtonGrp -query -text attr_name1`);\n    string $born[]=`ls - sl`;\n\n    string $opsit = substituteAllString($attname1, \"_L_\", \"_R_\");\n    duplicate -n $opsit -rr $attname;\n    blendShape -n test_blendshape -automatic $attname1 $attname;\n   \n    spaceLocator -n ($attname1+\"_loc\");\n    delete `parentConstraint $attname1 ($attname1+\"_loc\")`;\n   \n   \n    setAttr ($attname1+\".translateX\") 0;\n    setAttr ($attname1+\".translateY\") 0;    \n    setAttr ($attname1+\".translateZ\") 0;\n    setAttr ($opsit+\".scaleX\") -1;\n   \n    select -r $opsit ;\n    select -add $attname ;\n    CreateWrap ;\n    setAttr (\"test_blendshape.\"+$attname1) 1;\n   \n   \n    duplicate -n ($opsit+\"_dup\") -rr $opsit ;\n    delete $opsit;\n    rename ($opsit+\"_dup\") $opsit;\n    setAttr ($opsit+\".scaleX\") 1;\n   \n    delete `parentConstraint ($attname1+\"_loc\") $attname1`;\n    delete ($attname1+\"_loc\");\n    delete test_blendshape;\n    select -cl;\n}  \n \nglobal proc mirror_RtoL()\n{\n    string $attname = (`textFieldButtonGrp -query -text attr_name`);\n    string $attname1 = (`textFieldButtonGrp -query -text attr_name1`);\n    string $born[]=`ls - sl`;\n\n    string $opsit = substituteAllString($attname1, \"_R_\", \"_L_\");\n    duplicate -n $opsit -rr $attname;\n    blendShape -n test_blendshape -automatic $attname1 $attname;\n   \n    spaceLocator -n ($attname1+\"_loc\");\n    delete `parentConstraint $attname1 ($attname1+\"_loc\")`;\n   \n   \n    setAttr ($attname1+\".translateX\") 0;\n    setAttr ($attname1+\".translateY\") 0;\n    setAttr ($attname1+\".translateZ\") 0;\n    setAttr ($opsit+\".scaleX\") -1;\n   \n    select -r $opsit ;\n    select -add $attname ;\n    CreateWrap ;\n    setAttr (\"test_blendshape.\"+$attname1) 1;\n   \n   \n    duplicate -n ($opsit+\"_dup\") -rr $opsit ;\n    delete $opsit;\n    rename ($opsit+\"_dup\") $opsit;\n    setAttr ($opsit+\".scaleX\") 1;\n   \n    delete `parentConstraint ($attname1+\"_loc\") $attname1`;\n    delete ($attname1+\"_loc\");\n    delete test_blendshape;\n    select -cl;\n}  \nBSTarget_mirror;\n" 
