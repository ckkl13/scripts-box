        -annotation "global proc SftToClu(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"softselectTOCluster\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"convert your soft selection to cluster\" -widthHeight 200 50 $mygui;  \n\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -label \"select the point with softselect\" -collapsable 1 ; \n   text -l \"Please select the point with softselect and type in name that you want\";\n   columnLayout;\n            textFieldGrp\n            -label \"cluster name:\"\n            -text \"\"\n\n            attr_name;\n\n\n\n\n   button -l \"create ctrl\" -c \"stcTool(`textFieldGrp  -query -text attr_name`)\";\n\n   setParent ..;\n   setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\nglobal proc stcTool(string $nam){\n//??mesh???\n   string $selVtx[] = `ls -sl -fl`;\n   $selVtxPP = `pointPosition -w $selVtx[0]`;\n   string $selShape[] = `listRelatives -p $selVtx[0]`;\n   string $selMesh[] = `listRelatives -p $selShape[0]`;\n   $numVtx = `polyEvaluate -v $selMesh[0]`;\n   float $oldVtxPP[] = {};\n   float $newVtxPP[] = {};\n   string $subCtr = substituteAllString($selVtx[0], ($selMesh[0] + \".vtx[\"), \"\");\n   string $subCtr1 = substituteAllString($subCtr, \"]\", \"\");\n//????????????????\n      for ($i = 0;$i<$numVtx[0]; $i++)\n       {\n        $vtxBeforeMove = `pointPosition -w ($selMesh[0] + \".vtx[\" + $i + \"]\")`;\n        $oldVtxPP[$i] = $vtxBeforeMove[0] ;\n       }\n//??????X????????????????\n    move -r 1 0 0 ;\n      for ($i = 0;$i<$numVtx[0]; $i++)\n       {\n        $vtxAfterMove = `pointPosition -w ($selMesh[0] + \".vtx[\" + $i + \"]\")`;\n        $newVtxPP[$i] =  $vtxAfterMove[0] ;\n       }\n//????????????\n    move -r -1 0 0 ;\n//?????????????,????????????\n    $cluster = `cluster -n ($selMesh[0]+\"_\"+$subCtr1+\"_cluster\") -rel -en 1 $selMesh`;\n    move $selVtxPP[0] $selVtxPP[1] $selVtxPP[2] ($cluster[1] + \".scalePivot\") ($cluster[1] + \".rotatePivot\");\n    setAttr ($cluster[1] + \"Shape.origin\") $selVtxPP[0] $selVtxPP[1] $selVtxPP[2];\n//????????????,??????????\n      for ($i = 0;$i<$numVtx[0]; $i++)\n      {\n      $eachVtxPPValue[$i] = $newVtxPP[$i] - $oldVtxPP[$i];\n      percent -v $eachVtxPPValue[$i] $cluster[0] ($selMesh[0] + \".vtx\" + \"[\" +$i+ \"]\");\n      }\n//??????0????\n string $clusterSet[] = `listConnections -s 0 -t \"objectSet\" $cluster[0]`;\n for ($i = 0;$i<$numVtx[0]; $i++)\n {\n  float $temp[]  = `percent -q -v $cluster[0] ($selMesh[0] + \".vtx\" + \"[\" +$i+ \"]\")`;\n  if( 0 == $temp[0])\n     {\n   sets -rm $clusterSet[0] ($selMesh[0] + \".vtx\" + \"[\" +$i+ \"]\");\n  }\n }\n  curve -n (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\") -d 1 -p -0.5 0.5 -0.5 -p -0.5 0.5 0.5 -p 0.5 0.5 0.5 -p 0.5 0.5 -0.5 -p -0.5 0.5 -0.5 -p -0.5 -0.5 -0.5 -p -0.5 -0.5 0.5 -p 0.5 -0.5 0.5 -p 0.5 -0.5 -0.5 -p -0.5 -0.5 -0.5 -p -0.5 0.5 -0.5 -p 0.5 0.5 -0.5 -p 0.5 -0.5 -0.5 -p 0.5 -0.5 0.5 -p 0.5 0.5 0.5 -p -0.5 0.5 0.5 -p -0.5 -0.5 0.5 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 ;\n    rename `listRelatives -c -type \"shape\"` (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrlShape\");\n    group -n (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\") -em;\n    delete `parentConstraint (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\")`;\n    parent (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\");\n\n    delete `parentConstraint ($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\")`;\n\n    \n    \n     duplicate -rc -n (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\");\n rename `listRelatives -c -type \"shape\" (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\")` (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrlShape\");\n    \n    \n    int $degree = `getAttr ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\")+\".degree\")`;\n    int $spans = `getAttr ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n select -r -sym ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n\n\n    parent (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\") (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\");\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\");\n    \n    connectAttr ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\")+\".subCtrl\") ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrlShape\")+\".v\");\n    \n    setAttr -k 0 -channelBox true ((($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\")+\".subCtrl\");\n       parentConstraint (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\") ($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\") ;\n\n\nrename ($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\") ($nam+\"_clu\");\nrename (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl\") ($nam+\"_ctrl\");\nrename (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_sub_ctrl\") ($nam+\"_sub_ctrl\");\nrename (($selMesh[0]+\"_\"+$subCtr1+\"_clusterHandle\")+\"_ctrl_offset\") ($nam+\"_ctrl_offset\");\nsetAttr ($nam+\"_clu.v\") 0;\n\n}\n\nSftToClu\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n" 
