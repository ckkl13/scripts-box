        -command "global proc LocOnVexWin(){\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"locatoronvex\";\n   \n\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -bgc 0.08 0.02 0.13 -title \"vreate locator based on the points are selectd\" -widthHeight 200 50 $mygui;  \n\n// string $attname = (`textFieldGrp  -query -text attr_name`); \n frameLayout -bgc 0.35 0.35 0.1 -label \"select the point \" -collapsable 1 ; \n   text -l \"Please select the point and type in name that you want\";\n   columnLayout;\n            textFieldGrp \n            -label \"locator name:\"\n            -text \"\"\n\n            attr_name;\n\n\n\n\n   button -bgc 0.234 0 0 -hlc 1 0 0 -l \"create locator\" -c \"locOnVex(`textFieldGrp  -query -text attr_name`)\";\n\n   setParent ..;\n   setParent ..;\n\n\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\nglobal proc locOnVex(string $Pnam){\nstring $born1[]=`ls -sl -fl`;\nfor($i=0;$i<size($born1);$i++){\n       string $selShape[] = `listRelatives -p $born1[0]`;\n       string $selMesh[] = `listRelatives -p $selShape[0]`;\n       $selVtxPP = `pointPosition -w $born1[$i]`;\n   string $subCtr = substituteAllString($born1[$i], ($selMesh[0] + \".vtx[\"), \"\");\n   string $subCtr1 = substituteAllString($subCtr, \"]\", \"\");\n    spaceLocator -n ($Pnam+\"_\"+$subCtr1+\"_loc\");\n    move $selVtxPP[0] $selVtxPP[1] $selVtxPP[2] ;\n}\n}\nLocOnVexWin;" 
