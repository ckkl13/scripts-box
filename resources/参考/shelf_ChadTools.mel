 0 -p -0.5 -0.707107 -0.5 -p 0 -0.707107 -0.707107 -p 0.5 -0.707107 -0.5 -p 0.707107 -0.707107 0 -p 0.5 -0.707107 0.5 -p 0 -0.707107 0.707107 -p 0 -0.92388 0.382683 -p -0.270598 -0.92388 0.270598 -p -0.382683 -0.92388 0 -p -0.270598 -0.92388 -0.270598 -p 0 -0.92388 -0.382683 -p 0.270598 -0.92388 -0.270598 -p 0.382683 -0.92388 0 -p 0.270598 -0.92388 0.270598 -p 0 -0.92388 0.382683 -p 0 -1 0 -p 0 -0.92388 -0.382683 -p 0 -0.707107 -0.707107 -p 0 -0.382683 -0.923879 -p 0 0 -1 -p 0 0.382683 -0.923879 -p 0 0.707107 -0.707107 -p 0 0.92388 -0.382683 -p 0 1 0 -p -0.382683 0.92388 0 -p -0.707107 0.707107 0 -p -0.923879 0.382683 0 -p -1 0 0 -p -0.923879 -0.382683 0 -p -0.707107 -0.707107 0 -p -0.382683 -0.92388 0 -p 0 -1 0 -p 0.382683 -0.92388 0 -p 0.707107 -0.707107 0 -p 0.92388 -0.382683 0 -p 1 0 0 -p 0.92388 0.382683 0 -p 0.707107 0.707107 0 -p 0.382683 0.92388 0 -p 0 1 0 -p 0.270598 0.92388 -0.270598 -p 0.5 0.707107 -0.5 -p 0.653281 0.382683 -0.653281 -p 0.707107 0 -0.707107 -p 0.653281 -0.382683 -0.653281 -p 0.5 -0.707107 -0.5 -p 0.270598 -0.92388 -0.270598 -p 0 -1 0 -p -0.270598 -0.92388 0.270598 -p -0.5 -0.707107 0.5 -p -0.653281 -0.382683 0.653281 -p -0.707107 0 0.707107 -p -0.653281 0.382683 0.653281 -p -0.5 0.707107 0.5 -p -0.270598 0.92388 0.270598 -p 0 1 0 -p 0.270598 0.92388 0.270598 -p 0.5 0.707107 0.5 -p 0.653281 0.382683 0.653281 -p 0.707107 0 0.707107 -p 0.653281 -0.382683 0.653281 -p 0.5 -0.707107 0.5 -p 0.270598 -0.92388 0.270598 -p 0 -1 0 -p -0.270598 -0.92388 -0.270598 -p -0.5 -0.707107 -0.5 -p -0.653281 -0.382683 -0.653281 -p -0.707107 0 -0.707107 -p -0.653281 0.382683 -0.653281 -p -0.5 0.707107 -0.5 -p -0.270598 0.92388 -0.270598 -p 0 1 0 -k 0 -k 1 -k 2 -k 3 -k 4 -k 5 -k 6 -k 7 -k 8 -k 9 -k 10 -k 11 -k 12 -k 13 -k 14 -k 15 -k 16 -k 17 -k 18 -k 19 -k 20 -k 21 -k 22 -k 23 -k 24 -k 25 -k 26 -k 27 -k 28 -k 29 -k 30 -k 31 -k 32 -k 33 -k 34 -k 35 -k 36 -k 37 -k 38 -k 39 -k 40 -k 41 -k 42 -k 43 -k 44 -k 45 -k 46 -k 47 -k 48 -k 49 -k 50 -k 51 -k 52 -k 53 -k 54 -k 55 -k 56 -k 57 -k 58 -k 59 -k 60 -k 61 -k 62 -k 63 -k 64 -k 65 -k 66 -k 67 -k 68 -k 69 -k 70 -k 71 -k 72 -k 73 -k 74 -k 75 -k 76 -k 77 -k 78 -k 79 -k 80 -k 81 -k 82 -k 83 -k 84 -k 85 -k 86 -k 87 -k 88 -k 89 -k 90 -k 91 -k 92 -k 93 -k 94 -k 95 -k 96 -k 97 -k 98 -k 99 -k 100 -k 101 -k 102 -k 103 -k 104 -k 105 -k 106 -k 107 -k 108 -k 109 -k 110 -k 111 -k 112 -k 113 -k 114 -k 115 -k 116 -k 117 -k 118 -k 119 -k 120 ;\ngroup -n ($cnam+\"_ctrl_offset\") -em;\nparent ($cnam+\"_ctrl\") ($cnam+\"_ctrl_offset\");\n}\n\n\n\nglobal proc subctrl(){\nstring $pcon[] = `ls -sl`;\nfor ($item in $pcon){\n\tstring $subnam = substituteAllString($item, \"ctrl\", \"sub\");\t\n    duplicate -rc -n ($subnam+\"_ctrl\") $item;\n\n    delete `listRelatives -c -type \"transform\" ($subnam+\"_ctrl\")`;\n    rename `listRelatives -c` ($subnam+\"_ctrlShape\");\n    \n    int $degree = `getAttr (($subnam+\"_ctrl\")+\".degree\")`;\n    int $spans = `getAttr (($subnam+\"_ctrl\")+\".spans\")`;\n    int $max = ($degree+$spans)-1;\n\tselect -r -sym (($subnam+\"_ctrl\")+\".cv[0:\"+$max+\"]\") ;\n    scale -r -ocp 0.8 0.8 0.8;\n    select -cl;\n    \n    parent `listRelatives -c -type \"transform\" $item` ($subnam+\"_ctrl\");\n\n    parent ($subnam+\"_ctrl\") $item;\n    \n    addAttr -ln \"subCtrl\" -nn \"Sub Ctrl\" -at long  -min 0 -max 1 -dv 0 -k on $item;\n    \n    connectAttr ($item+\".subCtrl\") (($subnam+\"_ctrlShape\")+\".v\");\n    \n    setAttr -k 0 -channelBox true ($item+\".subCtrl\");\n}\n\n}\n\n\n\n///////////////////////////////////////////////////////////////////////////////////////create ctrls/////////////////////////////////////////////////////////////////////////////////////////////////////////////////\n/*****************************************************************1 cube 2 fourSquares 3 cicle3D 4 square 5 Cone 6 fourArrow 7 curveArrow*********************************************************/\nglobal proc createctrl1(string $obj,int $cnam,int $const, int $tell){\nselect -r $obj;\nstring $born[]=`ls - sl`;\nfor($i=0;$i<size($born);$i++){ \n    if($cnam==0){ \n        cube($born[$i]);\n    }\n    if($cnam==1){ \n        fourSquares($born[$i]);\n    }\n    if($cnam==2){ \n        cicle3D($born[$i]);\n    }\n    if($cnam==3){ \n        square($born[$i]);\n    }\n    if($cnam==4){ \n        Cone($born[$i]);\n    }\n    if($cnam==5){ \n        fourArrow($born[$i]);\n    }\n    if($cnam==6){ \n        angleBox($born[$i]);\n    }\n    if($cnam==7){ \n        curveArrow($born[$i]);\n    }\n    if($cnam==8){ \n        Arrow($born[$i]);\n    }\n    \n    if($cnam==9){ \n        Trangle($born[$i]);\n    }\n    \n    if($cnam==10){ \n        doubleStar($born[$i]);\n    }\n    \n    if($cnam==11){ \n        curveSquare($born[$i]);\n    }\n          \n\tif($cnam==12){ \n        rootCtrl($born[$i]);\n    }\n\tif($cnam==13){ \n        roundSquare($born[$i]);\n    }  \n\n\tif($cnam==14){ \n        localCtrl($born[$i]);\n    }      \n\n\tif($cnam==15){ \n        worldCtrl($born[$i]);\n    }\n\n\tif($cnam==16){ \n        sphare($born[$i]);\n    }\n\n\n\n    \n    if($const==0){\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_ctrl_offset\")`;\n        parentConstraint -n ($born[$i]+\"_pConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n    }\n    \n    \n    if($const==1){\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_ctrl_offset\")`;\n        pointConstraint -n ($born[$i]+\"_poConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n    }\n    \n    if($const==2){\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_ctrl_offset\")`;\n        orientConstraint -n ($born[$i]+\"_oConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n    }\n    \n    if($const==3){\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_ctrl_offset\")`;\n        pointConstraint -n ($born[$i]+\"_poConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n        orientConstraint -n ($born[$i]+\"_oConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n    }\n   \n    if($const==4){\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_ctrl_offset\")`;\n        pointConstraint -n ($born[$i]+\"_poConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n        orientConstraint -n ($born[$i]+\"_oConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n        scaleConstraint -n ($born[$i]+\"_sConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n    }\n    if($const==5){\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_ctrl_offset\")`;\n        parentConstraint -n ($born[$i]+\"_pConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n        scaleConstraint -n ($born[$i]+\"_sConst\") ($born[$i]+\"_ctrl\") ($born[$i]);\n    }\n    \n    if($const==6){\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_ctrl_offset\")`;\n\n    }\n    \n    if($const==7){\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_ctrl_offset\")`;\n        connectAttr (($born[$i]+\"_ctrl\")+\".translate\") (($born[$i])+\".translate\");\n        connectAttr (($born[$i]+\"_ctrl\")+\".rotate\") (($born[$i])+\".rotate\");\n    }\n    \n    \n    if($i>0){\n        if($tell==1){\n        parent ($born[$i]+\"_ctrl_offset\") ($born[$i-1]+\"_ctrl\");\n            }\n\t    }\n    }\n}\n\n\n\n\n\n\n/***************************************************************************************************************************************************************************************/\n/*************************************************************str set up****************************************************************************************************************/\nglobal proc createcur(int $curnum){\nint $curpot=$curnum-1;\ncurve -d 3 -p 12 0 0  -p 4 0 0  -p -4 0 0 -p -12 0 0  -k 0 -k 0 -k 0 -k 1 -k 1 -k 1 -n drv_cur1;\nrename  drv_cur1 drv_cur;\nrename `listRelatives -c drv_cur` drv_curShape;\n\n\nrebuildCurve  -s $curpot -d 3 \"drv_cur\";\ndelete drv_cur.cv[1];\ndelete drv_cur.cv[$curpot];\n\nint $degree = `getAttr drv_cur.degree`;\n    int $spans = `getAttr drv_cur.spans`;\n    select -r -sym drv_cur.cv[0:(($degree+$spans)-1)];\n    string $clu[]=`ls - sl`;\n    for($i=0;$i<($degree+$spans);$i++){  \n\n        cluster  (\"drv_cur\"+\".cv[\"+$i+\"]\") ;\n        rename  (\"drv_\"+$i+\"_clu\");\n    }\n    group -n drv_clu_grp (\"drv_*_clu\");\n}\n\n//////////////////////////////////////////////////////////////create ribban geo////////////////////////////////////////////////////\n\nglobal proc creategeo(int $gnum ){\n    nurbsPlane -n drv_geo -p 0 0 0 -ax 0 1 0 -w 24 -lr 0.04166666667 -d 3 -u 100 -v 1 -ch 1;\n\n    select -r drv_geo;\n    createHair $gnum 1 10 0 0 1 0 5 0 1 1 1;\n    \n    select (\"drv_*_clu\");\n    string $cluNum[] = `ls-sl`;\n    int $clumax = size($cluNum);\n\n    \n    delete (\"hairSystem1\", \"pfxHair1\",\"nucleus1\");\n    string $fol[] = `listRelatives  -c  hairSystem1Follicles`;\n    delete `listRelatives  -c -type \"transform\" $fol`;\n    rename hairSystem1Follicles drv_fol_grp;\n    string $foln[] = `listRelatives  -c  drv_fol_grp`;\n    for($f=0;$f<size($foln);$f++){  \n        rename $foln[$f] (\"drv_\"+$f+\"_fol\");\n        }\n        \n    \n    group -n drv_grp {\"drv_cur\",\"drv_geo\"}; \n    \n    \nint $degree1 = `getAttr drv_cur.degree`;\nint $spans1 = `getAttr drv_cur.spans`;  \nint $laticNum = $degree1+$spans1;\nselect -r drv_geo;\n\nlattice  -n drv_geo_lattice -divisions $laticNum 2 2 -objectCentered true  -ldv 2 2 2 ;\n\nfor ($lcNum=0;$lcNum < $laticNum; $lcNum++){\n   \n\n        select -r drv_geo_latticeLattice.pt[$lcNum][0:1][0] drv_geo_latticeLattice.pt[$lcNum][0:1][1] ;\n        newCluster  \" -envelope 1\";\n        rename (\"drv_latic_\"+$lcNum+\"_clu\");\n}\n   group -n drv_latic_clu_grp (\"drv_latic_*_clu\"); \n\ngroup -n drv_lattice_grp -em; \nparent drv_geo_latticeBase drv_lattice_grp;\nparent drv_geo_latticeLattice drv_lattice_grp;\n\n\n}\n////////////////////////////////////////////////////////////create ribban joint///////////////////////////////////////////////////\n\nglobal proc createjoint(string $selt){\n    joint -n joint_root -p 0 0 0 ;\n    select `listRelatives -c $selt`;\n    string $born[]=`ls - sl`;\n    for($i=0;$i<size($born);$i++){\n        duplicate -rr -n ($born[$i]+\"_joint\") joint_root;\n        delete`parentConstraint ($born[$i]) ($born[$i]+\"_joint\")`;\n        if($i>0){\n            select -r ($born[$i]+\"_joint\") ;\n            parent ($born[$i]+\"_joint\") ($born[$i-1]+\"_joint\");\n                }\n        pointConstraint -n ($born[$i]+\"_pocon\") -mo ($born[$i]) ($born[$i]+\"_joint\");\n        orientConstraint -n ($born[$i]+\"_ocon\") -mo ($born[$i]) ($born[$i]+\"_joint\");\n    }\n        delete joint_root;\n      \n}\n\n\n\n//////////////////////////////////////////////////connect ribban cur and geo///////////////////////////////////////////////////////////////////\n\nglobal proc createdrv1(int $max ,int $geonum){\n    \ncreatecur($max);\ncreategeo($geonum);\n\nint $end = $max-1;\n\nnonLinear -type twist  drv_geo ;\nrename drv_twisthandle;\nrotate -r 0 0 90;\nselect `listConnections drv_twisthandle` ;\nrename \"drv_twist\";\n\nselect -r drv_geo;\n\nnonLinear  -type \"sine\"  ;\nrename  drv_sinehandle;\nrotate -r 0 0 90;\nselect `listConnections drv_sinehandle` ;\nrename \"drv_sine\";\nselect -r drv_sinehandle;\nmove -r -os -wd 0 12 0 ;\nsetAttr \"drv_sine.lowBound\" -2;\nsetAttr \"drv_sine.highBound\" 0;\n\nwire  -n drv_wire -dds 0 100 -w drv_cur drv_geo;\n\nnonLinear  -type \"bend\" drv_geo ;\nrename  drv_bendhandle;\nrotate -r 0 0 90;\nselect `listConnections drv_bendhandle` ;\nrename \"drv_bend\";\nselect -r drv_bendhandle;\nmove -r -os -wd 0 12 0 ;\nsetAttr \"drv_bend.lowBound\" -2;\nsetAttr \"drv_bend.highBound\" 0;\n\n\ncreatectrl1((\"drv_*_clu\"),\"0\",\"0\",\"0\");\n\ncreatectrl1(\"drv_0_clu_ctrl_offset\",\"3\",\"0\",\"0\");\nrename drv_0_clu_ctrl_offset_ctrl drv_base_ctrl;\nrename drv_0_clu_ctrl_offset_ctrl_offset drv_base_ctrl_offset;\n\ncreatectrl1((\"drv_\"+$end+\"_clu_ctrl_offset\"),\"3\",\"0\",\"0\");\nrename (\"drv_\"+$end+\"_clu_ctrl_offset_ctrl\") drv_end_ctrl;\nrename (\"drv_\"+$end+\"_clu_ctrl_offset_ctrl_offset\") drv_end_ctrl_offset;\n\nconnectAttr drv_base_ctrl.rotateX drv_twist.startAngle;\nconnectAttr drv_end_ctrl.rotateX drv_twist.endAngle;\n\nint $top = $end-1;\nfor($se=1;$se<($end);$se++){\n    select -r drv_base_ctrl ;\n    select -tgl drv_end_ctrl ;\n    select -tgl (\"drv_\"+$se+\"_clu_ctrl_offset\") ;\n    pointConstraint -o 0 0 0 -w 1 -n (\"drv_\"+$se+\"_pcon\");\n    setAttr ((\"drv_\"+$se+\"_pcon\")+\".drv_base_ctrlW0\") ($top);\n    setAttr ((\"drv_\"+$se+\"_pcon\")+\".drv_end_ctrlW1\") ($se);  \n    orientConstraint -o 0 0 0 -w 1 -n (\"drv_\"+$se+\"_ocon\");\n    setAttr ((\"drv_\"+$se+\"_ocon\")+\".drv_base_ctrlW0\") ($top);\n    setAttr ((\"drv_\"+$se+\"_ocon\")+\".drv_end_ctrlW1\") ($se);  \n    $top--;\n}\n\ngroup -n drv_ctrl_grp (\"drv_*_ctrl_offset\");\ngroup -n drv_sub_ctrl_grp (\"drv_*_clu_ctrl_offset\");\ngroup -n drv_head_ctrl_grp {\"drv_base_ctrl_offset\",\"drv_end_ctrl_offset\"}; \ngroup -n drv_def_grp (\"drv_*handle\");\ngroup -n drv_rig_grp {\"drv_clu_grp\",\"drv_fol_grp\",\"drv_grp\",\"drv_def_grp\"}; \ngroup -n drv_str_grp {\"drv_ctrl_grp\",\"drv_rig_grp\"}; \n\ngroup -n drv_bendhandle_offset -em;\ndelete `parentConstraint drv_bendhandle drv_bendhandle_offset`;\nparent drv_bendhandle drv_bendhandle_offset;\nparent drv_bendhandle_offset drv_def_grp ;\n\ncreatejoint(\"drv_fol_grp\");\ngroup -n drv_joint_grp drv_0_fol_joint;\nparent drv_joint_grp drv_rig_grp;\nsetAttr \"drv_cur.inheritsTransform\" 0;\nsetAttr \"drv_fol_grp.inheritsTransform\" 0;\n\nmove -r -12 0 0 drv_str_grp.scalePivot drv_str_grp.rotatePivot ;\nparentConstraint -mo drv_str_grp drv_geo;\nparentConstraint -mo drv_str_grp drv_curBaseWire;\n//select `listRelatives -c -type \"shape\" drv_cur`;\n\n//rename \"drv_curBaseWire|curveShape1\" \"curvebaseShape\";\nparent drv_lattice_grp drv_rig_grp;\nparent drv_latic_clu_grp drv_rig_grp;\n\nsetAttr \"drv_latic_clu_grp.inheritsTransform\" 0;\n\ngroup -n drv_bind_grp -em;\ngroup -n drv_DONT_TOUCH_grp -em;\nparent drv_joint_grp drv_bind_grp;\nparent drv_clu_grp drv_fol_grp drv_grp drv_def_grp drv_lattice_grp drv_latic_clu_grp drv_DONT_TOUCH_grp;\nparent drv_bind_grp drv_DONT_TOUCH_grp drv_rig_grp;\nsetAttr \"drv_DONT_TOUCH_grp.visibility\" 0;\n\n\n/*******************************************************************************add inner ctrl*************************************************************************************/\ndelete (\"drv_*_fol_pocon\");\ndelete (\"drv_*_fol_ocon\");\n\ncreatectrl1((\"drv_*_fol_joint\"),\"16\",\"3\",\"0\");\n\ngroup -n drv_inner_ctrl_grp (\"drv_*_fol_joint_ctrl_offset\");\nparent drv_inner_ctrl_grp drv_ctrl_grp;\n\nselect (\"drv_*_fol_joint_ctrl_offset\");\nstring $inctrls[] = `ls - sl`;\nfor($ic=0;$ic<size($inctrls);$ic++){\n    pointConstraint -mo (\"drv_\"+$ic+\"_fol\") (\"drv_\"+$ic+\"_fol_joint_ctrl_offset\");\n    orientConstraint -mo (\"drv_\"+$ic+\"_fol\") (\"drv_\"+$ic+\"_fol_joint_ctrl_offset\");\n    }\n\n\n\n\n\n/*********************************************************************add attrs*****************************************************************************************************/\n\naddAttr -ln \"sine_cur\" -nn \"Sine Cur\" -at double  -dv 0 -keyable 1 drv_end_ctrl;\naddAttr -ln \"sine_offset\" -nn \"Sine Offset\" -at double  -dv 0 -keyable 1 drv_end_ctrl;\naddAttr -ln \"sine_falloff\" -nn \"Sine Falloff\" -at double  -dv 0 -keyable 1 drv_end_ctrl;\naddAttr -ln \"sine_wave\" -nn \"Sine Wave\" -at double  -dv 2 -keyable 1 drv_end_ctrl;\naddAttr -ln \"sine_rot\" -nn \"Sine Rot\" -at double  -dv 0 -keyable 1 drv_end_ctrl;\n\n\nconnectAttr drv_end_ctrl.sine_cur drv_sine.amplitude;\nconnectAttr drv_end_ctrl.sine_falloff drv_sine.dropoff;\nconnectAttr drv_end_ctrl.sine_offset drv_sine.offset;\nconnectAttr drv_end_ctrl.sine_wave drv_sine.wavelength;\nconnectAttr drv_end_ctrl.sine_rot drv_sinehandle.rotateY;\n\naddAttr -ln \"bend_cur\" -nn \"Bend Cur\" -at double  -dv 0 -keyable 1 drv_end_ctrl;\naddAttr -ln \"bend_rotX\" -nn \"Bend RotX\" -at double  -dv 0 -keyable 1 drv_end_ctrl;\naddAttr -ln \"bend_rotY\" -nn \"Bend RotY\" -at double  -dv 0 -keyable 1 drv_end_ctrl;\naddAttr -ln \"bend_rotZ\" -nn \"Bend RotZ\" -at double  -dv 0 -keyable 1 drv_end_ctrl;\naddAttr -ln \"bend_limits\" -nn \"Bend Limits\" -at double  -dv -2 -keyable 1 drv_end_ctrl;\n\n\nconnectAttr drv_end_ctrl.bend_cur drv_bend.curvature;\nconnectAttr drv_end_ctrl.bend_rotX drv_bendhandle.rotateX;\nconnectAttr drv_end_ctrl.bend_rotY drv_bendhandle.rotateY;\nconnectAttr drv_end_ctrl.bend_rotZ drv_bendhandle.rotateZ;\n\nconnectAttr drv_end_ctrl.bend_limits drv_bend.lowBound;\n\n\n\naddAttr -ln \"innerctrlVisb\" -nn \"InnerCtrlVisb\" -at bool  -dv 0 -keyable 1 drv_end_ctrl;\naddAttr -ln \"squash\" -nn \"Squash\" -at bool  -dv 0 -keyable 1 drv_end_ctrl;\n\nconnectAttr drv_end_ctrl.innerctrlVisb drv_inner_ctrl_grp.visibility;\n\nshadingNode -n drv_cur_curinfo -asUtility curveInfo;\nshadingNode -n drv_curbase_curinfo -asUtility curveInfo;\n\nconnectAttr drv_curShape.worldSpace[0] drv_cur_curinfo.inputCurve;\nconnectAttr drv_curBaseWireShape.worldSpace[0] drv_curbase_curinfo.inputCurve;\n\nshadingNode -n drv_cur_md -asUtility multiplyDivide;\nconnectAttr  drv_cur_curinfo.arcLength drv_cur_md.input1X;\nconnectAttr  drv_curbase_curinfo.arcLength drv_cur_md.input2X;\nsetAttr \"drv_cur_md.operation\" 2;\n\n\nshadingNode -n drv_cur_F_md -asUtility multiplyDivide;\nsetAttr \"drv_cur_F_md.operation\" 2;\nsetAttr \"drv_cur_F_md.input1X\" 1;\nconnectAttr  drv_cur_md.outputX drv_cur_F_md.input2X;\n\n\nshadingNode -n squa_cond -asUtility condition;\nconnectAttr drv_end_ctrl.squash squa_cond.firstTerm;\nsetAttr \"squa_cond.secondTerm\" 1;\nconnectAttr drv_cur_F_md.outputX squa_cond.colorIfTrueR;\n\ndelete (\"drv_latic_*_clu_pConst\");\n\nselect (\"drv_*_fol_joint\");\nstring $djoints[] = `ls - sl`;\nfor($j=0;$j<size($djoints);$j++){\n    connectAttr squa_cond.outColorR ($djoints[$j]+\".scaleY\");\n    connectAttr squa_cond.outColorR ($djoints[$j]+\".scaleZ\");\n    }\n\n\nselect -r (\"drv_latic_*_clu\");\nstring $latNum[] = `ls - sl`;\nint $latTo = size($latNum)-1;\nfor($lt=0;$lt<size($latNum);$lt++){\n    connectAttr ((\"drv_\"+$lt+\"_clu_ctrl\")+\".rotateX\") ((\"drv_latic_\"+$latTo +\"_clu\")+\".rotateX\");\n    $latTo = $latTo-1;\n\n    }\n\ncurve -n drv_defstart_ctrl -d 1 -p -2 0 0 -p 2 0 2 -p 2 0 -2 -p -2 0 0 -k 0 -k 1 -k 2 -k 3 ;\ngroup -n drv_defstart_ctrl_offset -em;\nparent drv_defstart_ctrl drv_defstart_ctrl_offset;\n\ndelete `parentConstraint drv_end_ctrl drv_defstart_ctrl_offset`;\n\nconnectAttr drv_defstart_ctrl.translate drv_def_grp.translate;\nparent drv_defstart_ctrl_offset drv_head_ctrl_grp;\n\n\n/*******************************************************add overall ctrls*******************************************************************/\ndelete drv_geo_parentConstraint1;\ndelete drv_curBaseWire_parentConstraint1;\n\ncurve -n drv_root_ctrl -d 1 -p 9.14414e-07 0 -1.804861 -p -0.69069 0 -1.667474 -p -1.276228 0 -1.276229 -p -1.667474 0 -0.690691 -p -1.804861 0 -6.45469e-07 -p -1.667474 0 0.69069 -p -1.276229 0 1.276228 -p -0.690691 0 1.667474 -p -2.68945e-07 0 1.804861 -p 0.69069 0 1.667474 -p 1.276228 0 1.276229 -p 1.667474 0 0.69069 -p 1.804861 0 0 -p 1.667474 0 -0.690689 -p 1.27623 0 -1.276228 -p 0.690691 0 -1.667474 -p 9.14414e-07 0 -1.804861 -p 5.88379e-07 0 -1.161337 -p -0.444424 0 -1.072936 -p -0.69069 0 -1.667474 -p -1.276228 0 -1.276229 -p -0.821188 0 -0.821188 -p -1.072935 0 -0.444424 -p -1.667474 0 -0.690691 -p -1.804861 0 -6.45469e-07 -p -1.161337 0 -4.15326e-07 -p -1.072936 0 0.444424 -p -1.667474 0 0.69069 -p -1.276229 0 1.276228 -p -0.821188 0 0.821188 -p -0.444424 0 1.072935 -p -0.690691 0 1.667474 -p -2.68945e-07 0 1.804861 -p -1.73053e-07 0 1.161337 -p 0.444424 0 1.072935 -p 0.69069 0 1.667474 -p 1.276228 0 1.276229 -p 0.821188 0 0.821188 -p 1.072935 0 0.444424 -p 1.667474 0 0.69069 -p 1.804861 0 0 -p 1.161337 0