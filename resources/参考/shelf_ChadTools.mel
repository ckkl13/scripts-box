        -annotation "global proc G_share_attr()\n{\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"G_IK_FK\"; \n\t\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"Sharing Attr\" -widthHeight 400 200 $mygui;   \nframeLayout \n\t\t-borderStyle \"in\" \n\t    -label \"select the shape node\";\n\t  \t\tcolumnLayout -adj 1;\n\t  \n\t\t\ttextFieldButtonGrp -label \"shared_attr_shape\"\n\t\t\t-text \"\"\n\t\t\t-buttonLabel \"Get_selection\"\n\t\t\t-cw3 100 100 20\n\t\t\t-ct3 \"left\" \"both\" \"left\"\n\t\t\t-buttonCommand \"get_attr()\" attr_name;\n\t\t\tsetParent ..;\n\t\tsetParent ..;\n\t\t\nframeLayout\n\t-label \"buttons to add or remove\";\t\n        rowColumnLayout -numberOfColumns 4\n            -columnWidth 1 70\n            -columnWidth 2 70\n            -columnWidth 3 70\n            -columnWidth 4 70;\n            \n        separator -visible 0 -height 10; separator -visible 0;    separator -visible 0;        separator -visible 0; \n        separator -visible 0; \n        button -label \"add\" -command \"G_add()\";\n\t\tbutton -label \"remove\" -command \"G_remove()\";                  \n        separator -visible 0;\n        setParent ..;\n\t\tsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\nglobal proc get_attr()\n{\n\tstring $mylist[] = `ls -sl`;\n\t\n\tstring $objname =$mylist[0];\n\t\n\tstring $buffer[] ;\n\ttokenize $objname \"|\" $buffer ;\n\tint $arraysize = size($buffer);\n\t\tif ($arraysize >1)\n\t\t\t{\n\t\t\t\ttextFieldButtonGrp -edit -text $buffer[1] attr_name;\n            }\n\t\t\telse\n\t\t\t{\n\t\t\t\ttextFieldButtonGrp -edit -text $buffer[0] attr_name;\n            }\n\t\n\t\n}\n\nglobal proc G_add()\n{\n\tstring $attname = (`textFieldButtonGrp -query -text attr_name`);\n\tstring $mylist[] = `ls -sl`;\n\t\n\tfor ($myitems in $mylist)\n\t\t{\n\t\t\n\t\tinstance  -name \"temp_bob\" $attname;\n\t\t\n\t\tselect -r \"temp_bob\";\n\t\tselect -replace (\"temp_bob|\" + $attname);\n\t\tselect -add\t$myitems;\n\t\tparent -r -s;   \n\t\tdelete \"temp_bob\"; \n        }\n}\nglobal proc G_remove()\n{\n\tstring $attname = (`textFieldButtonGrp -query -text attr_name`);\n\tstring $mylist[] = `ls -sl`;\n\t\n\t\n\tfor ($myitems in $mylist)\n\t\t{\n\t\tif ($myitems == $attname)\n\t\t\t{\n\t\t\tselect $myitems;\n\t\t\tparent -s -rm;\t\n            }\n\t\telse\n\t\t\t{\n\t\t\t  if (`objExists ($myitems +\"|\"+$attname)`)\n\t\t\t  \t{\n\t\t\t  \tselect ($myitems +\"|\"+$attname);\n\t\t\t\tparent -s -rm; \n\t\t\t\t}\n\t\t\t\n        \t}\n\t\t\t\t\n        }\n\t\n}\nG_share_attr" 
