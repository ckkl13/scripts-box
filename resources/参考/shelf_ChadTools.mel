        -annotation "global proc reshapeWin()\n{\nstring $chlist[] = (`ls  -sl`);\nstring $mygui = \"reshape\";\nif (`window -ex $mygui`) deleteUI $mygui;\n    window -title \"reshape low res geos\" -widthHeight 400 200 $mygui;  \nframeLayout\n   -label \"get the high res geo\";\n  columnLayout -adj 1;\n \ntextFieldButtonGrp -label \"get the high res geo\"\n-text \"\"\n-buttonLabel \"high res geo\"\n-cw3 100 100 20\n-ct3 \"left\" \"both\" \"left\"\n-buttonCommand \"get_org()\" attr_name;\nsetParent ..;\nsetParent ..;\n\nframeLayout\n-label \"mirror the BS traget\";\n        rowColumnLayout -numberOfColumns 4\n            -columnWidth 1 70\n            -columnWidth 2 70\n            -columnWidth 3 70\n            -columnWidth 4 70;\n           \n        separator -visible 0 -height 10; separator -visible 0;    separator -visible 0;        separator -visible 0;\n        separator -visible 0;\n        button -label \"reshape\" -command \"reShapeLowResGeos1(`textFieldButtonGrp -q -text attr_name`)\";\n               \n        separator -visible 0;\n        setParent ..;\nsetParent ..;\nshowWindow $mygui;\nwindow -e -width 250 $mygui;\n}\n\n\nglobal proc get_org()\n{\nstring $orglist[] = `ls -sl`;\nstring $orgobjname =$orglist[0];\nstring $orgbuffer[] ;\ntokenize $orgobjname \"|\" $orgbuffer ;\nint $org_arraysize = size($orgbuffer);\nif ($org_arraysize >1)\n{\ntextFieldButtonGrp -edit -text $orgbuffer[1] attr_name;\n            }\nelse\n{\ntextFieldButtonGrp -edit -text $orgbuffer[0] attr_name;\n            }\n}\n\n\nglobal proc reShapeLowResGeos1(string $highRes){\nselect -r (\"*_lowRes_geo\");\nDeleteHistory;\nstring $lowResswGeo[] = `ls - sl`;\nfor($lsg=0;$lsg<size($lowResswGeo);$lsg++){\n    select -r $lowResswGeo[$lsg];\n    select -tgl $highRes;\n    deformer -type shrinkWrap -n ($lowResswGeo[$lsg]+\"_SW\") $lowResswGeo[$lsg];\n    connectAttr ($highRes+\"Shape.boundaryRule\") ($lowResswGeo[$lsg]+\"_SW.boundaryRule\");\n    connectAttr ($highRes+\"Shape.continuity\") ($lowResswGeo[$lsg]+\"_SW.continuity\");\n    connectAttr ($highRes+\"Shape.keepBorder\") ($lowResswGeo[$lsg]+\"_SW.keepBorder\");\n    connectAttr ($highRes+\"Shape.keepHardEdge\") ($lowResswGeo[$lsg]+\"_SW.keepHardEdge\");\n    connectAttr ($highRes+\"Shape.propagateEdgeHardness\") ($lowResswGeo[$lsg]+\"_SW.propagateEdgeHardness\");\n    connectAttr ($highRes+\"Shape.smoothUVs\") ($lowResswGeo[$lsg]+\"_SW.smoothUVs\");\n    connectAttr ($highRes+\"Shape.worldMesh[0]\") ($lowResswGeo[$lsg]+\"_SW.targetGeom\");\n    setAttr ($lowResswGeo[$lsg]+\"_SW.projection\") 4;    \n    DeleteHistory;\n    string $lowResBindJnt = substituteAllString($lowResswGeo[$lsg], \"_lowRes_geo\", \"\");\n    select -r $lowResswGeo[$lsg];\n    select -add $lowResBindJnt;\n    \n   SmoothBindSkin ;\n}\n}\n\nreshapeWin;\n" 
