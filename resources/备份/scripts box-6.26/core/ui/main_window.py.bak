            delete_btn.setStyleSheet("""
                QPushButton {
                    background-color: #a83232;
                    color: white;
                    padding: 6px 12px;
                    border-radius: 6px;
                }
                QPushButton:hover { background-color: #b84242; }
                QPushButton:pressed { background-color: #982222; }
            """)
